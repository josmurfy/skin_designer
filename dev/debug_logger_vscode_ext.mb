## 🔧 INTÉGRATION DANS EXTENSION.TS

**File: `src/extension.ts` (Modified)**

```typescript
import * as vscode from 'vscode';
import { UpdateManager } from './updates/updateManager';
// ... autres imports

export async function activate(context: vscode.ExtensionContext) {
  console.log('DevFlow Pro is now active!');

  // ─────────────────────────────────────────────────────────
  // AUTO-UPDATE SYSTEM
  // ─────────────────────────────────────────────────────────
  const updateManager = UpdateManager.getInstance(context);
  await updateManager.initialize(context);

  // Register update commands
  context.subscriptions.push(
    vscode.commands.registerCommand('devflow.checkForUpdates', async () => {
      await updateManager.checkForUpdates(true);
    })
  );

  context.subscriptions.push(
    vscode.commands.registerCommand('devflow.rollbackVersion', async () => {
      await updateManager.rollback();
    })
  );

  // Add to status bar
  const updateStatusBar = vscode.window.createStatusBarItem(
    vscode.StatusBarAlignment.Right,
    99
  );
  updateStatusBar.text = '$(cloud-download) Check Updates';
  updateStatusBar.command = 'devflow.checkForUpdates';
  updateStatusBar.tooltip = 'Check for DevFlow Pro updates';
  updateStatusBar.show();
  context.subscriptions.push(updateStatusBar);

  // ─────────────────────────────────────────────────────────
  // REST OF EXTENSION CODE
  // ─────────────────────────────────────────────────────────
  
  // Initialize database, workflow, etc.
  // ... existing code
}

export function deactivate() {
  // Cleanup update manager
  const updateManager = UpdateManager.getInstance();
  updateManager.dispose();
}
```

