### 2. **Version Checker (Remote API)**

**File: `src/updates/versionChecker.ts`**

```typescript
import * as https from 'https';
import { UpdateInfo } from './updateManager';

export class VersionChecker {
  private updateServerUrl: string;

  constructor(private channel: 'stable' | 'beta') {
    // URL de ton serveur d'updates
    // Option 1: GitHub Releases API
    // Option 2: Ton propre serveur (phoenixdepot.com/devflow/updates/)
    // Option 3: Gumroad/LemonSqueezy API
    
    this.updateServerUrl = this.getUpdateServerUrl();
  }

  private getUpdateServerUrl(): string {
    const baseUrl = 'https://phoenixdepot.com/devflow/updates';
    
    // Option: Use GitHub releases
    // const baseUrl = 'https://api.github.com/repos/phoenixdepot/devflow-pro/releases';
    
    return `${baseUrl}/${this.channel}/manifest.json`;
  }

  /**
   * Fetch latest version from update server
   */
  async getLatestVersion(): Promise<UpdateInfo | null> {
    return new Promise((resolve, reject) => {
      https.get(this.updateServerUrl, {
        headers: {
          'User-Agent': 'DevFlow-Pro-Updater'
        }
      }, (res) => {
        let data = '';

        res.on('data', chunk => {
          data += chunk;
        });

        res.on('end', () => {
          try {
            if (res.statusCode === 200) {
              const manifest = JSON.parse(data);
              resolve(this.parseManifest(manifest));
            } else {
              console.error(`Update check failed with status ${res.statusCode}`);
              resolve(null);
            }
          } catch (error) {
            reject(error);
          }
        });
      }).on('error', (error) => {
        reject(error);
      });
    });
  }

  /**
   * Parse manifest JSON to UpdateInfo
   */
  private parseManifest(manifest: any): UpdateInfo {
    return {
      version: manifest.version,
      downloadUrl: manifest.downloadUrl,
      releaseDate: manifest.releaseDate,
      changelog: manifest.changelog,
      minVSCodeVersion: manifest.minVSCodeVersion || '^1.85.0',
      breaking: manifest.breaking || false
    };
  }

  /**
   * Alternative: Fetch from GitHub Releases API
   */
  async getLatestFromGitHub(): Promise<UpdateInfo | null> {
    const githubApi = 'https://api.github.com/repos/phoenixdepot/devflow-pro/releases/latest';
    
    return new Promise((resolve, reject) => {
      https.get(githubApi, {
        headers: {
          'User-Agent': 'DevFlow-Pro-Updater',
          'Accept': 'application/vnd.github.v3+json'
        }
      }, (res) => {
        let data = '';

        res.on('data', chunk => data += chunk);
        res.on('end', () => {
          try {
            if (res.statusCode === 200) {
              const release = JSON.parse(data);
              
              // Find .vsix asset
              const vsixAsset = release.assets.find((a: any) => 
                a.name.endsWith('.vsix')
              );

              if (!vsixAsset) {
                resolve(null);
                return;
              }

              resolve({
                version: release.tag_name.replace(/^v/, ''),
                downloadUrl: vsixAsset.browser_download_url,
                releaseDate: release.published_at,
                changelog: release.body,
                minVSCodeVersion: '^1.85.0',
                breaking: release.name.includes('BREAKING')
              });
            } else {
              resolve(null);
            }
          } catch (error) {
            reject(error);
          }
        });
      }).on('error', reject);
    });
  }
}
```

