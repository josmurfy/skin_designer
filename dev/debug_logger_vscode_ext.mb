### 3. **Download Manager**

**File: `src/updates/downloadManager.ts`**

```typescript
import * as vscode from 'vscode';
import * as https from 'https';
import * as fs from 'fs';
import * as path from 'path';
import * as os from 'os';

export class DownloadManager {
  private downloadDir: string;

  constructor() {
    // Use OS temp directory
    this.downloadDir = path.join(os.tmpdir(), 'devflow-updates');
    
    // Ensure directory exists
    if (!fs.existsSync(this.downloadDir)) {
      fs.mkdirSync(this.downloadDir, { recursive: true });
    }
  }

  /**
   * Download .vsix file from URL
   */
  async download(url: string, version: string): Promise<string> {
    const fileName = `devflow-pro-${version}.vsix`;
    const filePath = path.join(this.downloadDir, fileName);

    return new Promise((resolve, reject) => {
      const file = fs.createWriteStream(filePath);

      https.get(url, (response) => {
        if (response.statusCode === 302 || response.statusCode === 301) {
          // Follow redirect
          if (response.headers.location) {
            https.get(response.headers.location, (redirectResponse) => {
              redirectResponse.pipe(file);
              
              file.on('finish', () => {
                file.close();
                resolve(filePath);
              });
            }).on('error', (error) => {
              fs.unlink(filePath, () => {}); // Cleanup on error
              reject(error);
            });
          }
        } else if (response.statusCode === 200) {
          response.pipe(file);

          file.on('finish', () => {
            file.close();
            resolve(filePath);
          });
        } else {
          reject(new Error(`Download failed with status ${response.statusCode}`));
        }
      }).on('error', (error) => {
        fs.unlink(filePath, () => {}); // Cleanup on error
        reject(error);
      });
    });
  }

  /**
   * Cleanup downloaded file after installation
   */
  async cleanup(filePath: string): Promise<void> {
    return new Promise((resolve, reject) => {
      fs.unlink(filePath, (err) => {
        if (err && err.code !== 'ENOENT') {
          reject(err);
        } else {
          resolve();
        }
      });
    });
  }

  /**
   * Cleanup all old downloads
   */
  async cleanupAll(): Promise<void> {
    const files = fs.readdirSync(this.downloadDir);
    
    for (const file of files) {
      if (file.endsWith('.vsix')) {
        await this.cleanup(path.join(this.downloadDir, file));
      }
    }
  }
}
```

