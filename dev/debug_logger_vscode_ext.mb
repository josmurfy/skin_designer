## 🔒 SÉCURITÉ & VALIDATION

### File Hash Verification:

**Add to `downloadManager.ts`:**

```typescript
import * as crypto from 'crypto';

export class DownloadManager {
  // ... existing code

  /**
   * Verify downloaded file integrity
   */
  async verifyHash(filePath: string, expectedHash: string): Promise<boolean> {
    return new Promise((resolve, reject) => {
      const hash = crypto.createHash('sha256');
      const stream = fs.createReadStream(filePath);

      stream.on('data', data => hash.update(data));
      stream.on('end', () => {
        const calculatedHash = hash.digest('hex');
        resolve(calculatedHash === expectedHash);
      });
      stream.on('error', reject);
    });
  }

  async download(url: string, version: string, expectedHash?: string): Promise<string> {
    const filePath = await this.downloadFile(url, version);

    // Verify hash if provided
    if (expectedHash) {
      const valid = await this.verifyHash(filePath, expectedHash);
      if (!valid) {
        await this.cleanup(filePath);
        throw new Error('Downloaded file hash mismatch! Possible corruption or tampering.');
      }
    }

    return filePath;
  }
}
```

### HTTPS-Only:

