## 💰 MONÉTISATION AVEC AUTO-UPDATE

### Scenario 1: Free vs Pro Licensing

```typescript
// In updateManager.ts

async checkLicenseBeforeUpdate(updateInfo: UpdateInfo): Promise<boolean> {
  const licenseManager = new LicenseManager();
  const hasProLicense = await licenseManager.isPro();

  // Free users: limit to major versions only
  if (!hasProLicense) {
    const currentMajor = semver.major(this.currentVersion);
    const latestMajor = semver.major(updateInfo.version);

    if (latestMajor > currentMajor) {
      const choice = await vscode.window.showInformationMessage(
        `DevFlow Pro v${updateInfo.version} requires a Pro license. Upgrade?`,
        'View Plans',
        'Stay on Free'
      );

      if (choice === 'View Plans') {
        vscode.env.openExternal(vscode.Uri.parse('https://phoenixdepot.com/devflow/pricing'));
      }
      
      return false;
    }
  }

  return true;
}
```

### Scenario 2: Subscription-Based

```typescript
async checkSubscriptionStatus(): Promise<boolean> {
  const licenseKey = vscode.workspace.getConfiguration('devflow').get('licenseKey');
  
  const response = await fetch('https://api.phoenixdepot.com/devflow/verify-license', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ licenseKey })
  });

  const data = await response.json();
  
  if (!data.active) {
    vscode.window.showWarningMessage(
      'Your DevFlow Pro subscription has expired. Updates disabled.',
      'Renew Subscription'
    );
    return false;
  }

  return true;
}
```

