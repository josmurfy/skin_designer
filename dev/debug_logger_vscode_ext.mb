### 5. **Changelog Parser**

**File: `src/updates/changelogParser.ts`**

```typescript
export class ChangelogParser {
  /**
   * Extract specific version section from CHANGELOG.md
   */
  extractVersion(changelog: string, version: string): string {
    // Parse markdown changelog format
    // Expected format:
    // ## [1.2.0] - 2026-04-10
    // ### Added
    // - Feature 1
    // ### Fixed
    // - Bug fix 1

    const lines = changelog.split('\n');
    const versionHeader = `## [${version}]`;
    
    let capturing = false;
    let result: string[] = [];

    for (const line of lines) {
      if (line.startsWith(versionHeader)) {
        capturing = true;
        result.push(line);
        continue;
      }

      if (capturing) {
        // Stop at next version header
        if (line.startsWith('## [') && !line.startsWith(versionHeader)) {
          break;
        }
        result.push(line);
      }
    }

    return result.join('\n').trim();
  }

  /**
   * Extract breaking changes
   */
  extractBreakingChanges(changelog: string): string[] {
    const breaking: string[] = [];
    const lines = changelog.split('\n');

    let inBreakingSection = false;

    for (const line of lines) {
      if (line.includes('### Breaking Changes') || line.includes('### BREAKING')) {
        inBreakingSection = true;
        continue;
      }

      if (inBreakingSection) {
        if (line.startsWith('###')) {
          inBreakingSection = false;
          continue;
        }

        if (line.trim().startsWith('-')) {
          breaking.push(line.trim().substring(1).trim());
        }
      }
    }

    return breaking;
  }

  /**
   * Generate summary from changelog
   */
  generateSummary(changelog: string, maxLength = 200): string {
    const lines = changelog.split('\n')
      .filter(line => line.trim().startsWith('-'))
      .map(line => line.trim().substring(1).trim());

    const summary = lines.slice(0, 3).join(', ');
    
    if (summary.length > maxLength) {
      return summary.substring(0, maxLength) + '...';
    }

    return summary;
  }
}
```

