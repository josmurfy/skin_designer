### 4. **Install Manager**

**File: `src/updates/installManager.ts`**

```typescript
import * as vscode from 'vscode';
import * as cp from 'child_process';
import * as util from 'util';

const exec = util.promisify(cp.exec);

export class InstallManager {
  /**
   * Install .vsix file using VS Code CLI
   */
  async install(vsixPath: string): Promise<void> {
    try {
      // Method 1: Using VS Code CLI (recommended)
      await this.installViaCLI(vsixPath);
    } catch (error) {
      console.error('CLI install failed, trying API method:', error);
      
      // Method 2: Using VS Code API (fallback)
      await this.installViaAPI(vsixPath);
    }
  }

  /**
   * Install using 'code' CLI command
   */
  private async installViaCLI(vsixPath: string): Promise<void> {
    // Find VS Code executable
    const codeCommand = this.getCodeCommand();
    
    if (!codeCommand) {
      throw new Error('VS Code CLI not found');
    }

    // Execute: code --install-extension /path/to/extension.vsix
    const { stdout, stderr } = await exec(
      `"${codeCommand}" --install-extension "${vsixPath}" --force`
    );

    if (stderr && !stderr.includes('Successfully installed')) {
      throw new Error(`Installation failed: ${stderr}`);
    }

    console.log('Extension installed via CLI:', stdout);
  }

  /**
   * Install using VS Code Extension API (experimental)
   */
  private async installViaAPI(vsixPath: string): Promise<void> {
    // Note: This is a workaround as VS Code doesn't officially expose
    // an API to install extensions programmatically
    
    // We can use the internal command (not guaranteed to work in all versions)
    try {
      await vscode.commands.executeCommand(
        'workbench.extensions.installExtension',
        vscode.Uri.file(vsixPath)
      );
    } catch (error) {
      throw new Error(
        'Automatic installation failed. Please install manually from: ' + vsixPath
      );
    }
  }

  /**
   * Get VS Code CLI command path
   */
  private getCodeCommand(): string | null {
    const platform = process.platform;

    if (platform === 'darwin') {
      // macOS
      return '/usr/local/bin/code';
    } else if (platform === 'win32') {
      // Windows
      const programFiles = process.env['ProgramFiles'] || 'C:\\Program Files';
      return `${programFiles}\\Microsoft VS Code\\bin\\code.cmd`;
    } else {
      // Linux
      return '/usr/bin/code';
    }
  }

  /**
   * Uninstall current version
   */
  async uninstall(extensionId: string): Promise<void> {
    const codeCommand = this.getCodeCommand();
    
    if (!codeCommand) {
      throw new Error('VS Code CLI not found');
    }

    await exec(`"${codeCommand}" --uninstall-extension ${extensionId}`);
  }
}
```

