### 6. **Update Models**

**File: `src/updates/models.ts`**

```typescript
export interface UpdateManifest {
  version: string;
  downloadUrl: string;
  releaseDate: string;
  changelog: string;
  minVSCodeVersion: string;
  breaking: boolean;
  sha256?: string; // File hash for verification
  size?: number;   // File size in bytes
}

export interface UpdateChannel {
  stable: UpdateManifest;
  beta?: UpdateManifest;
}

export interface UpdateConfig {
  autoCheck: boolean;
  autoDownload: boolean;
  autoInstall: boolean;
  channel: 'stable' | 'beta';
  checkInterval: number; // in hours
}

export interface BackupInfo {
  version: string;
  date: string;
  path?: string;
}
```

