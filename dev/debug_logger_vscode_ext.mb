## 🔧 IMPLÉMENTATION DÉTAILLÉE

### 1. **Update Manager (Core)**

**File: `src/updates/updateManager.ts`**

```typescript
import * as vscode from 'vscode';
import * as semver from 'semver';
import { VersionChecker } from './versionChecker';
import { DownloadManager } from './downloadManager';
import { InstallManager } from './installManager';
import { ChangelogParser } from './changelogParser';

export interface UpdateInfo {
  version: string;
  downloadUrl: string;
  releaseDate: string;
  changelog: string;
  minVSCodeVersion: string;
  breaking: boolean;
}

export class UpdateManager {
  private static instance: UpdateManager;
  private currentVersion: string;
  private updateChannel: 'stable' | 'beta';
  private autoCheckEnabled: boolean;
  private checkInterval: NodeJS.Timeout | null = null;

  private constructor(context: vscode.ExtensionContext) {
    const manifest = context.extension.packageJSON;
    this.currentVersion = manifest.version;
    
    const config = vscode.workspace.getConfiguration('devflow');
    this.updateChannel = config.get('updates.channel', 'stable');
    this.autoCheckEnabled = config.get('updates.autoCheck', true);
  }

  static getInstance(context: vscode.ExtensionContext): UpdateManager {
    if (!UpdateManager.instance) {
      UpdateManager.instance = new UpdateManager(context);
    }
    return UpdateManager.instance;
  }

  /**
   * Initialize auto-update checker
   */
  async initialize(context: vscode.ExtensionContext): Promise<void> {
    // Check immediately on startup
    if (this.autoCheckEnabled) {
      await this.checkForUpdates(false); // Silent check
    }

    // Schedule periodic checks (every 6 hours)
    this.schedulePeriodicChecks();

    // Listen to configuration changes
    context.subscriptions.push(
      vscode.workspace.onDidChangeConfiguration(e => {
        if (e.affectsConfiguration('devflow.updates')) {
          this.onConfigChanged();
        }
      })
    );
  }

  /**
   * Check for available updates
   */
  async checkForUpdates(showNoUpdateMessage = true): Promise<UpdateInfo | null> {
    try {
      const versionChecker = new VersionChecker(this.updateChannel);
      const latestVersion = await versionChecker.getLatestVersion();

      if (!latestVersion) {
        if (showNoUpdateMessage) {
          vscode.window.showInformationMessage('Unable to check for updates');
        }
        return null;
      }

      // Compare versions
      if (semver.gt(latestVersion.version, this.currentVersion)) {
        // Check VS Code compatibility
        const vscodeVersion = vscode.version;
        if (!semver.satisfies(vscodeVersion, latestVersion.minVSCodeVersion)) {
          vscode.window.showWarningMessage(
            `DevFlow Pro ${latestVersion.version} requires VS Code ${latestVersion.minVSCodeVersion}. ` +
            `Your version: ${vscodeVersion}`
          );
          return null;
        }

        // Show update notification
        await this.showUpdateNotification(latestVersion);
        return latestVersion;
      } else {
        if (showNoUpdateMessage) {
          vscode.window.showInformationMessage(
            `DevFlow Pro is up to date (v${this.currentVersion})`
          );
        }
        return null;
      }
    } catch (error) {
      console.error('Error checking for updates:', error);
      vscode.window.showErrorMessage(`Failed to check for updates: ${error}`);
      return null;
    }
  }

  /**
   * Show update notification with actions
   */
  private async showUpdateNotification(updateInfo: UpdateInfo): Promise<void> {
    const changelogParser = new ChangelogParser();
    const changelogSummary = changelogParser.extractVersion(
      updateInfo.changelog,
      updateInfo.version
    );

    const message = updateInfo.breaking
      ? `🚨 DevFlow Pro v${updateInfo.version} available (Breaking Changes)`
      : `🎉 DevFlow Pro v${updateInfo.version} available`;

    const actions = ['Update Now', 'View Changelog', 'Remind Later', 'Disable Auto-Update'];
    const choice = await vscode.window.showInformationMessage(
      message,
      { modal: false },
      ...actions
    );

    switch (choice) {
      case 'Update Now':
        await this.performUpdate(updateInfo);
        break;
      
      case 'View Changelog':
        await this.showChangelog(changelogSummary);
        // Show notification again after viewing changelog
        setTimeout(() => this.showUpdateNotification(updateInfo), 500);
        break;
      
      case 'Remind Later':
        // Will check again on next startup or in 6 hours
        break;
      
      case 'Disable Auto-Update':
        await vscode.workspace.getConfiguration('devflow').update(
          'updates.autoCheck',
          false,
          vscode.ConfigurationTarget.Global
        );
        vscode.window.showInformationMessage('Auto-update disabled');
        break;
    }
  }

  /**
   * Perform the update installation
   */
  private async performUpdate(updateInfo: UpdateInfo): Promise<void> {
    const progress = await vscode.window.withProgress({
      location: vscode.ProgressLocation.Notification,
      title: `Updating DevFlow Pro to v${updateInfo.version}`,
      cancellable: false
    }, async (progress) => {
      try {
        // Step 1: Download
        progress.report({ message: 'Downloading...', increment: 0 });
        const downloadManager = new DownloadManager();
        const vsixPath = await downloadManager.download(
          updateInfo.downloadUrl,
          updateInfo.version
        );
        progress.report({ increment: 40 });

        // Step 2: Backup current version
        progress.report({ message: 'Creating backup...', increment: 50 });
        await this.createBackup();
        progress.report({ increment: 60 });

        // Step 3: Install
        progress.report({ message: 'Installing...', increment: 70 });
        const installManager = new InstallManager();
        await installManager.install(vsixPath);
        progress.report({ increment: 90 });

        // Step 4: Cleanup
        progress.report({ message: 'Cleaning up...', increment: 95 });
        await downloadManager.cleanup(vsixPath);
        progress.report({ increment: 100 });

        return true;
      } catch (error) {
        console.error('Update failed:', error);
        throw error;
      }
    });

    if (progress) {
      // Prompt to reload
      const reload = await vscode.window.showInformationMessage(
        `✅ DevFlow Pro updated to v${updateInfo.version}. Reload to activate.`,
        'Reload Now',
        'Later'
      );

      if (reload === 'Reload Now') {
        await vscode.commands.executeCommand('workbench.action.reloadWindow');
      }
    }
  }

  /**
   * Show changelog in new editor
   */
  private async showChangelog(changelog: string): Promise<void> {
    const doc = await vscode.workspace.openTextDocument({
      content: changelog,
      language: 'markdown'
    });
    await vscode.window.showTextDocument(doc, {
      preview: true,
      viewColumn: vscode.ViewColumn.Beside
    });
  }

  /**
   * Create backup of current version
   */
  private async createBackup(): Promise<void> {
    // Store current version info for potential rollback
    const backupInfo = {
      version: this.currentVersion,
      date: new Date().toISOString()
    };

    const context = vscode.extensions.getExtension('phoenixdepot.devflow-pro');
    if (context) {
      await context.extensionContext.globalState.update(
        'lastVersionBackup',
        backupInfo
      );
    }
  }

  /**
   * Rollback to previous version
   */
  async rollback(): Promise<void> {
    const context = vscode.extensions.getExtension('phoenixdepot.devflow-pro');
    if (!context) {
      throw new Error('Extension context not found');
    }

    const backup = context.extensionContext.globalState.get<any>('lastVersionBackup');
    if (!backup) {
      throw new Error('No backup found to rollback to');
    }

    const confirm = await vscode.window.showWarningMessage(
      `Rollback to v${backup.version}? Current version will be uninstalled.`,
      { modal: true },
      'Rollback',
      'Cancel'
    );

    if (confirm === 'Rollback') {
      vscode.window.showInformationMessage(
        'Rollback feature requires manual reinstallation. ' +
        `Please install v${backup.version} from marketplace or .vsix file.`
      );
      // TODO: Implement actual rollback if old .vsix files are kept
    }
  }

  /**
   * Schedule periodic update checks
   */
  private schedulePeriodicChecks(): void {
    if (this.checkInterval) {
      clearInterval(this.checkInterval);
    }

    if (this.autoCheckEnabled) {
      // Check every 6 hours
      const SIX_HOURS = 6 * 60 * 60 * 1000;
      this.checkInterval = setInterval(() => {
        this.checkForUpdates(false); // Silent check
      }, SIX_HOURS);
    }
  }

  /**
   * Handle configuration changes
   */
  private onConfigChanged(): void {
    const config = vscode.workspace.getConfiguration('devflow');
    this.updateChannel = config.get('updates.channel', 'stable');
    this.autoCheckEnabled = config.get('updates.autoCheck', true);
    
    this.schedulePeriodicChecks();
  }

  /**
   * Dispose resources
   */
  dispose(): void {
    if (this.checkInterval) {
      clearInterval(this.checkInterval);
    }
  }
}
```

