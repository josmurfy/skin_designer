**Logique d'envoi (admin/controller/module/debug_logger.php):**
```php
// Dans la méthode debugSave(), après l'insertion en DB:

if ($this->config->get('module_debug_logger_email_enable')) {
    $severity = $data['severity'];
    $setting_key = 'module_debug_logger_email_' . $severity;
    
    if ($this->config->get($setting_key)) {
        $this->sendNotificationEmail($report_id, $data);
    }
}

// Nouvelle méthode:
private function sendNotificationEmail(int $report_id, array $data): void {
    $to = $this->config->get('module_debug_logger_email_to');
    if (!$to) return;
    
    $subject = '[Debug Logger] New ' . strtoupper($data['severity']) . ' Report #' . $report_id;
    
    $message = "A new debug report has been submitted:\n\n";
    $message .= "Report ID: #" . $report_id . "\n";
    $message .= "Severity: " . $data['severity'] . "\n";
    $message .= "Source: " . $data['source'] . "\n";
    $message .= "URL: " . $data['url'] . "\n";
    $message .= "User: " . ($data['admin_user'] ?? 'Guest') . "\n";
    $message .= "Date: " . date('Y-m-d H:i:s') . "\n\n";
    
    if ($data['comment']) {
        $message .= "Comment:\n" . $data['comment'] . "\n\n";
    }
    
    if ($data['console_log']) {
        $message .= "Console Errors:\n" . $data['console_log'] . "\n\n";
    }
    
    $message .= "View report: " . $this->url->link('extension/debug_logger/module/debug_logger.reports', 'user_token=' . $this->session->data['user_token']);
    
    $mail = new \Opencart\System\Library\Mail($this->config->get('config_mail_engine'));
    $mail->parameter = $this->config->get('config_mail_parameter');
    $mail->smtp_hostname = $this->config->get('config_mail_smtp_hostname');
    $mail->smtp_username = $this->config->get('config_mail_smtp_username');
    $mail->smtp_password = html_entity_decode($this->config->get('config_mail_smtp_password'), ENT_QUOTES, 'UTF-8');
    $mail->smtp_port = $this->config->get('config_mail_smtp_port');
    $mail->smtp_timeout = $this->config->get('config_mail_smtp_timeout');
    
    $mail->setTo($to);
    $mail->setFrom($this->config->get('config_email'));
    $mail->setSender($this->config->get('config_name'));
    $mail->setSubject($subject);
    $mail->setText($message);
    $mail->send();
}
```

