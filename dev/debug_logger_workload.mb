#### 1.3 - Webhook Notifications (Slack/Discord)
**Description:** Envoyer les rapports vers Slack ou Discord via webhook.

**Nouvelle section config:**
```html
<div class="card mb-3">
    <div class="card-header"><i class="fa-brands fa-slack"></i> Webhook Notifications (PRO)</div>
    <div class="card-body">
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Type de webhook</label>
            <div class="col-sm-8">
                <select class="form-control" name="module_debug_logger_webhook_type">
                    <option value="">Désactivé</option>
                    <option value="slack">Slack</option>
                    <option value="discord">Discord</option>
                </select>
            </div>
        </div>
        
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Webhook URL</label>
            <div class="col-sm-8">
                <input type="url" class="form-control" name="module_debug_logger_webhook_url" placeholder="https://hooks.slack.com/services/...">
                <div class="form-text">URL du webhook Slack ou Discord</div>
            </div>
        </div>
    </div>
</div>
```

**Implémentation (admin/controller/module/debug_logger.php):**
```php
private function sendWebhookNotification(int $report_id, array $data): void {
    $webhook_type = $this->config->get('module_debug_logger_webhook_type');
    $webhook_url = $this->config->get('module_debug_logger_webhook_url');
    
    if (!$webhook_type || !$webhook_url) return;
    
    if ($webhook_type === 'slack') {
        $payload = $this->buildSlackPayload($report_id, $data);
    } elseif ($webhook_type === 'discord') {
        $payload = $this->buildDiscordPayload($report_id, $data);
    } else {
        return;
    }
    
    $ch = curl_init($webhook_url);
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_POST, true);
    curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode($payload));
    curl_setopt($ch, CURLOPT_HTTPHEADER, ['Content-Type: application/json']);
    curl_exec($ch);
    curl_close($ch);
}

private function buildSlackPayload(int $report_id, array $data): array {
    $severity_emoji = [
        'bug' => '🐛',
        'warning' => '⚠️',
        'info' => 'ℹ️'
    ];
    
    $severity_color = [
        'bug' => '#ef4444',
        'warning' => '#f59e0b',
        'info' => '#3b82f6'
    ];
    
    return [
        'text' => 'New Debug Report #' . $report_id,
        'attachments' => [
            [
                'color' => $severity_color[$data['severity']] ?? '#6b7280',
                'fields' => [
                    [
                        'title' => 'Severity',
                        'value' => $severity_emoji[$data['severity']] . ' ' . strtoupper($data['severity']),
                        'short' => true
                    ],
                    [
                        'title' => 'Source',
                        'value' => ucfirst($data['source']),
                        'short' => true
                    ],
                    [
                        'title' => 'URL',
                        'value' => $data['url'],
                        'short' => false
                    ],
                    [
                        'title' => 'Comment',
                        'value' => $data['comment'] ?: '_No comment_',
                        'short' => false
                    ]
                ],
                'footer' => 'Debug Logger',
                'ts' => time()
            ]
        ]
    ];
}

private function buildDiscordPayload(int $report_id, array $data): array {
    $severity_color = [
        'bug' => 0xef4444,
        'warning' => 0xf59e0b,
        'info' => 0x3b82f6
    ];
    
    return [
        'embeds' => [
            [
                'title' => '🐛 New Debug Report #' . $report_id,
                'color' => $severity_color[$data['severity']] ?? 0x6b7280,
                'fields' => [
                    [
                        'name' => 'Severity',
                        'value' => strtoupper($data['severity']),
                        'inline' => true
                    ],
                    [
                        'name' => 'Source',
                        'value' => ucfirst($data['source']),
                        'inline' => true
                    ],
                    [
                        'name' => 'URL',
                        'value' => $data['url']
                    ],
                    [
                        'name' => 'Comment',
                        'value' => $data['comment'] ?: '_No comment_'
                    ]
                ],
                'timestamp' => date('c')
            ]
        ]
    ];
}
```

