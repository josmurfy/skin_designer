## 🔧 MIGRATIONS SQL NÉCESSAIRES

```sql
-- Version 2.0.0 upgrade

-- 1. Screenshot support
ALTER TABLE `oc_debug_logger_reports` 
ADD COLUMN `screenshot` MEDIUMTEXT NULL AFTER `network_log`;

-- 2. Assignment support
ALTER TABLE `oc_debug_logger_reports` 
ADD COLUMN `assigned_to` INT(11) NULL AFTER `admin_user`,
ADD KEY `idx_assigned` (`assigned_to`);

-- 3. Tags table
CREATE TABLE IF NOT EXISTS `oc_debug_logger_tags` (
  `tag_id` INT(11) NOT NULL AUTO_INCREMENT,
  `report_id` INT(11) NOT NULL,
  `tag_name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`tag_id`),
  KEY `idx_report` (`report_id`),
  KEY `idx_tag` (`tag_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- 4. Analytics table (optional - pour cache)
CREATE TABLE IF NOT EXISTS `oc_debug_logger_stats` (
  `stat_date` DATE NOT NULL,
  `severity` VARCHAR(20) NOT NULL,
  `source` VARCHAR(20) NOT NULL,
  `count` INT(11) NOT NULL DEFAULT 0,
  PRIMARY KEY (`stat_date`, `severity`, `source`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
```

