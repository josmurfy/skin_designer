/* Performance Analytics CSS */

/* Pulse animation for stats update */
@keyframes pulse {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.05);
    }
    100% {
        transform: scale(1);
    }
}

.pulse-animation {
    animation: pulse 0.5s ease-in-out;
}

/* Card hover effects */
.card {
    transition: all 0.3s ease;
}

.card:hover {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

/* Sticky table headers */
.sticky-top {
    position: sticky;
    top: 0;
    z-index: 10;
}

/* Stats cards */
.card-body h3 {
    font-weight: bold;
    font-size: 2rem;
}

.card-body h6 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Badge styling */
.badge {
    font-size: 0.9rem;
    padding: 0.4rem 0.6rem;
}

/* Table improvements */
.table-sm td, .table-sm th {
    padding: 0.5rem;
}

.table-hover tbody tr:hover {
    background-color: rgba(0, 123, 255, 0.05);
}

/* Period selector */
#period-selector .btn-outline-primary:checked + label {
    background-color: #0d6efd;
    color: white;
}

/* Loading overlay */
#analytics-loading-overlay {
    backdrop-filter: blur(2px);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .card-body h3 {
        font-size: 1.5rem;
    }
    
    .fa-3x {
        font-size: 2rem !important;
    }
}

/* Alert cards */
.alert {
    border-left: 4px solid;
}

.alert-danger {
    border-left-color: #dc3545;
}

.alert-warning {
    border-left-color: #ffc107;
}

.alert-info {
    border-left-color: #0dcaf0;
}

/* Chart container */
.chart-container {
    position: relative;
    height: 300px;
    margin-bottom: 1rem;
}

/* Scrollable tables */
.table-responsive {
    border-radius: 0.25rem;
}

.table-responsive::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

.table-responsive::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
}

.table-responsive::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 10px;
}

.table-responsive::-webkit-scrollbar-thumb:hover {
    background: #555;
}

/* Icon opacity for stat cards */
.opacity-50 {
    opacity: 0.5;
}

/* Button group improvements */
.btn-group label {
    cursor: pointer;
}

/* Toast positioning */
.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 10000;
}
