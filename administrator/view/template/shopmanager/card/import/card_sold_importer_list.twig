<div class="table-responsive" style="font-size:12px;">
  <table class="table table-bordered table-hover table-sm mb-0">
    <thead class="table-dark">
      <tr>
        <td style="width:1px;" class="text-center">
          <input type="checkbox" id="check-all" class="form-check-input">
        </td>
        <td class="text-center">
          {% if sort == 'card_price_sold_id' %}
            <a href="{{ sort_card_price_sold_id }}" class="text-decoration-none fw-bold text-white">{{ column_card_price_sold_id }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_card_price_sold_id }}" class="text-decoration-none text-white-50">{{ column_card_price_sold_id }}</a>
          {% endif %}
        </td>
        <td style="width:60px;">{{ column_front_image }}</td>
        <td style="min-width:160px;">
          {% if sort == 'title' %}
            <a href="{{ sort_title }}" class="text-decoration-none fw-bold text-white">{{ column_title }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_title }}" class="text-decoration-none text-white-50">{{ column_title }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'category' %}
            <a href="{{ sort_category }}" class="text-decoration-none fw-bold text-white">{{ column_category }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_category }}" class="text-decoration-none text-white-50">{{ column_category }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'year' %}
            <a href="{{ sort_year }}" class="text-decoration-none fw-bold text-white">{{ column_year }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_year }}" class="text-decoration-none text-white-50">{{ column_year }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'brand' %}
            <a href="{{ sort_brand }}" class="text-decoration-none fw-bold text-white">{{ column_brand }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_brand }}" class="text-decoration-none text-white-50">{{ column_brand }}</a>
          {% endif %}
        </td>
        <td style="min-width:130px;">
          {% if sort == 'set_name' %}
            <a href="{{ sort_set_name }}" class="text-decoration-none fw-bold text-white">{{ column_set }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_set_name }}" class="text-decoration-none text-white-50">{{ column_set }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'player' %}
            <a href="{{ sort_player }}" class="text-decoration-none fw-bold text-white">{{ column_player }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_player }}" class="text-decoration-none text-white-50">{{ column_player }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'card_number' %}
            <a href="{{ sort_card_number }}" class="text-decoration-none fw-bold text-white">{{ column_card_number }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_card_number }}" class="text-decoration-none text-white-50">{{ column_card_number }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'grader' %}
            <a href="{{ sort_grader }}" class="text-decoration-none fw-bold text-white">{{ column_grader }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_grader }}" class="text-decoration-none text-white-50">{{ column_grader }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'grade' %}
            <a href="{{ sort_grade }}" class="text-decoration-none fw-bold text-white">{{ column_grade }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_grade }}" class="text-decoration-none text-white-50">{{ column_grade }}</a>
          {% endif %}
        </td>
        <td class="text-end">
          {% if sort == 'price' %}
            <a href="{{ sort_price }}" class="text-decoration-none fw-bold text-white">{{ column_price }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_price }}" class="text-decoration-none text-white-50">{{ column_price }}</a>
          {% endif %}
        </td>
        <td>{{ column_currency }}</td>
        <td>{{ column_type_listing }}</td>
        <td class="text-center">{{ column_bids }}</td>
        <td class="text-center">{{ column_total_sold }}</td>
        <td>{{ column_ebay_item_id }}</td>
        <td class="text-center">{{ column_status }}</td>
        <td>
          {% if sort == 'date_sold' %}
            <a href="{{ sort_date_sold }}" class="text-decoration-none fw-bold text-white">{{ column_date_sold }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_date_sold }}" class="text-decoration-none text-white-50">{{ column_date_sold }}</a>
          {% endif %}
        </td>
        <td>
          {% if sort == 'date_added' %}
            <a href="{{ sort_date_added }}" class="text-decoration-none fw-bold text-white">{{ column_date_added }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_date_added }}" class="text-decoration-none text-white-50">{{ column_date_added }}</a>
          {% endif %}
        </td>
      </tr>
    </thead>
    <tbody>
      {% if records %}
        {% for rec in records %}
          {% set missing_cn = (rec.card_number is empty) %}
          {% set row_class = missing_cn ? 'table-danger' : '' %}
          <tr class="{{ row_class }}" data-card-price-sold-id="{{ rec.card_price_sold_id }}">
            <td class="text-center">
              <input type="checkbox" name="selected[]" value="{{ rec.card_price_sold_id }}" class="form-check-input">
            </td>
            <td class="text-center text-muted">{{ rec.card_price_sold_id }}</td>
            <td class="text-center">
              {% if rec.front_image %}
                <img src="{{ rec.front_image }}" style="max-height:40px;max-width:55px;" onerror="this.style.display='none'">
              {% else %}
                &mdash;
              {% endif %}
            </td>
            <td>
              <div style="font-weight:600;line-height:1.3;">{{ rec.title }}</div>
              <div style="margin-top:3px;display:flex;flex-wrap:wrap;gap:2px;">
                {% if rec.year %}<span class="badge bg-secondary" style="font-size:10px;">{{ rec.year }}</span>{% endif %}
                {% if rec.brand %}<span class="badge bg-secondary" style="font-size:10px;">{{ rec.brand }}</span>{% endif %}
                {% if rec.set_name %}<span class="badge bg-dark" style="font-size:10px;">{{ rec.set_name }}</span>{% endif %}
                {% if rec.player %}<span class="badge bg-primary" style="font-size:10px;">{{ rec.player }}</span>{% endif %}
                {% if rec.card_number %}<span class="badge bg-light text-dark border" style="font-size:10px;">#{{ rec.card_number }}</span>{% endif %}
              </div>
            </td>
            <td>{{ rec.category }}</td>
            <td class="text-center">{{ rec.year }}</td>
            <td>{{ rec.brand }}</td>
            <td>{{ rec.set_name }}</td>
            <td>{{ rec.player }}</td>
            <td class="text-center">
              {% if missing_cn %}
                <span class="badge bg-danger" title="{{ text_missing_card_number }}"><i class="fa-solid fa-triangle-exclamation"></i></span>
              {% else %}
                {{ rec.card_number }}
              {% endif %}
            </td>
            <td>{{ rec.grader }}</td>
            <td class="text-center">
              {% if rec.grade %}
                <span class="badge bg-dark">{{ rec.grade }}</span>
              {% else %}
                &mdash;
              {% endif %}
            </td>
            <td class="text-end fw-bold">
              {% if rec.price > 0 %}
                <span style="color:#0d6efd;">${{ rec.price|number_format(2) }}</span>
              {% else %}
                &mdash;
              {% endif %}
            </td>
            <td>{{ rec.currency }}</td>
            <td>
              {% if rec.type_listing == 'auction' %}
                <span class="badge bg-dark">AUC</span>
              {% else %}
                <span class="badge bg-primary">BIN</span>
              {% endif %}
            </td>
            <td class="text-center">{{ rec.bids ?: '—' }}</td>
            <td class="text-center">{{ rec.total_sold }}</td>
            <td>
              {% if rec.ebay_item_id %}
                <a href="https://www.ebay.ca/itm/{{ rec.ebay_item_id }}" target="_blank" style="font-size:11px;">{{ rec.ebay_item_id }}</a>
              {% else %}
                &mdash;
              {% endif %}
            </td>
            <td class="text-center">
              {% if rec.status %}
                <span class="badge bg-success"><i class="fa-solid fa-check"></i></span>
              {% else %}
                <span class="badge bg-secondary"><i class="fa-solid fa-xmark"></i></span>
              {% endif %}
            </td>
            <td class="text-nowrap">{{ rec.date_sold ?: '—' }}</td>
            <td class="text-nowrap text-muted">{{ rec.date_added }}</td>
          </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td colspan="21" class="text-center text-muted py-4">
            <i class="fa-solid fa-inbox fa-2x d-block mb-2 opacity-50"></i>
            {{ text_no_records }}
          </td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>
<div class="row px-3 py-2">
  <div class="col-sm-6 text-start small text-muted">{{ results }}</div>
  <div class="col-sm-6 text-end">{{ pagination }}</div>
</div>
