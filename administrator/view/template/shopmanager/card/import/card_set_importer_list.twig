<div class="table-responsive">
  <table class="table table-bordered table-hover table-sm" id="price-list-table">
    <thead class="table-dark">
      <tr>
        <th style="width:36px;"><input type="checkbox" id="check-all" class="form-check-input" /></th>
        <th style="width:30px;">#</th>
        <th style="width:80px;">{{ column_front_image }}</th>
        <th style="min-width:200px;">
          {% if sort == 'title' %}
            <a href="{{ sort_title }}" class="text-decoration-none fw-bold text-white">{{ column_title }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_title }}" class="text-decoration-none text-white-50">{{ column_title }}</a>
          {% endif %}
        </th>
        <th style="min-width:120px;" class="text-end">
          {% if sort == 'best_price' %}
            <a href="{{ sort_best_price }}" class="text-decoration-none fw-bold text-white">Meilleur prix <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_best_price }}" class="text-decoration-none text-white-50">Meilleur prix</a>
          {% endif %}
        </th>
        <th style="width:80px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      {% if cards %}
        {% set n = 1 %}
        {% for card in cards %}
          {% set u   = card.ungraded|default(0) %}
          {% set g9  = card.grade_9|default(0) %}
          {% set g10 = card.grade_10|default(0) %}
          {% set max_price = max(u, g9, g10) %}
          {% if max_price >= 50 %}{% set row_class = 'table-warning' %}
          {% elseif max_price >= 20 %}{% set row_class = 'table-info' %}
          {% elseif max_price >= 5  %}{% set row_class = 'table-active' %}
          {% else %}{% set row_class = '' %}{% endif %}
          {% set keyword = card.title ?: ((card.set_name ?: '') ~ ' ' ~ (card.player ?: '') ~ ' #' ~ (card.card_number ?: '')) %}
          {% set sold_graded_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ keyword|url_encode ~ '&_sacat=261328&LH_Sold=1&Graded=Yes&_sop=3&_udlo=35' %}
          <tr class="{{ row_class }}" data-card-raw-id="{{ card.card_raw_id }}">

            {# Col 1 — Checkbox #}
            <td class="text-center"><input type="checkbox" name="selected[]" value="{{ card.card_raw_id }}" class="form-check-input" /></td>

            {# Col 2 — Row # #}
            <td class="text-center text-muted" style="font-size:11px;">{{ n }}</td>

            {# Col 3 — Image #}
            <td class="text-center">
              {% if card.front_image %}
                <img src="{{ card.front_image }}" class="preview-thumb-img" data-fullsrc="{{ card.front_image }}" style="max-height:65px;max-width:65px;cursor:zoom-in;" onerror="this.style.display='none'"/>
              {% else %}
                <span class="text-muted">—</span>
              {% endif %}
            </td>

            {# Col 4 — Card Info #}
            <td style="white-space:normal;">
              <div style="font-size:12px;font-weight:600;line-height:1.3;">{{ card.title }}</div>
              <div style="margin-top:4px;display:flex;flex-wrap:wrap;gap:3px;">
                {% if card.year    %}<span class="badge bg-secondary" style="font-size:10px;">{{ card.year }}</span>{% endif %}
                {% if card.brand   %}<span class="badge bg-secondary" style="font-size:10px;">{{ card.brand }}</span>{% endif %}
                {% if card.set_name%}<span class="badge bg-dark"      style="font-size:10px;">{{ card.set_name }}</span>{% endif %}
                {% if card.player  %}<span class="badge bg-primary"   style="font-size:10px;">{{ card.player }}</span>{% endif %}
                {% if card.card_number %}<span class="badge bg-light text-dark border" style="font-size:10px;">#{{ card.card_number }}</span>{% endif %}
                {% if card.category%}<span class="badge bg-info text-dark" styl
              </div>
         

            {# Col 5 — Prices + sold graded button #}
            <td style="w
              {% for pr in [{'
          
                  <div style="margin-bottom:2px;">
                    <span class="badge {{ pr.cls }}
                    <span style="font-
                  </div>
                {% else %}
         
                    <span class="badg
                    <span style="f
                  </div>
                {% endif %}
              {% endfor %}
              {% if keyword %}
                <div style="margin-top:4px;">
   
                </di
              {% endif %}
            </td>

            {# Col 6 — Actions #}
            <td class="text-center
              <button type="button" class="btn btn-sm btn-outline-primar
                <i class="fa-solid fa-tags"></i>
              </button>
 

          </tr>
          {% set n = n + 1 %}
        
      {% else %}
        <tr>
          <td class="text-center py-4 text-muted" colspan="6">
            <i class="fa-solid fa-in
            {{ text_no_records }}
          </td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>
<div class="row px-3 py-2">
  <div class
  <div class="col-sm-6 text-end">{{ pagination }}</div>
</div>
