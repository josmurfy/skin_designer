{# ── Summary bar ── #}
{% if summary and summary.total_cards > 0 %}
<div class="row g-2 mb-3">
  <div class="col-sm-3">
    <div class="card text-bg-info">
      <div class="card-body py-2 text-center">
        <small>{{ text_total_cards }}</small>
        <div class="fw-bold fs-5">{{ summary.total_cards }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card text-bg-success">
      <div class="card-body py-2 text-center">
        <small>{{ text_cards_above }} (${{ summary.threshold }}+)</small>
        <div class="fw-bold fs-5">{{ summary.cards_above }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card text-bg-warning">
      <div class="card-body py-2 text-center">
        <small>{{ text_avg_value }}</small>
        <div class="fw-bold fs-5">${{ summary.avg_value }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card text-bg-primary">
      <div class="card-body py-2 text-center">
        <small>{{ text_total_value }}</small>
        <div class="fw-bold fs-5">${{ summary.total_value }}</div>
      </div>
    </div>
  </div>
</div>
{% endif %}

{# ── Results table ── #}
<div class="table-responsive">
  <table class="table table-bordered table-hover table-sm align-middle">
    <thead class="table-light">
      <tr>
        <th class="text-center" style="width:50px;">
          {% if sort == 'card_number' %}
            <a href="{{ sort_card_number }}" class="text-decoration-none fw-bold">{{ column_card_number }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_card_number }}" class="text-decoration-none">{{ column_card_number }}</a>
          {% endif %}
        </th>
        <th class="text-start">
          {% if sort == 'player' %}
            <a href="{{ sort_player }}" class="text-decoration-none fw-bold">{{ column_player }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_player }}" class="text-decoration-none">{{ column_player }}</a>
          {% endif %}
        </th>
        <th class="text-start">{{ column_team }}</th>
        <th class="text-start">
          {% if sort == 'set_name' %}
            <a href="{{ sort_set_name }}" class="text-decoration-none fw-bold">{{ column_set_name }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_set_name }}" class="text-decoration-none">{{ column_set_name }}</a>
          {% endif %}
        </th>
        <th class="text-center">
          {% if sort == 'year' %}
            <a href="{{ sort_year }}" class="text-decoration-none fw-bold">{{ column_year }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_year }}" class="text-decoration-none">{{ column_year }}</a>
          {% endif %}
        </th>
        <th class="text-center">
          {% if sort == 'brand' %}
            <a href="{{ sort_brand }}" class="text-decoration-none fw-bold">{{ column_brand }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_brand }}" class="text-decoration-none">{{ column_brand }}</a>
          {% endif %}
        </th>
        <th class="text-end">
          {% if sort == 'ungraded' %}
            <a href="{{ sort_ungraded }}" class="text-decoration-none fw-bold">{{ column_ungraded }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_ungraded }}" class="text-decoration-none">{{ column_ungraded }}</a>
          {% endif %}
        </th>
        <th class="text-end">
          {% if sort == 'grade_9' %}
            <a href="{{ sort_grade_9 }}" class="text-decoration-none fw-bold">{{ column_grade_9 }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_grade_9 }}" class="text-decoration-none">{{ column_grade_9 }}</a>
          {% endif %}
        </th>
        <th class="text-end">
          {% if sort == 'grade_10' %}
            <a href="{{ sort_grade_10 }}" class="text-decoration-none fw-bold">{{ column_grade_10 }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_grade_10 }}" class="text-decoration-none">{{ column_grade_10 }}</a>
          {% endif %}
        </th>
        <th class="text-end">
          {% if sort == 'best_price' %}
            <a href="{{ sort_best_price }}" class="text-decoration-none fw-bold">{{ column_best_price }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_best_price }}" class="text-decoration-none">{{ column_best_price }}</a>
          {% endif %}
        </th>
        <th class="text-center">{{ column_sold_count }}</th>
        <th class="text-end">{{ column_sold_avg }}</th>
        <th class="text-center">{{ column_active_count }}</th>
        <th class="text-end">{{ column_active_avg }}</th>
        <th class="text-end">
          {% if sort == 'grading_gain' %}
            <a href="{{ sort_grading_gain }}" class="text-decoration-none fw-bold">{{ column_grading_gain }} <i class="fa-solid fa-sort-{{ order|lower }}"></i></a>
          {% else %}
            <a href="{{ sort_grading_gain }}" class="text-decoration-none">{{ column_grading_gain }}</a>
          {% endif %}
        </th>
        <th class="text-center">{{ column_verdict }}</th>
      </tr>
    </thead>
    <tbody>
      {% if cards %}
        {% for card in cards %}
          <tr class="row-{{ card.price_category }}">
            <td class="text-center">{{ card.card_number }}</td>
            <td class="text-start">
              {{ card.player }}
              {% if card.attributes %}<br><small class="text-muted">{{ card.attributes }}</small>{% endif %}
              {% if card.variation %}<br><small class="text-info">{{ card.variation }}</small>{% endif %}
            </td>
            <td class="text-start">{{ card.team }}</td>
            <td class="text-start">
              {{ card.set_name }}
              {% if card.subset %}<br><small class="text-muted">{{ card.subset }}</small>{% endif %}
            </td>
            <td class="text-center">{{ card.year }}</td>
            <td class="text-center">{{ card.brand }}</td>
            <td class="text-end">{% if card.ungraded > 0 %}${{ card.ungraded|number_format(2) }}{% else %}-{% endif %}</td>
            <td class="text-end">{% if card.grade_9 > 0 %}${{ card.grade_9|number_format(2) }}{% else %}-{% endif %}</td>
            <td class="text-end">{% if card.grade_10 > 0 %}${{ card.grade_10|number_format(2) }}{% else %}-{% endif %}</td>
            <td class="text-end fw-bold">
              <span class="badge bg-{{ card.price_category == 'gold' ? 'warning text-dark' : (card.price_category == 'orange' ? 'orange' : (card.price_category == 'blue' ? 'primary' : 'secondary')) }}">
                ${{ card.best_price|number_format(2) }}
              </span>
              {% if card.grading_potential > 100 %}
                <br><small class="text-success" title="Grading potential: +{{ card.grading_potential }}%"><i class="fa-solid fa-arrow-trend-up"></i> +{{ card.grading_potential }}%</small>
              {% endif %}
            </td>
            <td class="text-center">
              {% if card.sold_count > 0 %}
                <span class="badge bg-info">{{ card.sold_count }}</span>
              {% else %}
                -
              {% endif %}
            </td>
            <td class="text-end">
              {% if card.sold_avg > 0 %}${{ card.sold_avg|number_format(2) }}{% else %}-{% endif %}
            </td>
            <td class="text-center">
              {% if card.active_count > 0 %}
                <span class="badge bg-success">{{ card.active_count }}</span>
              {% else %}
                -
              {% endif %}
            </td>
            <td class="text-end">
              {% if card.active_avg > 0 %}${{ card.active_avg|number_format(2) }}{% else %}-{% endif %}
            </td>
            <td class="text-end">
              {% if card.grading_gain > 0 %}
                <span class="text-success fw-bold">+${{ card.grading_gain|number_format(2) }}</span>
              {% elseif card.grading_gain < 0 %}
                <span class="text-danger">${{ card.grading_gain|number_format(2) }}</span>
              {% else %}
                -
              {% endif %}
            </td>
            <td class="text-center">
              {% if card.verdict == 'grade' %}
                <span class="badge bg-success"><i class="fa-solid fa-gem"></i> {{ text_worth_grading }}</span>
              {% elseif card.verdict == 'sell_raw' %}
                <span class="badge bg-primary"><i class="fa-solid fa-tag"></i> {{ text_sell_individual }}</span>
              {% else %}
                <span class="badge bg-secondary"><i class="fa-solid fa-box"></i> {{ text_sell_lot }}</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td class="text-center" colspan="16">{{ text_no_results }}</td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>

{# ── Pagination ── #}
<div class="row">
  <div class="col-sm-6 text-start">{{ results }}</div>
  <div class="col-sm-6 text-end">{{ pagination }}</div>
</div>

{# ── Row color styles (price categories) ── #}
<style>
  .row-gold   { background-color: #fff8e1 !important; }
  .row-orange { background-color: #fff3e0 !important; }
  .row-blue   { background-color: #e3f2fd !important; }
  .row-gray   { opacity: 0.6; }
  .bg-orange  { background-color: #ff9800 !important; color: #fff; }
</style>
