<script>
$(document).ready(function() {
    // Global variables
    var USER_TOKEN = '{{ user_token|default("")|escape('js') }}';
    var uploadUrl = '{{ upload|raw|escape('js') }}';
    var saveToDbUrl = 'index.php?route=shopmanager/card/card_importer.saveListings&user_token=' + USER_TOKEN;
  var TEXT_GRADING_GROUP_BADGE = '{{ text_grading_group_badge|default('Grading potential')|escape('js') }}';
    var TEXT_BRAND_MISMATCH_BLOCK_SAVE = '{{ text_brand_mismatch_block_save|default('Fix brand mismatch issues in preview before saving.')|escape('js') }}';
    var uploadLoadingModalElement = document.getElementById('uploadLoadingModal');
    var uploadLoadingModal = null;

    if (uploadLoadingModalElement && typeof bootstrap !== 'undefined' && typeof bootstrap.Modal === 'function') {
      uploadLoadingModal = new bootstrap.Modal(uploadLoadingModalElement, {
        backdrop: 'static',
        keyboard: false
      });
    }

    function normalizeUrl(url) {
      return String(url || '').replace(/&amp;/g, '&');
    }

    uploadUrl = normalizeUrl(uploadUrl);
    saveToDbUrl = normalizeUrl(saveToDbUrl);
    console.log('Upload URL:', uploadUrl);
    console.log('Save to DB URL:', saveToDbUrl);

    // ===== SAVE BUTTON GATING =====
    // Disabled tant qu'il reste des prix non sélectionnés ou des brands manquantes
    function normalizeBrandComparable(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function isBrandInCardTitle(brandValue, titleValue) {
      var brand = normalizeBrandComparable(brandValue);
      var title = normalizeBrandComparable(titleValue);

      if (!brand || !title) {
        return false;
      }

      if (title.indexOf(brand) !== -1) {
        return true;
      }

      var brandWords = brand.split(' ').filter(function(word) {
        return word.length > 1;
      });

      if (brandWords.length > 1) {
        return brandWords.every(function(word) {
          return title.indexOf(word) !== -1;
        });
      }

      return false;
    }

    window.updateBrandValidationState = function() {
      var missingBrands = 0;
      var brandTitleMismatches = 0;
      var mismatchedListings = 0;

      $('#preview-content .brand-group').each(function() {
        var $group = $(this);
        var normalizedBrands = {};

        $group.find('.brand-input').each(function() {
          var rawValue = String($(this).val() || '').trim();
          if (!rawValue) {
            return;
          }

          normalizedBrands[normalizeBrandComparable(rawValue)] = true;
        });

        var listingMismatch = Object.keys(normalizedBrands).length > 1;

        if (listingMismatch) {
          mismatchedListings++;
        }

        $group.find('.brand-input').each(function() {
          var $brandInput = $(this);
          var $brandCell = $brandInput.closest('td.brand-cell');
          var brandValue = String($brandInput.val() || '').trim();
          var $row = $brandInput.closest('tr');
          var $titleInput = $row.find('input[name$="[title]"]').first();
          var titleValue = String($titleInput.val() || '').trim();
          var titleMismatch = false;

          if (!brandValue) {
            missingBrands++;
          } else {
            titleMismatch = !isBrandInCardTitle(brandValue, titleValue);

            if (titleMismatch) {
              brandTitleMismatches++;
            }
          }

          var hasBrandError = !brandValue || listingMismatch || titleMismatch;

          $brandCell.toggleClass('brand-cell-error', hasBrandError);
          $brandInput.toggleClass('field-warning', hasBrandError);
        });
      });

      return {
        missingBrands: missingBrands,
        brandTitleMismatches: brandTitleMismatches,
        mismatchedListings: mismatchedListings
      };
    };

    window.evaluateBrandConsistency = function() {
      var brandState = window.updateBrandValidationState ? window.updateBrandValidationState() : { mismatchedListings: 0 };

      return brandState.mismatchedListings || 0;
    };

    window.checkSaveReady = function() {
        var unresolvedPrices = $('[data-price-unresolved="1"]').length;
      var brandState = window.updateBrandValidationState ? window.updateBrandValidationState() : {
        missingBrands: 0,
        brandTitleMismatches: 0,
        mismatchedListings: 0
      };
      var missingBrands = brandState.missingBrands || 0;
      var brandTitleMismatches = brandState.brandTitleMismatches || 0;
      var mismatchedListings = brandState.mismatchedListings || 0;

        var $btn = $('#button-save-to-database');
      if (unresolvedPrices === 0 && missingBrands === 0 && mismatchedListings === 0 && brandTitleMismatches === 0) {
            $btn.prop('disabled', false)
                .removeClass('btn-secondary').addClass('btn-primary')
                .attr('title', '');
        } else {
            var msgs = [];
            if (unresolvedPrices > 0) msgs.push(unresolvedPrices + ' prix non sélectionné(s)');
            if (missingBrands > 0) msgs.push(missingBrands + ' brand(s) manquante(s)');
        if (mismatchedListings > 0) msgs.push(mismatchedListings + ' listing(s) avec brand mismatch');
        if (brandTitleMismatches > 0) msgs.push(brandTitleMismatches + ' card(s) brand hors title');
            $btn.prop('disabled', true)
                .removeClass('btn-primary').addClass('btn-secondary')
                .attr('title', msgs.join(' | '));
        }
    };

        window.decorateGradingPotentialGroups = function() {
          $('#preview-content .brand-group').each(function() {
            var $group = $(this);
            var $headerContent = $group.find('.brand-header > div').first();
            var profitableCardsCount = $group.find('.grading-profit-note-importer').length;
            var $collapse = $group.find('.collapse').first();

            $headerContent.find('.grading-potential-group-badge').remove();

            if (profitableCardsCount > 0) {
              $headerContent.append(' <span class="badge bg-warning text-dark ms-2 grading-potential-group-badge"><i class="fa-solid fa-gem me-1"></i>' + TEXT_GRADING_GROUP_BADGE + '</span>');

              if ($collapse.length && !$collapse.hasClass('show')) {
                if (typeof $collapse.collapse === 'function') {
                  $collapse.collapse('show');
                } else {
                  $collapse.addClass('show');
                }
              }
            }
          });
        };

        window.updateListingMenusVisibility = function() {
          window.decorateGradingPotentialGroups && window.decorateGradingPotentialGroups();

          var hasGradingPotential = $('#preview-content .grading-profit-note-importer').length > 0;

          if (hasGradingPotential) {
            $('#grading-potential-listing-alert').stop(true, true).slideDown(150);
          } else {
            $('#grading-potential-listing-alert').stop(true, true).slideUp(150);
          }
        };

    var cardsData = [];

    $(document).on('change input', '#preview-content .brand-input', function() {
      window.checkSaveReady && window.checkSaveReady();
    });

    $(document).on('change input', '#preview-content input[name$="[title]"]', function() {
      window.checkSaveReady && window.checkSaveReady();
    });

    // ==========================================
    // MODAL HELPER FUNCTIONS
    // ==========================================
    
    /**
     * Show alert modal
     * @param {string} message - The message to display
     * @param {string} title - The title (default: Error)
     * @param {string} type - 'success', 'error', 'warning', 'info'
     */
    function showAlert(message, title, type) {
        title = title || '{{ text_error|escape('js') }}';
        type = type || 'error';

      if (!$('#alertModal').length || typeof $.fn.modal !== 'function') {
        alert((title ? title + ': ' : '') + $('<div>').html(String(message || '')).text());
        return;
      }
        
        var $modal = $('#alertModal');
        var $header = $modal.find('#alert-header');
        var $icon = $modal.find('#alert-icon');
        
        // Set colors and icon based on type
        if (type === 'success') {
            $header.css('background', 'linear-gradient(135deg, #28a745 0%, #20c997 100%)');
            $icon.removeClass().addClass('fa-solid fa-circle-check me-2');
        } else if (type === 'error') {
            $header.css('background', 'linear-gradient(135deg, #dc3545 0%, #c82333 100%)');
            $icon.removeClass().addClass('fa-solid fa-circle-xmark me-2');
        } else if (type === 'warning') {
            $header.css('background', 'linear-gradient(135deg, #ffc107 0%, #e0a800 100%)');
            $icon.removeClass().addClass('fa-solid fa-triangle-exclamation me-2');
        } else {
            $header.css('background', 'linear-gradient(135deg, #17a2b8 0%, #138496 100%)');
            $icon.removeClass().addClass('fa-solid fa-circle-info me-2');
        }
        
        $modal.find('#alert-title').text(title);
        $modal.find('#alert-message').html(message);
        $modal.modal('show');
    }
    
    /**
     * Show confirm modal
     * @param {string} message - The message to display
     * @param {function} callback - Function to call if confirmed
     * @param {string} title - The title (default: Confirm)
     */
    function showConfirm(message, callback, title) {
        title = title || '{{ text_confirm_cancel|escape('js') }}';

      if (!$('#confirmModal').length || typeof $.fn.modal !== 'function') {
        if (confirm($('<div>').html(String(message || '')).text())) {
          if (typeof callback === 'function') {
            callback();
          }
        }
        return;
      }
        
        var $modal = $('#confirmModal');
        $modal.find('#confirm-title').text(title);
        $modal.find('#confirm-message').html(message);
        
        // Remove any existing click handlers
        $('#btn-confirm-action').off('click');
        
        // Add new click handler
        $('#btn-confirm-action').on('click', function() {
            $modal.modal('hide');
            if (typeof callback === 'function') {
                callback();
            }
        });
        
        $modal.modal('show');
    }
    
