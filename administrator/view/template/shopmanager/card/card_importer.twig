{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  
  <style>
    /* Cache buster: {{ "now"|date("U") }} */

    /* Upload drop zone */
    #upload-zone { border: 2px dashed #adb5bd; border-radius: 8px; padding: 30px; text-align: center; cursor: pointer; transition: border-color .2s; }
    #upload-zone:hover, #upload-zone.dragover { border-color: #0d6efd; background: #f0f4ff; }
    #upload-zone input[type=file] { display: none; }

    /* Import Results Modal Styling */
    #importResultsModal .modal-content {
      border: none;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      border-radius: 15px;
      overflow: hidden;
    }
    #importResultsModal .modal-header {
      background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
      border: none;
      padding: 1.5rem;
    }
    #importResultsModal .card {
      transition: all 0.3s ease;
      border-radius: 10px;
    }
    #importResultsModal .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    #importResultsModal .card-body h3 {
      font-size: 2rem;
      font-weight: bold;
      color: #333;
      animation: countUp 0.5s ease-out;
    }
    @keyframes countUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Save success popup */
    #saveSuccessModal .modal-content {
      border: none;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 18px 48px rgba(118, 75, 162, 0.22);
    }
    #saveSuccessModal .modal-header {
      background: linear-gradient(135deg, #ff8cc6 0%, #8f7cff 100%);
      border: none;
      justify-content: center;
      padding: 1.25rem 1.5rem;
    }
    #saveSuccessModal .modal-body {
      text-align: center;
      padding: 2rem 1.5rem 1.5rem;
      background: linear-gradient(180deg, #fff8fd 0%, #ffffff 100%);
    }
    #saveSuccessModal .success-bubble {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      background: radial-gradient(circle at 30% 30%, #ffd6ec 0%, #ffc0e1 38%, #b99cff 100%);
      box-shadow: 0 14px 30px rgba(185, 156, 255, 0.35);
      color: #fff;
      font-size: 2.5rem;
    }
    #saveSuccessModal .success-subtitle {
      color: #6c757d;
      font-size: 1rem;
      margin-bottom: 0.75rem;
    }
    #saveSuccessModal .success-details {
      background: #fff;
      border: 1px solid #f0d8ff;
      border-radius: 14px;
      padding: 0.9rem 1rem;
      color: #5c4a72;
    }
    #saveSuccessModal .modal-footer {
      border: none;
      justify-content: center;
      padding: 0 1.5rem 1.75rem;
      background: #ffffff;
    }
    #saveSuccessModal .btn-success-reload {
      min-width: 180px;
      border: none;
      border-radius: 999px;
      padding: 0.8rem 1.4rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ff8cc6 0%, #8f7cff 100%);
      box-shadow: 0 10px 22px rgba(143, 124, 255, 0.28);
    }

    /* Upload loading modal */
    #uploadLoadingModal .modal-content {
      border: none;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 22px 60px rgba(102, 126, 234, 0.28);
      background: linear-gradient(180deg, #f8faff 0%, #ffffff 100%);
    }
    #uploadLoadingModal .modal-body {
      text-align: center;
      padding: 2.2rem 1.75rem 2rem;
    }
    #uploadLoadingModal .loading-bubble {
      width: 108px;
      height: 108px;
      margin: 0 auto 1rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #dbe7ff 35%, #9db8ff 68%, #7b8dff 100%);
      box-shadow: 0 18px 40px rgba(123, 141, 255, 0.35);
      position: relative;
    }
    #uploadLoadingModal .loading-bubble::after {
      content: '';
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      border: 2px dashed rgba(123, 141, 255, 0.35);
      animation: uploadOrbit 2.2s linear infinite;
    }
    #uploadLoadingModal .loading-bubble i {
      font-size: 2.8rem;
      color: #fff;
      text-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
    }
    #uploadLoadingModal .loading-title {
      font-size: 1.35rem;
      font-weight: 700;
      color: #334155;
      margin-bottom: 0.35rem;
    }
    #uploadLoadingModal .loading-subtitle {
      color: #64748b;
      margin-bottom: 1rem;
    }
    #uploadLoadingModal .loading-file {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      max-width: 100%;
      border-radius: 999px;
      background: #eef4ff;
      color: #4c5d88;
      padding: 0.6rem 0.9rem;
      font-weight: 600;
      margin-bottom: 0.9rem;
    }
    #uploadLoadingModal .loading-file-name {
      display: inline-block;
      max-width: 320px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      vertical-align: bottom;
    }
    #uploadLoadingModal .loading-hint {
      color: #7c8aa5;
      font-size: 0.92rem;
      margin-bottom: 0;
    }
    @keyframes uploadOrbit {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

  </style>
  
  <div class="container-fluid">
    <div class="card">
      <div class="card-header">
        <i class="fa-solid fa-upload"></i> {{ text_upload_instructions }}
      </div>
      <div class="card-body">
        <small class="text-muted d-block mb-3">{{ text_csv_format }}</small>
        <form id="form-upload" method="post" enctype="multipart/form-data">
          <div id="upload-zone" onclick="document.getElementById('input-file').click()">
            <i class="fa-solid fa-cloud-arrow-up fa-3x text-muted mb-2"></i>
            <p class="mb-1 text-muted">{{ text_drop_here }}</p>
            <span id="file-name-display" class="text-secondary small"></span>
            <input type="file" id="input-file" name="file" accept=".csv,.txt">
          </div>
          <div class="mt-3">
            <button type="submit" id="button-upload" class="btn btn-primary">
              <i class="fa-solid fa-upload me-1"></i>{{ button_upload }}
            </button>
            <span id="upload-spinner" class="ms-2 text-muted" style="display:none;">
              <i class="fa-solid fa-spinner fa-spin"></i> {{ text_uploading }}
            </span>
          </div>
        </form>
      </div>
    </div>

    <!-- Preview Container -->
    <div id="preview-container" class="card mt-3" style="display: none;">
      <div class="card-header">
        <i class="fa-solid fa-table"></i> {{ text_preview_title }}
        <span id="preview-count" class="badge bg-primary ms-2"></span>
      </div>
      <div class="card-body">
        <div id="preview-content"></div>
        
        <!-- Configuration Section -->
        <div class="mt-4">
          <h5>{{ text_listing_configuration }}</h5>

          <div class="alert alert-warning mb-3" id="grading-potential-listing-alert" style="display:none;">
            <i class="fa-solid fa-gem me-2"></i>
            <strong>{{ text_grading_potential_detected }}</strong> {{ text_grading_listing_menu_hint }}
          </div>
          
          <!-- Listing Type removed - always multi-variation with auto-grouping -->
          <div class="alert alert-info mb-3">
            <i class="fa-solid fa-info-circle"></i> <strong>{{ text_auto_grouped }}:</strong> {{ text_auto_grouped_desc }}
          </div>
          
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_category }}</label>
            <div class="col-sm-10">
              <input type="text" id="input-category" class="form-control" placeholder="261328" value="261328">
              <div class="form-text">{{ help_category }}</div>
            </div>
          </div>
          
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_condition }}</label>
            <div class="col-sm-10">
              <select id="input-condition" class="form-select">
                <option value="1000">New</option>
                <option value="3000" selected>Used</option>
                <option value="4000">Very Good</option>
                <option value="5000">Good</option>
                <option value="6000">Acceptable</option>
              </select>
            </div>
          </div>
          
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ text_ebay_policies }}</label>
            <div class="col-sm-10">
              <div class="alert alert-success mb-0">
                <strong><i class="fa-solid fa-check-circle"></i> {{ text_configured_auto }}:</strong><br>
                <ul class="mb-0 mt-2">
                  <li><strong>Shipping:</strong> Canada_Shipping_Cards (270305103019)</li>
                  <li><strong>Return:</strong> Canada_No_Return (261009811019)</li>
                  <li><strong>Payment:</strong> Canada_PayPal (66471759019)</li>
                </ul>
              </div>
              <input type="hidden" id="input-shipping-policy" value="270305103019">
              <input type="hidden" id="input-return-policy" value="261009811019">
              <input type="hidden" id="input-payment-policy" value="66471759019">
            </div>
          </div>
        </div>
        
        <div class="text-end mt-3">
          <button type="button" id="button-cancel" class="btn btn-secondary">
            <i class="fa-solid fa-times"></i> {{ button_cancel }}
          </button>
          <button type="button" id="button-save-to-database" class="btn btn-secondary me-2" disabled title="">
            <i class="fa-solid fa-database"></i> {{ button_save_to_db }}
          </button>
        </div>
      </div>
    </div>
    
  </div>
</div>

<!-- Upload Loading Modal -->
