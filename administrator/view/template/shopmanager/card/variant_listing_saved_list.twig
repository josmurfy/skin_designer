{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="index.php?route=shopmanager/card/variant_listing_creator&user_token={{ user_token }}" class="btn btn-primary">
          <i class="fa-solid fa-plus"></i> Create New
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item">
            <a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
          </li>
        {% endfor %}
      </ol>
    </div>
  </div>
  
  <div class="container-fluid">
    <div class="card">
      <div class="card-header">
        <i class="fa-solid fa-list"></i> Saved Multi-Variation Listings
      </div>
      <div class="card-body">
        
        {% if listings is empty %}
          <div class="alert alert-info">
            <i class="fa-solid fa-info-circle"></i> No saved listings found. 
            <a href="index.php?route=shopmanager/card/variant_listing_creator&user_token={{ user_token }}">Create your first listing</a>.
          </div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead class="table-light">
                <tr>
                  <th style="width: 60px;">ID</th>
                  <th>Title / Set Name</th>
                  <th style="width: 80px;">Year</th>
                  <th style="width: 120px;">Brand</th>
                  <th style="width: 100px;">Variations</th>
                  <th style="width: 120px;">Price Range</th>
                  <th style="width: 100px;">Status</th>
                  <th style="width: 140px;">Date</th>
                  <th style="width: 150px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for listing in listings %}
                  <tr>
                    <td class="text-center"><strong>{{ listing.listing_id }}</strong></td>
                    <td>
                      <strong>{{ listing.title|default(listing.set_name) }}</strong>
                      <br><small class="text-muted">{{ listing.set_name }}</small>
                      {% if listing.ebay_item_id %}
                        <br><span class="badge bg-info">eBay: {{ listing.ebay_item_id }}</span>
                      {% endif %}
                    </td>
                    <td class="text-center">
                      {% if listing.year %}
                        <span class="badge bg-secondary">{{ listing.year }}</span>
                      {% else %}
                        <span class="text-muted">-</span>
                      {% endif %}
                    </td>
                    <td>{{ listing.brand|default('-') }}</td>
                    <td class="text-center">
                      <span class="badge bg-primary">{{ listing.variation_count }} cards</span>
                    </td>
                    <td class="text-end">
                      {% if listing.price_min > 0 %}
                        ${{ listing.price_min|number_format(2) }}
                        {% if listing.price_max != listing.price_min %}
                          - ${{ listing.price_max|number_format(2) }}
                        {% endif %}
                      {% else %}
                        <span class="text-muted">-</span>
                      {% endif %}
                    </td>
                    <td class="text-center">
                      {% if listing.status == 0 %}
                        <span class="badge bg-secondary">Draft</span>
                      {% elseif listing.status == 1 %}
                        <span class="badge bg-success">Active</span>
                      {% elseif listing.status == 2 %}
                        <span class="badge bg-danger">Ended</span>
                      {% endif %}
                    </td>
                    <td>
                      <small>{{ listing.date_modified|date('Y-m-d H:i') }}</small>
                    </td>
                    <td class="text-center">
                      <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-info btn-view" data-id="{{ listing.listing_id }}" title="View Details">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                        <button type="button" class="btn btn-warning btn-edit" data-id="{{ listing.listing_id }}" title="Edit">
                          <i class="fa-solid fa-pencil"></i>
                        </button>
                        <button type="button" class="btn btn-danger btn-delete" data-id="{{ listing.listing_id }}" title="Delete">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</div>

<script>
$(document).ready(function() {
    var userToken = '{{ user_token }}';
    
    // View listing details
    $('.btn-view').on('click', function() {
        var listingId = $(this).data('id');
        
        $.ajax({
            url: 'index.php?route=shopmanager/card/variant_listing_creator.viewListing&user_token=' + userToken + '&listing_id=' + listingId,
            type: 'GET',
            dataType: 'json',
            success: function(json) {
                if (json.success && json.listing) {
                    var listing = json.listing;
                    var html = '<div class="modal fade" id="listing-modal" tabindex="-1">';
                    html += '<div class="modal-dialog modal-xl">';
                    html += '<div class="modal-content">';
                    html += '<div class="modal-header">';
                    html += '<h5 class="modal-title">' + (listing.title || listing.set_name) + '</h5>';
                    html += '<button type="button" class="btn-close" data-bs-dismiss="modal"></button>';
                    html += '</div>';
                    html += '<div class="modal-body">';
                    
                    // Listing details
                    html += '<div class="row mb-3">';
                    html += '<div class="col-md-6">';
                    html += '<strong>Set:</strong> ' + listing.set_name + '<br>';
                    html += '<strong>Year:</strong> ' + (listing.year || '-') + '<br>';
                    html += '<strong>Brand:</strong> ' + (listing.brand || '-') + '<br>';
                    html += '</div>';
                    html += '<div class="col-md-6">';
                    html += '<strong>Shipping:</strong> Cards Policy<br>';\n                    html += '<strong>Return:</strong> Canada_No_Return<br>';\n                    html += '<strong>Payment:</strong> Canada_PayPal<br>';
                    html += '<strong>Total Variations:</strong> ' + listing.variations.length + '<br>';
                    html += '<strong>Price Range:</strong> $' + parseFloat(listing.price_min).toFixed(2) + ' - $' + parseFloat(listing.price_max).toFixed(2) + '<br>';
                    html += '</div>';
                    html += '</div>';
                    
                    // Variations table
                    html += '<h6 class="mt-3">Variations</h6>';
                    html += '<div class="table-responsive">';
                    html += '<table class="table table-sm table-bordered">';
                    html += '<thead><tr><th>Card</th><th>Brand</th><th>Year</th><th>Condition</th><th>Qty</th><th>Price</th></tr></thead>';
                    html += '<tbody>';
                    
                    listing.variations.forEach(function(v) {
                        html += '<tr>';
                        html += '<td>' + v.variation_name + '</td>';
                        html += '<td>' + (v.brand || '-') + '</td>';
                        html += '<td>' + (v.year || '-') + '</td>';
                        html += '<td>' + v.condition_name + '</td>';
                        html += '<td>' + v.quantity + '</td>';
                        html += '<td>$' + parseFloat(v.price).toFixed(2) + '</td>';
                        html += '</tr>';
                    });
                    
                    html += '</tbody></table>';
                    html += '</div>';
                    html += '</div>';
                    html += '<div class="modal-footer">';
                    html += '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>';
                    html += '</div>';
                    html += '</div></div></div>';
                    
                    $('body').append(html);
                    $('#listing-modal').modal('show');
                    $('#listing-modal').on('hidden.bs.modal', function() {
                        $(this).remove();
                    });
                }
            },
            error: function(xhr, status, error) {
                alert('Error loading listing: ' + error);
            }
        });
    });
    
    // Delete listing
    $('.btn-delete').on('click', function() {
        var listingId = $(this).data('id');
        var $row = $(this).closest('tr');
        
        if (!confirm('Delete this listing? This action cannot be undone.')) {
            return;
        }
        
        $.ajax({
            url: 'index.php?route=shopmanager/card/variant_listing_creator.deleteListing&user_token=' + userToken,
            type: 'POST',
            data: { listing_id: listingId },
            dataType: 'json',
            success: function(json) {
                if (json.success) {
                    $row.fadeOut(300, function() {
                        $(this).remove();
                    });
                    alert('Listing deleted successfully');
                } else {
                    alert('Error: ' + json.error);
                }
            },
            error: function(xhr, status, error) {
                alert('Error deleting listing: ' + error);
            }
        });
    });
    
    // Edit listing - redirect to creator with listing data
    $('.btn-edit').on('click', function() {
        var listingId = $(this).data('id');
        alert('Edit functionality coming soon! Listing ID: ' + listingId);
        // TODO: Load listing data back into creator form
    });
});
</script>

{{ footer }}
