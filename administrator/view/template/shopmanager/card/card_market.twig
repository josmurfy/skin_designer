{{ header }}{{ column_left }}
<div id="content">
<style>
.market-dropzone {
  border: 2px dashed #b9c3cf;
  border-radius: 10px;
  background: #f8fafc;
  text-align: center;
  padding: 18px 12px;
  cursor: pointer;
  transition: border-color .15s, background .15s, transform .15s;
}
.market-dropzone:hover,
.market-dropzone.is-dragover {
  border-color: #0d6efd;
  background: #eef5ff;
  transform: translateY(-1px);
}
.market-image-preview {
  width: 100%;
  max-height: 180px;
  object-fit: contain;
  border-radius: 8px;
  background: #fff;
  border: 1px solid #dee2e6;
}
</style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" data-bs-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-market').toggleClass('d-none');" class="btn btn-light d-lg-none"><i class="fa-solid fa-filter"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for b in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ b.href }}">{{ b.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">

      <div id="filter-market" class="col-lg-3 col-md-12 order-lg-last d-none d-lg-block mb-3">
        <div class="card">
          <div class="card-header">
            <i class="fa-solid fa-filter"></i> {{ text_filter }}
            <button type="button" id="button-reset-filters" class="btn btn-sm btn-outline-secondary float-end"><i class="fa-solid fa-redo"></i></button>
          </div>
          <div class="card-body">
            <form id="form-filter">
              <input type="hidden" name="filter_image_token" id="input-image-token" value="{{ filter_image_token }}"/>
              <input type="file" id="input-image-file" accept="image/jpeg,image/png,image/webp" class="d-none"/>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_image }}</label>
                <div id="market-image-dropzone" class="market-dropzone">
                  <div class="mb-2"><i class="fa-regular fa-image fa-2x text-primary"></i></div>
                  <div class="fw-semibold">{{ text_drop_image }}</div>
                  <div class="small text-muted">{{ text_drop_image_help }}</div>
                </div>
                <div id="market-image-preview-wrap" class="mt-2 d-none">
                  <img id="market-image-preview" class="market-image-preview" src="" alt=""/>
                  <div class="d-grid mt-2">
                    <button type="button" id="button-clear-image" class="btn btn-sm btn-outline-secondary">{{ button_clear_image }}</button>
                  </div>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_player }}</label>
                <input type="text" name="filter_player" value="{{ filter_player }}" placeholder="{{ entry_player }}" class="form-control"/>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_set }}</label>
                <input type="text" name="filter_set" value="{{ filter_set }}" placeholder="{{ entry_set }}" class="form-control"/>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label">{{ text_filter_year }}</label>
                  <input type="text" name="filter_year" value="{{ filter_year }}" placeholder="{{ entry_year }}" class="form-control"/>
                </div>
                <div class="col-6">
                  <label class="form-label">{{ text_filter_brand }}</label>
                  <select name="filter_brand" class="form-select">
                    <option value="">{{ text_all }}</option>
                    {% for mfr in manufacturers %}
                      <option value="{{ mfr }}" {% if filter_brand == mfr %}selected{% endif %}>{{ mfr }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_sport }}</label>
                <select name="filter_sport" class="form-select" onchange="$('#button-filter').trigger('click');">
                  <option value="">{{ text_all }}</option>
                  {% for ct in card_types %}
                    <option value="{{ ct.name }}" {% if filter_sport == ct.name %}selected{% endif %}>{{ ct.name }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_card_number }}</label>
                <input type="text" name="filter_card_number" value="{{ filter_card_number }}" placeholder="{{ entry_card_number }}" class="form-control"/>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_listing_type }}</label>
                <select name="filter_listing_type" class="form-select" onchange="$('#button-filter').trigger('click');">
                  <option value="all" {% if filter_listing_type == 'all' %}selected{% endif %}>{{ text_all }}</option>
                  <option value="AUCTION" {% if filter_listing_type == 'AUCTION' %}selected{% endif %}>{{ text_auction }}</option>
                  <option value="FIXED_PRICE" {% if filter_listing_type == 'FIXED_PRICE' %}selected{% endif %}>{{ text_fixed_price }}</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_sale_mode }}</label>
                <select name="filter_sale_mode" class="form-select" onchange="$('#button-filter').trigger('click');">
                  <option value="present" {% if filter_sale_mode == 'present' %}selected{% endif %}>{{ text_sale_mode_present }}</option>
                  <option value="sold" {% if filter_sale_mode == 'sold' %}selected{% endif %}>{{ text_sale_mode_sold }}</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_condition }}</label>
                <select name="filter_condition" id="input-condition" class="form-select" onchange="toggleGraderFields(); $('#button-filter').trigger('click');">
                  <option value="all" {% if filter_condition == 'all' %}selected{% endif %}>{{ text_all }}</option>
                  <option value="graded" {% if filter_condition == 'graded' %}selected{% endif %}>{{ text_graded_only }}</option>
                  <option value="raw" {% if filter_condition == 'raw' %}selected{% endif %}>{{ text_raw_only }}</option>
                </select>
              </div>
              <div id="grader-fields" class="{% if filter_condition != 'graded' %}d-none{% endif %}">
                <div class="mb-3">
                  <label class="form-label">{{ text_filter_grader }}</label>
                  <select name="filter_grader" id="input-grader" class="form-select" onchange="$('#button-filter').trigger('click');">
                    <option value="all" {% if filter_grader == 'all' %}selected{% endif %}>{{ text_all }}</option>
                    <option value="PSA" {% if filter_grader == 'PSA' %}selected{% endif %}>PSA</option>
                    <option value="BGS" {% if filter_grader == 'BGS' %}selected{% endif %}>BGS / Beckett</option>
                    <option value="SGC" {% if filter_grader == 'SGC' %}selected{% endif %}>SGC</option>
                    <option value="CSA" {% if filter_grader == 'CSA' %}selected{% endif %}>CSA</option>
                    <option value="HGA" {% if filter_grader == 'HGA' %}selected{% endif %}>HGA</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label">{{ text_filter_grade }}</label>
                  <input type="text" name="filter_grade" value="{{ filter_grade }}" placeholder="{{ entry_grade }}" class="form-control"/>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_site }}</label>
                <select name="filter_site_id" id="input-site" class="form-select">
                  <option value="0" {% if filter_site_id == 0 %}selected{% endif %}>{{ site_us }}</option>
                  <option value="2" {% if filter_site_id == 2 %}selected{% endif %}>{{ site_ca }}</option>
                  <option value="3" {% if filter_site_id == 3 %}selected{% endif %}>{{ site_gb }}</option>
                  <option value="77" {% if filter_site_id == 77 %}selected{% endif %}>{{ site_de }}</option>
                  <option value="71" {% if filter_site_id == 71 %}selected{% endif %}>{{ site_fr }}</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">{{ text_filter_per_page }}</label>
                <select name="limit" id="input-limit" class="form-select">
                  {% for opt in per_page_options %}
                    <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="text-end">
                <button type="button" id="button-filter" class="btn btn-primary">
                  <i class="fa-solid fa-magnifying-glass"></i> {{ button_filter }}
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-9 col-md-12">
        <div class="card">
          <div class="card-header"><i class="fa-brands fa-ebay"></i> {{ text_list }}</div>
          <div id="market-results" class="card-body">{{ list }}</div>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="modal fade" id="modal-market-photo" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title text-truncate" id="modal-photo-title" style="max-width:90%;"></h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0 text-center bg-dark">
        <img id="modal-photo-img" src="" alt="" style="max-width:100%;max-height:80vh;object-fit:contain;">
      </div>
      <div class="modal-footer py-2 justify-content-between">
        <div>
          <span id="modal-photo-price" class="fw-bold text-success fs-5 me-2"></span>
          <span id="modal-photo-grade" class="badge bg-warning text-dark me-1"></span>
          <div id="modal-photo-created" class="text-muted small"></div>
          <div id="modal-photo-ended" class="text-muted small"></div>
        </div>
        <a id="modal-photo-link" href="#" target="_blank" class="btn btn-sm btn-outline-primary"><i class="fa-brands fa-ebay me-1"></i>eBay</a>
      </div>
    </div>
  </div>
</div>

<script>
var USER_TOKEN_MARKET = '{{ user_token }}';
var TEXT_LOADING_MARKET = '{{ text_loading|escape('js') }}';
var TEXT_DROP_IMAGE_MARKET = '{{ text_drop_image|escape('js') }}';
var TEXT_UPLOADING_IMAGE_MARKET = '{{ text_loading|escape('js') }}';
var TEXT_DATE_CREATED_MARKET = '{{ column_date_created|escape('js') }}';
var TEXT_DATE_ENDED_MARKET = '{{ column_date_ended|escape('js') }}';

function setMarketImagePreview(src) {
  if (!src) {
    $('#market-image-preview').attr('src', '');
    $('#market-image-preview-wrap').addClass('d-none');
    return;
  }

  $('#market-image-preview').attr('src', src);
  $('#market-image-preview-wrap').removeClass('d-none');
}

function uploadMarketImage(file) {
  if (!file) return;

  var formData = new FormData();
  formData.append('image', file);

  $('#market-image-dropzone').addClass('disabled').html('<div class="spinner-border spinner-border-sm text-primary me-2"></div>' + TEXT_UPLOADING_IMAGE_MARKET);

  $.ajax({
    url: 'index.php?route=shopmanager/card/card_market.uploadImage&user_token=' + USER_TOKEN_MARKET,
    type: 'POST',
    data: formData,
    processData: false,
    contentType: false,
    success: function(json) {
      if (json && json.token) {
        $('#input-image-token').val(json.token);
        setMarketImagePreview(URL.createObjectURL(file));
        $('#button-filter').trigger('click');
      } else {
        alert((json && json.error) ? json.error : 'Image upload failed');
      }
    },
    error: function(xhr) {
      alert(xhr.responseJSON && xhr.responseJSON.error ? xhr.responseJSON.error : 'Image upload failed');
    },
    complete: function() {
      $('#market-image-dropzone').removeClass('disabled').html('<div class="mb-2"><i class="fa-regular fa-image fa-2x text-primary"></i></div><div class="fw-semibold">' + TEXT_DROP_IMAGE_MARKET + '</div><div class="small text-muted">{{ text_drop_image_help|escape('js') }}</div>');
    }
  });
}

function toggleGraderFields() {
    if ($('#input-condition').val() === 'graded') $('#grader-fields').removeClass('d-none');
    else $('#grader-fields').addClass('d-none');
}

function marketLoad(url) {
    console.log('[CardMarket] Loading:', url);
    $('#market-results').html('<div class="text-center p-5"><div class="spinner-border text-primary"></div><p class="mt-3 text-muted">' + TEXT_LOADING_MARKET + '</p></div>');
    $.ajax({
        url: url,
        type: 'GET',
        success: function(html, status, xhr) {
            console.log('[CardMarket] HTTP ' + xhr.status + ' len=' + html.length);
            // Detect if OC4 returned a full page (permission/login redirect) instead of partial
            if (html.indexOf('error/permission') !== -1 || html.indexOf('common/login') !== -1 || html.indexOf('<!DOCTYPE') !== -1) {
                console.error('[CardMarket] Full OC4 page returned instead of partial – permission or session issue!');
                $('#market-results').html('<div class="alert alert-danger"><strong>DEBUG – OC4 permission/session page reçu.</strong><br>Route: ' + url + '<br>Vérifier session ou logs PHP.</div><pre style="font-size:11px;max-height:200px;overflow:auto">' + $('<div>').text(html.substring(0, 1000)).html() + '...</pre>');
            } else if (html.trim() === '') {
                console.warn('[CardMarket] Empty response!');
                $('#market-results').html('<div class="alert alert-warning">Réponse vide du serveur. Vérifier les logs PHP.</div>');
            } else {
                $('#market-results').html(html);
            }
        },
        error: function(xhr, status, err) {
            console.error('[CardMarket] AJAX error:', xhr.status, status, err);
            console.error('[CardMarket] Response:', xhr.responseText.substring(0, 500));
            $('#market-results').html('<div class="alert alert-danger"><strong>Erreur HTTP ' + xhr.status + '</strong> – ' + err + '<pre style="font-size:11px;max-height:200px;overflow:auto">' + $('<div>').text(xhr.responseText.substring(0, 800)).html() + '</pre></div>');
        }
    });
}

$('#button-filter').on('click', function() {
    var url = '';
    $('#form-filter').serializeArray().forEach(function(f) {
        if (f.value !== '') url += '&' + encodeURIComponent(f.name) + '=' + encodeURIComponent(f.value);
    });
    console.log('[CardMarket] Filter params:', url);
    window.history.pushState({}, null, 'index.php?route=shopmanager/card/card_market&user_token=' + USER_TOKEN_MARKET + url);
    marketLoad('index.php?route=shopmanager/card/card_market.list&user_token=' + USER_TOKEN_MARKET + url);
});

$('#button-reset-filters').on('click', function() {
    $('#form-filter input').val('');
    $('#form-filter select').each(function() { $(this).val($(this).find('option:first').val()); });
    $('#grader-fields').addClass('d-none');
  setMarketImagePreview('');
    window.history.pushState({}, null, 'index.php?route=shopmanager/card/card_market&user_token=' + USER_TOKEN_MARKET);
    marketLoad('index.php?route=shopmanager/card/card_market.list&user_token=' + USER_TOKEN_MARKET);
});

$('#market-image-dropzone').on('click', function() {
  $('#input-image-file').trigger('click');
});

$('#input-image-file').on('change', function() {
  if (this.files && this.files[0]) {
    uploadMarketImage(this.files[0]);
  }
});

$('#market-image-dropzone').on('dragenter dragover', function(e) {
  e.preventDefault();
  e.stopPropagation();
  $(this).addClass('is-dragover');
});

$('#market-image-dropzone').on('dragleave dragend drop', function(e) {
  e.preventDefault();
  e.stopPropagation();
  $(this).removeClass('is-dragover');
});

$('#market-image-dropzone').on('drop', function(e) {
  var files = e.originalEvent.dataTransfer.files;
  if (files && files[0]) {
    uploadMarketImage(files[0]);
  }
});

$('#button-clear-image').on('click', function() {
  $('#input-image-token').val('');
  $('#input-image-file').val('');
  setMarketImagePreview('');
});

$('#market-results').on('click', 'thead a, .pagination a, .sort-bar a', function(e) {
    e.preventDefault();
    marketLoad(this.href);
});

$('input[name^="filter_"]').on('keydown', function(e) {
    if (e.which === 13) $('#button-filter').trigger('click');
});

$(document).on('click', '.market-photo-trigger', function() {
    var pic = $(this).data('picture');
    if (!pic) return;
    $('#modal-photo-img').attr('src', pic);
    $('#modal-photo-title').text($(this).data('title'));
    $('#modal-photo-price').text($(this).data('price'));
    var g = $(this).data('grade') || '';
    $('#modal-photo-grade').text(g).toggle(!!g);
    var created = $(this).data('created') || '';
    var ended = $(this).data('ended') || '';
    $('#modal-photo-created').text(created ? (TEXT_DATE_CREATED_MARKET + ': ' + created) : '');
    $('#modal-photo-ended').text(ended ? (TEXT_DATE_ENDED_MARKET + ': ' + ended) : '');
    $('#modal-photo-link').attr('href', $(this).data('url') || '#');
    new bootstrap.Modal(document.getElementById('modal-market-photo')).show();
});
</script>
{{ footer }}
