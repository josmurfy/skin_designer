{{ header }}{{ column_left }}
<div id="content">

  {# Hidden fields for language strings used in JavaScript #}
  <input type="hidden" id="lang_update_confirm" value="{{ text_update_confirm }}" />
  <input type="hidden" id="lang_update_success" value="{{ text_update_success }}" />
  <input type="hidden" id="lang_update_error" value="{{ text_update_error }}" />
  <input type="hidden" id="lang_updating" value="{{ text_updating }}" />
  <input type="hidden" id="user_token" value="{{ user_token }}" />
  <input type="hidden" id="url_get_data" value="{{ url_get_data }}" />
  <input type="hidden" id="url_sync_marketplace" value="index.php?route=shopmanager/inventory/sync.importMarketplace&user_token={{ user_token }}" />
  <input type="hidden" id="url_force_refresh_marketplace" value="index.php?route=shopmanager/inventory/sync.importMarketplace&force_refresh=1&user_token={{ user_token }}" />
  <input type="hidden" id="url_scan_image_backup" value="index.php?route=shopmanager/inventory/sync.scanImageBackupCounts&user_token={{ user_token }}" />

  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" id="button-scan-backup" data-bs-toggle="tooltip" title="{{ tooltip_scan_image_backup }}" class="btn btn-info me-2">
          <i class="fa-solid fa-folder-magnifying-glass"></i> {{ button_scan_image_backup }}
        </button>
        <button type="button" id="button-force-refresh" data-bs-toggle="tooltip" title="{{ tooltip_force_refresh }}" class="btn btn-danger me-2">
          <i class="fa-solid fa-rotate"></i> {{ button_force_refresh }}
        </button>
        <button type="button" id="button-sync-marketplace" data-bs-toggle="tooltip" title="{{ tooltip_import_from_ebay }}" class="btn btn-warning">
          <i class="fa-solid fa-download"></i> {{ button_import_from_ebay }}
        </button>
      </div>
      <h1><i class="fa-solid fa-sync"></i> {{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    
    {# Sync Progress #}
    <div id="sync-progress-container" class="row mb-3 d-none">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h5>{{ text_sync_progress }}</h5>
            <div class="progress" style="height: 30px;">
              <div id="sync-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">0%</div>
            </div>
            <p class="mt-2 mb-0" id="sync-message">{{ text_starting_sync }}</p>
          </div>
        </div>
      </div>
    </div>

    {# Inventory Stats #}
    <div class="row mb-3">
      <div class="col-md-3">
        <div class="card border-success stat-card" style="cursor: default;">
          <div class="card-body text-center">
            <h2 class="text-success stat-number">{{ analytics_data.total_listed_ebay }}</h2>
            <p class="text-muted mb-0">{{ text_listed_ebay }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-warning stat-card" data-tab="not-listed" style="cursor: pointer;" onclick="document.getElementById('not-listed-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-warning stat-number">{{ analytics_data.not_listed_count }}</h2>
            <p class="text-muted mb-0">{{ text_not_listed_qty }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-danger stat-card" data-tab="errors" style="cursor: pointer;" onclick="document.getElementById('errors-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-danger stat-number">{{ analytics_data.error_count }}</h2>
            <p class="text-muted mb-0">{{ text_marketplace_errors }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-info stat-card" data-tab="not-synced" style="cursor: pointer;" onclick="document.getElementById('not-synced-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-info stat-number">{{ analytics_data.not_synced_count }}</h2>
            <p class="text-muted mb-0">{{ text_not_synced }}</p>
          </div>
        </div>
      </div>
    </div>

    {# Detailed Mismatch Stats #}
    {# Row 1: Price, Quantity, Specifics #}
    <div class="row mb-3">
      <div class="col-md-4">
        <div class="card border-warning stat-card" data-tab="price-mismatch" style="cursor: pointer;" onclick="document.getElementById('price-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-warning stat-number">{{ analytics_data.price_mismatch_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-dollar-sign"></i> {{ tab_price_mismatch }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-primary stat-card" data-tab="qty-mismatch" style="cursor: pointer;" onclick="document.getElementById('qty-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-primary stat-number">{{ analytics_data.qty_mismatch_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-box"></i> {{ tab_qty_mismatch }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-info stat-card" data-tab="specifics-mismatch" style="cursor: pointer;" onclick="document.getElementById('specifics-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-info stat-number">{{ analytics_data.specifics_mismatch_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-list"></i> {{ tab_specifics_mismatch }}</p>
          </div>
        </div>
      </div>
    </div>

    {# Row 2: Condition, Category, Image #}
    <div class="row mb-3">
      <div class="col-md-4">
        <div class="card border-success stat-card" data-tab="condition-mismatch" style="cursor: pointer;" onclick="document.getElementById('condition-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-success stat-number">{{ analytics_data.condition_mismatch_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-certificate"></i> {{ tab_condition_mismatch }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-danger stat-card" data-tab="category-mismatch" style="cursor: pointer;" onclick="document.getElementById('category-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-danger stat-number">{{ analytics_data.category_mismatch_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-tags"></i> {{ tab_category_mismatch }}</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-warning stat-card" data-tab="image-mismatch" style="cursor: pointer;" onclick="document.getElementById('image-mismatch-tab').click();">
          <div class="card-body text-center">
            <h2 class="text-warning stat-number">{{ analytics_data.image_mismatch_count + analytics_data.backup_image_mismatch_count + analytics_data.resolution_upgrade_count }}</h2>
            <p class="text-muted mb-0"><i class="fa-solid fa-images"></i> {{ tab_image_mismatch }}</p>
            <small class="text-muted" style="font-size:10px;">
              eBay: {{ analytics_data.image_mismatch_count }} &nbsp;|&nbsp;
              Backup: {{ analytics_data.backup_image_mismatch_count }} &nbsp;|&nbsp;
              Résol.: {{ analytics_data.resolution_upgrade_count }}
            </small>
          </div>
        </div>
      </div>
    </div>

    {# Sync Issues Tabs #}
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <ul class="nav nav-tabs card-header-tabs" id="syncIssueTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="errors-tab" data-bs-toggle="tab" data-bs-target="#errors" type="button" role="tab">
                  <i class="fa-solid fa-exclamation-triangle text-danger"></i> {{ tab_errors }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="not-listed-tab" data-bs-toggle="tab" data-bs-target="#not-listed" type="button" role="tab">
                  <i class="fa-solid fa-times-circle text-warning"></i> {{ tab_not_listed }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="not-synced-tab" data-bs-toggle="tab" data-bs-target="#not-synced" type="button" role="tab">
                  <i class="fa-solid fa-clock text-info"></i> {{ tab_not_synced }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="mismatch-tab" data-bs-toggle="tab" data-bs-target="#mismatch" type="button" role="tab">
                  <i class="fa-solid fa-balance-scale text-danger"></i> {{ tab_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="price-mismatch-tab" data-bs-toggle="tab" data-bs-target="#price-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-dollar-sign text-warning"></i> {{ tab_price_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="qty-mismatch-tab" data-bs-toggle="tab" data-bs-target="#qty-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-box text-primary"></i> {{ tab_qty_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="specifics-mismatch-tab" data-bs-toggle="tab" data-bs-target="#specifics-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-list text-info"></i> {{ tab_specifics_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="condition-mismatch-tab" data-bs-toggle="tab" data-bs-target="#condition-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-certificate text-success"></i> {{ tab_condition_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="category-mismatch-tab" data-bs-toggle="tab" data-bs-target="#category-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-tags text-danger"></i> {{ tab_category_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="image-mismatch-tab" data-bs-toggle="tab" data-bs-target="#image-mismatch" type="button" role="tab">
                  <i class="fa-solid fa-images text-warning"></i> {{ tab_image_mismatch }}
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="slow-moving-tab" data-bs-toggle="tab" data-bs-target="#slow-moving" type="button" role="tab">
                  <i class="fa-solid fa-turtle"></i> {{ tab_slow_moving }}
                </button>
              </li>
            </ul>
          </div>
          <div class="card-body">
            <div class="tab-content" id="syncIssueTabContent">
              
              {# Products with Marketplace Errors #}
              <div class="tab-pane fade show active" id="errors" role="tabpanel">
                {% if analytics_data.products_with_errors|length > 0 %}
                  
                  {# Error Summary Stats #}
                  {% if analytics_data.error_summary|length > 0 %}
                  <div class="card border-danger mb-3">
                    <div class="card-header bg-danger text-white">
                      <h6 class="mb-0"><i class="fa-solid fa-chart-pie"></i> Error Statistics ({{ analytics_data.error_summary|length }} types found)</h6>
                    </div>
                    <div class="card-body">
                      <div class="row">
                        {% for error_type in analytics_data.error_summary %}
                        <div class="col-md-6 mb-2">
                          <div class="d-flex align-items-center">
                            {% if error_type.severity == 'Error' %}
                              <span class="badge bg-danger me-2" style="min-width: 80px;">{{ error_type.code }}</span>
                            {% else %}
                              <span class="badge bg-warning me-2" style="min-width: 80px;">{{ error_type.code }}</span>
                            {% endif %}
                            <div class="flex-grow-1">
                              <small class="text-muted">{{ error_type.message }}</small>
                            </div>
                            <span class="badge bg-secondary ms-2">{{ error_type.count }}</span>
                          </div>
                        </div>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                  {% endif %}

                  <div class="alert alert-info mb-3">
                    <h6><i class="fa-solid fa-lightbulb"></i> Solutions rapides:</h6>
                    <ul class="mb-0">
                      <li><strong>107 - Category is not valid:</strong> Change la catégorie eBay dans le produit</li>
                      <li><strong>21919136 - Low resolution photos:</strong> Upload des images 500px+ minimum</li>
                      <li><strong>21919303 - Missing item specifics:</strong> Ajoute Format, Movie/TV Title dans les item specifics</li>
                      <li><strong>21917121 - Condition not applicable:</strong> Change la condition du produit selon la catégorie</li>
                      <li><strong>21919456 - Business policies:</strong> Configure tes business policies eBay</li>
                    </ul>
                  </div>
                  
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <th>{{ column_product }}</th>
                          <th>{{ column_ebay_id }}</th>
                          <th style="width: 50%;">{{ text_error_details }}</th>
                          <th>{{ text_last_sync }}</th>
                          <th class="text-center">{{ column_actions }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for product in analytics_data.products_with_errors %}
                          <tr>
                            <td>{{ product.name }}</td>
                            <td><a href="https://www.ebay.ca/itm/{{ product.marketplace_item_id }}" target="_blank" class="text-primary"><i class="fa-brands fa-ebay"></i> {{ product.marketplace_item_id }}</a></td>
                            <td>
                              {% if product.parsed_errors %}
                                {% for error in product.parsed_errors %}
                                  <div class="mb-2 p-2 border-start border-3 {% if error.severity == 'Error' %}border-danger bg-danger bg-opacity-10{% else %}border-warning bg-warning bg-opacity-10{% endif %}">
                                    <div class="d-flex justify-content-between align-items-start">
                                      <strong class="{% if error.severity == 'Error' %}text-danger{% else %}text-warning{% endif %}">
                                        <i class="fa-solid fa-{% if error.severity == 'Error' %}times-circle{% else %}exclamation-triangle{% endif %}"></i>
                                        {{ error.short_message }}
                                      </strong>
                                      <span class="badge {% if error.severity == 'Error' %}bg-danger{% else %}bg-warning{% endif %} ms-2">{{ error.code }}</span>
                                    </div>
                                    {% if error.long_message and error.long_message != error.short_message %}
                                      <small class="text-muted d-block mt-1">{{ error.long_message }}</small>
                                    {% endif %}
                                  </div>
                                {% endfor %}
                              {% else %}
                                <span class="badge bg-danger">{{ product.error|slice(0, 100) }}...</span>
                              {% endif %}
                            </td>
                            <td>{{ product.last_sync|date('Y-m-d H:i') }}</td>
                            <td class="text-center">
                              <div class="btn-group-vertical" role="group" style="width: 100%;">
                                <button type="button" class="btn btn-sm btn-info refresh-item-btn mb-1" data-product-id="{{ product.product_id }}" data-bs-toggle="tooltip" title="{{ tooltip_refresh_item }}">
                                  <i class="fa-solid fa-rotate"></i> 
                                </button>
                                <a href="index.php?route=shopmanager/catalog/product.form&product_id={{ product.product_id }}&user_token={{ user_token }}" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="{{ button_edit }}">
                                  <i class="fa-solid fa-edit"></i> 
                                </a>
                              </div>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> {{ text_no_errors }}</div>
                {% endif %}
              </div>

              {# Products NOT Listed on eBay #}
              <div class="tab-pane fade" id="not-listed" role="tabpanel">
                {% if analytics_data.products_not_listed|length > 0 %}
                  <div class="alert alert-warning">
                    <i class="fa-solid fa-info-circle"></i> {{ text_not_listed_info }}
                  </div>
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <th>{{ column_product }}</th>
                          <th>{{ column_sku }}</th>
                          <th class="text-end">{{ column_quantity }}</th>
                          <th class="text-end">{{ column_unallocated }}</th>
                          <th class="text-end">{{ column_total }}</th>
                          <th class="text-center">{{ column_actions }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for product in analytics_data.products_not_listed %}
                          <tr>
                            <td>{{ product.name }}</td>
                            <td><code>{{ product.sku }}</code></td>
                            <td class="text-end">{{ product.quantity }}</td>
                            <td class="text-end">{{ product.unallocated_quantity }}</td>
                            <td class="text-end"><strong class="text-primary">{{ product.quantity + product.unallocated_quantity }}</strong></td>
                            <td class="text-center">
                              <a href="index.php?route=shopmanager/catalog/product.form&product_id={{ product.product_id }}&user_token={{ user_token }}" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="{{ text_edit_product }}">
                                <i class="fa-solid fa-edit"></i>
                              </a>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> {{ text_all_listed }}</div>
                {% endif %}
              </div>

              {# Products Not Synced #}
              <div class="tab-pane fade" id="not-synced" role="tabpanel">
                {% if analytics_data.products_not_synced|length > 0 %}
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <th>{{ column_product }}</th>
                          <th>{{ column_ebay_id }}</th>
                          <th class="text-end">{{ column_quantity }}</th>
                          <th>{{ text_last_sync }}</th>
                          <th class="text-center">{{ column_actions }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for product in analytics_data.products_not_synced %}
                          <tr>
                            <td>{{ product.name }}</td>
                            <td>
                              {% if product.marketplace_item_id %}
                                <a href="https://www.ebay.ca/itm/{{ product.marketplace_item_id }}" target="_blank" class="text-primary"><i class="fa-brands fa-ebay"></i> {{ product.marketplace_item_id }}</a>
                              {% else %}
                                <span class="text-muted">{{ text_not_listed }}</span>
                              {% endif %}
                            </td>
                            <td class="text-end">{{ product.quantity }} + {{ product.unallocated_quantity }}</td>
                            <td>
                              {% if product.last_sync and product.last_sync != '0000-00-00 00:00:00' %}
                                <span class="badge bg-warning">{{ product.last_sync|date('Y-m-d H:i') }}</span>
                              {% else %}
                                <span class="badge bg-danger">{{ text_never_synced }}</span>
                              {% endif %}
                            </td>
                            <td class="text-center">
                              <button class="btn btn-sm btn-warning sync-product-btn" 
                                      data-product-id="{{ product.product_id }}" 
                                      data-product-name="{{ product.name }}"
                                      data-bs-toggle="tooltip" 
                                      title="{{ button_sync_ebay }}">
                                <i class="fa-solid fa-sync"></i> Sync
                              </button>
                              <a href="index.php?route=shopmanager/catalog/product.edit&product_id={{ product.product_id }}&user_token={{ user_token }}" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="{{ text_edit_product }}">
                                <i class="fa-solid fa-edit"></i>
                              </a>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> {{ text_all_synced }}</div>
                {% endif %}
              </div>

              {# Quantity Mismatch #}
              <div class="tab-pane fade" id="mismatch" role="tabpanel">
                {% if analytics_data.quantity_mismatch|length > 0 %}
                  <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <div>
                      <i class="fa-solid fa-info-circle"></i> {{ text_products_info }}
                    </div>
                    <button class="btn btn-primary print-report" data-bs-toggle="tooltip" title="{{ button_print_report }}">
                      <i class="fa-solid fa-print"></i> Print All ({{ analytics_data.quantity_mismatch|length }})
                    </button>
                  </div>
                  <div class="table-responsive" style="overflow-x: auto; max-width: 100%;">
                    <table class="table table-bordered table-hover" style="white-space: nowrap; font-size: 11px;">
                      <thead>
                        <tr>
                          <th style="width: 80px;">{{ column_product_id }}</th>
                          <th style="max-width: 200px;">{{ column_product }}</th>
                          <th style="width: 120px;">{{ column_ebay_id }}</th>
                          <th style="width: 150px;">{{ column_price }}</th>
                          <th style="width: 150px;">{{ column_quantity }}</th>
                          <th style="width: 120px;">{{ column_specifics }}</th>
                          <th style="width: 100px;">{{ column_location }}</th>
                          <th class="text-center" style="width: 80px;">{{ column_actions }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for product in analytics_data.quantity_mismatch %}
                          <tr>
                            <td class="text-center">{{ product.product_id }}</td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ product.name }}">{{ product.name }}</td>
                            <td><a href="https://www.ebay.ca/itm/{{ product.marketplace_item_id }}" target="_blank" class="text-primary"><i class="fa-brands fa-ebay"></i> {{ product.marketplace_item_id }}</a></td>
                            
                            {# Price Column #}
                            <td>
                              <div style="line-height: 1.3;">
                                <small class="text-muted d-block">Local: ${{ product.local_price|number_format(2) }} CAD</small>
                                <small class="text-muted d-block">eBay: ${{ product.ebay_price|number_format(2) }} CAD</small>
                                {% if product.price_diff %}
                                  <span class="badge bg-warning text-dark">⚠ Diff</span>
                                  <div class="btn-group btn-group-sm mt-1">
                                    <button class="btn btn-xs btn-outline-primary sync-price-btn" data-product-id="{{ product.product_id }}" data-direction="to_ebay" title="{{ text_sync_to_ebay }}">
                                      <i class="fa-solid fa-arrow-right"></i>
                                    </button>
                                    <button class="btn btn-xs btn-outline-secondary sync-price-btn" data-product-id="{{ product.product_id }}" data-direction="from_ebay" title="{{ text_sync_from_ebay }}">
                                      <i class="fa-solid fa-arrow-left"></i>
                                    </button>
                                  </div>
                                {% else %}
                                  <span class="badge bg-success">✓ OK</span>
                                {% endif %}
                              </div>
                            </td>
                            
                            {# Quantity Column #}
                            <td>
                              <div style="line-height: 1.3;">
                                <small class="text-muted d-block">Local: {{ product.total_quantity }}</small>
                                <small class="text-muted d-block">eBay: {{ product.ebay_available }}</small>
                                {% if product.qty_diff %}
                                  <span class="badge bg-warning text-dark">⚠ Diff</span>
                                  <div class="btn-group btn-group-sm mt-1">
                                    <button class="btn btn-xs btn-outline-primary sync-quantity-btn" data-product-id="{{ product.product_id }}" data-direction="to_ebay" title="{{ text_sync_to_ebay }}">
                                      <i class="fa-solid fa-arrow-right"></i>
                                    </button>
                                    <button class="btn btn-xs btn-outline-secondary sync-quantity-btn" data-product-id="{{ product.product_id }}" data-direction="from_ebay" title="{{ text_sync_from_ebay }}">
                                      <i class="fa-solid fa-arrow-left"></i>
                                    </button>
                                  </div>
                                {% else %}
                                  <span class="badge bg-success">✓ OK</span>
                                {% endif %}
                              </div>
                            </td>
                            
                            {# Specifics Column #}
                            <td>
                              {% if product.specifics_diff %}
                                <span class="badge bg-warning text-dark">⚠ Diff</span>
                                <div class="btn-group btn-group-sm mt-1">
                                  <button class="btn btn-xs btn-outline-primary sync-specifics-btn" data-product-id="{{ product.product_id }}" data-direction="to_ebay" title="{{ text_sync_to_ebay }}">
                                    <i class="fa-solid fa-arrow-right"></i>
                                  </button>
                                  <button class="btn btn-xs btn-outline-secondary sync-specifics-btn" data-product-id="{{ product.product_id }}" data-direction="from_ebay" title="{{ text_sync_from_ebay }}">
                                    <i class="fa-solid fa-arrow-left"></i>
                                  </button>
                                </div>
                              {% else %}
                                <span class="badge bg-success">✓ OK</span>
                              {% endif %}
                            </td>
                            
                            <td><span class="badge bg-secondary">{{ product.location }}</span></td>
                            <td class="text-center">
                              <div class="btn-group-vertical" role="group" style="width: 100%;">
                                <button type="button" class="btn btn-sm btn-info refresh-item-btn mb-1" data-product-id="{{ product.product_id }}" data-bs-toggle="tooltip" title="{{ tooltip_refresh_item }}">
                                  <i class="fa-solid fa-rotate"></i> 
                                </button>
                                <a href="index.php?route=shopmanager/catalog/product.form&product_id={{ product.product_id }}&user_token={{ user_token }}" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="{{ button_edit }}">
                                  <i class="fa-solid fa-edit"></i> 
                                </a>
                              </div>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> {{ text_no_mismatch }}</div>
                {% endif %}
              </div>

              {# Price Mismatch Only #}
              <div class="tab-pane fade" id="price-mismatch" role="tabpanel">
                {{ price_mismatch_content }}
              </div>

              {# Quantity Mismatch Only #}
              <div class="tab-pane fade" id="qty-mismatch" role="tabpanel">
                {{ qty_mismatch_content }}
              </div>

              {# Specifics Mismatch Only #}
              <div class="tab-pane fade" id="specifics-mismatch" role="tabpanel">
                {{ specifics_mismatch_content }}
              </div>

              {# Condition Mismatch Only #}
              <div class="tab-pane fade" id="condition-mismatch" role="tabpanel">
                {{ condition_mismatch_content }}
              </div>

              {# Category Mismatch Only #}
              <div class="tab-pane fade" id="category-mismatch" role="tabpanel">
                {{ category_mismatch_content }}
              </div>

              {# Image Count Mismatch — OC vs eBay #}
              <div class="tab-pane fade" id="image-mismatch" role="tabpanel">
                {{ image_mismatch_content }}
              </div>

              {# Slow Moving Products #}
              <div class="tab-pane fade" id="slow-moving" role="tabpanel">
                {% if analytics_data.bottom_products|length > 0 %}
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <th>{{ column_product }}</th>
                          <th>{{ column_ebay_id }}</th>
                          <th class="text-end">{{ column_stock }}</th>
                          <th class="text-end">{{ column_price }}</th>
                          <th class="text-end">{{ column_sales }}</th>
                          <th>{{ text_last_sync }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for product in analytics_data.bottom_products %}
                          <tr>
                            <td>{{ product.name }}</td>
                            <td>
                              {% if product.marketplace_item_id %}
                                <a href="https://www.ebay.ca/itm/{{ product.marketplace_item_id }}" target="_blank" class="text-primary"><i class="fa-brands fa-ebay"></i> {{ product.marketplace_item_id }}</a>
                              {% else %}
                                <span class="text-muted">-</span>
                              {% endif %}
                            </td>
                            <td class="text-end">{{ product.quantity }}</td>
                            <td class="text-end">${{ product.price|number_format(2) }}</td>
                            <td class="text-end">{{ product.units_sold }}</td>
                            <td>
                              {% if product.last_sync and product.last_sync != '0000-00-00 00:00:00' %}
                                <span class="badge bg-info">{{ product.last_sync|date('Y-m-d H:i') }}</span>
                              {% else %}
                                <span class="badge bg-warning">{{ text_never_synced }}</span>
                              {% endif %}
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <p class="text-muted">{{ text_no_data }}</p>
                {% endif %}
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
var TEXT_CONFIRM_SYNC_ALL     = '{{ text_confirm_sync_all|escape('js') }}';
var TEXT_ERROR_SYNC_URL       = '{{ text_error_sync_url|escape('js') }}';
var TEXT_CONFIRM_SYNC_PRODUCT = '{{ text_confirm_sync_product|escape('js') }}';
var TEXT_CONFIRM_REFRESH_ALL  = '{{ text_confirm_refresh_all|escape('js') }}';
var TEXT_CONFIRM_FORCE_REFRESH = '{{ text_confirm_force_refresh|escape('js') }}';
var TEXT_CONFIRM_SCAN_BACKUP   = '{{ text_scan_backup_confirm|escape('js') }}';
</script>

{{ footer }}
