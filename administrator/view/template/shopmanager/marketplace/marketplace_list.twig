<form id="form-marketplace-account" method="post">
  <div class="table-responsive">
    <table class="table table-bordered table-hover">
      <thead>
        <tr>
          <td class="text-center" style="width: 1px;"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
          <th class="text-center">
            {% if sort == 'store_name' %}
              <a href="{{ sort_store_name }}" class="{{ order }}">{{ column_marketplace_store_name }}</a>
            {% else %}
              <a href="{{ sort_store_name }}">{{ column_marketplace_store_name }}</a>
            {% endif %}
          </th>
          <th class="text-center">{{ column_marketplace_sites }}</th>
          <th class="text-center">{{ column_status }}</th>
          <th class="text-center">{{ text_token_status }}</th>
          <th class="text-center">{{ column_action }}</th>
        </tr>
      </thead>
      <tbody>
        {% if marketplace_accounts %}
          {% for account in marketplace_accounts %}
          <tr{% if not account.status %} class="opacity-50"{% endif %}>
            <td class="text-center"><input type="checkbox" name="selected[]" value="{{ account.marketplace_account_id }}" /></td>
            <td class="text-center">{{ account.store_name }}</td>
            <td class="text-center">
              <img src="{{ account.marketplace_image }}" title="{{ account.marketplace_name }}" alt="{{ account.marketplace_name }}" style="max-height: 30px;" />
            </td>
            <td class="text-center">{{ account.marketplace_status_image|raw }}</td>
            <td class="text-center" id="token-status-{{ account.marketplace_account_id }}">
              {% if account.is_ebay %}
                {% if account.has_refresh_token %}
                    <span class="token-status-badge token-ok"><i class="fa fa-key"></i> {{ text_token_present }}</span>
                {% else %}
                  <span class="token-status-badge token-bad"><i class="fa fa-times-circle"></i> {{ text_token_absent }}</span>
                {% endif %}
              {% else %}
                <span class="text-muted">—</span>
              {% endif %}
            </td>
            <td class="text-center text-nowrap">
              {% if account.url_connexion %}
                <button type="button" data-bs-toggle="tooltip" title="{{ button_refresh }}" class="btn btn-sm btn-success" onClick="window.open('{{ account.url_connexion }}', '_self')"><i class="fa fa-refresh"></i></button>
              {% endif %}
              <a href="{{ account.edit }}" data-bs-toggle="tooltip" title="{{ column_action }}" class="btn btn-sm btn-primary"><i class="fa-solid fa-pencil"></i></a>
            </td>
          </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td class="text-center" colspan="6">{{ text_no_results }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
  <div class="row">
    <div class="col-sm-6 text-start">{{ pagination }}</div>
    <div class="col-sm-6 text-end">{{ results }}</div>
  </div>
</form>
