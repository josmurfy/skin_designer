 // Autocomplétion pour recherche par nom ou category_id
$('#input-category').autocomplete({
    'source': function(request, response) {
        var user_token = document.querySelector('input[name="user_token"]').value;

        // Si c'est un ID numérique -> on ne montre pas de dropdown, le blur handler s'en charge
        if ($.isNumeric(request.trim()) && request.trim() !== '') {
            response([]);
            return;
        }

        // Recherche par nom
        $.ajax({
            url: 'index.php?route=shopmanager/catalog/category.autocomplete&user_token=' + user_token + '&filter_name=' + encodeURIComponent(request),
            dataType: 'json',
            success: function(json) {
                response($.map(json, function(item) {
                    return {
                        label: item['name'] + ' (' + item['category_id'] + ')',
                        value: item['category_id']
                    }
                }));
            }
        });
    },
    'select': function(item) {
        $('#input-category').val('');
        $('#category-id').val(item['value']);
        $('#product-category-' + item['value']).remove();

        var html = '<tr id="product-category-' + item['value'] + '">';
        html += '  <td>' + item['label'] + '<input type="hidden" name="product_category[]" value="' + item['value'] + '"/></td>';
        html += '  <td class="text-end"><button type="button" class="btn btn-danger btn-sm"><i class="fa-solid fa-minus-circle"></i></button></td>';
        html += '</tr>';

        $('#product-category- tbody').append(html);
    }
});

// Saisie manuelle d'un category_id (entrée numérique) — déclenchée au blur ou Enter
function fetchCategoryById(categoryInput) {
    if (!$.isNumeric(categoryInput) || categoryInput === '') return;
    var user_token = document.querySelector('input[name="user_token"]').value;
    var site_id = $('#site-id').val() || '';
    var url = 'index.php?route=shopmanager/catalog/category.getDetails&user_token=' + user_token + '&site_id=' + encodeURIComponent(site_id) + '&category_id=' + encodeURIComponent(categoryInput);
    console.log('[fetchCategoryById] URL:', url);
    $.ajax({
        url: url,
        dataType: 'json',
        success: function(json) {
            console.log('[fetchCategoryById] response:', json);
            if (!json.erreur && json.name) {
                if (json.leaf != 1) {
                    alert('Catégorie ID ' + categoryInput + ' n\'est pas une catégorie feuille (leaf=1)');
                    $('#input-category').val('').focus();
                    return;
                }
                $('#input-category').val('');
                $('#category-id').val(categoryInput);
                $('#site-id').val(json.site_id || site_id);
                $('#product-category- tbody').empty();
                // Une ligne par catégorie parente
                if (json.parents && json.parents.length > 0) {
                    $.each(json.parents, function(index, parent) {
                        var parentHtml = '<tr id="product-category-' + parent.id + '">';
                        parentHtml += '  <td class="small">' + htmlspecialchars(parent.name) + '<input type="hidden" name="product_category[]" value="' + parent.id + '"/></td>';
                        parentHtml += '  <td class="text-end"><button type="button" class="btn btn-danger btn-sm py-0"><i class="fa-solid fa-minus-circle"></i></button></td>';
                        parentHtml += '</tr>';
                        $('#product-category- tbody').append(parentHtml);
                    });
                }
                // Une ligne pour la catégorie feuille (avec path > name + id)
                var leafName = json.name_category || json.name;
                var leafPath = json.path || '';
                var leafDisplay = leafPath
                    ? htmlspecialchars(leafPath) + ' &gt; ' + htmlspecialchars(leafName) + ' (' + categoryInput + ')'
                    : htmlspecialchars(leafName) + ' (' + categoryInput + ')';
                var leafHtml = '<tr id="product-category-' + categoryInput + '">';
                leafHtml += '  <td class="small">' + leafDisplay + '<input type="hidden" name="product_category[]" value="' + categoryInput + '"/></td>';
                leafHtml += '  <td class="text-end"><button type="button" class="btn btn-danger btn-sm py-0"><i class="fa-solid fa-minus-circle"></i></button></td>';
                leafHtml += '</tr>';
                $('#product-category- tbody').append(leafHtml);
            } else {
                console.warn('[fetchCategoryById] not found or error field:', json);
                alert('Catégorie non trouvée (ID: ' + categoryInput + ')');
                $('#input-category').val('').focus();
            }
        },
        error: function(xhr, status, err) {
            console.error('[fetchCategoryById] AJAX error:', status, err, xhr.responseText);
            alert('Erreur lors de la récupération des détails de la catégorie');
            $('#input-category').val('').focus();
        }
    });
}

$('#input-category').on('keydown', function(e) {
    if (e.key === 'Enter') {
        var val = $(this).val().trim();
        if ($.isNumeric(val) && val !== '') {
            e.preventDefault();
            fetchCategoryById(val);
        }
    }
});

$('#input-category').on('blur', function() {
    var categoryInput = $(this).val().trim();
    if ($.isNumeric(categoryInput) && categoryInput !== '') {
        fetchCategoryById(categoryInput);
    }
});

