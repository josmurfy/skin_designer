{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-product" data-bs-toggle="tooltip" id="saveButton" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i></button>
        <button type="button" onclick="translateAllContent();" data-bs-toggle="tooltip" title="{{ text_translate_all }}" class="btn btn-success"><i class="fa-solid fa-language"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" id="cancelButton" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    {{ wait_popup|raw }}
    {{ alert_popup|raw }}
    {{ marketplace_error_popup|raw }}

    <div class="card">
      <div class="card-header">
        <h3 class="card-title"><i class="fa-solid fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="card-body">
        <form action="{{ save }}" method="post" enctype="multipart/form-data" id="form-product" data-oc-toggle="ajax">
          <input type="hidden" id="product-id" name="product_id" value="{{ product_id }}">
          <input type="hidden" id="to-translate" name="to_translate" value="">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <input type="hidden" id="product_search_data" name="product_search_data" value="{{ product_search_data is not empty ? 'true' : '' }}">

          <ul class="nav nav-tabs">
            <li class="nav-item"><a href="#tab-quick" data-bs-toggle="tab" class="nav-link {% if specifics is not defined %}active{% endif %}">⚡ {{ tab_quick }}</a></li>
            <li class="nav-item"><a href="#tab-general" data-bs-toggle="tab" class="nav-link">{{ tab_general }}</a></li>
           
            {% if product_id is defined %}
              <li class="nav-item"><a href="#tab-image" data-bs-toggle="tab" class="nav-link">{{ tab_image }}</a></li>
            {% endif %}
            <li class="nav-item">
              <a href="#tab-specifics" data-bs-toggle="tab" class="nav-link {% if specifics is defined %}active{% endif %}">{{ tab_specifics }}</a>
            </li>
             <li class="nav-item"><a href="#tab-data" data-bs-toggle="tab" class="nav-link">{{ tab_data }}</a></li>
            <li class="nav-item"><a href="#tab-links" data-bs-toggle="tab" class="nav-link">{{ tab_links }}</a></li>
            <li class="nav-item"><a href="#tab-attribute" data-bs-toggle="tab" class="nav-link">{{ tab_attribute }}</a></li>
            <li class="nav-item"><a href="#tab-option" data-bs-toggle="tab" class="nav-link">{{ tab_option }}</a></li>
            <li class="nav-item"><a href="#tab-subscription" data-bs-toggle="tab" class="nav-link">{{ tab_subscription }}</a></li>
            <li class="nav-item"><a href="#tab-discount" data-bs-toggle="tab" class="nav-link">{{ tab_discount }}</a></li>
            <li class="nav-item"><a href="#tab-reward" data-bs-toggle="tab" class="nav-link">{{ tab_reward }}</a></li>
            <li class="nav-item"><a href="#tab-seo" data-bs-toggle="tab" class="nav-link">{{ tab_seo }}</a></li>
            <li class="nav-item"><a href="#tab-design" data-bs-toggle="tab" class="nav-link">{{ tab_design }}</a></li>
            <li class="nav-item"><a href="#tab-report" data-bs-toggle="tab" class="nav-link">{{ tab_report }}</a></li>
          </ul>

          <div class="tab-content">

            {# ===================== QUICK TAB ===================== #}
            <div id="tab-quick" class="tab-pane {% if specifics is not defined %}active{% endif %}">
              <div class="row g-3 mt-1">
                <div class="col-12 col-xxl-10">
                <div class="row g-3 align-items-center">

                {# ── LEFT COLUMN ─────────────────────────────────── #}
                <div class="col-md-5 border-end pe-3">

                  {# Marketplace Account #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_marketplace_account_id }}</label>
                    <div class="col-sm-9">
                      <label id="label-marketplace-item-id">
                        {% if marketplace_accounts_id %}
                          {% for marketplace_account_id, marketplace in marketplace_accounts_id %}
                            {% set marketplace_item_id = marketplace.marketplace_item_id|default(0) %}
                            {% set marketplace_name = marketplace.marketplace_name %}
                            {% set url_product = marketplace.url_product %}
                            {% set marketplace_thumb = marketplace.thumb %}
                            {% set marketplace_id_tmp = marketplace.marketplace_id %}
                            <span id="marketplace-account-id-{{ product_id }}-{{ marketplace_account_id }}">
                              <input type="hidden" name="url_product_{{ product_id }}_{{ marketplace_account_id }}" value="{{ url_product }}">
                              <input type="hidden" name="marketplace_name_{{ product_id }}_{{ marketplace_account_id }}" value="{{ marketplace_name }}">
                              {% if marketplace_item_id and (marketplace.error is not defined or marketplace.error == '') %}
                                {% set product_link = url_product|replace({'{item_id}': marketplace_item_id}) %}
                                <a href="{{ product_link }}" target="marketplace_item_id">
                                  <img src="{{ marketplace_thumb }}" alt="{{ marketplace_name }}" style="width:25px;height:auto;">
                                </a>
                                <button type="button"
                                  id="end-listing-btn-{{ product_id }}-{{ marketplace_account_id }}"
                                  onclick="endListing('{{ product_id }}','{{ marketplace_item_id }}','{{ marketplace_account_id }}','{{ marketplace_id_tmp }}');"
                                  data-bs-toggle="tooltip" title="{{ button_end_listing }}"
                                  class="btn btn-sm btn-danger ms-1"><i class="fa-solid fa-ban"></i></button>
                              {% elseif marketplace.error is defined and marketplace.error != '' %}
                                <a href="javascript:void(0);" onclick="showErrorPopup('{{ product_id }}');">
                                  <img src="{{ marketplace_thumb }}" alt="{{ marketplace_name }}" style="width:25px;height:auto;">
                                </a>
                                <button type="button"
                                  id="end-listing-btn-{{ product_id }}-{{ marketplace_account_id }}"
                                  onclick="endListing('{{ product_id }}','{{ marketplace_item_id }}','{{ marketplace_account_id }}','{{ marketplace_id_tmp }}');"
                                  data-bs-toggle="tooltip" title="{{ button_end_listing }}"
                                  class="btn btn-sm btn-danger ms-1"><i class="fa-solid fa-ban"></i></button>
                              {% else %}
                                <a href="javascript:void(0);" onclick="addToMarketplace('{{ product_id }}','{{ marketplace_account_id }}','{{ marketplace_id_tmp }}');">
                                  <img src="{{ marketplace_thumb }}" alt="{{ marketplace_name }}" style="width:25px;height:auto;">
                                </a>
                              {% endif %}
                            </span>
                          {% endfor %}
                        {% endif %}
                      </label>
                    </div>
                  </div>

                  {# Condition — radios when qty=0, badge+hidden otherwise #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_condition }}</label>
                    <div class="col-sm-9">
                      {% if (quantity + unallocated_quantity) == 0 %}
                        <div class="d-flex flex-wrap gap-1">
                          {% for c in conditions[1]|default([]) %}
                            <div class="form-check me-2">
                              <input type="radio"
                                     name="condition_id"
                                     class="form-check-input save_data-radio"
                                     id="condition-{{ c.condition_marketplace_item_id }}"
                                     value="{{ c.condition_id }}"
                                     {% if condition_id is defined and condition_id == c.condition_id %}checked{% endif %}
                                     onclick="{% if existing_products[c.condition_id] is defined %}changeProduct('{{ existing_products[c.condition_id].url }}');{% else %}updateCondition('{{ c.condition_marketplace_item_id }}','{{ c.condition_id }}');checkFormStatus();{% endif %}">
                              <label class="form-check-label small" for="condition-{{ c.condition_marketplace_item_id }}">{{ c.condition_name }}</label>
                            </div>
                          {% endfor %}
                        </div>
                      {% else %}
                        <input type="hidden" id="condition-id" name="condition_id" value="{{ condition_id }}">
                        <span class="badge bg-secondary">{{ conditions[1][condition_id].condition_name|default(condition_id) }}</span>
                      {% endif %}
                    </div>
                  </div>

                  {# Manufacturer #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_manufacturer }}</label>
                    <div class="col-sm-5">
                      <input type="text" name="manufacturer" value="{{ manufacturer }}" placeholder="{{ entry_manufacturer }}" id="input-manufacturer" data-oc-target="autocomplete-manufacturer" class="form-control" autocomplete="off"/>
                      <input type="hidden" name="manufacturer_id" value="{{ manufacturer_id }}" id="input-manufacturer-id"/>
                      <ul id="autocomplete-manufacturer" class="dropdown-menu"></ul>
                    </div>
                    <div class="col-sm-4">
                      <div class="input-group input-group-sm">
                        <button type="button" id="btn-uppercase-manufacturer" class="btn btn-warning btn-sm" title="{{ button_uppercase }}" onclick="(function(f){var t=f.value;if(t===t.toUpperCase())t=t.toLowerCase();f.value=t.replace(/\b([a-zA-Z\u00C0-\u00ff][a-zA-Z\u00C0-\u00ff']*)\b/g,function(m,w){return w.charAt(0).toUpperCase()+w.slice(1);});})(document.getElementById('input-manufacturer'));"><i class="fa fa-text-height"></i></button>
                        <button type="button" id="btn-add-manufacturer" class="btn btn-success btn-sm" title="{{ button_add }}"><i class="fa-solid fa-plus"></i></button>
                        <button type="button" id="btn-edit-manufacturer" class="btn btn-info btn-sm" title="{{ button_edit }}"><i class="fa-solid fa-pencil"></i></button>
                        <button type="button" id="btn-delete-manufacturer" class="btn btn-danger btn-sm" title="{{ button_delete }}"><i class="fa-solid fa-trash"></i></button>
                      </div>
                    </div>
                  </div>

                  {# Category #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">
                      <span data-bs-toggle="tooltip" title="{{ help_category }}">{{ entry_category }}</span>
                    </label>
                    <div class="col-sm-9">
                      <input type="text" name="category" value="" placeholder="{{ entry_category }}" id="input-category" data-oc-target="autocomplete-category" class="form-control" autocomplete="off"/>
                      <ul id="autocomplete-category" class="dropdown-menu"></ul>
                      <input type="hidden" id="category-id" name="category_id" value="{{ category_id|default('') }}">
                      <input type="hidden" id="category-name" name="category_name" value="{{ category_name|default('') }}">
                      <input type="hidden" id="site-id" name="site_id" value="{{ site_id|default('') }}">
                      <div class="form-control p-0 mt-1" style="height:90px;overflow:auto;">
                        <table id="product-category-" class="table table-sm m-0">
                          <tbody>
                            {% for product_category in product_categories %}
                              <tr id="product-category-{{ product_category.category_id }}">
                                <td class="small">{{ product_category.name }}{% if product_category.leaf==1 %} ({{ product_category.category_id }}){% endif %}<input type="hidden" name="product_category[]" value="{{ product_category.category_id }}"/></td>
                                <td class="text-end"><button type="button" class="btn btn-danger btn-sm py-0"><i class="fa-solid fa-minus-circle"></i></button></td>
                              </tr>
                            {% endfor %}
                          </tbody>
                        </table>
                      </div>
                      <div id="error-category" class="invalid-feedback"></div>
                    </div>
                  </div>

                  {# Model #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_model }}</label>
                    <div class="col-sm-5">
                      <div class="input-group">
                        <input type="text" name="model" value="{{ model }}" placeholder="{{ entry_model }}" id="input-model" class="form-control">
                        <button type="button" class="btn btn-warning" title="{{ button_uppercase }}" onclick="(function(f){var t=f.value;if(t===t.toUpperCase())t=t.toLowerCase();f.value=t.replace(/\b([a-zA-Z\u00C0-\u00ff][a-zA-Z\u00C0-\u00ff']*)\b/g,function(m,w){return w.charAt(0).toUpperCase()+w.slice(1);});})(document.getElementById('input-model'));"><i class="fa fa-text-height"></i></button>
                      </div>
                    </div>
                    <div class="col-sm-4">
                      <div class="form-check mt-1">
                        <input type="checkbox" class="form-check-input" id="checkbox-none" onclick="document.getElementById('input-model').value = this.checked ? '{{ text_none }}' : '';">
                        <label class="form-check-label small" for="checkbox-none">{{ text_none }}</label>
                      </div>
                    </div>
                  </div>

                  {# Made in Country #}
                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_made_in_country }}</label>
                    <div class="col-sm-9" id="check-made-in-country-id" {% if made_in_country_id == '0' or made_in_country_id is null %}style="background-color:RED"{% endif %}>
                   
                      <select name="made_in_country_id" id="input-made-in-country-id" class="form-select" onchange="editMadeInCountry({{ product_id }})">
                        {% for country in countries %}
                          <option value="{{ country.country_id }}"{% if country.country_id == made_in_country_id %} selected="selected"{% endif %}>{{ country.name }}</option>
                        {% endfor %}
                      </select>
                    
                    </div>
                  </div>

                

                  <div class="row mb-2">
                    <label class="col-sm-3 col-form-label fw-bold fs-6">{{ entry_status }}</label>
                    <div class="col-sm-9">
                      <div class="form-check form-switch form-switch-lg">
                        <input type="hidden" name="status" value="0"/>
                        <input type="checkbox" name="status" value="1" id="input-status" class="form-check-input"{% if status %} checked{% endif %}/>
                      </div>
                    </div>
                  </div>

                </div>{# end col-md-5 #}

                {# ── RIGHT COLUMN ─────────────────────────────────── #}
                <div class="col-md-7 ps-3">

                  {# Price #}
                  <fieldset>
                   
                    <div class="row g-2 mb-2">
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_price }}</label>
                        <input type="text" name="price" value="{{ price }}" placeholder="{{ entry_price }}" id="input-price" class="form-control">
                        <span id="price-computed-display" class="badge bg-warning text-dark mt-1" style="display:none;font-size:0.85em;"></span>
                      </div>
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_shipping_cost }}</label>
                        <input type="hidden" name="shipping_carrier" value="{{ shipping_carrier }}" id="input-shipping-carrier">
                        <input type="text" name="shipping_cost" value="{{ shipping_cost }}" placeholder="{{ entry_shipping_cost }}" id="input-shipping-cost" class="form-control">
                        <div id="error-shipping-cost" class="invalid-feedback"></div>
                        <small id="shipping-carrier" class="text-muted d-block text-end">{{ shipping_carrier }}</small>
                      </div>
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_price_with_shipping }}</label>
                        <input type="text" name="price_with_shipping" value="{{ price_with_shipping }}" placeholder="{{ entry_price_with_shipping }}" id="input-price-with-shipping" class="form-control">
                      </div>
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_rabate }} (%)</label>
                        <input type="text" name="discount" value="0" id="input-discount" class="form-control" onchange="updatePrice();">
                      </div>
                    </div>
                    {% if ebay_pricevariant is not empty %}
                      <div class="table-responsive">
                        <table class="table table-bordered table-hover table-sm" style="font-size:0.8em;">
                          <thead>
                            <tr>
                              <td></td>
                              <td>{{ text_condition_name }}</td>
                              <td>{{ text_price }}</td>
                              <td>{{ text_url }}</td>
                              <td><a href="https://www.ebay.com/sch/i.html?_nkw={{ upc }}&_ipg=100&rt=nc&LH_Sold=1&LH_Complete=1" target="sold">{{ text_all_sold }}</a></td>
                            </tr>
                          </thead>
                          <tbody>
                            {% set condition_marketplace_item_id = conditions[1][condition_id].condition_marketplace_item_id ?? null %}
                            {% set price_check = ebay_info.our_price|default(price_with_shipping) %}
                            {% for key, ebayinfo in ebay_pricevariant %}
                              {% set row_class = '' %}
                              {% if key == condition_marketplace_item_id %}
                                {% if (ebayinfo.price is empty and ebay_info.our_price is defined) %}{% set row_class = 'table-success' %}
                                {% elseif price_check < ebayinfo.price %}{% set row_class = 'table-warning' %}
                                {% elseif price_check > ebayinfo.price %}{% set row_class = 'table-danger' %}
                                {% else %}{% set row_class = 'table-success' %}
                                {% endif %}
                              {% endif %}
                              <tr class="{{ row_class }}">
                                <td><input type="radio" class="form-check-input save-data-radio radioreadonly" name="price_ebay[{{ key }}]" value="{{ ebayinfo.price|default('') }}" {% if key == 0 %}checked{% endif %}></td>
                                <td>{{ ebayinfo.condition_name }}{% if ebay_info.our_price is defined and key == condition_marketplace_item_id %} (${{ ebay_info.our_price }}){% endif %}</td>
                                <td>{% if ebayinfo.price %}${{ ebayinfo.price }}{% endif %}</td>
                                <td>{% if ebayinfo.url %}<a href="{{ ebayinfo.url }}" target="ebay">{{ text_view_website }}</a>{% endif %}</td>
                                <td><a href="https://www.ebay.com/sch/i.html?_nkw={{ upc }}&_ipg=100&rt=nc&LH_Sold=1&LH_Complete=1&LH_ItemCondition={{ key }}" target="sold">{{ text_view_website_sold }}</a></td>
                              </tr>
                            {% endfor %}
                          </tbody>
                        </table>
                      </div>
                    {% endif %}
                  </fieldset>
  {# Quantity + Location + Unallocated #}
                  <div class="row g-2 mb-2">
                    <div class="col-sm-4">
                      <label class="form-label small text-muted">{{ entry_quantity }}</label>
                      <div class="input-group">
                        <button type="button" id="btn-print-quantity-label" class="btn btn-warning btn-sm" title="{{ button_print_qty_label }}"><i class="fa-solid fa-print"></i></button>
                        <input type="text" name="quantity" value="{{ quantity }}" placeholder="{{ entry_quantity }}" id="input-quantity" class="form-control">
                      </div>
                    </div>
                    <div class="col-sm-4">
                      <label class="form-label small text-muted">{{ entry_location }}</label>
                      <div class="input-group">
                        <button type="button" id="btn-print-label" class="btn btn-warning btn-sm" title="{{ button_print_label }}"><i class="fa-solid fa-print"></i></button>
                        <input type="text" name="location" value="{{ location }}" placeholder="{{ entry_location }}" id="input-location" class="form-control">
                      </div>
                      <div id="error-location" class="invalid-feedback"></div>
                    </div>
                    <div class="col-sm-4">
                      <label class="form-label small text-muted">{{ entry_unallocated_quantity }}</label>
                      <input type="text" name="unallocated_quantity" value="{{ unallocated_quantity }}" placeholder="{{ entry_unallocated_quantity }}" id="input-unallocated-quantity" class="form-control">
                    </div>
                  </div>
                  {# Dimensions + Weight #}
                  <fieldset class="mt-2">
                    <div class="row g-2">
                      <div class="col-sm-2">
                        <label class="form-label small text-muted">{{ entry_length }}</label>
                        <input type="text" name="length" value="{{ length }}" placeholder="{{ entry_length }}" id="input-length" class="form-control">
                        <small class="text-muted d-block text-end">{{ length_class_title }}</small>
                        <div id="error-length" class="invalid-feedback"></div>
                        <input type="hidden" name="length_class_id" value="{{ length_class_id }}" id="hidden-length-class">
                      </div>
                      <div class="col-sm-2">
                        <label class="form-label small text-muted">{{ entry_width }}</label>
                        <input type="text" name="width" value="{{ width }}" placeholder="{{ entry_width }}" id="input-width" class="form-control">
                        <small class="text-muted d-block text-end">{{ length_class_title }}</small>
                        <div id="error-width" class="invalid-feedback"></div>
                      </div>
                      <div class="col-sm-2">
                        <label class="form-label small text-muted">{{ entry_height }}</label>
                        <input type="text" name="height" value="{{ height }}" placeholder="{{ entry_height }}" id="input-height" class="form-control">
                        <small class="text-muted d-block text-end">{{ length_class_title }}</small>
                        <div id="error-height" class="invalid-feedback"></div>
                      </div>
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_weight }}</label>
                        <input type="text" name="weight" value="{{ weight|default(0) }}" placeholder="{{ entry_weight }}" id="input-weight" class="form-control" onchange="updateWeightOz()">
                        <small class="text-muted d-block text-end">{{ weight_class_title }}</small>
                        <input type="hidden" name="weight_class_id" id="hidden-weight-class" value="{{ weight_class_id }}">
                      </div>
                      <div class="col-sm-3">
                        <label class="form-label small text-muted">{{ entry_weight_oz }}</label>
                        <input type="text" name="weight_oz" value="{{ (weight|default(0)*16)|round }}" placeholder="{{ entry_weight_oz }}" id="input-weight-oz" class="form-control" onchange="updateWeight()">
                        <small class="text-muted d-block text-end">oz</small>
                      </div>
                    </div>
                  </fieldset>

                </div>{# end col-md-7 #}
                </div>{# end inner row #}
                </div>{# end col-xxl-10 #}
              </div>{# end outer row #}
            </div>{# end tab-quick #}

            {# ===================== GENERAL TAB ===================== #}
            <div class="tab-pane" id="tab-general">
          
            <ul class="nav nav-tabs" id="language-">
              {% set specifics_row = 0 %}    
                {% for language in languages %}
                  <li class="nav-item"><a href="#language-{{ language.language_id }}" data-bs-toggle="tab" class="nav-link{% if loop.first %} active{% endif %}"><img src="{{ language.image }}" title="{{ language.name }}"/> {{ language.name }}</a></li>
                {% endfor %}
              <input type="hidden" name="languages_json" id="languages-json" value='{{ languages_json|raw }}'>
              <input type="hidden" name="stores_json" id="stores-json" value='{{ stores_json|raw }}'>
            </ul>
              <div class="tab-content">
                {% for language in languages %}
                  {% set specifics_row = 0 %}
                  <div id="language-{{ language.language_id }}" class="tab-pane{% if loop.first %} active{% endif %}">
                    
                    <div class="row mb-3 required">
                      <label class="col-sm-2 col-form-label" for="product-description-{{ language.language_id }}-{{ specifics_row }}">{{ entry_name }}</label>
                      <div class="col-sm-6">
                        <div id="ai-result-name" style="display:none; margin-bottom: 10px; padding: 15px; background: #007bff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,123,255,0.3); animation: slideDown 0.3s ease-out; position: relative;">
                          <button type="button" onclick="document.getElementById('ai-result-name').style.display='none'" style="position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.2); border: none; color: #fff; width: 24px; height: 24px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: bold; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.3)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'">×</button>
                          <div style="display: flex; align-items: center; gap: 10px;">
                            <i class="fa-solid fa-robot" style="color: #fff; font-size: 24px;"></i>
                            <div style="flex: 1;">
                              <div style="color: rgba(255,255,255,0.9); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">{{ text_ai_suggestion }} <label id="ai-result-name-count" style="display: inline;"></label></div>
                              <div id="ai-result-name-text" style="color: #fff; font-size: 15px; font-weight: 500; line-height: 1.4;"></div>
                            </div>
