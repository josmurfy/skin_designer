{% if ebay_pricevariant is not empty %}
  {% set condition_marketplace_item_id = conditions[1][condition_id].condition_marketplace_item_id ?? null %}
  {% set price_check = ebay_info.our_price|default(price_with_shipping|default(0)) %}

  <div style="border:2px solid #0064d2; border-radius:6px; overflow:hidden; margin:8px 0; font-size:0.8em; box-shadow:0 2px 8px rgba(0,100,210,0.15);">

    <div style="background:#0064d2; color:#fff; padding:5px 10px; display:flex; align-items:center; justify-content:space-between;">
      <span style="font-weight:700; letter-spacing:0.04em;">
        <i class="fa-brands fa-ebay me-1"></i> Sold Prices
      </span>
      {% if upc is defined and upc %}
        <div style="display:inline-flex; border-radius:4px; overflow:hidden; border:1px solid rgba(255,255,255,0.7);">
          <a href="https://www.ebay.ca/sch/i.html?_nkw={{ upc }}&amp;_ipg=100&amp;rt=nc&amp;LH_Sold=1&amp;LH_Complete=1&amp;_sop=15"
             target="sold" style="background:#fff; color:#0064d2; padding:2px 9px; font-size:0.82em; font-weight:700; text-decoration:none; border-right:1px solid rgba(0,100,210,0.25);">
            <i class="fa-solid fa-magnifying-glass-dollar me-1"></i>All Sold
          </a>
          <a href="https://www.ebay.ca/sch/i.html?_nkw={{ upc }}&amp;_ipg=100&amp;rt=nc&amp;LH_BIN=1&amp;_sop=15"
             target="sold" style="background:rgba(255,255,255,0.15); color:#fff; padding:2px 9px; font-size:0.82em; font-weight:700; text-decoration:none;">
            <i class="fa-solid fa-tag me-1"></i>For Sale
          </a>
        </div>
      {% endif %}
    </div>

    <table class="table table-sm mb-0" style="background:#fff;">
      <thead style="background:#e8f0fe; color:#0064d2;">
        <tr>
          <th style="width:28px; border-bottom:2px solid #0064d2;"></th>
          <th style="border-bottom:2px solid #0064d2;">{{ text_condition_name }}</th>
          <th class="text-end" style="border-bottom:2px solid #0064d2;">USD</th>
          <th class="text-end" style="border-bottom:2px solid #0064d2;">CAD</th>
          <th class="text-center" style="width:36px; border-bottom:2px solid #0064d2;"></th>
          {% if upc is defined and upc %}<th class="text-center" style="width:36px; border-bottom:2px solid #0064d2;"></th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for key, ebayinfo in ebay_pricevariant %}
          {% set is_active = (condition_marketplace_item_id is not null and key == condition_marketplace_item_id) %}
          {% set cad_price = ebayinfo.price_cad|default(null) %}
          {% if is_active %}
            {% if price_check and cad_price %}
              {% if price_check < cad_price %}
                {% set row_style = 'background:#f0fdf4; border-left:3px solid #22c55e;' %}
                {% set price_color = '#22c55e' %}
              {% elseif price_check > cad_price %} 
                {% set row_style = 'background:#fef2f2; border-left:3px solid #ef4444;' %}
                {% set price_color = '#ef4444' %}
              {% else %}
                {% set row_style = 'background:#f0fdf4; border-left:3px solid #22c55e;' %}
                {% set price_color = '#22c55e' %}
              {% endif %}
            {% else %}
              {% set row_style = 'background:#f0f4ff; border-left:3px solid #0064d2;' %}
              {% set price_color = '#0064d2' %}
            {% endif %}
          {% else %}
            {% set row_style = 'border-left:3px solid transparent;' %}
            {% set price_color = '#198754' %}
          {% endif %}
          <tr style="{{ row_style }}">
            <td class="text-center align-middle">
              <input type="radio" class="form-check-input save-data-radio radioreadonly"
                     name="price_ebay[{{ key }}]"
                     value="{{ ebayinfo.price|default('') }}"
                     {% if is_active %}checked{% endif %}>
            </td>
            <td class="align-middle" style="{% if is_active %}font-weight:700;{% endif %}">
              {{ ebayinfo.condition_name }}
            </td>
            <td class="text-end align-middle" style="color:#888;">
              {% if ebayinfo.price %}<span>$US{{ ebayinfo.price }}</span>{% else %}<span style="color:#aaa;">—</span>{% endif %}
            </td>
            <td class="text-end align-middle" style="font-weight:700; color:{{ price_color }};">
              {% if cad_price %}CA${{ cad_price }}{% else %}<span style="color:#aaa;">—</span>{% endif %}
            </td>
            <td class="text-center align-middle">
              {% if ebayinfo.url %}
                <a href="{{ ebayinfo.url|replace({'ebay.com': 'ebay.ca'}) }}" target="ebay"
                   style="background:#343a40; color:#fff; border-radius:4px; padding:1px 6px; font-size:0.85em; text-decoration:none;">
                  <i class="fa-solid fa-up-right-from-square"></i>
                </a>
              {% endif %}
            </td>
            {% if upc is defined and upc %}
              <td class="text-center align-middle">
                <a href="https://www.ebay.ca/sch/i.html?_nkw={{ upc }}&amp;_ipg=100&amp;rt=nc&amp;LH_BIN=1&amp;LH_ItemCondition={{ key }}&amp;_sop=15"
                   target="sold"
                   style="background:#0064d2; color:#fff; border-radius:4px; padding:1px 6px; font-size:0.85em; text-decoration:none;"
                   title="Buy It Now - {{ ebayinfo.condition_name }}">
                  <i class="fa-solid fa-tag"></i>
                </a>
              </td>
            {% endif %}
          </tr>
        {% endfor %}
      </tbody>
    </table>

  </div>
{% endif %}
