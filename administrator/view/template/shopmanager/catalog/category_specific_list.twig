            <a href="{{ sort_specific_name }}">{{ column_specific_name }}</a>
            {% endif %}</td>
                
                {% for language in languages %}
                    {% if language.code != 'en' %}
                        <td>{{ language.name }}</td>
                    {% endif %}
                {% endfor %}
                
            </tr>
        </thead>
        
        <tbody>
            {% if category_specifics %}
                {% for specific in category_specifics %}
                    <tr>
                    <td class="text-center">{% if specific.category_specifics_id in selected %}
