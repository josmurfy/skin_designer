                    <input type="checkbox" name="selected[]" value="{{ specific.category_specifics_id }}" />
                    {% endif %}</td>

                        <td>{{ specific.specific_name }}</td>
                        {% for language in languages %}
                            {% if language.code != 'en' %}
                                <td>
                                    <input type="text" name="translation_{{ language.code }}[{{ specific.specific_name }}]" value="{{ specific.languages[language.code]|default('') }}" class="form-control" />
                                </td>
                            {% endif %}
                        {% endfor %}
                       
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="{{ languages|length + 1 }}" class="text-center">{{ text_no_results }}</td>
                </tr>
            {% endif %}
        </tbody>
        
          
            </table>
