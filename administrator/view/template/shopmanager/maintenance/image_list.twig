<!-- Statistiques -->
<div class="alert alert-info">
  <strong>{{ text_statistics }}</strong><br>
  {{ text_total_checked }} <strong>{{ total_checked }}</strong> {{ text_products }}<br>
  {{ text_missing_images }} <strong class="text-danger">{{ missing_images }}</strong>
</div>

<!-- Bouton de correction -->
<div class="mb-3">
  <button type="button" id="btn-check-ebay-images-selected" class="btn btn-primary" style="display:none;">
    <i class="fa-brands fa-ebay"></i> {{ button_check_ebay_images }}
  </button>
  <button type="button" id="btn-import-ebay-selected" class="btn btn-success" style="display:none;">
    <i class="fa-brands fa-ebay"></i> {{ button_import_ebay_images }}
  </button>
  <button type="button" id="btn-fix-selected" class="btn btn-warning" style="display:none;">
    <i class="fa-solid fa-wrench"></i> Fix Selected Images
  </button>
</div>

<!-- Tableau des résultats -->
<div class="table-responsive">
  <table class="table table-bordered table-hover">
    <thead>
      <tr>
        <th class="text-center" style="width: 1px;"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', $(this).prop('checked'));" class="form-check-input" id="select-all"/></th>
        <th><a href="{{ sort_product_id }}"{% if sort == 'p.product_id' %} class="{{ order|lower }}"{% endif %}>{{ column_id }}</a></th>
        <th><a href="{{ sort_name }}"{% if sort == 'pd.name' %} class="{{ order|lower }}"{% endif %}>{{ column_name }}</a></th>
        <th>{{ column_main_image }}</th>
        <th>{{ column_secondary_images }}</th>
        <th>{{ column_orphan_images }}</th>
        <th>{{ column_status }}</th>
        <th>{{ column_action }}</th>
      </tr>
    </thead>
            <tbody>
              {% for product in products %}
                <tr class="{% if product.has_missing %}table-danger{% else %}table-success{% endif %}" data-product-id="{{ product.product_id }}">
                  <td class="text-center">
                    <input type="checkbox" name="selected[{{ product.product_id }}]" value="{{ product.product_id }}" class="form-check-input" />
                  </td>
                  <td>{{ product.product_id }}</td>
                  <td>{{ product.name }}</td>
                  <td>
                    {% if product.main_image %}
                      {% if product.main_image_exists %}
                        <div class="actual-image-container" style="display: inline-block; position: relative; cursor: pointer; border: 3px solid {% if product.is_low_resolution or product.is_old_nomenclature %}#dc3545{% else %}#28a745{% endif %}; border-radius: 4px; padding: 2px;">
                          <img src="{{ product.main_image_thumb }}" alt="{{ product.name }}" class="img-thumbnail"/>
                          <div class="fullsize-actual-image-wrapper">
                            <img src="{{ constant('HTTP_CATALOG') }}image/{{ product.main_image_fullsize }}" alt="{{ product.name }}" class="fullsize-actual-image" data-resolution="{{ product.main_image_resolution }}">
                            <div class="fullsize-resolution-overlay"></div>
                          </div>
                        </div>
                      {% else %}
                        <div class="d-flex align-items-start gap-2">
                          <div>
                            <i class="fa-solid fa-times text-danger"></i> 
                            <small class="text-danger">{{ product.main_image }}</small><br>
                            <small class="text-muted">{{ text_file_not_found }}</small>
                          </div>
                          <div class="form-check">
                            <input type="checkbox" class="form-check-input remove-missing-image" 
                                   data-product-id="{{ product.product_id }}" 
                                   data-image-path="{{ product.main_image }}"
                                   data-type="main"
                                   id="remove-main-{{ product.product_id }}">
                            <label class="form-check-label" for="remove-main-{{ product.product_id }}" style="font-size: 11px;">
                              Remove from DB
                            </label>
                          </div>
                        </div>
                      {% endif %}
                    {% else %}
                      <i class="fa-solid fa-exclamation-triangle text-warning"></i> {{ text_no_image }}
                    {% endif %}
                  </td>
                  <td>
                    {% if product.secondary_images %}
                      <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                        {% for sec_img in product.secondary_images %}
                          {% if sec_img.exists %}
                            <div class="actual-image-container" style="display: inline-block; position: relative; cursor: pointer; border: 3px solid {% if sec_img.is_low_resolution or sec_img.wrong_extension %}#dc3545{% else %}#28a745{% endif %}; border-radius: 4px; padding: 2px;">
                              <img src="{{ sec_img.thumb }}" alt="Secondary" class="img-thumbnail" style="width: 40px; height: 40px;"/>
                              <div class="fullsize-actual-image-wrapper">
                                <img src="{{ constant('HTTP_CATALOG') }}image/{{ sec_img.fullsize }}" alt="Secondary" class="fullsize-actual-image" data-resolution="{{ sec_img.resolution }}">
                                <div class="fullsize-resolution-overlay"></div>
                              </div>
                            </div>
                          {% else %}
                            <div style="text-align: center; width: 60px;">
                              <i class="fa-solid fa-times text-danger" title="{{ sec_img.image }}"></i><br>
                              <input type="checkbox" class="form-check-input remove-missing-image mt-1" 
                                     data-product-id="{{ product.product_id }}" 
                                     data-image-path="{{ sec_img.image }}"
                                     data-type="secondary"
                                     style="font-size: 10px;">
                            </div>
                          {% endif %}
                        {% endfor %}
                      </div>
                      <small class="text-muted d-block mt-1">
                        {{ text_total }} {{ product.secondary_images|length }}
                        {% if product.missing_secondary > 0 %}
                          | <span class="text-danger">{{ text_missing }} {{ product.missing_secondary }}</span>
                        {% endif %}
                      </small>
                    {% else %}
                      <span class="text-muted">{{ text_none }}</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if product.orphan_images|length > 0 %}
                      <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-start;">
                        {% for orphan_img in product.orphan_images %}
                          <div class="actual-image-container" style="text-align: center; width: 60px;">
                            <img src="{{ constant('HTTP_CATALOG') }}image/{{ orphan_img.image }}"
                                 alt="Orphan Image"
                                 class="img-thumbnail"
                                 data-image-path="{{ orphan_img.image }}"
                                 data-resolution="{{ orphan_img.resolution }}"
                                 style="width: 60px; height: 60px; object-fit: cover; cursor: pointer;"
                                 title="{{ orphan_img.image }}">
                            <div style="display: flex; gap: 2px; justify-content: center; margin-top: 2px;">
                              <input type="checkbox" class="form-check-input add-orphan-secondary" 
                                     data-product-id="{{ product.product_id }}" 
                                     data-image-path="{{ orphan_img.image }}"
                                  checked
                                     title="Add as secondary"
                                     style="font-size: 12px; width: 16px; height: 16px;">
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                      <small class="text-muted d-block mt-1">
                        {{ product.orphan_images|length }} orphan image(s) found
                      </small>
                    {% else %}
                      <span class="text-muted">{{ text_none }}</span>
                    {% endif %}
                  </td>
                  <td class="text-start" style="max-width: 300px;">
                    {% if product.has_missing or product.is_low_resolution or product.is_wrong_path or product.is_old_nomenclature %}
                      <span class="badge bg-danger mb-1">Problems</span><br>
                      <small>{{ product.status_message|raw }}</small>
                    {% else %}
                      <span class="badge bg-success">{{ status_ok }}</span>
                    {% endif %}
                  </td>
                  <td>
                    <a href="{{ product.edit }}" class="btn btn-primary btn-sm" target="_blank">
                      <i class="fa-solid fa-pencil"></i> {{ button_edit }}
                    </a>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="8" class="text-center">No products found!</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        
        <!-- Button to remove selected missing images -->
        <div class="row mb-3">
          <div class="col-12">
            <button type="button" id="remove-selected-images" class="btn btn-danger" style="display:none;">
              <i class="fa-solid fa-trash"></i> Remove Selected Missing Images
            </button>
            <button type="button" id="add-orphan-images-btn" class="btn btn-success" style="display:none;">
              <i class="fa-solid fa-plus"></i> Add Selected Orphan Images
            </button>
          </div>
        </div>
        
        <!-- Pagination -->
        <div class="row">
          <div class="col-sm-6 text-start">{{ results }}</div>
          <div class="col-sm-6 text-end">{{ pagination }}</div>
        </div>

