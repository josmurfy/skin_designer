{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" onclick="window.print();" class="btn btn-info"><i class="fa-solid fa-print"></i> {{ button_print }}</button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div id="filter-report" class="col-lg-3 col-md-12 order-lg-last d-none d-lg-block mb-3">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-filter"></i> {{ text_filter }}</div>
          <div class="card-body">
            <form id="form-filter">
              <input type="hidden" name="user_token" value="{{ user_token }}">
              
              <div class="mb-3">
                <label for="input-product-id" class="form-label">{{ entry_product_id }}</label>
                <input type="text" name="filter_product_id" value="{{ filter_product_id }}" placeholder="{{ entry_product_id }}" id="input-product-id" class="form-control"/>
              </div>
              
              <div class="mb-3">
                <label for="input-name" class="form-label">{{ entry_name }}</label>
                <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control"/>
              </div>
              
              <div class="mb-3">
                <label for="input-model" class="form-label">{{ entry_model }}</label>
                <input type="text" name="filter_model" value="{{ filter_model }}" placeholder="{{ entry_model }}" id="input-model" class="form-control"/>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_image_issue" value="1" id="input-image-issue" class="form-check-input" {% if filter_image_issue %}checked{% endif %}>
                  <label for="input-image-issue" class="form-check-label">{{ entry_image_issue }}</label>
                </div>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_low_resolution" value="1" id="input-low-resolution" class="form-check-input" {% if filter_low_resolution %}checked{% endif %}>
                  <label for="input-low-resolution" class="form-check-label">{{ entry_low_resolution }}</label>
                </div>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_wrong_path" value="1" id="input-wrong-path" class="form-check-input" {% if filter_wrong_path %}checked{% endif %}>
                  <label for="input-wrong-path" class="form-check-label">{{ entry_wrong_path }}</label>
                </div>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_old_nomenclature" value="1" id="input-old-nomenclature" class="form-check-input" {% if filter_old_nomenclature %}checked{% endif %}>
                  <label for="input-old-nomenclature" class="form-check-label">{{ entry_old_nomenclature }}</label>
                </div>
              </div>

              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_orphan_images" value="1" id="input-orphan-images" class="form-check-input" {% if filter_orphan_images %}checked{% endif %}>
                  <label for="input-orphan-images" class="form-check-label">{{ entry_orphan_images }}</label>
                </div>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input type="checkbox" name="filter_zero_quantity" value="1" id="input-zero-quantity" class="form-check-input" {% if filter_zero_quantity %}checked{% endif %}>
                  <label for="input-zero-quantity" class="form-check-label">{{ entry_zero_quantity }}</label>
                </div>
              </div>
              
              <div class="text-end">
                <button type="button" id="button-filter" class="btn btn-light"><i class="fa-solid fa-filter"></i> {{ button_filter }}</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      
      <div class="col-lg-9 col-md-12">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-list"></i> {{ text_list }}</div>
          <div id="report" class="card-body" data-oc-load="{{ action }}" data-oc-target="#report">{{ list }}</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de validation -->
<div class="modal fade" id="validation-modal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Validation Required</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="validation-info"></div>
        <div id="validation-progress" style="display:none;">
          <div class="progress mt-3">
            <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">0%</div>
          </div>
          <p class="text-center mt-2"><small id="validation-status"></small></p>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Show Current Data</button>
        <button type="button" id="btn-start-validation" class="btn btn-primary">Start Validation</button>
      </div>
    </div>
  </div>
</div>

<script src="view/javascript/shopmanager/bootstrap_helper.js" type="text/javascript"></script>
<script>
var MAINT_IMAGE_TOKEN = '{{ user_token }}';
</script>
<script src="view/javascript/shopmanager/maintenance/image.js" type="text/javascript"></script>

{{ footer }}
