<div class="table-responsive">
  <table class="table table-bordered table-hover">
    <thead>
      <tr>
        <td class="text-center" style="width: 1px;"><input type="checkbox" id="select-all" /></td>
        <td class="text-center"><a href="{{ sort_id }}"{% if sort == 'p.product_id' %} class="{{ order|lower }}"{% endif %}>ID / Image</a></td>
        <td class="text-start"><a href="{{ sort_name }}"{% if sort == 'pd.name' %} class="{{ order|lower }}"{% endif %}>{{ column_product }}</a></td>
        <td class="text-center"><a href="{{ sort_quantity }}"{% if sort == 'p.quantity' %} class="{{ order|lower }}"{% endif %}>Quantity</a></td>
        <td class="text-center"><a href="{{ sort_modified }}"{% if sort == 'p.date_modified' %} class="{{ order|lower }}"{% endif %}>{{ column_modified }}</a></td>
        <td class="text-center"><a href="{{ sort_missing }}"{% if sort == 'missing_fields' %} class="{{ order|lower }}"{% endif %}>{{ column_missing }}</a></td>
        <td class="text-end">{{ column_action }}</td>
      </tr>
    </thead>
    <tbody>
      {% if products %}
        {% for product in products %}
          <tr>
            <td class="text-center">
              <input type="checkbox" name="product_id[]" value="{{ product.product_id }}" />
            </td>
            <td class="text-center">{{ product.product_id }}<br>
              <div class="actual-image-container" style="border: 2px dashed #ccc; padding: 0px; text-align: center; position: relative; cursor: pointer;" id="drop-{{ product.product_id }}">
                {% if product.image %}
                  <img src="{{ product.image }}" alt="{{ product.name }}" class="img-thumbnail preview-{{ product.product_id }}" />
                  <div class="fullsize-actual-image-wrapper">
                    <img src="{{ constant('HTTP_CATALOG') }}image/{{ product.fullsize_image }}" alt="{{ product.name }}" class="fullsize-actual-image" data-resolution="">
                    <div class="fullsize-resolution-overlay"></div>
                  </div>
                {% else %}
                  <span class="img-thumbnail list"><i class="fa-solid fa-camera fa-2x"></i></span>
                {% endif %}
              </div>
            </td>
            <td class="text-start">
              <strong>{{ product.name }}</strong>
            </td>
            <td class="text-center">
              {% if product.quantity <= 0 %}
                <span class="badge bg-warning">{{ product.quantity }}</span>
              {% elseif product.quantity <= 5 %}
                <span class="badge bg-danger">{{ product.quantity }}</span>
              {% else %}
                <span class="badge bg-success">{{ product.quantity }}</span>
              {% endif %}
            </td>
            <td class="text-center">
              <span class="badge bg-{{ product.date_modified < 'now'|date_modify('-6 months')|date('Y-m-d') ? 'danger' : 'warning' }}">
                {{ product.date_modified }}
              </span>
            </td>
            <td class="text-center">
              {% if product.missing_fields > 0 %}
                <span class="badge bg-danger">
                  {{ product.missing_fields }} missing
                  {% if not product.has_included_accessories %}
                    <i class="fa-solid fa-box" title="Included Accessories"></i>
                  {% endif %}
                  {% if not product.has_condition_supp %}
                    <i class="fa-solid fa-exclamation-triangle" title="Condition Supp"></i>
                  {% endif %}
                  {% if not product.has_description_supp %}
                    <i class="fa-solid fa-file-text" title="Description Supp"></i>
                  {% endif %}
                </span>
              {% else %}
                <span class="badge bg-success">Complete</span>
              {% endif %}
            </td>
            <td class="text-end">
              <div class="btn-group">
                <button type="button" onclick="aiSuggestDescriptionSupp('{{ product.product_id }}');" data-bs-toggle="tooltip" class="btn btn-primary btn-sm" title="{{ button_ai_suggest }}">
                  <i class="fa-solid fa-robot"></i><i class="fa-solid fa-question"></i>
                </button>
                <a href="{{ product.edit }}" data-bs-toggle="tooltip" title="{{ button_edit }}" class="btn btn-info btn-sm">
                  <i class="fa-solid fa-pencil"></i>
                </a>
              </div>
            </td>
          </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td class="text-center" colspan="7">{{ text_no_results }}</td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>
<div class="row">
  <div class="col-sm-6 text-start">{{ pagination }}</div>
  <div class="col-sm-6 text-end">{{ results }}</div>
</div>
