};
function refresh_account(marketplace_account_id) {
 //showAlertPopup('test' + marketplace_account_id);
  document.getElementById('refresh_account_id').value=marketplace_account_id;

   // showAlertPopup($result + marketplace_account_id);
    document.getElementById('refresh_account_id').value="";

};
function delete_account(marketplace_account_id) {
 //showAlertPopup('test' + marketplace_account_id);
  document.getElementById('delete_account_id').value=marketplace_account_id;
  $result=confirm('{{ text_confirm }}') ? $('#form-marketplace-account').submit() : false;
  if ($result == false){
   // showAlertPopup($result + marketplace_account_id);
    document.getElementById('delete_account_id').value="";
  }
};


</script>