{{ header }}{{ column_left }}

<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-ocrForm" data-toggle="tooltip" title="{{ button_submit }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-ocrForm" class="form-horizontal">
          <input type="hidden" name="user_token" value="{{ user_token }}" />

          <div class="form-group">
            <label class="col-sm-3 control-label">{{ text_image_upload }}</label>
            <div class="col-sm-7" id="drop" style="border:2px dashed #ccc;padding:20px;text-align:center;">
              <input type="hidden" name="image" value="{{ image }}" id="input-image" />
              <p>{{ text_drag_drop }}</p>
              <input type="file" id="fileElem" name="fileElem" accept="image/*" style="display:none;" />
            </div>
          </div>

            <div class="form-group">
              <label class="col-sm-3 control-label">{{ text_recognized_text }}</label>
              <div class="col-sm-7">
                <textarea id="recognizedText" name="recognizedText" class="form-control" rows="5" readonly></textarea>
              </div>
            </div>

          <div class="form-group">
            <label class="col-sm-3 control-label" for="input-name">{{ entry_name }}</label>
            <div class="col-sm-7">
              <input type="text"
                     maxlength="80"
                     name="product_name"
                     value=""
                     placeholder="{{ entry_name }}"
                     id="input-name"
                     class="form-control"
                     onchange="aiSuggestDescriptionSupp('ocrForm');"
                     oninput="updateCharacterCount('')" />
              <div id="char-count" class="text-right char-count" style="font-weight:bold;margin-top:5px;">
                <label id="ai-result-name-count" style="display:none;"></label>
              </div>
            </div>
            <div class="col-sm-2">
              <button id="ai-suggest-entry-name-btn"
                      type="button"
                      onclick="suggestEntryName('ocrForm');"
                      data-toggle="tooltip"
                      title="{{ button_ai_suggest_entry_name }}"
                      class="btn btn-primary">
                <i class="fa-solid fa-robot"></i><i class="fa-solid fa-question"></i>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label" for="input-description-supp">{{ entry_description_supp }}</label>
            <div class="col-sm-7">
              <textarea name="product_description_supp"
                        placeholder="{{ entry_description_supp }}"
                        id="input-description-supp"
                        class="form-control summernote"></textarea>
            </div>
            <div class="col-sm-2">
              <button id="ai-suggest-description-supp-btn"
                      type="button"
                      onclick="aiSuggestDescriptionSupp('ocrForm');"
                      data-toggle="tooltip"
                      title="{{ button_ai_description_supp }}"
                      class="btn btn-primary">
                <i class="fa-solid fa-robot"></i><i class="fa-solid fa-question"></i>
              </button>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript" src="view/javascript/summernote/summernote.js"></script>
<link href="view/javascript/summernote/summernote.css" rel="stylesheet" />
<script type="text/javascript" src="view/javascript/summernote/opencart.js"></script>

{{ footer }}

