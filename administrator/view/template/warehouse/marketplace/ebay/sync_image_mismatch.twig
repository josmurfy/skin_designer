  // ─── Render OC images section ─────────────────────────────────────────────
  function renderOcSection(ocImages, productId) {
    if (!ocImages || !ocImages.length) {
      return '<div class="alert alert-warning py-2 mb-0"><i class="fa-solid fa-triangle-exclamation me-1"></i>Aucune image dans OpenCart pour ce produit.</div>';
    }
    // Bulk toolbar OC
    var toolbar = '<div class="d-flex flex-wrap align-items-center gap-2 mb-2 px-2 py-1 rounded" style="background:#f0f4ff;">';
    toolbar += '<input type="checkbox" id="oc-bulk-select-all" class="form-check-input" style="width:17px;height:17px;cursor:pointer;accent-color:#dc3545;">';
    toolbar += '<label for="oc-bulk-select-all" class="form-check-label small fw-bold mb-0">Tout</label>';
    toolbar += '<span class="badge bg-secondary" id="oc-bulk-count">0 s\u00e9l.</span>';
    toolbar += '<div class="ms-auto">';
    toolbar += '<button type="button" class="btn btn-sm btn-danger btn-bulk-remove-oc" disabled style="font-size:11px;"><i class="fa-solid fa-trash me-1"></i>Retirer s\u00e9lection OC</button>';
    toolbar += '</div></div>';
    var html = toolbar + '<div class="row g-2">';
    $.each(ocImages, function(i, img) {
      var qual  = resQuality(img.width, img.height);
      var dim   = dimLabel(img.width, img.height);
      var isPri = img.role === 'primary';
      html += '<div class="col-6 col-md-3 col-lg-2">';
      html += '<div class="card h-100 position-relative oc-selectable-card" style="border:3px solid var(--bs-' + qual + ');cursor:pointer;">';
      html += '<input type="checkbox" class="oc-bulk-check"'
            + ' data-image="' + encodeURIComponent(img.image) + '"'
            + ' data-role="' + img.role + '"'
            + ' onclick="event.stopPropagation();"'
            + ' style="position:absolute;top:6px;left:6px;z-index:10;width:18px;height:18px;cursor:pointer;accent-color:#dc3545;">';
      html += '<div class="position-relative" style="height:130px;background:#f5f5f5;overflow:hidden;">';
      html += '<img src="' + img.url + '" style="width:100%;height:100%;object-fit:contain;" loading="lazy" onerror="this.style.opacity=0.15;">';
      html += '<span class="position-absolute top-0 start-0 m-1 badge ' + (isPri ? 'bg-danger' : 'bg-secondary') + '" style="font-size:9px;">' + (isPri ? '&#11088; Principal' : 'Secondaire') + '</span>';
      html += '<span class="position-absolute bottom-0 end-0 m-1 badge bg-' + qual + '" style="font-size:9px;">' + dim + '</span>';
      html += '</div>';
      html += '<div class="card-body p-1 d-flex flex-column gap-1">';
      if (!isPri) {
        html += '<button type="button" class="btn btn-sm btn-outline-warning w-100 btn-popup-set-primary"'
              + ' data-product-id="' + productId + '" data-image="' + encodeURIComponent(img.image) + '"'
              + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-star me-1"></i>&#8594; Principal</button>';
      } else {
        html += '<button type="button" class="btn btn-sm btn-outline-secondary w-100" disabled'
              + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-star me-1"></i>Principal &#10003;</button>';
      }
      html += '<button type="button" class="btn btn-sm btn-outline-danger w-100 btn-popup-remove-oc"'
            + ' data-product-id="' + productId + '" data-image="' + encodeURIComponent(img.image) + '" data-role="' + img.role + '"'
            + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-trash me-1"></i>Retirer OC</button>';
      html += '<button type="button" class="btn btn-sm btn-outline-secondary w-100 btn-popup-rotate"'
            + ' data-source="oc" data-product-id="' + productId + '" data-image="' + encodeURIComponent(img.image) + '"'
            + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-rotate-right me-1"></i>Rotation 90°</button>';
      html += '</div></div></div>';
    });
    return html + '</div>';
  }

  // ─── Render Backup images section ─────────────────────────────────────────
  function renderBackupSection(backupImages, productId) {
    if (!backupImages || !backupImages.length) {
      return '<div class="alert alert-info py-2 mb-0"><i class="fa-solid fa-folder-open me-1"></i>Aucune image backup pour ce produit.</div>';
    }
    // Bulk toolbar
    var html = '<div class="d-flex flex-wrap align-items-center gap-2 mb-2 px-2 py-1 rounded" style="background:#f8f9fa;">';
    html += '<input type="checkbox" id="backup-bulk-select-all" class="form-check-input" style="width:17px;height:17px;cursor:pointer;accent-color:#0d6efd;">';
    html += '<label for="backup-bulk-select-all" class="form-check-label small fw-bold mb-0">Tout</label>';
    html += '<span class="badge bg-secondary" id="backup-bulk-count">0 s\u00e9l.</span>';
    html += '<span class="small text-muted"><i class="fa-solid fa-hand-pointer me-1" style="font-size:10px;"></i>Glisser vers OC</span>';
    html += '<div class="ms-auto d-flex gap-1">';
    html += '<button type="button" class="btn btn-sm btn-outline-danger btn-bulk-xfer-backup" data-role="primary" disabled style="font-size:11px;"><i class="fa-solid fa-star me-1"></i>&#8594; Principal</button>';
    html += '<button type="button" class="btn btn-sm btn-outline-primary btn-bulk-xfer-backup" data-role="secondary" disabled style="font-size:11px;"><i class="fa-solid fa-images me-1"></i>&#8594; Sec.</button>';
    html += '<button type="button" class="btn btn-sm btn-danger btn-bulk-delete-backup" disabled style="font-size:11px;"><i class="fa-solid fa-trash me-1"></i>Suppr.</button>';
    html += '</div></div>';
    html += '<div class="row g-2">';
    $.each(backupImages, function(i, f) {
      var qual  = resQuality(f.width, f.height);
      var dim   = dimLabel(f.width, f.height);
      var inOC  = f.oc_exists;
      html += '<div class="col-6 col-md-3 col-lg-2">';
      html += '<div class="card h-100 position-relative backup-selectable-card" draggable="true"'
            + ' data-drag-filename="' + escAttr(f.filename) + '"'
            + ' data-drag-product-id="' + productId + '"'
            + ' style="border:3px solid var(--bs-' + qual + ');cursor:pointer;">';
      html += '<input type="checkbox" class="backup-bulk-check"'
            + ' data-filename="' + escAttr(f.filename) + '"'
            + ' data-type="' + escAttr(f.type) + '"'
            + ' onclick="event.stopPropagation();"'
            + ' style="position:absolute;top:6px;left:6px;z-index:10;width:18px;height:18px;cursor:pointer;accent-color:#0d6efd;">';
      html += '<div class="position-relative" style="height:130px;background:#f5f5f5;overflow:hidden;">';
      html += '<img src="' + f.url + '" style="width:100%;height:100%;object-fit:contain;" loading="lazy" onerror="this.style.opacity=0.15;">';
      if (inOC) {
        html += '<div class="position-absolute top-0 start-0 w-100 text-center" style="background:rgba(25,135,84,0.85);padding:2px 0;">';
        html += '<small style="color:#fff;font-size:10px;"><i class="fa-solid fa-check me-1"></i>D&#233;j&#224; dans OC</small>';
        html += '</div>';
      }
      var typeBadge = (f.type === 'primary') ? 'bg-danger' : 'bg-secondary';
      html += '<span class="position-absolute bottom-0 start-0 m-1 badge ' + typeBadge + '" style="font-size:9px;">' + (f.type === 'primary' ? '&#11088;' : 'Sec.') + '</span>';
      html += '<span class="position-absolute bottom-0 end-0 m-1 badge bg-' + qual + '" style="font-size:9px;">' + dim + '</span>';
      html += '</div>';
      html += '<div class="card-body p-1 d-flex flex-column gap-1">';
      if (!inOC) {
        html += '<button type="button" class="btn btn-sm btn-outline-danger w-100 btn-popup-xfer-pri"'
              + ' data-product-id="' + productId + '" data-filename="' + escAttr(f.filename) + '"'
              + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-star me-1"></i>&#8594; Principal</button>';
        html += '<button type="button" class="btn btn-sm btn-outline-primary w-100 btn-popup-xfer-sec"'
              + ' data-product-id="' + productId + '" data-filename="' + escAttr(f.filename) + '"'
              + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-plus me-1"></i>&#8594; Secondaire</button>';
      }
      html += '<button type="button" class="btn btn-sm btn-outline-danger w-100 btn-popup-del-backup"'
            + ' data-product-id="' + productId + '" data-filename="' + escAttr(f.filename) + '"'
            + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-trash me-1"></i>Suppr. backup</button>';
      html += '<button type="button" class="btn btn-sm btn-outline-secondary w-100 btn-popup-rotate"'
            + ' data-source="backup" data-product-id="' + productId + '" data-filename="' + escAttr(f.filename) + '"'
            + ' style="font-size:10px;padding:2px 4px;"><i class="fa-solid fa-rotate-right me-1"></i>Rotation 90°</button>';
      html += '</div></div></div>';
    });
    return html + '</div>';
  }

  // ─── Load/Reload popup content ────────────────────────────────────────────
  function reloadPopup(productId) {
    $('#backup-modal-body').html('<div class="text-center p-4"><i class="fa-solid fa-spinner fa-spin fa-2x text-muted"></i></div>');
    $.ajax({
      url: URL_IMAGES_FULL, type: 'GET', dataType: 'json',
      data: { product_id: productId },
      success: function(json) {
        if (json.error) { $('#backup-modal-body').html('<div class="alert alert-danger">' + json.error + '</div>'); return; }
        var ocCnt  = (json.oc_images     || []).length;
        var bckCnt = (json.backup_images || []).length;
        currentPopupBackupCount = bckCnt;
        var html = '<h6 class="fw-bold mb-2 text-primary"><i class="fa-brands fa-opencart me-1"></i>Images OpenCart <span class="badge bg-primary">' + ocCnt + '</span></h6>';
        html += renderOcSection(json.oc_images, productId);
        html += '<hr class="my-3">';
        html += '<h6 class="fw-bold mb-2 text-warning"><i class="fa-solid fa-folder-open me-1"></i>Images Backup <span class="badge bg-warning text-dark">' + bckCnt + '</span></h6>';
        html += renderBackupSection(json.backup_images, productId);
        $('#backup-modal-body').html(html);
      },
      error: function(xhr) {
        console.error('getProductImagesFull:', xhr.status, xhr.responseText);
        $('#backup-modal-body').html('<div class="alert alert-danger">Erreur AJAX (' + xhr.status + ')</div>');
      }
    });
  }

  // ─── Modal close: sync badge in table ─────────────────────────────────────
  document.getElementById('backup-images-modal').addEventListener('hidden.bs.modal', function() {
    var pid     = currentBackupProductId;
    var section = currentPopupSection;
    if (pid && section === 'resolution') {
      $('#resolution-row-' + pid).remove();
    }
    if (pid && currentPopupBackupCount !== null) {
      var count  = currentPopupBackupCount;
      var $badge = $('#backup-count-' + pid);
      if ($badge.length) {
        $badge.text(count);
        if (count === 0) {
          $('#backup-row-' + pid).css('opacity', '0.4').find('button').prop('disabled', true);
        } else {
          $('#backup-row-' + pid).css('opacity', '');
        }
      }
    }
    currentPopupBackupCount = null;
    currentPopupSection     = null;
    if (popupOcModified) {
      popupOcModified = false;
      loadImageMismatchTab({{ image_mismatch_page }}, '{{ image_mismatch_sort }}', '{{ image_mismatch_order }}',
                           {{ backup_mismatch_page }}, '{{ backup_mismatch_sort }}', '{{ backup_mismatch_order }}');
    }
  });

  // ─── Open Backup Popup ────────────────────────────────────────────────────
  $(document).off('click.openBackupPopup', '.btn-open-backup-popup')
             .on('click.openBackupPopup', '.btn-open-backup-popup', function() {
    var productId   = $(this).data('product-id');
    var productName = $(this).data('product-name');
    var section     = $(this).data('section') || null;
    currentBackupProductId = productId;
    currentPopupSection    = section;
    $('#backup-modal-title-text').text(productName + ' (#' + productId + ')');
    var $modal = new bootstrap.Modal(document.getElementById('backup-images-modal'));
    $modal.show();
    if (section === 'resolution') {
      $.post(URL_RESET_SCAN, { product_id: productId });
    }
    reloadPopup(productId);
  });

  // ─── Set OC image as Primary ──────────────────────────────────────────────
  $(document).off('click.setPrimary', '.btn-popup-set-primary')
             .on('click.setPrimary', '.btn-popup-set-primary', function() {
    var $btn = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var pid  = $(this).data('product-id');
    var img  = decodeURIComponent($(this).data('image'));
    $.ajax({
      url: URL_SET_PRIMARY, type: 'POST', dataType: 'json',
      data: { product_id: pid, image_path: img },
      success: function(json) {
        if (json.error) { alert(json.error); $btn.prop('disabled', false).html('<i class="fa-solid fa-star me-1"></i>&#8594; Principal'); return; }
        reloadPopup(pid);
      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); $btn.prop('disabled', false).html('<i class="fa-solid fa-star me-1"></i>&#8594; Principal'); }
    });
  });

  // ─── Remove OC image ──────────────────────────────────────────────────────
  $(document).off('click.removeOc', '.btn-popup-remove-oc')
             .on('click.removeOc', '.btn-popup-remove-oc', function() {
    if (!confirm('Confirmer la suppression de cette image de OpenCart ?')) return;
    var $btn = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var pid  = $(this).data('product-id');
    var img  = decodeURIComponent($(this).data('image'));
    var role = $(this).data('role');
    $.ajax({
      url: URL_REMOVE_OC, type: 'POST', dataType: 'json',
      data: { product_id: pid, image_path: img, role: role },
      success: function(json) {
        if (json.error) { alert(json.error); $btn.prop('disabled', false).html('<i class="fa-solid fa-trash me-1"></i>Retirer OC'); return; }
        reloadPopup(pid);

      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); $btn.prop('disabled', false).html('<i class="fa-solid fa-trash me-1"></i>Retirer OC'); }
    });
  });

  // ─── Transfer Backup → Principal ─────────────────────────────────────────
  $(document).off('click.xferPri', '.btn-popup-xfer-pri')
             .on('click.xferPri', '.btn-popup-xfer-pri', function() {
    var $btn = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var pid  = $(this).data('product-id');
    var fn   = $(this).data('filename');
    $.ajax({
      url: URL_XFER_ROLE, type: 'POST', dataType: 'json',
      data: { product_id: pid, filename: fn, role: 'primary' },
      success: function(json) {
        if (json.error) { alert(json.error); $btn.prop('disabled', false).html('<i class="fa-solid fa-star me-1"></i>&#8594; Principal'); return; }
        reloadPopup(pid);
      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); $btn.prop('disabled', false).html('<i class="fa-solid fa-star me-1"></i>&#8594; Principal'); }
    });
  });

  // ─── Transfer Backup → Secondaire ────────────────────────────────────────
  $(document).off('click.xferSec', '.btn-popup-xfer-sec')
             .on('click.xferSec', '.btn-popup-xfer-sec', function() {
    var $btn = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var pid  = $(this).data('product-id');
    var fn   = $(this).data('filename');
    $.ajax({
      url: URL_XFER_ROLE, type: 'POST', dataType: 'json',
      data: { product_id: pid, filename: fn, role: 'secondary' },
      success: function(json) {
        if (json.error) { alert(json.error); $btn.prop('disabled', false).html('<i class="fa-solid fa-plus me-1"></i>&#8594; Secondaire'); return; }
        reloadPopup(pid);
      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); $btn.prop('disabled', false).html('<i class="fa-solid fa-plus me-1"></i>&#8594; Secondaire'); }
    });
  });

  // ─── Supprimer du Backup ──────────────────────────────────────────────────
  $(document).off('click.delBackup', '.btn-popup-del-backup')
             .on('click.delBackup', '.btn-popup-del-backup', function() {
    if (!confirm('Supprimer d\u00e9finitivement cette image du backup ?')) return;
    var $btn = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var pid  = $(this).data('product-id');
    var fn   = $(this).data('filename');
    $.ajax({
      url: URL_DEL_BACKUP, type: 'POST', dataType: 'json',
      data: { product_id: pid, 'filenames[]': [fn] },
      success: function(json) {
        if (json.error) { alert(json.error); $btn.prop('disabled', false).html('<i class="fa-solid fa-trash me-1"></i>Suppr. backup'); return; }
        reloadPopup(pid);
      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); $btn.prop('disabled', false).html('<i class="fa-solid fa-trash me-1"></i>Suppr. backup'); }
    });
  });

  // ─── OC images bulk helpers ───────────────────────────────────────────────
  function updateOcBulkBtn() {
    var n = $('.oc-bulk-check:checked').length;
    $('.btn-bulk-remove-oc').prop('disabled', n === 0);
    $('#oc-bulk-count').text(n + ' s\u00e9l.');
  }

  $(document).off('change.ocSelectAll', '#oc-bulk-select-all')
             .on('change.ocSelectAll', '#oc-bulk-select-all', function() {
    var isChecked = $(this).is(':checked');
    $('.oc-bulk-check').prop('checked', isChecked)
      .closest('.card').toggleClass('oc-card-selected', isChecked);
    updateOcBulkBtn();
  });

  $(document).off('change.ocBulkCheck', '.oc-bulk-check')
             .on('change.ocBulkCheck', '.oc-bulk-check', function() {
    $(this).closest('.card').toggleClass('oc-card-selected', $(this).is(':checked'));
    var total   = $('.oc-bulk-check').length;
    var checked = $('.oc-bulk-check:checked').length;
    $('#oc-bulk-select-all').prop('indeterminate', checked > 0 && checked < total)
                            .prop('checked', checked === total && total > 0);
    updateOcBulkBtn();
  });

  $(document).off('click.ocCardSelect', '.oc-selectable-card')
             .on('click.ocCardSelect', '.oc-selectable-card', function(e) {
    if ($(e.target).closest('button, a, input').length) return;
    var $cb = $(this).find('.oc-bulk-check');
    $cb.prop('checked', !$cb.prop('checked')).trigger('change');
  });

  $(document).off('click.bulkRemoveOc', '.btn-bulk-remove-oc')
             .on('click.bulkRemoveOc', '.btn-bulk-remove-oc', function() {
    var items = [];
    $('.oc-bulk-check:checked').each(function() {
      items.push({ image: decodeURIComponent($(this).data('image')), role: $(this).data('role') });
    });
    if (!items.length) return;
    if (!confirm('Retirer ' + items.length + ' image(s) d\u2019OpenCart ?')) return;
    var pid  = currentBackupProductId;
    var done = 0, errors = [];
    $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i>En cours\u2026');
    function next() {
      if (done >= items.length) {
        if (errors.length) alert('Erreurs : ' + errors.join(', '));
        reloadPopup(pid);
       

        return;
      }
      var item = items[done++];
      $.ajax({
        url: URL_REMOVE_OC, type: 'POST', dataType: 'json',
        data: { product_id: pid, image_path: item.image, role: item.role },
        success: function(json) { if (json.error) errors.push(item.image + ': ' + json.error); next(); },
        error: function(xhr) { errors.push(item.image + ' (HTTP ' + xhr.status + ')'); next(); }
      });
    }
    next();
  });

  // ─── Bulk delete helpers ──────────────────────────────────────────────────
  function updateBulkDeleteBtn() {
    var $checked = $('.backup-bulk-check:checked');
    var n = $checked.length;
    $('.btn-bulk-delete-backup, .btn-bulk-xfer-backup').prop('disabled', n === 0);
    $('#backup-bulk-count').text(n + ' s\u00e9l.');
  }

  $(document).off('change.bulkSelectAll', '#backup-bulk-select-all')
             .on('change.bulkSelectAll', '#backup-bulk-select-all', function() {
    var isChecked = $(this).is(':checked');
    $('.backup-bulk-check').prop('checked', isChecked)
      .closest('.card').toggleClass('backup-card-selected', isChecked);
    updateBulkDeleteBtn();
  });

  $(document).off('change.bulkCheck', '.backup-bulk-check')
             .on('change.bulkCheck', '.backup-bulk-check', function() {
    $(this).closest('.card').toggleClass('backup-card-selected', $(this).is(':checked'));
    var total   = $('.backup-bulk-check').length;
    var checked = $('.backup-bulk-check:checked').length;
    $('#backup-bulk-select-all').prop('indeterminate', checked > 0 && checked < total)
                                .prop('checked', checked === total && total > 0);
    updateBulkDeleteBtn();
  });

  // Clic sur la carte = toggle sélection (sauf si clic sur un bouton/lien/drag)
  $(document).off('click.backupCardSelect', '.backup-selectable-card')
             .on('click.backupCardSelect', '.backup-selectable-card', function(e) {
    if ($(e.target).closest('button, a, input').length) return;
    var $cb = $(this).find('.backup-bulk-check');
    $cb.prop('checked', !$cb.prop('checked')).trigger('change');
  });

  $(document).off('click.bulkXfer', '.btn-bulk-xfer-backup')
             .on('click.bulkXfer', '.btn-bulk-xfer-backup', function() {
    var baseRole    = $(this).data('role');
    var $checked    = $('.backup-bulk-check:checked');
    var totalImgs   = $('.backup-bulk-check').length;
    var allSelected = ($checked.length === totalImgs && totalImgs > 0);
    var filenames = [], types = [];
    $checked.each(function() {
      filenames.push($(this).data('filename'));
      types.push($(this).data('type') || 'secondary');
    });
    if (!filenames.length) return;
    var useOriginalRoles = false;
    if (allSelected) {
      useOriginalRoles = true;
    } else {
      var label = baseRole === 'primary' ? 'principal (1\u00e8re) + secondaires (reste)' : 'secondaire';
      
    }
    var pid = currentBackupProductId;
    $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i>En cours\u2026');
    var done = 0, errors = [];
    function next() {
      if (done >= filenames.length) {
        if (errors.length) alert('Erreurs : ' + errors.join(', '));
        reloadPopup(pid); return;
      }
      var fn   = filenames[done];
      var role = useOriginalRoles ? types[done] : ((baseRole === 'primary' && done > 0) ? 'secondary' : baseRole);
      done++;
      $.ajax({
        url: URL_XFER_ROLE, type: 'POST', dataType: 'json',
        data: { product_id: pid, filename: fn, role: role },
        success: function(json) { if (json.error) errors.push(fn + ': ' + json.error); next(); },
        error: function(xhr) { errors.push(fn + ' (HTTP ' + xhr.status + ')'); next(); }
      });
    }
    next();
  });

  $(document).off('click.bulkDelete', '.btn-bulk-delete-backup')
             .on('click.bulkDelete', '.btn-bulk-delete-backup', function() {
    var filenames = [];
    $('.backup-bulk-check:checked').each(function() { filenames.push($(this).data('filename')); });
    if (!filenames.length) return;
    if (!confirm('Supprimer ' + filenames.length + ' image(s) du backup ?')) return;
    var pid = currentBackupProductId;
    $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i>Suppression\u2026');
    $.ajax({
      url: URL_DEL_BACKUP, type: 'POST', dataType: 'json',
      data: { product_id: pid, 'filenames[]': filenames },
      success: function(json) { if (json.error) { alert(json.error); } reloadPopup(pid); },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); reloadPopup(pid); }
    });
  });

  // ─── Drag & Drop: backup → OC drop zones ─────────────────────────────────
  $(document).off('dragstart.backupDrag').on('dragstart.backupDrag', '[data-drag-filename]', function(e) {
    var payload = JSON.stringify({ filename: $(this).data('drag-filename'), product_id: $(this).data('drag-product-id') });
    e.originalEvent.dataTransfer.setData('text/plain', payload);
    e.originalEvent.dataTransfer.effectAllowed = 'move';
    $(this).addClass('opacity-50');
  });

  $(document).off('dragend.backupDrag').on('dragend.backupDrag', '[data-drag-filename]', function() {
    $(this).removeClass('opacity-50');
  });

  $(document).off('dragover.dropZone').on('dragover.dropZone', '.backup-drop-zone', function(e) {
    e.preventDefault();
    e.originalEvent.dataTransfer.dropEffect = 'move';
    $(this).css('background', $(this).data('role') === 'primary' ? '#ffd0d0' : '#d0d4ff');
  });

  $(document).off('dragleave.dropZone').on('dragleave.dropZone', '.backup-drop-zone', function() {
    $(this).css('background', $(this).data('role') === 'primary' ? '#fff8f8' : '#f8f8ff');
  });

  $(document).off('drop.dropZone').on('drop.dropZone', '.backup-drop-zone', function(e) {
    e.preventDefault();
    var role = $(this).data('role');
    var pid  = $(this).data('product-id');
    $(this).css('background', role === 'primary' ? '#fff8f8' : '#f8f8ff');
    var data;
    try { data = JSON.parse(e.originalEvent.dataTransfer.getData('text/plain')); } catch(ex) { return; }
    if (!data || !data.filename) return;
    var $zone = $(this);
    $zone.html('<i class="fa-solid fa-spinner fa-spin text-muted"></i>');
    $.ajax({
      url: URL_XFER_ROLE, type: 'POST', dataType: 'json',
      data: { product_id: pid, filename: data.filename, role: role },
      success: function(json) {
        if (json.error) { alert(json.error); }
        reloadPopup(pid);
      },
      error: function(xhr) { alert('Erreur AJAX: ' + xhr.status); reloadPopup(pid); }
    });
  });

  // ─── Rotate image 90° CW ─────────────────────────────────────────────────
  $(document).off('click.rotateImg', '.btn-popup-rotate')
             .on('click.rotateImg', '.btn-popup-rotate', function() {
    var $btn    = $(this).prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
    var source  = $(this).data('source');
    var pid     = $(this).data('product-id');
    var postData = { source: source, product_id: pid, degrees: 90 };
    if (source === 'oc') {
      postData.image_path = decodeURIComponent($(this).data('image'));
    } else {
      postData.filename = $(this).data('filename');
    }
    $.ajax({
      url: URL_ROTATE, type: 'POST', dataType: 'json',
      data: postData,
      success: function(json) {
        if (json.error) {
          alert('Erreur rotation: ' + json.error);
          $btn.prop('disabled', false).html('<i class="fa-solid fa-rotate-right me-1"></i>Rotation 90°');
          return;
        }
        if (source === 'oc') { popupOcModified = true; }
        reloadPopup(pid);
      },
      error: function(xhr) {
        alert('Erreur AJAX: ' + xhr.status);
        $btn.prop('disabled', false).html('<i class="fa-solid fa-rotate-right me-1"></i>Rotation 90°');
      }
    });
  });

})();
</script>

