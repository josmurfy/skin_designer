{# Original: shopmanager/inventory/sync_category_mismatch.twig #}
{# Category Mismatch Tab with Pagination and Ordering #}
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    {{ text_mismatch_found|replace({'%s': '<strong>' ~ category_mismatch_total ~ '</strong> ' ~ text_category|lower})|raw }}
  </div>
  <div class="btn-group">
    <button class="btn btn-sm btn-info sync-selected-to-ebay" type="button" disabled>
      <i class="fa-solid fa-cloud-arrow-up"></i> {{ text_sync_to_ebay }}
    </button>
    <button class="btn btn-sm btn-info sync-selected-from-ebay" type="button" disabled>
      <i class="fa-solid fa-cloud-arrow-down"></i> {{ text_sync_from_ebay }}
    </button>
  </div>
</div>

{% if category_mismatch|length > 0 %}
  <div class="table-responsive" style="overflow-x: auto; max-width: 100%;">
    <table class="table table-bordered table-hover" style="white-space: nowrap; font-size: 11px;">
      <thead>
        <tr>
          <th style="width: 40px;">
            <input type="checkbox" id="select-all-category" />
          </th>
          <th style="width: 80px;">
            <a href="#" class="sort-category-mismatch" data-sort="product_id" data-order="{{ category_mismatch_sort == 'product_id' and category_mismatch_order == 'ASC' ? 'DESC' : 'ASC' }}">
              {{ column_product_id }}
              {% if category_mismatch_sort == 'product_id' %}
                <i class="fa-solid fa-sort-{{ category_mismatch_order == 'ASC' ? 'up' : 'down' }}"></i>
              {% endif %}
            </a>
          </th>
          <th style="max-width: 200px;">
            <a href="#" class="sort-category-mismatch" data-sort="name" data-order="{{ category_mismatch_sort == 'name' and category_mismatch_order == 'ASC' ? 'DESC' : 'ASC' }}">
              {{ column_product }}
              {% if category_mismatch_sort == 'name' %}
                <i class="fa-solid fa-sort-{{ category_mismatch_order == 'ASC' ? 'up' : 'down' }}"></i>
              {% endif %}
            </a>
          </th>
          <th style="width: 120px;">{{ column_ebay_id }}</th>
          <th style="width: 200px;">{{ column_category }}</th>
          <th style="width: 100px;">{{ column_location }}</th>
          <th class="text-center" style="width: 100px;">{{ column_actions }}</th>
        </tr>
      </thead>
      <tbody>
        {% for product in category_mismatch %}
          <tr>
            <td class="text-center">
              <input type="checkbox" class="category-checkbox" data-product-id="{{ product.product_id }}" />
            </td>
            <td class="text-center">{{ product.product_id }}</td>
            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ product.name }}">{{ product.name }}</td>
            <td><a href="https://www.ebay.ca/itm/{{ product.marketplace_item_id }}" target="_blank" class="text-primary"><i class="fa-brands fa-ebay"></i> {{ product.marketplace_item_id }}</a></td>
            <td>
              {% set source_matches_local = product.source_category_id and product.source_category_id == product.local_category_id %}
              {% set source_matches_ebay  = product.source_category_id and product.source_category_id == product.ebay_category_id %}
              {# Outer card: red if no leaf, orange if values differ #}
              {% if product.leaf != 1 %}
                <div style="border: 2px solid #dc3545; padding: 8px; border-radius: 4px; background-color: #f8d7da;">
                  <div class="text-danger fw-bold mb-2" style="font-size: 11px;">
                    <i class="fa-solid fa-exclamation-triangle"></i> {{ text_no_leaf_category }}
                  </div>
              {% else %}
                <div style="border: 2px solid #ffc107; padding: 8px; border-radius: 4px; background-color: #fff3cd;">
                  <div class="text-warning fw-bold mb-2" style="font-size: 11px;">
                    <i class="fa-solid fa-exclamation-circle"></i> {{ text_category_values_differ }}
                  </div>
              {% endif %}
                  {# Local line — green border if source matches local #}
                  <small class="d-block" style="{% if source_matches_local %}border: 1px solid #198754; border-radius: 3px; background-color: #d1e7dd; padding: 1px 4px; font-weight: bold;{% endif %}">
                    {% if source_matches_local %}<i class="fa-solid fa-star text-success"></i> {% endif %}
                    {{ text_local }}: {{ product.local_category_id ?? 'N/A' }}{% if product.local_category_name %} - {{ product.local_category_name }}{% endif %}
                    {% if source_matches_local %}<span class="badge bg-success ms-1" style="font-size:9px;">{{ product.source_percent }}%</span>{% endif %}
                  </small>
                  {# eBay line — green border if source matches eBay #}
                  <small class="d-block mt-1" style="{% if source_matches_ebay %}border: 1px solid #198754; border-radius: 3px; background-color: #d1e7dd; padding: 1px 4px; font-weight: bold;{% endif %}">
                    {% if source_matches_ebay %}<i class="fa-solid fa-star text-success"></i> {% endif %}
                    {{ text_ebay }}: {{ product.ebay_category_id ?? 'N/A' }}{% if product.ebay_category_name %} - {{ product.ebay_category_name }}{% endif %}
                    {% if source_matches_ebay %}<span class="badge bg-success ms-1" style="font-size:9px;">{{ product.source_percent }}%</span>{% endif %}
                  </small>
                  {# Source exists but matches neither → show it as info #}
                  {% if product.source_category_id and not source_matches_local and not source_matches_ebay %}
                    <small class="d-block mt-1 text-success">
                      <i class="fa-solid fa-star"></i>
                      {{ product.source_category_id }}{% if product.source_category_name %} - {{ product.source_category_name }}{% endif %}
                      <span class="badge bg-success ms-1" style="font-size:9px;">{{ product.source_percent }}%</span>
                    </small>
                  {% endif %}
                </div>
              {# No source badge #}
              {% if not product.source_category_id %}
                <div style="margin-top: 4px;">
                  <span style="background-color: #dc3545; color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: bold;">
                    <i class="fa-solid fa-circle-xmark"></i> No source
                  </span>
                </div>
              {% endif %}
            </td>
            <td><span class="badge bg-secondary">{{ product.location }}</span></td>
            <td class="text-center">
              <div class="d-flex flex-column gap-1 align-items-center">
                {% if product.ebay_category_id %}
                <button class="btn btn-xs btn-outline-warning sync-category-btn"
                        data-product-id="{{ product.product_id }}"
                        data-direction="from_ebay"
                        title="eBay ({{ product.ebay_category_id }}) → OC">
                  <i class="fa-solid fa-cloud-arrow-down"></i>
                </button>
                {% endif %}
                {% if product.local_category_id %}
                <button class="btn btn-xs btn-outline-primary sync-category-btn"
                        data-product-id="{{ product.product_id }}"
                        data-direction="to_ebay"
                        title="OC ({{ product.local_category_id }}) → eBay">
                  <i class="fa-solid fa-cloud-arrow-up"></i>
                </button>
                {% endif %}
                {% if product.source_category_id %}
                <button class="btn btn-xs btn-outline-success sync-category-btn"
                        data-product-id="{{ product.product_id }}"
                        data-direction="from_source"
                        title="Source: {{ product.source_category_id }}{% if product.source_category_name %} - {{ product.source_category_name }}{% endif %} ({{ product.source_percent }}%) → OC">
                  <i class="fa-solid fa-star"></i> {{ product.source_percent }}%
                </button>
                {% endif %}
                <a href="index.php?route=shopmanager/catalog/product.form&product_id={{ product.product_id }}&user_token={{ user_token }}"
                   class="btn btn-xs btn-outline-secondary"
                   title="Edit product" target="_blank">
                  <i class="fa-solid fa-edit"></i>
                </a>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  
  {# Pagination #}
  {% if category_mismatch_pagination %}
    <div class="d-flex justify-content-between align-items-center mt-3">
      <div>
        Showing {{ category_mismatch_start }} to {{ category_mismatch_end }} of {{ category_mismatch_total }}
      </div>
      <nav>
        <ul class="pagination pagination-sm mb-0">
          {% for page_num in 1..category_mismatch_num_pages %}
            <li class="page-item {{ page_num == category_mismatch_page ? 'active' : '' }}">
              <a class="page-link page-category-mismatch" href="#" data-page="{{ page_num }}">{{ page_num }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  {% endif %}
{% else %}
  <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> {{ text_no_mismatch_found|replace({'%s': text_category|lower}) }}</div>
{% endif %}

<script>
$(document).ready(function() {
  // Select all checkbox
  $('#select-all-category').on('change', function() {
    $('.category-checkbox').prop('checked', $(this).prop('checked'));
    updateSyncButtons();
  });
  
  // Individual checkbox
  $('.category-checkbox').on('change', function() {
    updateSyncButtons();
    var allChecked = $('.category-checkbox:checked').length === $('.category-checkbox').length;
    $('#select-all-category').prop('checked', allChecked);
  });
  
  function updateSyncButtons() {
    var selectedCount = $('.category-checkbox:checked').length;
    $('.sync-selected-to-ebay, .sync-selected-from-ebay').prop('disabled', selectedCount === 0);
    if (selectedCount > 0) {
      $('.sync-selected-to-ebay').html('<i class="fa-solid fa-cloud-arrow-up"></i> {{ text_sync_to_ebay }} (' + selectedCount + ')');
      $('.sync-selected-from-ebay').html('<i class="fa-solid fa-cloud-arrow-down"></i> {{ text_sync_from_ebay }} (' + selectedCount + ')');
    } else {
      $('.sync-selected-to-ebay').html('<i class="fa-solid fa-cloud-arrow-up"></i> {{ text_sync_to_ebay }}');
      $('.sync-selected-from-ebay').html('<i class="fa-solid fa-cloud-arrow-down"></i> {{ text_sync_from_ebay }}');
    }
  }
  
  // Bulk sync to eBay
  $('.sync-selected-to-ebay').on('click', function() {
    var productIds = [];
    $('.category-checkbox:checked').each(function() {
      productIds.push($(this).data('product-id'));
    });
    
    if (productIds.length === 0) return;
    
    if (!confirm('Export ' + productIds.length + ' product(s) to eBay?')) return;
    
    bulkSyncCategory(productIds, 'to_ebay');
  });
  
  // Bulk sync from eBay
  $('.sync-selected-from-ebay').on('click', function() {
    var productIds = [];
    $('.category-checkbox:checked').each(function() {
      productIds.push($(this).data('product-id'));
    });
    
    if (productIds.length === 0) return;
    
    if (!confirm('Import ' + productIds.length + ' product(s) from eBay?')) return;
    
    bulkSyncCategory(productIds, 'from_ebay');
  });
  
  function bulkSyncCategory(productIds, direction) {
    var route = direction === 'to_ebay' ? 'syncCategoryBulkToEbay' : 'syncCategoryBulkFromEbay';
    var btn = direction === 'to_ebay' ? $('.sync-selected-to-ebay') : $('.sync-selected-from-ebay');
    
    console.log('=== BULK SYNC START ===');
    console.log('Direction:', direction);
    console.log('Route:', route);
    console.log('Product IDs:', productIds);
    console.log('URL:', 'index.php?route=shopmanager/inventory/sync.' + route + '&user_token={{ user_token }}');
    
    $.ajax({
      url: 'index.php?route=shopmanager/inventory/sync.' + route + '&user_token={{ user_token }}',
      type: 'POST',
      data: {product_ids: productIds},
      dataType: 'json',
      beforeSend: function() {
        console.log('Sending request...');
        btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Processing...');
      },
      success: function(json) {
        console.log('Response received:', json);
        btn.prop('disabled', false);
        if (json.success) {
          console.log('SUCCESS:', json.success);
          if (json.details) console.log('Details:', json.details);
          alert('Success: ' + json.success + (json.details ? '\n\nDetails:\n' + json.details : ''));
          loadCategoryMismatchTab({{ category_mismatch_page }}, '{{ category_mismatch_sort }}', '{{ category_mismatch_order }}');
        } else if (json.error) {
          console.error('ERROR:', json.error);
          if (json.details) console.error('Details:', json.details);
          alert('Error: ' + json.error + (json.details ? '\n\nDetails:\n' + json.details : ''));
          updateSyncButtons();
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        console.error('=== AJAX ERROR ===');
        console.error('Status:', xhr.status);
        console.error('Response:', xhr.responseText);
        console.error('Error:', thrownError);
        btn.prop('disabled', false);
        alert('Error: ' + thrownError + '\n\nCheck console for details');
        updateSyncButtons();
      }
    });
  }
  
  // Refresh category mismatch data
  $('.refresh-category-mismatch').on('click', function() {
    loadCategoryMismatchTab({{ category_mismatch_page }}, '{{ category_mismatch_sort }}', '{{ category_mismatch_order }}');
  });
  
  // Sorting
  $('.sort-category-mismatch').on('click', function(e) {
    e.preventDefault();
    var sort = $(this).data('sort');
    var order = $(this).data('order');
    loadCategoryMismatchTab(1, sort, order);
  });
  
  // Pagination
  $('.page-category-mismatch').on('click', function(e) {
    e.preventDefault();
    var page = $(this).data('page');
    loadCategoryMismatchTab(page, '{{ category_mismatch_sort }}', '{{ category_mismatch_order }}');
  });
  
  function loadCategoryMismatchTab(page, sort, order) {
    $.ajax({
      url: 'index.php?route=shopmanager/inventory/sync.getCategoryMismatchTab&user_token={{ user_token }}',
      type: 'GET',
      data: {
        page: page,
        sort: sort,
        order: order
      },
      dataType: 'html',
      beforeSend: function() {
        $('#category-mismatch').html('<div class="text-center p-5"><i class="fa-solid fa-spinner fa-spin fa-3x"></i></div>');
      },
      success: function(html) {
        $('#category-mismatch').html(html);
      },
      error: function(xhr, ajaxOptions, thrownError) {
        console.error(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });
  }
  
  // Sync category buttons (bidirectional + from source)
  $('.sync-category-btn').on('click', function() {
    var btn = $(this);
    var productId = btn.data('product-id');
    var direction = btn.data('direction');
    
    var routes = {
      'to_ebay':    'syncCategoryToEbay',
      'from_ebay':  'syncCategoryFromEbay',
      'from_source': 'syncCategoryFromInfoSource'
    };
    var msgs = {
      'to_ebay':    'Export local category to eBay?',
      'from_ebay':  'Import eBay category to local product?',
      'from_source': 'Apply best info_source category to local product?'
    };
    var icons = {
      'to_ebay':    'fa-cloud-arrow-up',
      'from_ebay':  'fa-cloud-arrow-down',
      'from_source': 'fa-star'
    };

    if (!confirm(msgs[direction] || 'Confirm?')) return;

    $.ajax({
      url: 'index.php?route=shopmanager/inventory/sync.' + routes[direction] + '&user_token={{ user_token }}',
      type: 'POST',
      data: {product_id: productId},
      dataType: 'json',
      beforeSend: function() {
        btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
      },
      success: function(json) {
        if (json.success) {
          btn.html('<i class="fa-solid fa-check"></i>');
          // Fade row + reload tab
          btn.closest('tr').fadeOut(300, function() { $(this).remove(); });
          loadCategoryMismatchTab({{ category_mismatch_page }}, '{{ category_mismatch_sort }}', '{{ category_mismatch_order }}');
        } else if (json.error) {
          btn.prop('disabled', false).html('<i class="fa-solid ' + (icons[direction] || 'fa-refresh') + '"></i>');
          alert('Error: ' + json.error);
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        btn.prop('disabled', false).html('<i class="fa-solid ' + (icons[direction] || 'fa-refresh') + '"></i>');
        alert('Error: ' + thrownError);
      }
    });
  });
});
</script>
