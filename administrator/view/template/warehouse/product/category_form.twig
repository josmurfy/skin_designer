{# Original: shopmanager/catalog/category_form.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
       <div class="float-end"><button type="submit" form="form-category" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_form }}</div>
      <div class="card-body">
        <form id="form-category" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <input type="hidden" name="user_token" value="{{ user_token }}" />
          <input type="hidden" name="category_id" value="{{ category_id }}" />

          <ul class="nav nav-tabs">
            <li class="nav-item"><a href="#tab-general" data-bs-toggle="tab" class="nav-link{% if not specifics is defined %} active{% endif %}">{{ tab_general }}</a></li>
            {% if leaf == 1 %}
              <li class="nav-item"><a href="#tab-specifics" data-bs-toggle="tab" class="nav-link{% if specifics is defined %} active{% endif %}">{{ tab_specifics }}</a></li>
            {% endif %}
            <li class="nav-item"><a href="#tab-data" data-bs-toggle="tab" class="nav-link">{{ tab_data }}</a></li>
            <li class="nav-item"><a href="#tab-seo" data-bs-toggle="tab" class="nav-link">{{ tab_seo }}</a></li>
            <li class="nav-item"><a href="#tab-design" data-bs-toggle="tab" class="nav-link">{{ tab_design }}</a></li>
          </ul>

          <div class="tab-content">
            <div id="tab-general" class="tab-pane{% if not specifics is defined %} active{% endif %}">
              <ul class="nav nav-tabs">
                {% set specifics_row = 0 %}
                {% for language in languages %}
                  <li class="nav-item"><a href="#language-{{ language.language_id }}" data-bs-toggle="tab" class="nav-link{% if loop.first %} active{% endif %}"><img src="{{ language.image }}" title="{{ language.name }}" /> {{ language.name }}</a></li>
                {% endfor %}
              </ul>
              <div class="tab-content">
                {% for language in languages %}
                  {% set specifics_row = 0 %}
                  <div id="language-{{ language.language_id }}" class="tab-pane{% if loop.first %} active{% endif %}">
                    <div class="row mb-3 required">
                      <label for="category-description-{{ language.language_id }}-{{ specifics_row }}" class="col-sm-2 col-form-label">{{ entry_name }}</label>
                      <div class="col-sm-10">
                        <input type="text" id="category-description-{{ language.language_id }}-{{ specifics_row }}" name="category_description[{{ language.language_id }}][name]" value="{{ category_description[language.language_id].name|default('') }}" placeholder="{{ entry_name }}" class="form-control" />
                        {% set specifics_row = specifics_row + 1 %}
                        {% if error_name[language.language_id] is defined %}
                          <div class="invalid-feedback d-block">{{ error_name[language.language_id] }}</div>
                        {% endif %}
                      </div>
                    </div>

                    {% if language.code starts with 'en' %}
                      <div class="row mb-3">
                        <label for="input-image" class="col-sm-2 col-form-label">{{ entry_image }}</label>
                        <div class="col-sm-10">
                          <div class="col-sm-3">
                            <a href="" id="thumb-image" data-toggle="image" class="img-thumbnail"><img id="thumb-image-result" src="{{ thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a>
                            <button id="ai-suggest-image-btn" type="button" onclick="aiSuggestImage('form-category','category');" data-bs-toggle="tooltip" title="{{ button_ai_image }}" class="btn btn-primary"><i class="fa-solid fa-robot"></i> <i class="fa-solid fa-photo"></i></button>
                            <button id="ai-suggest-image-open-btn" type="button" onclick="" data-bs-toggle="tooltip" title="Open" class="btn btn-primary" style="display:none"><i class="fa-solid fa-image"></i></button>
                          </div>
                          <div class="col-sm-7">
                            <input type="hidden" name="image" value="{{ image }}" id="input-image" />
                            <input class="col-sm-8" type="text" id="image-url" class="form-control" style="display:none;" readonly>
                            <button id="ai-suggest-image-download-btn" type="button" onclick="" data-bs-toggle="tooltip" title="Download" class="col-sm-2 btn btn-primary" style="display:none"></button>
                          </div>
                        </div>
                      </div>

                      <div class="row mb-3">
                        <label class="col-sm-2 col-form-label">{{ entry_condition }}</label>
                        {% set json_condition = conditions[language.language_id]|default([])|json_encode %}
                        <input type="hidden" id="conditions-json-{{ language.language_id }}" name="conditions_json{{ language.language_id }}" value='{{ json_condition|e('html_attr') }}' />
                        <input type="hidden" id="product-description-condition-{{ language.language_id }}" name="product_description[{{ language.language_id }}][condition]" value='{{ product_description[language.language_id].condition|default('') }}' />

                        <div class="col-sm-10">
                          <label id="condition-name-{{ language.language_id }}" style="text-align: left; display: {% if product_description[language.language_id].condition is not defined %}none{% else %}block{% endif %}; padding-top: 10px;">
                            {{ product_description[language.language_id].condition|default('') }}
                          </label><br>
                          <div class="row">
                            {% for condition in conditions[language.language_id]|default([]) %}
                              <div class="col-sm-5">
                                <label for="condition-{{ condition.condition_marketplace_item_id }}">
                                  {{ condition.condition_name }}
                                </label>
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      </div>
                    {% endif %}

                    <div class="row mb-3">
                      <label class="col-sm-2 col-form-label" for="category-description-{{ language.language_id }}-{{ specifics_row }}">{{ entry_description }}</label>
                      <div class="col-sm-10 text-end">
                        <button id="ai-suggest-description-category-btn" type="button" onclick="aiSuggestCategoryDescription({{ specifics_row }},'form-category','category');" data-bs-toggle="tooltip" title="{{ button_ai_description_category }}" class="btn btn-primary">
                          {% set row_description = specifics_row %}
                          <i class="fa-solid fa-robot"></i> <i class="fa-solid fa-question"></i>
                        </button>
                        <textarea id="category-description-{{ language.language_id }}-{{ specifics_row }}" name="category_description[{{ language.language_id }}][description]" placeholder="{{ entry_description }}" class="form-control summernote">{{ category_description[language.language_id].description|default('') }}</textarea>
                        {% set specifics_row = specifics_row + 1 %}
                      </div>
                    </div>

                    <div class="row mb-3 required">
                      <label class="col-sm-2 col-form-label" for="category-description-{{ language.language_id }}-{{ specifics_row }}">{{ entry_meta_title }}</label>
                      <div class="col-sm-10">
                        <input type="text" id="category-description-{{ language.language_id }}-{{ specifics_row }}" name="category_description[{{ language.language_id }}][meta_title]" value="{{ category_description[language.language_id].meta_title|default('') }}" placeholder="{{ entry_meta_title }}" class="form-control" />
                        {% set specifics_row = specifics_row + 1 %}
                        {% if error_meta_title[language.language_id] is defined %}
                          <div class="invalid-feedback d-block">{{ error_meta_title[language.language_id] }}</div>
                        {% endif %}
                      </div>
                    </div>

                    <div class="row mb-3">
                      <label class="col-sm-2 col-form-label" for="category-description-{{ language.language_id }}-{{ specifics_row }}">{{ entry_meta_description }}</label>
                      <div class="col-sm-10">
                        <textarea id="category-description-{{ language.language_id }}-{{ specifics_row }}" name="category_description[{{ language.language_id }}][meta_description]" rows="5" placeholder="{{ entry_meta_description }}" class="form-control">{{ category_description[language.language_id].meta_description|default('') }}</textarea>
                        {% set specifics_row = specifics_row + 1 %}
                      </div>
                    </div>

                    <div class="row mb-3">
                      <label class="col-sm-2 col-form-label" for="category-description-{{ language.language_id }}-{{ specifics_row }}">{{ entry_meta_keyword }}</label>
                      <div class="col-sm-10">
                        <textarea id="category-description-{{ language.language_id }}-{{ specifics_row }}" name="category_description[{{ language.language_id }}][meta_keyword]" rows="5" placeholder="{{ entry_meta_keyword }}" class="form-control">{{ category_description[language.language_id].meta_keyword|default('') }}</textarea>
                        {% set specifics_row = specifics_row + 1 %}
                      </div>
                    </div>

                    
                  </div>
                {% endfor %}
                <input type="hidden" name="languages_json" id="languages-json" value='{{ languages_json|raw }}' />
              </div>
            </div>

            {% if leaf == 1 %}
              <div class="tab-pane{% if specifics is defined %} active{% endif %}" id="tab-specifics">
                <ul class="nav nav-tabs" id="specifics-language">
                  <div id="error-container" class="text-danger" style="display:none; margin-top: 10px;"></div>
                  {% for language in languages %}
                    <li class="nav-item">
                      <a class="nav-link{% if language.language_id == 1 %} active{% endif %}" href="#specifics-language-{{ language.language_id }}" data-bs-toggle="tab">
                        <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
                <div class="tab-content">
                  {% set specifics_row_specific = specifics_row %}
                  {% for language in languages %}
                    {% set specifics_row = specifics_row_specific %}
                    <div class="tab-pane{% if language.language_id == 1 %} active{% endif %}" id="specifics-language-{{ language.language_id }}">
                      <table id="specifics-{{ language.language_id }}" class="table table-striped table-bordered table-hover">
                        <thead>
                          <tr>
                            <td class="text-left">{{ column_specifics }}</td>
                            <td class="text-left">{{ column_found_value }}</td>
                            <td class="text-left">
                              <button type="button" id="button-get-specifics" onclick="getCategorySpecifics({{ category_id }},{{ site_id }},{{ specifics_row }})" data-bs-toggle="tooltip" title="{{ button_get_specifics }}" class="btn btn-primary">
                                <i class="fa-solid fa-robot"></i> <i class="fa-solid fa-question"></i> {{ button_get_specifics }}
                              </button>
                            </td>
                          </tr>
                        </thead>
                        <tbody></tbody>
                        <tfoot>
                          <tr>
                            <td colspan="2"></td>
                            <td class="text-left">
                              <button type="button" onclick="addSpecifics();" data-bs-toggle="tooltip" title="{{ button_specifics_add }}" class="btn btn-primary">
                                <i class="fa-solid fa-plus-circle"></i>
                              </button>
                            </td>
                          </tr>
                        </tfoot>
                      </table>
                    </div>
                  {% endfor %}
                  <script>
                    var specifics_row = {{ specifics_row }};
                  </script>
                </div>
              </div>
            {% endif %}

             <div id="tab-data" class="tab-pane">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_image }}</label>
                <div class="col-sm-10">
                  <div class="border rounded d-block" style="max-width: 300px;">
                    <img src="{{ thumb }}" alt="" title="" id="thumb-image" data-oc-placeholder="{{ placeholder }}" class="img-fluid"/>
                    <input type="hidden" name="image" value="{{ image }}" id="input-image"/>
                    <input type="text" id="image-url" class="form-control mt-2" style="display:none;" readonly placeholder="Generated image URL">
                    <div class="d-grid">
                      <button type="button" data-oc-toggle="tooltip" data-oc-target="#input-image" data-oc-thumb="#thumb-image" class="btn btn-primary rounded-0" id="ai-suggest-image-btn" onclick="aiSuggestImage('form-category','category');" title="{{ button_ai_image }}"><i class="fa-solid fa-robot"></i> <i class="fa-solid fa-photo"></i> {{ button_generate_image }}</button>
                      <button type="button" id="ai-suggest-image-open-btn" onclick="" data-bs-toggle="tooltip" title="Open Image" class="btn btn-info rounded-0" style="display:none"><i class="fa-solid fa-image"></i> Open</button>
                      <button type="button" id="ai-suggest-image-download-btn" onclick="" data-bs-toggle="tooltip" title="Download & Set" class="btn btn-success rounded-0" style="display:none"><i class="fa-solid fa-download"></i> Download</button>
                      <button type="button" data-oc-toggle="image" data-oc-target="#input-image" data-oc-thumb="#thumb-image" class="btn btn-primary rounded-0"><i class="fa-solid fa-pencil"></i> {{ button_edit }}</button>
                      <button type="button" data-oc-toggle="clear" data-oc-target="#input-image" data-oc-thumb="#thumb-image" class="btn btn-warning rounded-0"><i class="fa-regular fa-trash-can"></i> {{ button_clear }}</button>
                    </div>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-parent" class="col-sm-2 col-form-label">{{ entry_parent }}</label>
                <div class="col-sm-10">
                  <input type="text" name="path" value="{{ path }}" placeholder="{{ entry_parent }}" id="input-parent" data-oc-target="autocomplete-parent" class="form-control" autocomplete="off"/>
                  <ul id="autocomplete-parent" class="dropdown-menu"></ul>
                  <input type="hidden" name="parent_id" value="{{ parent_id }}" id="input-parent-id"/>
                  <div class="form-text">{{ help_parent }}</div>
                  <div id="error-parent" class="invalid-feedback"></div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_filter }}</label>
                <div class="col-sm-10">
                  <input type="text" name="filter" value="" placeholder="{{ entry_filter }}" id="input-filter" data-oc-target="autocomplete-filter" class="form-control" autocomplete="off"/>
                  <ul id="autocomplete-filter" class="dropdown-menu"></ul>
                  <div class="form-control p-0" style="height: 150px; overflow: auto;">
                    <table id="category-filter" class="table m-0">
                      <tbody>
                        {% for category_filter in category_filters %}
                          <tr id="category-filter-{{ category_filter.filter_id }}">
                            <td>{{ category_filter.name }}<input type="hidden" name="category_filter[]" value="{{ category_filter.filter_id }}"/></td>
                            <td class="text-end"><button type="button" class="btn btn-danger"><i class="fa-solid fa-minus-circle"></i></button></td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  <div class="form-text">{{ help_filter }}</div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_store }}</label>
                <div class="col-sm-10">
                  <div class="form-control" style="height: 150px; overflow: auto;">
                    {% for store in stores %}
                      <div class="form-check">
                        <input type="checkbox" name="category_store[]" value="{{ store.store_id }}" id="input-store-{{ store.store_id }}" class="form-check-input"{% if store.store_id in category_store %} checked{% endif %}/> <label for="input-store-{{ store.store_id }}" class="form-check-label">{{ store.name }}</label>
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>
             
              <div class="row mb-3">
                <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
                <div class="col-sm-10">
                  <input type="number" name="sort_order" value="{{ sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="status" value="0"/>
                    <input type="checkbox" name="status" value="1" id="input-status" class="form-check-input" {% if status %} checked{% endif %}/>
                  </div>
                </div>
              </div>
            </div>
          <div id="tab-seo" class="tab-pane">
              <div class="alert alert-info"><i class="fa-solid fa-info-circle"></i> {{ text_keyword }}</div>
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <th>{{ entry_store }}</th>
                      <th>{{ entry_keyword }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for store in stores %}
                      <tr>
                        <td>{{ store.name }}</td>
                        <td>
                          {% for language in languages %}
                            <div class="input-group">
                              <div class="input-group-text"><img src="{{ language.image }}" title="{{ language.name }}"/></div>
                              <input type="text" name="category_seo_url[{{ store.store_id }}][{{ language.language_id }}]" value="{% if category_seo_url[store.store_id][language.language_id] %}{{ category_seo_url[store.store_id][language.language_id] }}{% endif %}" placeholder="{{ entry_keyword }}" id="input-keyword-{{ store.store_id }}-{{ language.language_id }}" class="form-control"/>
                            </div>
                            <div id="error-keyword-{{ store.store_id }}-{{ language.language_id }}" class="invalid-feedback"></div>
                          {% endfor %}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
            <div id="tab-design" class="tab-pane">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <th>{{ entry_store }}</th>
                      <th>{{ entry_layout }}</th>
                    </tr>
                  </thead>
                  <tbody>
                     {% for store in stores %}
                      <tr>
                        <td>{{ store.name }}</td>
                        <td><select name="category_layout[{{ store.store_id }}]" class="form-select">
                            <option value=""></option>
                            {% for layout in layouts %}
                              <option value="{{ layout.layout_id }}"{% if category_layout[store.store_id] and category_layout[store.store_id] == layout.layout_id %} selected{% endif %}>{{ layout.name }}</option>
                            {% endfor %}
                          </select></td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

<script type="text/javascript"><!--
 $('textarea[data-oc-toggle=\'ckeditor\']').ckeditor({
    language: '{{ ckeditor }}'
});

$('#input-parent').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=shopmanager/catalog/category.autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          json.unshift({
              'category_id': '0',
              'name': '{{ text_none }}'
          });
          response($.map(json, function(item) {
            return {
                value: item['category_id'],
                label: item['name']
            }
          }));
        }
      });
    },
    'select': function(item) {
        $('#input-parent').val(decodeHTMLEntities(item['label']));
        $('#input-parent-id').val(item['value']);
    }
  });

$('#input-filter').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=shopmanager/catalog/filter/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item['name'],
              value: item['filter_id']
            }
          }));
        }
      });
    },
    'select': function(item) {
        $('#input-filter').val('');

        $('#category-filter-' + item['value']).remove();

        html = '<tr id="category-filter-' + item['value'] + '">';
        html += '  <td>' + item['label'] + '<input type="hidden" name="category_filter[]" value="' + item['value'] + '"/></td>';
        html += '  <td class="text-end"><button type="button" class="btn btn-danger btn-sm"><i class="fa-solid fa-minus-circle"></i></button></td>';
        html += '</tr>';

        $('#category-filter tbody').append(html);
      }
  });

$('#category-filter').on('click', '.btn', function() {
    $(this).parent().parent().remove();
});

  function addSpecifics() {
    var languages = JSON.parse($('#languages-json').val());
    for (var language_id in languages) {
      var html = '<tr id="specifics' + language_id + '-row' + specifics_row + '">';
      html += '<td class="text-left"><div id="category-description-' + language_id + '-specific-' + specifics_row + '-name"></div>';
      html += '<input type="hidden" id="hidden-category-description-' + language_id + '-specific-' + specifics_row + '-name" name="category_description[' + language_id + '][specifics][' + specifics_row + '][Name]" placeholder="{{ column_specifics }}" class="form-control" />';
      html += '<input type="text" id="text-category-description-' + language_id + '-specific-' + specifics_row + '-name" name="category_description[' + language_id + '][specifics][' + specifics_row + '][Name]" placeholder="{{ column_specifics }}" class="form-control" onchange="updateSpecifics(' + specifics_row + ')" />';
      html += '</td>';
      html += '<td class="text-left">';
      html += '<div id="response-category-description-' + language_id + '-' + specifics_row + '"></div>';
      html += '<input type="text" id="category-description-' + language_id + '-' + specifics_row + '" name="category_description[' + language_id + '][specifics][' + specifics_row + '][Value]" placeholder="{{ entry_text }}" class="form-control" /></td>';
      html += '<td class="text-left">';
      html += '<button type="button" onclick="removeSpecificsRow(' + specifics_row + ', ' + specifics_row + ',\'' + specifics_row + '\');" data-bs-toggle="tooltip" title="" class="btn btn-danger" data-bs-original-title="{{ button_remove }}"><i class="fa-solid fa-minus-circle"></i></button></td>';
      html += '</tr>';
      $('#specifics-' + language_id + ' tbody').append(html);
    }
    specifics_row++;
  }

  function removeSpecificsRow(field, specifics_row, specificName) {
    // Parse the languages JSON data to get the language codes
    var user_token = document.querySelector('input[name="user_token"]').value;
    var languages = JSON.parse($('#languages-json').val());

    // Call PHP controller to exclude the specific
    $.ajax({
        url: `index.php?route=shopmanager/category_specific.excludeSpecific&user_token=${user_token}`,
        type: 'POST',
        data: {
            specific_name: specificName
        },
        success: function (response) {
            console.log('Specific excluded:', response);
        },
        error: function (xhr, status, error) {
            console.error('Error excluding specific:', error);
        }
    });

    // Iterate over the languages object to remove the specific rows
    for (var language_id in languages) {
        if (languages.hasOwnProperty(language_id)) {
            var language_code = languages[language_id];
            var rowId = `#specifics${language_id}-row${specifics_row}`;
            var rowId2 = `#specifics${language_code}row${specifics_row}`;

            // Remove the rows
            $(rowId).remove();
            $(rowId2).remove();
        }
    }

    specifics_row--;
}

$('.form-control, .summernote').on('change summernote.blur', function() {
    var elementId = $(this).attr('id');
    
    // Vérifiez si lID commence par "category_description_"
    if (elementId && elementId.startsWith('category_description_')) {
        //translateContentForAllLanguages(elementId, $(this).hasClass('summernote') ? 'summernote' : '', 'category');
    }
});

function updateSpecifics(rowId) {
    // Récupérer les données des langues
    var languages = JSON.parse($('#languages-json').val());
    var textInput = document.querySelector(`#text-category-description-1-specific-${rowId}-name`);
    var newName = textInput.value;
    if (newName == '') {
        var textInput = document.querySelector(`#text-category-description-2-specific-${rowId}-name`);
        var newName = textInput.value;
    }
   
    // Nouvelle valeur du champ de texte
   

    // Parcourir chaque langue
    for (var language_id in languages) {
        // Sélecteurs pour les différents éléments
        var divElement = document.querySelector(`#category-description-${language_id}-specific-${rowId}-name`);
        var hiddenInput = document.querySelector(`#hidden-category-description-${language_id}-specific-${rowId}-name`);
        var textInput = document.querySelector(`#text-category-description-${language_id}-specific-${rowId}-name`);
        var valueInput = document.querySelector(`#category-description-${language_id}-${rowId}`);

       

        // Mise à jour du texte du div
        if (divElement) {
            divElement.textContent = newName;
        }

        // Mise à jour des attributs name des inputs cachés et de texte
        if (hiddenInput) {
            hiddenInput.name = `category_description[${language_id}][specifics][${newName}][Name]`;
            hiddenInput.value = newName; // Mettre à jour la valeur cachée si nécessaire
        }

        if (valueInput) {
            valueInput.name = `category_description[${language_id}][specifics][${newName}][Value]`;
        }
        // Rendre le champ de texte invisible
        if (textInput) {
            textInput.style.display = 'none';
            textInput.removeAttribute('name');
        }


        var removeButton = document.querySelector(`#specifics${language_id}-row${rowId} .btn-danger`);
        if (removeButton) {
            removeButton.setAttribute('onclick', `removeSpecificsRow('${newName}', ${rowId},'${newName}');`);
        }
    }
}


              
window.addEventListener('load', async function() {
    {% if specifics is defined %}
        await getCategorySpecifics({{ category_id }}, {{ site_id }}, {{ specifics_row }});
    {% elseif leaf == 1 and specifics_data is defined %}
        await updateCategorySpecificsTable({{ specifics_data|json_encode|raw }}, {{ specifics_row }});
    {% endif %}
});

