var TEXT_ENTER_MANUFACTURER_NAME = '{{ text_enter_manufacturer_name|escape('js') }}';
var TEXT_MANUFACTURER_UPDATED_SUCCESS = '{{ text_manufacturer_updated_success|escape('js') }}';
