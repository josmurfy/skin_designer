{# Original: shopmanager/maintenance/product_description.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" data-bs-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-product-description').toggleClass('d-none');" class="btn btn-light d-lg-none"><i class="fa-solid fa-filter"></i></button>
        <button type="button" id="button-refresh" data-bs-toggle="tooltip" title="{{ button_refresh }}" class="btn btn-primary">
          <i class="fa-solid fa-refresh"></i>
        </button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div id="filter-product-description" class="col-lg-3 col-md-12 order-lg-last d-none d-lg-block mb-3">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-filter"></i> {{ text_filter }} <button type="button" id="button-reset-filters" class="btn btn-sm btn-outline-secondary float-end" data-bs-toggle="tooltip" title="Reset Filters"><i class="fa-solid fa-redo"></i></button></div>
          <div class="card-body">
            <form id="form-filter">
              <input type="hidden" name="user_token" value="{{ user_token }}">
              
              <div class="mb-3">
                <label for="input-product-id" class="form-label">Product ID</label>
                <input type="text" name="filter_product_id" value="{{ filter_product_id }}" placeholder="Product ID" id="input-product-id" class="form-control form-control-sm"/>
              </div>

              <div class="mb-3">
                <label for="input-name" class="form-label">Product Name</label>
                <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="Product Name" id="input-name" class="form-control form-control-sm"/>
              </div>

              <div class="mb-3">
                <label for="input-missing-type" class="form-label">Missing Fields</label>
                <select name="filter_missing_type" id="input-missing-type" class="form-select form-select-sm">
                  <option value="*"></option>
                  <option value="all" {% if filter_missing_type == 'all' %}selected{% endif %}>All Missing (3 fields)</option>
                  <option value="included_accessories" {% if filter_missing_type == 'included_accessories' %}selected{% endif %}>Missing Included Accessories</option>
                  <option value="condition_supp" {% if filter_missing_type == 'condition_supp' %}selected{% endif %}>Missing Condition Supp</option>
                  <option value="description_supp" {% if filter_missing_type == 'description_supp' %}selected{% endif %}>Missing Description Supp</option>
                  <option value="complete" {% if filter_missing_type == 'complete' %}selected{% endif %}>Complete (No Missing)</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="input-outdated" class="form-label">Last Modified</label>
                <select name="filter_outdated" id="input-outdated" class="form-select form-select-sm">
                  <option value="*"></option>
                  <option value="6months" {% if filter_outdated == '6months' %}selected{% endif %}>> 6 months</option>
                  <option value="1year" {% if filter_outdated == '1year' %}selected{% endif %}>> 1 year</option>
                  <option value="recent" {% if filter_outdated == 'recent' %}selected{% endif %}>< 6 months</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="input-quantity-from" class="form-label">Quantity</label>
                <div class="row">
                  <div class="col">
                    <input type="text" name="filter_quantity_from" value="{{ filter_quantity_from }}" placeholder="From" id="input-quantity-from" class="form-control form-control-sm"/>
                  </div>
                  <label class="col-auto col-form-label px-0"><i class="fa-solid fa-minus"></i></label>
                  <div class="col">
                    <input type="text" name="filter_quantity_to" value="{{ filter_quantity_to }}" placeholder="To" id="input-quantity-to" class="form-control form-control-sm"/>
                  </div>
                </div>
              </div>

              <div class="text-end">
                <button type="button" id="button-filter" class="btn btn-primary btn-sm"><i class="fa-solid fa-filter"></i> Filter</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <div class="col-lg-9 col-md-12">
        <div class="card">
          <div class="card-header">
            <i class="fa-solid fa-list"></i> {{ text_list }}
            <div class="float-end">
              <small class="text-muted">
                <i class="fa-solid fa-info-circle"></i> {{ help_outdated }}
              </small>
            </div>
          </div>
          <div class="card-body">
            <div id="product-list">{{ list }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// Variables globales
var USER_TOKEN = '{{ user_token }}';

// Refresh list
$('#button-refresh').on('click', function() {
  filter();
});

// Filter button
$('#button-filter').on('click', function() {
  filter();
});

// Reset filters
$('#button-reset-filters').on('click', function() {
  $('#form-filter')[0].reset();
  filter();
});

// Filter function
function filter() {
  var url = 'index.php?route=shopmanager/maintenance/product_description.list&user_token=' + USER_TOKEN;

  var filter_product_id = $('#input-product-id').val();
  if (filter_product_id) {
    url += '&filter_product_id=' + encodeURIComponent(filter_product_id);
  }

  var filter_name = $('#input-name').val();
  if (filter_name) {
    url += '&filter_name=' + encodeURIComponent(filter_name);
  }

  var filter_missing_type = $('#input-missing-type').val();
  if (filter_missing_type && filter_missing_type != '*') {
    url += '&filter_missing_type=' + encodeURIComponent(filter_missing_type);
  }

  var filter_outdated = $('#input-outdated').val();
  if (filter_outdated && filter_outdated != '*') {
    url += '&filter_outdated=' + encodeURIComponent(filter_outdated);
  }

  var filter_quantity_from = $('#input-quantity-from').val();
  if (filter_quantity_from) {
    url += '&filter_quantity_from=' + encodeURIComponent(filter_quantity_from);
  }

  var filter_quantity_to = $('#input-quantity-to').val();
  if (filter_quantity_to) {
    url += '&filter_quantity_to=' + encodeURIComponent(filter_quantity_to);
  }

  $('#product-list').load(url);
}

// Filter on Enter key
$('#form-filter input').on('keydown', function(e) {
  if (e.keyCode == 13) {
    e.preventDefault();
    filter();
  }
});

// AI Suggest function
function aiSuggestDescriptionSupp(productId) {
  if (confirm('{{ text_confirm }}')) {
    $.ajax({
      url: 'index.php?route=shopmanager/maintenance/product_description.aiSuggest&user_token=' + USER_TOKEN + '&product_id=' + productId,
      type: 'get',
      dataType: 'json',
      success: function(json) {
        if (json.redirect) {
          window.location.href = json.redirect;
        }
        if (json.error) {
          alert(json.error);
        }
        if (json.success) {
          alert(json.success);
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });
  }
}

// AJAX pagination
$('#product-list').on('click', 'thead a, .pagination a', function(e) {
  e.preventDefault();
  $('#product-list').load(this.href);
});

// Select all checkboxes
$('#product-list').on('change', '#select-all', function() {
  $('input[name^="product_id"]').prop('checked', this.checked);
});

// Update select-all state when individual checkboxes change
$('#product-list').on('change', 'input[name^="product_id"]', function() {
  if ($('input[name^="product_id"]:checked').length == $('input[name^="product_id"]').length) {
    $('#select-all').prop('checked', true);
  } else {
    $('#select-all').prop('checked', false);
  }
});

// Initialize image preview popup on page load and after AJAX updates
function initImagePreview() {
  document.querySelectorAll('.actual-image-container').forEach(function(container) {
    if (container.dataset.previewInitialized === 'true') return;
    container.dataset.previewInitialized = 'true';

    const thumbnail = container.querySelector('.img-thumbnail, .thumbnail-actual-image');
    const wrapper = container.querySelector('.fullsize-actual-image-wrapper');
    const fullsizeImg = container.querySelector('.fullsize-actual-image, .actual-image-preview');
    const resolutionOverlay = container.querySelector('.fullsize-resolution-overlay');

    if (!thumbnail || !wrapper || !fullsizeImg) return;

    if (resolutionOverlay) {
      const resolution = fullsizeImg.getAttribute('data-resolution');
      if (resolution) {
        const parts = resolution.split('x');
        const width = parseInt(parts[0]);
        const height = parseInt(parts[1]);
        
        if (width < 400 || height < 600) {
          resolutionOverlay.classList.add('low-res');
        } else {
          resolutionOverlay.classList.add('good-res');
        }
        resolutionOverlay.textContent = resolution;
      }
    }

    thumbnail.addEventListener('mouseenter', function() {
      // Clone wrapper and add to body to avoid opacity inheritance
      const clone = wrapper.cloneNode(true);
      clone.id = 'temp-fullsize-preview';
      clone.style.display = 'block';
      document.body.appendChild(clone);
    });

    thumbnail.addEventListener('mouseleave', function() {
      // Remove clone from body
      const clone = document.getElementById('temp-fullsize-preview');
      if (clone) {
        clone.remove();
      }
    });

    wrapper.addEventListener('mouseenter', function() {
      wrapper.style.display = 'block';
    });

    wrapper.addEventListener('mouseleave', function() {
      wrapper.style.display = 'none';
    });
  });
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
  initImagePreview();
});

// Re-initialize after AJAX list update
var originalLoad = $('#product-list').load;
$('#product-list').load = function() {
  return originalLoad.apply(this, arguments).done(function() {
    initImagePreview();
  });
};
</script>

{{ footer }}
