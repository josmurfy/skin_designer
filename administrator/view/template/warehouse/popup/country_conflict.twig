{# Original: warehouse/popup/country_conflict.twig #}
<div id="countryConflictModal" class="modal" tabindex="-1" style="display: block; background: rgba(0,0,0,0.5);">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">{{ heading_title }}</h5>
            </div>
            <div class="modal-body">
                <p>{{ text_conflict_message|raw }}</p>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="countryChoice" id="choice1" value="1" checked>
                    <label class="form-check-label" for="choice1">
                        {{ text_made_in_country|raw }} <span id="madeInCountryValue">{{ made_in_country }}</span>
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="countryChoice" id="choice2" value="2">
                    <label class="form-check-label" for="choice2">
                        {{ text_country_region_manufacture|raw }} <span id="specificsCountryValue">{{ specifics_country }}</span>
                    </label>
                </div>
                <p class="mt-3 text-muted small">{{ text_apply_all_languages }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="confirmCountryChoice">{{ button_confirm }}</button>
            </div>
        </div>
    </div>
</div>
