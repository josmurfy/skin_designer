{# Original: shopmanager/marketplace_error_popup.twig #}
<style>
.spinner-grow { animation: spin 1s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.modal-content { box-shadow: 0 5px 15px rgba(0,0,0,.3); background-color:#f9f9f9; border-radius:10px; }
.modal-header { padding:15px; background-color:#0056b3; border-top-left-radius:10px; border-top-right-radius:10px; color:#fff; }
.modal-body { padding:30px; text-align:center; }
.modal-title { font-size:20px; font-weight:bold; }
.spinner-grow { width:3rem; height:3rem; }
.processing-bar { width:100%; height:10px; background:#f1f1f1; border-radius:5px; position:relative; overflow:hidden; margin-top:20px; }
.moving-bar { width:30%; height:100%; background:#007bff; border-radius:5px; position:absolute; left:0; animation:moveBar 2s ease-in-out infinite; }
@keyframes moveBar { 0% { left:-30%; } 50% { left:50%; } 100% { left:100%; } }
.custom-marketplace-error-modal .modal-content { border-radius:20px; background:#f0f0f0; }
.custom-marketplace-error-modal .modal-header { background:#0056b3; border-top-left-radius:20px; border-top-right-radius:20px; }
.custom-marketplace-error-modal .modal-title { color:#fff; font-weight:bold; }
.custom-marketplace-error-modal .modal-body { text-align:left; padding:20px; max-height:70vh; overflow:auto; }
.custom-marketplace-error-modal .spinner-grow { width:3rem; height:3rem; }
.custom-marketplace-error-modal .processing-bar { margin-top:20px; }
.custom-marketplace-error-modal .moving-bar { background:#007bff; }
.custom-marketplace-error-modal p { margin-top:20px; font-size:14px; color:#999; }
.custom-marketplace-error-modal .modal-footer { padding:15px; border-top:1px solid #e9ecef; display:flex; justify-content:flex-end; gap:12px; flex-wrap:wrap; align-items:center; }
.custom-marketplace-error-modal .btn { margin:0; flex:0 0 auto; white-space:nowrap; }
.custom-marketplace-error-modal .modal-dialog { width:80%; margin:auto; }
.custom-marketplace-error-modal .table-responsive { max-height:60vh; overflow:auto; }
.custom-marketplace-error-modal table th,
.custom-marketplace-error-modal table td { vertical-align:top; word-break:break-word; font-size:13px; }
.custom-marketplace-error-modal table table { font-size:12px; margin-bottom:0; background:transparent; }
</style>

<div id="popup-error" class="modal fade custom-marketplace-error-modal" tabindex="-1" role="dialog" data-product-id="{{ product_id }}">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">{{ heading_title }}</h5>
        <button type="button" class="close btn-close" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr><th>Key</th><th>Value</th></tr>
            </thead>
            <tbody>
              {{ rows_error|raw }}
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
     
        <button type="button" class="btn btn-primary btn-retry">{{ text_retry }}</button>
        <button type="button" class="btn btn-warning btn-fix-issue">{{ text_fix_issue }}</button>
      </div>
    </div>
  </div>
</div>