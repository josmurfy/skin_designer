{# Original: warehouse/order/order_print_report.twig #}
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Orders Report - {{ "now"|date("Y-m-d H:i") }}</title>
  <style>
    @page { size: 8.5in 11in; margin: 0.5in; }
    body { 
      font-family: 'Verdana', 'Tahoma', Arial, sans-serif; 
      font-size: 14px; 
      margin: 0;
      padding: 0;
      line-height: 1.4;
    }
    h1 { 
      text-align: center; 
      margin: 10px 0 20px 0; 
      font-size: 22px;
      border-bottom: 3px solid #000;
      padding-bottom: 10px;
      font-weight: bold;
    }
    table { 
      width: 100%; 
      border-collapse: collapse; 
      margin-top: 5px;
      page-break-inside: auto;
    }
    tr { 
      page-break-inside: avoid; 
      page-break-after: auto; 
    }
    thead { 
      display: table-header-group; 
    }
    th, td { 
      border: 1px solid #000; 
      padding: 10px 8px; 
      text-align: left;
      line-height: 1.5;
    }
    th { 
      background-color: #d0d0d0; 
      font-weight: bold; 
      font-size: 13px;
      text-transform: uppercase;
    }
    td { 
      font-size: 14px; 
    }
    .text-center { text-align: center; }
    .text-end { text-align: right; }
    .order-header {
      background-color: #ffffcc;
      font-weight: bold;
      font-size: 16px;
      border-top: 3px solid #000;
      page-break-after: avoid;
      padding: 12px 8px !important;
    }
    .product-row {
      background-color: #fff;
      page-break-before: avoid;
    }
    .product-row:hover {
      background-color: #f5f5f5;
    }
    .location-badge {
      background-color: #0066cc;
      color: white;
      padding: 4px 10px;
      border-radius: 3px;
      font-size: 13px;
      font-weight: bold;
    }
    .qty-badge {
      background-color: #28a745;
      color: white;
      padding: 4px 10px;
      border-radius: 3px;
      font-weight: bold;
      font-size: 14px;
    }
    .total-row {
      background-color: #e9ecef;
      font-weight: bold;
      border-top: 2px solid #000;
    }
    @media print {
      button { display: none; }
      body { margin: 0; }
    }
  </style>
</head>
<body>

<h1>Orders Report - {{ "now"|date("Y-m-d H:i") }}
{% if filter_date_start or filter_date_end %}
  <br><small style="font-size: 14px;">
    {% if filter_date_start and filter_date_end %}
      Period: {{ filter_date_start }} to {{ filter_date_end }}
    {% elseif filter_date_start %}
      From: {{ filter_date_start }} to today
    {% elseif filter_date_end %}
      Up to: {{ filter_date_end }}
    {% endif %}
  </small>
{% endif %}
</h1>

{{ list }}

<script>
  window.onload = function() { window.print(); };
</script>
</body>
</html>
