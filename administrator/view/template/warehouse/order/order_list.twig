{# Original: shopmanager/order_list.twig #}


  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_orders }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ process }}" method="post" enctype="multipart/form-data" id="form-order">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  {% if type_report is not defined %}
                  <td class="text-center"><input type="checkbox" onclick="toggleSelectAll(this)" value="Select All"></td>
                  {% endif %}
                  <td class="text-left">{{ column_order_id }}</td>
                  <td class="text-left">{{ column_image }}</td>
                  <td class="text-left">{{ column_sku }}</td>
                  <td class="text-left">{{ column_customer }}</td>
                  <td class="text-left">{{ column_product_name }}</td>
                  <td class="text-left">{{ column_total }}</td>
                  <td class="text-right">{{ column_quantity }}</td>
                </tr>
              </thead>
              <tbody>
                {% if orders %}
                  {% for order in orders %}
                    <tr>
                      {% if type_report is not defined %}
                      <td class="text-center">
                        <input type="checkbox"
                               name="vendu[]"
                               value="{{ order.customlabel }},{{ order.needed_quantity }},{{ order.quantity }},{{ order.unallocated_quantity }},{{ order.com }},{{ order.location|default('') }}">
                      </td>
                      {% endif %}
                      <td class="text-left">{{ order.sales_record_number }}</td>
                      <td class="text-left">
                        {% if order.com == 'CARD_' and order.listing_id %}
                          <a href="index.php?route=shopmanager/card/card_listing.form&listing_id={{ order.listing_id }}&user_token={{ user_token }}" target="_blank">{{ order.image|raw }}</a>
                        {% else %}
                          {{ order.image|raw }}
                        {% endif %}
                      </td>
                      <td class="text-left"><strong>{{ order.sku }}</strong></td>
                      <td class="text-left">
                        <strong>{{ order.customer }}</strong><br>
                        <small>{{ order.adress }}<br>{{ order.adress2 }}</small>
                      </td>
                      <td class="text-left">{{ order.name }}</td>
                      <td class="text-left">
                        ${{ order.needed_quantity * order.price }}{% if order.transaction_site_id == 'Canada' %} CAD{% endif %}
                      </td>
                      <td class="text-left">{{ order.needed_quantity }}</td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr>
                    <td class="text-center" colspan="{% if type_report is not defined %}8{% else %}7{% endif %}">{{ text_no_orders }}</td>
                  </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_inventaire }}</h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <td class="text-left" style="width: 80px;">{{ column_image }}</td>
                <td class="text-left" style="width: 15%;">{{ column_sku }}</td>
                <td class="text-left">{{ column_product_name }}</td>
                <td class="text-center" style="width: 10%;">{{ column_quantity }}</td>
                <td class="text-center" style="width: 10%;">{{ column_unallocated_quantity }}</td>
                <td class="text-center" style="width: 10%;">{{ column_needed_quantity }}</td>
              </tr>
            </thead>
            <tbody>
              {% if orders_sorted %}
                {% set current_location = null %}
                {% for o in orders_sorted %}
                  {% if current_location != o.location %}
                    {% set current_location = o.location %}
                    <tr class="table-active order-header">
                      <td colspan="6" style="background-color: #ffffcc; font-weight: bold; font-size: 13px;">
                        <i class="fa-solid fa-map-marker-alt"></i> LOCATION: {{ o.location|default(text_unlocated) }}
                      </td>
                    </tr>
                  {% endif %}
                  <tr class="product-row">
                    <td class="text-left">
                      {% if o.com == 'CARD_' and o.listing_id %}
                        <a href="index.php?route=shopmanager/card/card_listing.form&listing_id={{ o.listing_id }}&user_token={{ user_token }}" target="_blank">{{ o.image|raw }}</a>
                      {% else %}
                        {{ o.image|raw }}
                      {% endif %}
                    </td>
                    <td class="text-left"><strong>{{ o.sku }}</strong></td>
                    <td class="text-left">{{ o.name }}</td>
                    <td class="text-center">{{ o.quantity }}</td>
                    <td class="text-center">{{ o.unallocated_quantity }}</td>
                    <td class="text-center">
                      <span style="background-color: #28a745; color: white; padding: 6px 12px; border-radius: 3px; font-weight: bold; font-size: 14px;">{{ o.needed_quantity }}</span>
                    </td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td class="text-center" colspan="6">{{ text_no_orders }}</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
