{# Original: warehouse/card/listing_form.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-listing" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa-solid fa-circle-check"></i> {{ success }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> {{ error_warning }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}
    {% if google_image_count > 0 %}
      <div class="alert alert-warning d-flex align-items-center justify-content-between">
        <span><i class="fa-solid fa-triangle-exclamation me-2"></i>
          <strong>{{ google_image_count }} image(s) Google</strong> (googleapis.com) not yet migrated to eBay.
          eBay may reject or expire these external URLs.
        </span>
        <button type="button" id="btn-migrate-images" class="btn btn-warning btn-sm ms-3" style="white-space:nowrap;">
          <i class="fa-solid fa-cloud-arrow-up me-1"></i> Migrate to eBay
        </button>
      </div>
    {% endif %}

    <!-- Migrate Images Modal -->
    <div class="modal fade" id="modal-migrate-images" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fa-solid fa-cloud-arrow-up me-2"></i>Image Migration Report</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="migrate-modal-body">
            <div class="text-center py-4">
              <div class="spinner-border text-warning" role="status"></div>
              <p class="mt-2 text-muted">Uploading images to eBay…</p>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-outline-primary" id="btn-reload-after-migrate" style="display:none;" onclick="location.reload()">
              <i class="fa-solid fa-rotate-right me-1"></i>Reload page
            </button>
          </div>
        </div>
      </div>
    </div>

    {% if cards_without_offer_count > 0 %}
      <div class="alert alert-info d-flex align-items-center justify-content-between">
        <span><i class="fa-solid fa-circle-info me-2"></i>
          <strong>{{ cards_without_offer_count }} card(s)</strong> listed on eBay but missing an <code>offer_id</code>.
          Click to fetch their offer status, published flag and any errors from eBay.
        </span>
        <button type="button" id="btn-sync-offers" class="btn btn-info btn-sm ms-3" style="white-space:nowrap;">
          <i class="fa-solid fa-rotate me-1"></i> Sync Offers from eBay
        </button>
      </div>
    {% endif %}

    <!-- Sync Offers Modal -->
    <div class="modal fade" id="modal-sync-offers" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fa-solid fa-rotate me-2"></i>eBay Offer Sync Report</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="sync-offers-modal-body">
            <div class="text-center py-4">
              <div class="spinner-border text-info" role="status"></div>
              <p class="mt-2 text-muted">Querying eBay for offer status…</p>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-outline-primary" id="btn-reload-after-sync" style="display:none;" onclick="location.reload()">
              <i class="fa-solid fa-rotate-right me-1"></i>Reload page
            </button>
          </div>
        </div>
      </div>
    </div>

    {% if cards_unpublished_count > 0 %}
      <div class="alert alert-danger d-flex align-items-center justify-content-between">
        <span><i class="fa-solid fa-circle-exclamation me-2"></i>
          <strong>{{ cards_unpublished_count }} card(s)</strong> have an eBay offer but are <strong>not published</strong>.
          Click to attempt re-publication and update their status.
        </span>
        <button type="button" id="btn-republish-offers" class="btn btn-danger btn-sm ms-3" style="white-space:nowrap;">
          <i class="fa-solid fa-upload me-1"></i> Re-publish on eBay
        </button>
      </div>
    {% endif %}

    {% if needs_batch_warning %}
    <div class="alert alert-warning d-flex align-items-center justify-content-between" id="batch-warning-banner">
      <span>
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        <strong>{{ text_needs_batch_warning_title }}</strong><br>
        {{ text_needs_batch_warning_body|raw }}
      </span>
      <button type="button" class="btn btn-warning btn-sm ms-3 btn-assign-batches-trigger"
              data-listing-id="{{ listing_id }}"
              data-url="{{ url_assign_batches }}">
        <i class="fa-solid fa-arrows-rotate me-1"></i>{{ button_calculate_batches_now }}
      </button>
    </div>
    {% endif %}

    <!-- Re-publish Offers Modal -->
    <div class="modal fade" id="modal-republish-offers" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fa-solid fa-upload me-2"></i>Re-publish Report</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="republish-offers-modal-body">
            <div class="text-center py-4">
              <div class="spinner-border text-danger" role="status"></div>
              <p class="mt-2 text-muted">Publishing offers on eBay…</p>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-outline-primary" id="btn-reload-after-republish" style="display:none;" onclick="location.reload()">
              <i class="fa-solid fa-rotate-right me-1"></i>Reload page
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_form }}</div>
      <div class="card-body">
        <form id="form-listing" action="{{ save }}" method="post">
          <input type="hidden" name="listing_id" value="{{ listing_id }}"/>
          
          <ul class="nav nav-tabs">
            <li class="nav-item"><a href="#tab-general" data-bs-toggle="tab" class="nav-link active">{{ tab_general }}</a></li>
            <li class="nav-item"><a href="#tab-cards" data-bs-toggle="tab" class="nav-link">{{ tab_cards }}</a></li>
            <li class="nav-item"><a href="#tab-descriptions" data-bs-toggle="tab" class="nav-link">{{ tab_descriptions }}</a></li>
            <li class="nav-item"><a href="#tab-ebay" data-bs-toggle="tab" class="nav-link">{{ tab_ebay }}</a></li>
            {% if listing_id %}<li class="nav-item"><a href="#tab-import" data-bs-toggle="tab" class="nav-link"><i class="fa fa-upload"></i> Import / Regenerate</a></li>{% endif %}
          </ul>
          
          <div class="tab-content">
            <div id="tab-general" class="tab-pane active">
              <div class="row mb-3 required">
                <label for="input-set-name" class="col-sm-2 col-form-label">{{ entry_set_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="set_name" value="{{ set_name }}" placeholder="{{ entry_set_name }}" id="input-set-name" class="form-control"/>
                </div>
              </div>

              <div class="row mb-3">
                <label for="input-subset" class="col-sm-2 col-form-label">Subset</label>
                <div class="col-sm-10">
                  <input type="text" name="subset" value="{{ subset|default('') }}" placeholder="ex: Gold, Holofoil, Insert, SP..." id="input-subset" class="form-control"/>
                  <div class="form-text">Sous-série optionnelle. Sera ajoutée après le Set Name dans le titre eBay généré.</div>
                </div>
              </div>
              
              <div class="row mb-3 required">
                <label for="input-card-type" class="col-sm-2 col-form-label">{{ entry_sport }}</label>
                <div class="col-sm-10">
                  <select name="card_type_id" id="input-card-type" class="form-select">
                    <option value="">{{ text_select }}</option>
                    {% for card_type in card_types %}
                      <option value="{{ card_type.card_type_id }}"{% if card_type.card_type_id == card_type_id %} selected{% endif %}>{{ card_type.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              
              <div class="row mb-3">
                <label for="input-year" class="col-sm-2 col-form-label">{{ entry_year }}</label>
                <div class="col-sm-10">
                  <input type="text" name="year" value="{{ year }}" placeholder="{{ entry_year }}" id="input-year" class="form-control"/>
                </div>
              </div>
              
              <div class="row mb-3">
                <label for="input-manufacturer" class="col-sm-2 col-form-label">{{ entry_manufacturer }}</label>
                <div class="col-sm-10">
                  <select name="manufacturer" id="input-manufacturer" class="form-select">
                    <option value="">{{ text_select }}</option>
                    {% for manufacturer_name in manufacturers %}
                      <option value="{{ manufacturer_name }}"{% if manufacturer_name == manufacturer %} selected{% endif %}>{{ manufacturer_name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="row mb-3">
                <label for="input-location" class="col-sm-2 col-form-label">{{ entry_location }}</label>
                <div class="col-sm-10">
                  <div class="input-group">
                    {% if listing_id > 0 %}
                    <button type="button" id="btn-print-label" class="btn btn-warning" title="{{ button_print_label }}">
                      <i class="fa-solid fa-print"></i>
                    </button>
                    {% endif %}
                    <input type="text" name="location" value="{{ location }}" placeholder="{{ entry_location }}"
                           id="input-location" class="form-control" style="text-transform:uppercase;"
                           {% if listing_id > 0 %}
                           data-url="{{ url_update_location }}"
                           data-listing-id="{{ listing_id }}"
                           data-user-token="{{ user_token }}"
                           {% endif %}/>
                  </div>
                  <small id="location-save-feedback" class="form-text" style="display:none;"></small>
                </div>
              </div>
              
              <div class="row mb-3">
                <label for="input-status" class="col-sm-2 col-form-label">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="status" value="0"/>
                    <input type="checkbox" name="status" value="1" id="input-status" class="form-check-input"{% if status %} checked{% endif %}/>
                  </div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_cards }}</label>
                <div class="col-sm-10">
                  <div class="alert alert-info">
                    <i class="fa-solid fa-info-circle"></i> {{ text_variation_info }}
                    <br/>
                    <strong>{{ text_variation_count }}:</strong> {{ variation_count }}
                    <br/>
                    <strong>{{ text_total_quantity }}:</strong> {{ total_quantity }}
                  </div>
                </div>
              </div>
            </div>
                        <div id="tab-cards" class="tab-pane">
              {{ tab_cards_html|raw }}
            </div>
            
            <div id="tab-descriptions" class="tab-pane">
              {{ tab_descriptions_html|raw }}
            </div>
            
            <div id="tab-ebay" class="tab-pane">
              <h4>{{ text_ebay_settings }}</h4>
              <p class="text-muted">{{ help_ebay_settings }}</p>

              {# ── eBay Batches panel ──────────────────────────────────────── #}
              {% if listing_id > 0 %}
              <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                  <strong><i class="fa-solid fa-layer-group me-2"></i>{{ text_ebay_batches_panel }}</strong>
                  <button type="button" id="btn-assign-batches" class="btn btn-sm btn-outline-secondary"
                          data-listing-id="{{ listing_id }}"
                          data-url="{{ url_assign_batches }}">
                    <i class="fa-solid fa-arrows-rotate me-1"></i>{{ button_recalculate_batches }}
                  </button>
                </div>
                <div class="card-body p-0" id="ebay-batches-wrap">
                  {% if ebay_batches|length > 0 %}
                  <table class="table table-sm table-bordered mb-0" id="ebay-batches-table">
                    <thead class="table-light">
                      <tr>
                        <th style="width:60px">{{ column_batch }}</th>
                        <th style="width:100px">Cards</th>
                        <th style="width:140px">eBay Item ID</th>
                        <th style="width:80px">{{ column_variations }}</th>
                        <th style="width:110px">Total Value</th>
                        <th style="width:90px">Status</th>
                        <th style="width:160px">Published</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for b in ebay_batches %}
                      {% set desc = batch_descriptions[b.batch_name] ?? {} %}
                      {% set tot  = batch_totals[b.batch_name] ?? {} %}
                      <tr>
                        <td class="text-center">
                          <span class="badge {% if b.batch_name < 99 %}bg-primary{% else %}bg-dark{% endif %}">
                            B{{ b.batch_name }}
                          </span>
                        </td>
                        <td class="text-center small text-muted">
                          #{{ b.card_sort_start }}&ndash;#{{ b.card_sort_end }}
                        </td>
                        <td id="ebay-batch-cell-{{ b.batch_name }}">
                          {% if desc.ebay_item_id %}
                            <a href="https://www.ebay.ca/itm/{{ desc.ebay_item_id }}" target="_blank" class="small d-block mb-1">{{ desc.ebay_item_id }}</a>
                            <button type="button" class="btn btn-danger btn-sm btn-end-batch" data-batch="{{ b.batch_name }}">End</button>
                          {% else %}
                            <button type="button" class="btn btn-success btn-sm btn-add-batch" data-batch="{{ b.batch_name }}">Add Listing</button>
                          {% endif %}
                        </td>
                        <td class="text-center">{{ b.variation_count }}</td>
                        <td class="text-end">
                          {% if tot.total_value is defined %}
                            <strong>$ {{ tot.total_value|number_format(2) }}</strong>
                          {% else %}
                            <span class="text-muted">—</span>
                          {% endif %}
                        </td>
                        <td class="text-center">
                          {% if desc.status == 1 %}
                            <span class="badge bg-success">{{ text_batch_status_published }}</span>
                          {% elseif desc.status == 2 %}
                            <span class="badge bg-secondary">{{ text_batch_status_ended }}</span>
                          {% else %}
                            <span class="badge bg-warning text-dark">{{ text_batch_status_draft }}</span>
                          {% endif %}
                        </td>
                        <td class="text-muted small">{{ desc.date_published ?: '—' }}</td>
                      </tr>
                      {% endfor %}
                    </tbody>
                    <tfoot class="table-light fw-bold">
                      <tr>
                        {% set grand_total = 0 %}
                        {% for tot in batch_totals %}
                          {% set grand_total = grand_total + tot.total_value %}
                        {% endfor %}
                        <td colspan="4" class="text-end text-muted small pe-2">{{ text_grand_total ?? 'Grand Total' }}</td>
                        <td class="text-end text-success">$ {{ grand_total|number_format(2) }}</td>
                        <td colspan="2"></td>
                      </tr>
                    </tfoot>
                  </table>
                  {% else %}
                  <div class="p-3 text-muted" id="ebay-batches-empty">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    {{ text_no_batches_assigned|raw }}
                  </div>
                  {% endif %}
                </div>
              </div>
              {% endif %}
              {# ─────────────────────────────────────────────────────────── #}
              <script>var BATCH_I18N = {{ batch_i18n|raw }};</script>

              {# ── Lot eBay panel ──────────────────────────────────────────── #}
              {% if listing_id > 0 %}
              <div class="card mb-4" id="lot-ebay-panel">
                <div class="card-header d-flex align-items-center justify-content-between">
                  <strong><i class="fa-brands fa-ebay me-2"></i>{{ text_lot_panel_title }}</strong>
                  <button type="button" id="btn-lot-refresh" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-rotate me-1"></i>{{ button_lot_refresh }}
                  </button>
                </div>
                <div class="card-body">
                  {# Status banner #}
                  <div id="lot-status-banner">
                  {% if lot_info.lot_status == 1 and lot_info.lot_ebay_item_id %}
                    <div class="alert alert-success d-flex align-items-center justify-content-between mb-3">
                      <span>
                        <i class="fa-solid fa-check-circle me-2"></i>
                        <strong>{{ text_lot_published_live }}</strong> —
                        <a href="https://www.ebay.com/itm/{{ lot_info.lot_ebay_item_id }}" target="_blank" class="alert-link">
                          {{ lot_info.lot_ebay_item_id }}
                        </a>
                        {% if lot_info.lot_date_published %} · <span class="text-muted small">{{ lot_info.lot_date_published }}</span>{% endif %}
                      </span>
                      <button type="button" id="btn-end-lot" class="btn btn-danger btn-sm ms-3">
                        <i class="fa-solid fa-xmark me-1"></i>{{ button_end_lot }}
                      </button>
                    </div>
                  {% else %}
                    <div class="alert alert-secondary mb-3">
                      <i class="fa-solid fa-circle-info me-2"></i>{{ text_lot_not_published }}
                    </div>
                  {% endif %}
                  </div>

                  {# Stats row #}
                  <div class="row g-3 mb-3" id="lot-stats-row">
                    <div class="col-sm-3">
                      <div class="border rounded p-2 text-center">
                        <div class="fs-4 fw-bold text-primary" id="lot-stat-cards">{{ lot_calculated.card_count }}</div>
                        <div class="text-muted small">{{ text_lot_stat_cards }}</div>
                      </div>
                    </div>
                    <div class="col-sm-3">
                      <div class="border rounded p-2 text-center">
                        <div class="fs-4 fw-bold text-primary" id="lot-stat-qty">{{ lot_calculated.total_qty }}</div>
                        <div class="text-muted small">{{ text_lot_stat_qty }}</div>
                      </div>
                    </div>
                    <div class="col-sm-3">
                      <div class="border rounded p-2 text-center">
                        <div class="fs-4 fw-bold text-success" id="lot-stat-price">$ {{ lot_calculated.calculated_price|number_format(2) }}</div>
                        <div class="text-muted small">{{ text_lot_stat_price }}</div>
                      </div>
                    </div>
                    <div class="col-sm-3">
                      <div class="border rounded p-2 text-center">
                        <div class="fs-6 fw-bold text-warning" id="lot-stat-floored">{{ lot_calculated.floored_count }}</div>
                        <div class="text-muted small">{{ text_lot_stat_floored }}</div>
                      </div>
                    </div>
                  </div>

                  {# Price override #}
                  <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-semibold">{{ text_lot_price_label }}</label>
                    <div class="col-sm-4">
                      <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" id="lot-price-input" class="form-control" step="0.01" min="0.01"
                               value="{{ lot_info.lot_status == 1 and lot_info.lot_price ? lot_info.lot_price : lot_calculated.calculated_price|number_format(2) }}"
                               placeholder="Auto-calculé">
                        <button type="button" id="btn-reset-lot-price" class="btn btn-outline-secondary btn-sm" title="{{ text_lot_price_reset }}">
                          <i class="fa-solid fa-rotate-left"></i>
                        </button>
                      </div>
                      <small class="form-text text-muted">{{ text_lot_price_help }}</small>
                    </div>
                  </div>

                  {# Weight #}
                  <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-semibold">{{ text_lot_weight }}</label>
                    <div class="col-sm-4">
                      <div class="input-group">
                        <input type="number" id="lot-weight-input" class="form-control" step="0.01" min="0"
                               value="{{ lot_info.lot_weight ?? 0 }}" placeholder="0.00">
                        <select id="lot-weight-class-input" class="form-select" style="max-width:80px;">
                          {% for wc in weight_classes %}
                            <option value="{{ wc.weight_class_id }}"{% if wc.weight_class_id == lot_info.lot_weight_class_id %} selected{% endif %}>{{ wc.title }}</option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>
                  </div>

                  {# Dimensions #}
                  <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-semibold">{{ text_lot_dimensions }}</label>
                    <div class="col-sm-7">
                      <div class="input-group">
                        <input type="number" id="lot-length-input" class="form-control" step="0.01" min="0"
                               value="{{ lot_info.lot_length ?? 0 }}" placeholder="L">
                        <span class="input-group-text">×</span>
                        <input type="number" id="lot-width-input" class="form-control" step="0.01" min="0"
                               value="{{ lot_info.lot_width ?? 0 }}" placeholder="l">
                        <span class="input-group-text">×</span>
                        <input type="number" id="lot-height-input" class="form-control" step="0.01" min="0"
                               value="{{ lot_info.lot_height ?? 0 }}" placeholder="H">
                        <select id="lot-length-class-input" class="form-select" style="max-width:80px;">
                          {% for lc in length_classes %}
                            <option value="{{ lc.length_class_id }}"{% if lc.length_class_id == lot_info.lot_length_class_id %} selected{% endif %}>{{ lc.title }}</option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>
                  </div>

                  {# Publish button (hidden if already published) #}
                  {% if lot_info.lot_status != 1 %}
                  <div class="mt-2">
                    <button type="button" id="btn-publish-lot" class="btn btn-success">
                      <i class="fa-brands fa-ebay me-2"></i>{{ button_publish_lot }}
                    </button>
                    <span id="lot-publish-spinner" class="ms-2 d-none">
                      <span class="spinner-border spinner-border-sm text-success"></span> {{ text_lot_publishing }}
                    </span>
                  </div>
                  {% endif %}

                </div>{# /card-body #}
              </div>
              {% endif %}
              {# ── End Lot eBay panel ──────────────────────────────────────── #}
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_ebay_category }}</label>
                <div class="col-sm-10">
                  <input type="text" name="ebay_category_id" value="{{ ebay_category_id }}" class="form-control"/>
                  <small class="form-text text-muted">{{ help_ebay_category }}</small>
                </div>
              </div>
              

            </div>
                        <div id="tab-variations" class="tab-pane">
              <div class="alert alert-warning">
                <i class="fa-solid fa-exclamation-triangle"></i> {{ text_variations_managed }}
              </div>
            </div>{# /tab-variations #}

            {# ── TAB IMPORT / REGENERATE (in tab-content, outside submit scope) ── #}
            {% if listing_id %}
            <div id="tab-import" class="tab-pane">

          {# ─── SECTION 1: CSV IMPORT ─────────────────────────────────── #}
          <div class="card mb-3 mt-3">
            <div class="card-header"><i class="fa fa-upload"></i> <strong>Import CSV — Add cards to this listing</strong></div>
            <div class="card-body">
              <p class="text-muted">Format CSV: same as Variant Listing Creator (<code>title, sale_price, card_number, player, team, year, brand, condition, front_image, back_image</code>)</p>

              <div class="row mb-3">
                <div class="col-sm-6">
                  <label class="form-label">CSV File</label>
                  <input type="file" id="import-csv-file" accept=".csv" class="form-control"/>
                </div>
                <div class="col-sm-6 d-flex align-items-end gap-2">
                  <button type="button" id="btn-import-preview" class="btn btn-secondary">
                    <i class="fa fa-eye"></i> Preview
                  </button>
                  <button type="button" id="btn-import-confirm" class="btn btn-success" style="display:none;">
                    <i class="fa fa-check"></i> Confirm Import
                  </button>
                  <button type="button" id="btn-import-cancel" class="btn btn-outline-secondary" style="display:none;">
                    <i class="fa fa-times"></i> Cancel
                  </button>
                </div>
              </div>

              {# Import status #}
              <div id="import-status" style="display:none;" class="alert alert-info">
                <i class="fa fa-spinner fa-spin"></i> <span id="import-status-text">Processing...</span>
              </div>

              {# Preview panel #}
              <div id="import-preview-panel" style="display:none;">
                <div class="alert alert-secondary mb-2">
                  <strong>Preview:</strong> <span id="import-preview-stats"></span>
                </div>
                <div id="import-preview-html" style="max-height: 500px; overflow-y: auto;"></div>
              </div>
            </div>
          </div>

          {# ─── SECTION 2: REGENERATE ─────────────────────────────────── #}
          <div class="card mb-3">
            <div class="card-header"><i class="fa fa-refresh"></i> <strong>Regenerate — Merge duplicates &amp; rebuild description</strong></div>
            <div class="card-body">
              <p class="text-muted">
                Groups cards by <strong>card_number + player</strong>. Merges quantities, takes highest price, consolidates photos, 
                deletes duplicates from <code>oc_card</code>, and rebuilds the EN description.
              </p>

              {# Live preview before regenerate #}
              <div id="regen-preview-panel" class="mb-3" style="display:none;"></div>

              <div class="d-flex gap-2 flex-wrap">
                <button type="button" id="btn-regen-preview" class="btn btn-secondary">
                  <i class="fa fa-eye"></i> Preview (current cards grouped)
                </button>
                <button type="button" id="btn-regenerate" class="btn btn-warning">
                  <i class="fa fa-refresh"></i> Regenerate Now
                </button>
              </div>

              <div id="regen-status" style="display:none;" class="alert alert-info mt-2">
                <i class="fa fa-spinner fa-spin"></i> <span id="regen-status-text">Processing...</span>
              </div>
            </div>
          </div>

            </div>{# /tab-import #}
            {% endif %}
          </div>{# /tab-content #}
        </form>
      </div>
    </div>
  </div>
</div>

