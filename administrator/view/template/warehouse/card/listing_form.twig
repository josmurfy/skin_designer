var URL_CONFIRM_IMPORT   = '{{ url_confirm_import }}';
var URL_REGEN_CARDS      = '{{ url_regenerate_cards }}';
var URL_MERGE_VARIANTS         = '{{ url_merge_variants }}';
var URL_PROCESS_MERGE_GROUPS  = '{{ url_process_merge_groups }}';
var URL_REGEN_PREVIEW         = '{{ url_regen_preview }}';
var URL_MIGRATE_IMAGES        = '{{ url_migrate_images }}';
var URL_SYNC_OFFERS           = '{{ url_sync_offers }}';
var URL_REPUBLISH_OFFERS      = '{{ url_republish_offers }}';
var URL_SAVE_BATCH_SPECIFICS  = '{{ url_save_batch_specifics }}';
var URL_ADD_BATCH             = '{{ url_add_batch }}';
var URL_END_BATCH             = '{{ url_end_batch }}';
// Lot eBay
var URL_PUBLISH_LOT           = '{{ url_publish_lot }}';
var URL_END_LOT               = '{{ url_end_lot }}';
var URL_LOT_PREVIEW           = '{{ url_lot_preview }}';
var URL_GENERATE_LOT_IMAGES   = '{{ url_generate_lot_images }}';
var LOT_IMAGE_BASE_URL        = '{{ lot_image_base_url }}';
var LOT_IMAGES_EMPTY          = {{ lot_images_empty is defined and lot_images_empty ? 'true' : 'false' }};
var LOT_CALCULATED_PRICE      = {{ lot_calculated.calculated_price ?? 0 }};
var TEXT_LOT_CONFIRM_PUBLISH  = '{{ text_lot_confirm_publish|escape('js') }}';
var TEXT_LOT_CONFIRM_END      = '{{ text_lot_confirm_end|escape('js') }}';
var TEXT_LOT_PRICE_ERROR      = '{{ text_lot_price_error|escape('js') }}';
var TEXT_LOT_PUBLISHED_OK     = '{{ text_lot_published_ok|escape('js') }}';
var TEXT_LOT_PUBLISHED_LIVE   = '{{ text_lot_published_live|escape('js') }}';
var TEXT_LOT_ENDED_OK         = '{{ text_lot_ended_ok|escape('js') }}';
var TEXT_LOT_PUBLISHING       = '{{ text_lot_publishing|escape('js') }}';
var BUTTON_END_LOT            = '{{ button_end_lot|escape('js') }}';
var BUTTON_PUBLISH_LOT        = '{{ button_publish_lot|escape('js') }}';
var BUTTON_LOT_REFRESH        = '{{ button_lot_refresh|escape('js') }}';
var TEXT_LETTER_MERGED       = '{{ text_letter_merged|escape('js') }}';
var TEXT_LETTER_WARN_PRICE   = '{{ text_letter_warn_price|escape('js') }}';
var TEXT_LETTER_WARN_FORMAT  = '{{ text_letter_warn_format|escape('js') }}';
var TEXT_EBAY_LIVE_WARNING   = '{{ text_ebay_live_warning|escape('js') }}';
var TEXT_PENDING_DELETES     = '{{ text_pending_deletes|escape('js') }}';
var BTN_MERGE_ANYWAY         = '{{ btn_merge_anyway|escape('js') }}';
