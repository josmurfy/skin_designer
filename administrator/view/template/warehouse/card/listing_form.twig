<script type="text/javascript" src="view/javascript/warehouse/card/listing_import.js"></script>
<script type="text/javascript">
$(document).on('click', '.btn-add-batch', function() {
    var btn = $(this);
    var batchName = btn.data('batch');
    btn.prop('disabled', true).text('...');
    $.ajax({
        url: URL_ADD_BATCH,
        type: 'POST',
        data: { listing_id: LISTING_ID, batch_name: batchName },
        dataType: 'json',
        success: function(json) {
            if (json.success && json.ebay_item_id) {
                var cell = $('#ebay-batch-cell-' + batchName);
                cell.html(
                    '<a href="https://www.ebay.ca/itm/' + json.ebay_item_id + '" target="_blank" class="small d-block mb-1">' + json.ebay_item_id + '</a>' +
                    '<button type="button" class="btn btn-danger btn-sm btn-end-batch" data-batch="' + batchName + '">End</button>'
                );
            } else {
                alert(json.error || 'Erreur lors de la publication.');
                btn.prop('disabled', false).text('Add Listing');
            }
        },
        error: function() {
            alert('Erreur AJAX.');
            btn.prop('disabled', false).text('Add Listing');
        }
    });
});
$(document).on('click', '.btn-end-batch', function() {
    var btn = $(this);
    var batchName = btn.data('batch');
    if (!confirm('Terminer le listing eBay pour le batch ' + batchName + '?')) return;
    btn.prop('disabled', true).text('...');
    $.ajax({
        url: URL_END_BATCH,
        type: 'POST',
        data: { listing_id: LISTING_ID, batch_name: batchName },
        dataType: 'json',
        success: function(json) {
            if (json.success) {
                var cell = $('#ebay-batch-cell-' + batchName);
                cell.html('<button type="button" class="btn btn-success btn-sm btn-add-batch" data-batch="' + batchName + '">Add Listing</button>');
            } else {
                alert(json.error || 'Erreur lors de la terminaison.');
                btn.prop('disabled', false).text('End');
            }
        },
        error: function() {
            alert('Erreur AJAX.');
            btn.prop('disabled', false).text('End');
        }
    });
});
</script>
{% endif %}

{% if listing_id > 0 %}
{# ─── Modal : génération mosaïques lot ─────────────────────────────── #}
<div class="modal fade" id="modalGenerateLotImages" tabindex="-1"
     data-bs-backdrop="static" data-bs-keyboard="false"
     aria-labelledby="modalGenLotLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0" style="background:#1a1a2e;color:#fff;border-radius:8px 8px 0 0;">
        <h5 class="modal-title" id="modalGenLotLabel">🖼️ Mosaic Images</h5>
      </div>
      <div class="modal-body text-center py-5" id="modalGenLotBody">
        <div class="spinner-border text-primary mb-3" role="status" style="width:3rem;height:3rem;">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="fw-bold mb-1 fs-5">Generating mosaic images&hellip;</p>
        <p class="text-muted small mb-0">Composing card images into mosaics, please wait.</p>
      </div>
      <div class="modal-footer d-none justify-content-center" id="modalGenLotFooter">
        <button type="button" class="btn btn-success px-5" data-bs-dismiss="modal">✅ Close</button>
      </div>
    </div>
  </div>
</div>
<script>
$(document).ready(function () {
  $(document).on('click', '.btn-generate-lot-mosaic', function () {
    // Reset modal
    $('#modalGenLotBody').html(
      '<div class="spinner-border text-primary mb-3" role="status" style="width:3rem;height:3rem;"><span class="visually-hidden">Loading...</span></div>' +
      '<p class="fw-bold mb-1 fs-5">Generating mosaic images&hellip;</p>' +
      '<p class="text-muted small mb-0">Composing card images into mosaics, please wait.</p>'
    );
    $('#modalGenLotFooter').addClass('d-none');

    var $modal = new bootstrap.Modal(document.getElementById('modalGenerateLotImages'));
    $modal.show();

    $.ajax({
      url      : URL_GENERATE_LOT_IMAGES,
      type     : 'POST',
      data     : { listing_id: LISTING_ID },
      dataType : 'json',
      success  : function (json) {
        if (json.success && json.images && json.images.length > 0) {
          var html = '<div class="d-flex flex-wrap gap-2 justify-content-center">';
          $.each(json.images, function (i, img) {
            html += '<a href="' + img.url + '" target="_blank">';
            html += '<img src="' + img.url + '" style="width:120px;height:120px;object-fit:cover;border:1px solid #dee2e6;border-radius:4px;"/>';
            html += '</a>';
          });
          html += '</div>';
          $('.lot-mosaic-images-panel').html(html);
          $('#modalGenLotBody').html(
            '<p class="text-success fw-bold fs-5 mb-0">✅ ' + json.images.length + ' mosaic image(s) generated!</p>'
          );
        } else {
          $('#modalGenLotBody').html(
            '<p class="text-warning fw-bold mb-0">⚠️ ' + (json.error || 'No card front images available to generate mosaics.') + '</p>'
          );
        }
        $('#modalGenLotFooter').removeClass('d-none');
      },
      error: function () {
        $('#modalGenLotBody').html('<p class="text-danger fw-bold mb-0">❌ AJAX error during mosaic generation.</p>');
        $('#modalGenLotFooter').removeClass('d-none');
      }
    });
  });
});
</script>
{% endif %}

