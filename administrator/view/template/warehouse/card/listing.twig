// Dynamic content loading for table headers and pagination
$('#listing').on('click', 'thead a, .pagination a', function(e) {
    e.preventDefault();
    
    var url = this.href;
    
    $('#listing').html('<div class="text-center"><i class="fa fa-spinner fa-spin fa-3x"></i><br/>Loading...</div>');
    
    $('#listing').load(url);
});

$('#button-filter').on('click', function() {
    var url = '';
    
    var filter_listing_id = $('input[name=\'filter_listing_id\']').val();
    if (filter_listing_id) {
        url += '&filter_listing_id=' + encodeURIComponent(filter_listing_id);
    }
    
    var filter_set_name = $('input[name=\'filter_set_name\']').val();
    if (filter_set_name) {
        url += '&filter_set_name=' + encodeURIComponent(filter_set_name);
    }
    
    var filter_card_type_id = $('select[name=\'filter_card_type_id\']').val();
    if (filter_card_type_id !== '') {
        url += '&filter_card_type_id=' + encodeURIComponent(filter_card_type_id);
    }
    
    var filter_year = $('input[name=\'filter_year\']').val();
    if (filter_year) {
        url += '&filter_year=' + encodeURIComponent(filter_year);
    }
    
    var filter_manufacturer = $('input[name=\'filter_manufacturer\']').val();
    if (filter_manufacturer) {
        url += '&filter_manufacturer=' + encodeURIComponent(filter_manufacturer);
    }
    
    var filter_location = $('input[name=\'filter_location\']').val();
    if (filter_location) {
        url += '&filter_location=' + encodeURIComponent(filter_location);
    }
    
    var filter_status = $('select[name=\'filter_status\']').val();
    if (filter_status !== '') {
        url += '&filter_status=' + encodeURIComponent(filter_status);
    }
    
    var filter_ebay_item_id = $('input[name=\'filter_ebay_item_id\']').val();
    if (filter_ebay_item_id) {
        url += '&filter_ebay_item_id=' + encodeURIComponent(filter_ebay_item_id);
    }
    
    var filter_publish_status = $('select[name=\'filter_publish_status\']').val();
    if (filter_publish_status !== '') {
        url += '&filter_publish_status=' + encodeURIComponent(filter_publish_status);
    }

    var filter_sync = $('select[name=\'filter_sync\']').val();
    if (filter_sync !== '') {
        url += '&filter_sync=' + encodeURIComponent(filter_sync);
    }

    var limit = $('#input-limit').val();
    if (limit) {
        url += '&limit=' + encodeURIComponent(limit);
    }
    
    // Update URL in browser without page reload
    window.history.pushState({}, null, 'index.php?route=shopmanager/card/card_listing&user_token={{ user_token }}' + url);
    
    // Load list content via AJAX
    $('#listing').load('index.php?route=shopmanager/card/card_listing.list&user_token={{ user_token }}' + url);
});

// Reset filters
$('#button-reset-filters').on('click', function() {
    // Clear all form inputs and selects
    $('#form-filter input, #form-filter select').each(function() {
        $(this).val('');
    });
    
    // Reload list without filters
    window.history.pushState({}, null, 'index.php?route=shopmanager/card/card_listing&user_token={{ user_token }}');
    $('#listing').load('index.php?route=shopmanager/card/card_listing.list&user_token={{ user_token }}');
});

// Trigger filter on Enter key
$('input[name^=\'filter_\']').on('keydown', function(e) {
    if (e.which == 13) {
        $('#button-filter').trigger('click');
    }
});

// Autocomplete for Set Name
$('#input-set-name').autocomplete({
    'source': function(request, response) {
        $.ajax({
            url: 'index.php?route=shopmanager/card/card_listing.autocomplete&user_token={{ user_token }}&filter_set_name=' + encodeURIComponent(request),
            dataType: 'json',
            success: function(json) {
                response($.map(json, function(item) {
                    return {
                        label: item['label'],
                        value: item['value']
                    };
                }));
            }
        });
    },
    'select': function(item) {
        $('#input-set-name').val(item['label']);
    }
});

// Autocomplete for Manufacturer
$('#input-manufacturer').autocomplete({
    'source': function(request, response) {
        $.ajax({
            url: 'index.php?route=shopmanager/card/card_listing.autocomplete&user_token={{ user_token }}&filter_manufacturer=' + encodeURIComponent(request),
            dataType: 'json',
            success: function(json) {
                response($.map(json, function(item) {
                    return {
                        label: item['label'],
                        value: item['value']
                    };
                }));
            }
        });
    },
    'select': function(item) {
        $('#input-manufacturer').val(item['label']);
    }
});
</script>

<!-- Loading Popup for eBay Publishing -->
<div id="loading-popup" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background-color:rgba(0,0,0,0.6); z-index:9999;">
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:#fff; padding:20px 30px; border-radius:8px; width:500px; max-width:90%; box-shadow:0 0 15px rgba(0,0,0,0.3); text-align:center;">
        <div id="loading-spinner" style="margin-bottom:10px;">
            <img src="https://i.imgur.com/llF5iyg.gif" width="50" alt="Loading..."> <!-- Spinner GIF -->
        </div>
        <h4 id="loading-title" style="color:#0056b3; margin-bottom:15px;">Publication sur eBay...</h4>
        <div id="loading-messages" style="max-height:300px; overflow-y:auto; text-align:left; margin-top:10px; font-size:13px; line-height:1.6; padding:10px; background:#f8f9fa; border-radius:5px;"></div>
        <button onclick="hideLoadingPopup()" style="margin-top:15px; display:none; padding:8px 20px; background:#0056b3; color:#fff; border:none; border-radius:5px; cursor:pointer;" id="close-loading-btn">Fermer</button>
    </div>
</div>

{{ footer }}
