{# Original: shopmanager/card/card_listing.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" data-bs-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-listing').toggleClass('d-none');" class="btn btn-light d-lg-none"><i class="fa-solid fa-filter"></i></button>
        <a href="{{ add }}" data-bs-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i></a>
        <button type="submit" form="form-listing" formaction="{{ delete }}" data-bs-toggle="tooltip" title="{{ button_delete }}" onclick="return confirm('{{ text_confirm }}');" class="btn btn-danger"><i class="fa-regular fa-trash-can"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div id="filter-listing" class="col-lg-3 col-md-12 order-lg-last d-none d-lg-block mb-3">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-filter"></i> {{ text_filter }} <button type="button" id="button-reset-filters" class="btn btn-sm btn-outline-secondary float-end" data-bs-toggle="tooltip" title="{{ button_reset }}"><i class="fa-solid fa-redo"></i></button></div>
          <div class="card-body">
            <form id="form-filter">
            <div class="mb-3">
              <label for="input-listing-id" class="form-label">{{ entry_listing_id }}</label>
              <input type="text" name="filter_listing_id" value="{{ filter_listing_id }}" placeholder="{{ entry_listing_id }}" id="input-listing-id" class="form-control"/>
            </div>
            <div class="mb-3">
              <label for="input-set-name" class="form-label">{{ entry_set_name }}</label>
              <input type="text" name="filter_set_name" value="{{ filter_set_name }}" placeholder="{{ entry_set_name }}" id="input-set-name" data-oc-target="autocomplete-set-name" class="form-control" autocomplete="off"/>
              <ul id="autocomplete-set-name" class="dropdown-menu"></ul>
            </div>
            <div class="mb-3">
              <label for="input-card-type" class="form-label">{{ entry_sport }}</label>
              <select name="filter_card_type_id" id="input-card-type" class="form-select" onchange="$('#button-filter').trigger('click');">
                <option value=""></option>
                {% for card_type in card_types %}
                  {% if filter_card_type_id == card_type.card_type_id %}
                    <option value="{{ card_type.card_type_id }}" selected>{{ card_type.name }}</option>
                  {% else %}
                    <option value="{{ card_type.card_type_id }}">{{ card_type.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
            <div class="mb-3">
              <label for="input-year" class="form-label">{{ entry_year }}</label>
              <input type="text" name="filter_year" value="{{ filter_year }}" placeholder="{{ entry_year }}" id="input-year" class="form-control"/>
            </div>
            <div class="mb-3">
              <label for="input-manufacturer" class="form-label">{{ entry_manufacturer }}</label>
              <input type="text" name="filter_manufacturer" value="{{ filter_manufacturer }}" placeholder="{{ entry_manufacturer }}" id="input-manufacturer" data-oc-target="autocomplete-manufacturer" class="form-control" autocomplete="off"/>
              <ul id="autocomplete-manufacturer" class="dropdown-menu"></ul>
            </div>
            <div class="mb-3">
              <label for="input-location" class="form-label">{{ entry_location }}</label>
              <input type="text" name="filter_location" value="{{ filter_location }}" placeholder="{{ entry_location }}" id="input-location" class="form-control"/>
            </div>
            <div class="mb-3">
              <label for="input-status" class="form-label">{{ entry_status }}</label>
              <select name="filter_status" id="input-status" class="form-select" onchange="$('#button-filter').trigger('click');">
                <option value=""></option>
                {% if filter_status == '1' %}
                  <option value="1" selected>{{ text_enabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                {% endif %}
                {% if filter_status == '0' %}
                  <option value="0" selected>{{ text_disabled }}</option>
                {% else %}
                  <option value="0">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
            <div class="mb-3">
              <label for="input-ebay-item-id" class="form-label">{{ entry_ebay_item_id }}</label>
              <input type="text" name="filter_ebay_item_id" value="{{ filter_ebay_item_id }}" placeholder="{{ entry_ebay_item_id }}" id="input-ebay-item-id" class="form-control"/>
            </div>
            <div class="mb-3">
              <label for="input-publish-status" class="form-label">Statut eBay</label>
              <select name="filter_publish_status" id="input-publish-status" class="form-select" onchange="$('#button-filter').trigger('click');">
                <option value="">-- Tous --</option>
                <option value="none" {% if filter_publish_status == 'none' %}selected{% endif %}>Non publié</option>
                <option value="partial" {% if filter_publish_status == 'partial' %}selected{% endif %}>Partiel</option>
                <option value="full" {% if filter_publish_status == 'full' %}selected{% endif %}>Publié</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="input-sync" class="form-label"><i class="fa-solid fa-heart-pulse"></i> Sync eBay</label>
              <select name="filter_sync" id="input-sync" class="form-select" onchange="$('#button-filter').trigger('click');">
                <option value="">-- Tous --</option>
                <option value="1" {% if filter_sync == '1' %}selected{% endif %}>À synchroniser</option>
                <option value="0" {% if filter_sync == '0' %}selected{% endif %}>Synchronisé</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="input-limit" class="form-label">{{ entry_limit }}</label>
              <select name="limit" id="input-limit" class="form-select">
                {% for option in per_page_options %}
                  <option value="{{ option }}" {% if limit == option %}selected{% endif %}>{{ option }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="text-end">
              <button type="button" id="button-filter" class="btn btn-light"><i class="fa-solid fa-filter"></i> {{ button_filter }}</button>
            </div>
            </form>
          </div>
        </div>
      </div>
      <div class="col-lg-9 col-md-12">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-list"></i> {{ text_list }}</div>
          <div id="listing" class="card-body">{{ list }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
