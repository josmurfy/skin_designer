{# Original: warehouse/card/search.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" data-bs-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-search').toggleClass('d-none');" class="btn btn-light d-lg-none"><i class="fa-solid fa-filter"></i></button>
      </div>
      <h1><i class="fa-solid fa-magnifying-glass-dollar"></i> {{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    <div class="row">
      {# ── RIGHT: Filter panel (all dropdowns) ── #}
      <div id="filter-search" class="col-lg-3 col-md-12 order-lg-last d-none d-lg-block mb-3">
        <div class="card border-primary">
          <div class="card-header bg-primary text-white">
            <i class="fa-solid fa-filter"></i> {{ button_filter }}
            <button type="button" id="button-reset-filters" class="btn btn-sm btn-outline-light float-end" data-bs-toggle="tooltip" title="{{ button_reset }}"><i class="fa-solid fa-redo"></i></button>
          </div>
          <div class="card-body">
            <form id="form-filter">
              <input type="hidden" name="user_token" value="{{ user_token }}">

              {# Set Name (primary filter) #}
              <div class="mb-2">
                <label for="input-set" class="form-label">{{ entry_set_name }}</label>
                <select name="filter_set" id="input-set" class="form-select form-select-sm cascade-filter">
                  <option value="">{{ text_all }}</option>
                  {% for val in options_set_name %}
                    <option value="{{ val }}" {% if val == filter_set %}selected{% endif %}>{{ val }}</option>
                  {% endfor %}
                </select>
              </div>

              {# Year #}
              <div class="mb-2">
                <label for="input-year" class="form-label">{{ entry_year }}</label>
                <select name="filter_year" id="input-year" class="form-select form-select-sm cascade-filter">
                  <option value="">{{ text_all }}</option>
                  {% for val in options_year %}
                    <option value="{{ val }}" {% if val == filter_year %}selected{% endif %}>{{ val }}</option>
                  {% endfor %}
                </select>
              </div>

              {# Category (Sport) #}
              <div class="mb-2">
                <label for="input-category" class="form-label">{{ entry_category }}</label>
                <select name="filter_category" id="input-category" class="form-select form-select-sm cascade-filter">
                  <option value="">{{ text_all }}</option>
                  {% for val in options_category %}
                    <option value="{{ val }}" {% if val == filter_category %}selected{% endif %}>{{ val }}</option>
                  {% endfor %}
                </select>
              </div>

              {# Brand #}
              <div class="mb-2">
                <label for="input-brand" class="form-label">{{ entry_brand }}</label>
                <select name="filter_brand" id="input-brand" class="form-select form-select-sm cascade-filter">
                  <option value="">{{ text_all }}</option>
                  {% for val in options_brand %}
                    <option value="{{ val }}" {% if val == filter_brand %}selected{% endif %}>{{ val }}</option>
                  {% endfor %}
                </select>
              </div>

              {# Player #}
              <div class="mb-2">
                <label for="input-player" class="form-label">{{ entry_player }}</label>
                <select name="filter_player" id="input-player" class="form-select form-select-sm cascade-filter">
                  <option value="">{{ text_all }}</option>
                  {% for val in options_player %}
                    <option value="{{ val }}" {% if val == filter_player %}selected{% endif %}>{{ val }}</option>
                  {% endfor %}
                </select>
              </div>

              <hr>

              {# Price Range #}
              <div class="row mb-2">
                <div class="col-6">
                  <label for="input-min-price" class="form-label">{{ entry_min_price }}</label>
                  <input type="number" step="0.01" name="filter_min_price" value="{{ filter_min_price }}" placeholder="5.00" id="input-min-price" class="form-control form-control-sm"/>
                </div>
                <div class="col-6">
                  <label for="input-max-price" class="form-label">{{ entry_max_price }}</label>
                  <input type="number" step="0.01" name="filter_max_price" value="{{ filter_max_price }}" placeholder="" id="input-max-price" class="form-control form-control-sm"/>
                </div>
              </div>

              {# Per page #}
              <div class="mb-2">
                <label for="input-limit" class="form-label">{{ entry_limit }}</label>
                <select name="limit" id="input-limit" class="form-select form-select-sm">
                  {% for opt in per_page_options %}
                    <option value="{{ opt }}" {% if opt == 50 %}selected{% endif %}>{{ opt }}</option>
                  {% endfor %}
                </select>
              </div>

              <div class="text-end mt-3">
                <button type="button" id="button-filter" class="btn btn-primary btn-sm w-100"><i class="fa-solid fa-filter"></i> {{ button_filter }}</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      {# ── LEFT: Results area ── #}
      <div class="col-lg-9 col-md-12">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-list"></i> {{ text_list }}</div>
          <div class="card-body">
            <div id="search-list">
              {% if list %}
                {{ list }}
              {% else %}
                <div class="text-center text-muted py-5">
                  <i class="fa-solid fa-magnifying-glass fa-3x mb-3"></i>
                  <p>{{ text_select_filters }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// ─── i18n variables for search.js ───
var USER_TOKEN       = '{{ user_token }}';
var TEXT_LOADING     = '{{ text_loading|escape('js') }}';
var TEXT_NO_RESULTS  = '{{ text_no_results|escape('js') }}';
var TEXT_ALL         = '{{ text_all|escape('js') }}';

var URL_SEARCH_LIST    = 'index.php?route=warehouse/card/search.list&user_token={{ user_token }}';
var URL_FILTER_OPTIONS = 'index.php?route=warehouse/card/search.filterOptions&user_token={{ user_token }}';
</script>
{{ footer }}
