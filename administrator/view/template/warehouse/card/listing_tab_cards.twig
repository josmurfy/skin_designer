{# Original: shopmanager/card/card_listing_tab_cards.twig #}
<h4>{{ text_cards_list }}</h4>
<p class="text-muted">{{ help_cards_list }}</p>

{% if cards_total > 0 %}
  <div class="mb-2 d-flex align-items-center gap-2">
   
    <button type="button" id="btn-fetch-market-prices" class="btn btn-sm btn-outline-info">
      <i class="fa-solid fa-magnifying-glass-dollar"></i> {{ button_fetch_market_prices }}
    </button>
    <span id="market-price-progress" class="text-muted" style="font-size:0.85em;"></span>
  </div>
  <div class="table-responsive">
    <table class="table table-bordered table-hover" id="cards-table"
           data-listing-id="{{ listing_id }}"
           data-total="{{ cards_total }}"
           data-sort="c.card_number"
           data-order="ASC"
           data-url-get-cards="{{ url_get_cards }}"
           data-url-fetch-market-price="{{ url_fetch_market_price }}"
           data-own-list-label="{{ text_our_ebay_price|escape('html_attr') }}"
           data-variant-label="{{ text_variant_short|escape('html_attr') }}"
           data-market-manual-sold-graded-label="{{ text_market_manual_sold_graded|default('Sold Graded')|escape('html_attr') }}"
           data-market-progress-label="{{ text_market_price_progress|default('Fetching prices...')|escape('html_attr') }}"
           data-market-progress-done="{{ text_market_fetch_progress_done|default('prices updated.')|escape('html_attr') }}"
           data-market-progress-limit="{{ text_market_api_limit_reached|default('eBay API limit reached. Stopping checks.')|escape('html_attr') }}"
           data-market-progress-fallback="{{ text_market_fallback_kept|default('Manual buttons displayed for the remaining rows.')|escape('html_attr') }}"
           data-page="1"
           data-limit="25">
      <thead>
        <tr>
          <th style="width: 30px;" class="text-center">
            <input type="checkbox" id="cards-select-all" class="form-check-input" />
          </th>
          <th style="width: 200px;">{{ column_image }}</th>
          <th style="width: 150px; cursor: pointer;" class="sortable" data-sort="c.player_name">
            {{ column_player }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 100px; cursor: pointer;" class="sortable" data-sort="c.card_number">
            {{ column_card_number }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 60px; cursor: pointer;" class="sortable" data-sort="c.batch_name">Batch <i class="fa fa-sort"></i></th>
          <th style="width: 100px; cursor: pointer;" class="sortable" data-sort="c.price">
            {{ column_price }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 90px; cursor: pointer;" class="sortable" data-sort="c.price_sold" title="Lowest auction price (eBay, CAD)">
            {{ column_price_sold }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 90px; cursor: pointer;" class="sortable" data-sort="c.price_list" title="Lowest buy now price (eBay, CAD)">
            {{ column_price_list }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 100px; cursor: pointer;" class="sortable" data-sort="c.raw_price">
            {{ column_raw_price }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 100px; cursor: pointer;" class="sortable" data-sort="c.quantity">
            {{ column_quantity }} <i class="fa fa-sort"></i>
          </th>
          <th style="width: 80px;">{{ column_merge }}</th>
          <th style="width: 60px;">{{ column_action }}</th>
        </tr>
      </thead>
      <tbody id="cards-tbody">
        {% for card in cards %}
          {% set market_keyword = '' %}
          {% if card.title is defined and card.title is not empty %}
            {% set market_keyword = card.title %}
          {% endif %}
          {% if market_keyword is empty and set_name is defined and set_name is not empty %}
            {% set market_keyword = set_name %}
          {% endif %}
          {% if market_keyword is empty and card.player_name is defined and card.player_name is not empty %}
            {% set market_keyword = card.player_name %}
          {% endif %}
          {% if market_keyword is empty and card.card_number is defined and card.card_number is not empty %}
            {% set market_keyword = '#' ~ card.card_number %}
          {% endif %}
          {% if market_keyword is empty and card.brand is defined and card.brand is not empty %}
            {% set market_keyword = card.brand %}
          {% endif %}
          {% if market_keyword is empty and card.year is defined and card.year is not empty %}
            {% set market_keyword = card.year %}
          {% endif %}
          {% set market_keyword_raw = market_keyword|trim %}
          {% set manual_sold_graded_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&LH_Sold=1&Graded=Yes&_sop=3&_udlo=35' %}
          <tr data-card-id="{{ card.card_id }}"
              data-sku="{{ card.sku|escape('html') }}"
              data-player="{{ card.player_name|lower }}" 
              data-card-number="{{ card.card_number }}" 
              data-price="{{ card.price }}"
              data-quantity="{{ card.quantity }}"
              data-batch="{{ card.batch_name }}"
              data-keyword="{{ market_keyword|escape('html_attr') }}"
              data-price-sold="{{ card.price_sold ?? '' }}"
              data-price-list="{{ card.price_list ?? '' }}"
              >
            <td class="text-center">
              <input type="checkbox" class="form-check-input card-select-checkbox" data-card-id="{{ card.card_id }}" />
            </td>
            <td>
              <div style="display: flex; gap: 5px;">
                {% if card.images|length > 0 %}
                  <div class="actual-image-container" style="width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; position: relative;">
                    <img src="{{ card.images[0] }}" alt="Card Image 1" class="img-thumbnail" style="max-width: 90px; max-height: 90px; width: auto; height: auto;"/>
                    <div class="fullsize-actual-image-wrapper">
                      <img src="{{ card.images[0] }}" alt="Card Image 1" class="fullsize-actual-image">
                    </div>
                  </div>
                {% else %}
                  <div class="text-muted" style="width: 90px; height: 90px; border: 1px dashed #ccc; display: flex; align-items: center; justify-content: center;">
                    <i class="fa fa-image"></i>
                  </div>
                {% endif %}

                {% if card.images|length > 1 %}
                  <div class="actual-image-container" style="width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; position: relative;">
                    <img src="{{ card.images[1] }}" alt="Card Image 2" class="img-thumbnail" style="max-width: 90px; max-height: 90px; width: auto; height: auto;"/>
                    <div class="fullsize-actual-image-wrapper">
                      <img src="{{ card.images[1] }}" alt="Card Image 2" class="fullsize-actual-image">
                    </div>
                  </div>
                {% else %}
                  <div class="text-muted" style="width: 90px; height: 90px; border: 1px dashed #ccc; display: flex; align-items: center; justify-content: center;">
                    <i class="fa fa-image"></i>
                  </div>
                {% endif %}
              </div>
            </td>
            <td>{{ card.player_name }}</td>
            <td>{{ card.card_number }}</td>
            <td class="text-center batch-badge-cell">
              {% set batch_colors = {1: 'primary', 2: 'success', 3: 'warning', 4: 'danger', 99: 'dark', 100: 'dark'} %}
              {% set bcolor = batch_colors[card.batch_name] ?? 'secondary' %}
              <span class="badge bg-{{ bcolor }}" title="eBay Batch {{ card.batch_name }}">B{{ card.batch_name }}</span>
            </td>
            <td>
              <input type="text" 
                     class="form-control price-input" 
                     data-card-id="{{ card.card_id }}"
                     data-original-value="{{ card.price|number_format(2, '.', '') }}"
                     value="{{ card.price|number_format(2, '.', '') }}" 
                     style="width: 80px;"/>
              {% if market_keyword_raw is not empty %}
                <div class="mt-1">
                  <a class="btn btn-sm btn-dark w-100" style="font-size:10px;padding:2px 6px;line-height:1.15;" target="ebay_market_preview" href="{{ manual_sold_graded_url|e('html_attr') }}">{{ text_market_manual_sold_graded|default('Sold Graded') }}</a>
                </div>
              {% endif %}
            </td>
            <td class="market-price-auction text-center" style="min-width:80px;">
              {% if card.price_sold is not null and card.price_sold is not empty %}
                {% set ps = card.price_sold|number_format(2, '.', '') %}
                <span style="font-weight:700;color:#fff;background:{{ ps <= card.price|number_format(2, '.', '') ? '#28a745' : '#dc3545' }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ ps }}</span>
              {% else %}
                <span class="text-muted">—</span>
              {% endif %}
            </td>
            <td class="market-price-list text-center" style="min-width:80px;">
              {% if card.price_list is not null and card.price_list is not empty %}
                {% set pl = card.price_list|number_format(2, '.', '') %}
                <span style="font-weight:700;color:#fff;background:{{ pl <= card.price|number_format(2, '.', '') ? '#28a745' : '#dc3545' }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ pl }}</span>
              {% else %}
                <span class="text-muted">—</span>
              {% endif %}
            </td>
            <td>
              <input type="text" 
                     class="form-control raw-price-input{% if card.raw_price_is_ref %} raw-price-ref{% endif %}" 
                     data-card-id="{{ card.card_id }}"
                     data-original-value="{{ card.raw_price is not null ? card.raw_price|number_format(2, '.', '') : '' }}"
                     data-is-ref="{{ card.raw_price_is_ref ? '1' : '0' }}"
                     value="{{ card.raw_price is not null ? card.raw_price|number_format(2, '.', '') : '' }}" 
                     placeholder="—"
                     {% if card.raw_price_is_ref %}title="Valeur de référence (oc_card_price) — modifier pour l'enregistrer"{% endif %}
                     style="width: 80px;"/>
            </td>
            <td>
              <input type="text" 
                     class="form-control quantity-input" 
                     data-card-id="{{ card.card_id }}"
                     data-original-value="{{ card.quantity }}"
                     value="{{ card.quantity }}" 
                     style="width: 80px;"/>
            </td>
            <td>
              {% if card.merge == 1 %}
                <span class="badge bg-success">{{ text_yes }}</span>
              {% else %}
                <span class="badge bg-secondary">{{ text_no }}</span>
              {% endif %}
            </td>
            <td>
              <button type="button" class="btn btn-sm btn-primary edit-card" data-card-id="{{ card.card_id }}">
                <i class="fa fa-pencil"></i>
              </button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <div id="cards-load-sentinel" style="height:1px;"></div>
    <div id="cards-loading-indicator" style="display:none; text-align:center; padding:12px;">
      <i class="fa fa-spinner fa-spin"></i> Chargement...
    </div>
  </div>
{% else %}
  <div class="alert alert-info">
    <i class="fa-solid fa-info-circle"></i> {{ text_no_cards }}
  </div>
{% endif %}

<style>
.drag-handle {
  cursor: move;
}
.raw-price-ref {
  color: #888;
  font-style: italic;
  background-color: #f8f9fa !important;
}
.raw-price-ref:focus {
  color: inherit;
  font-style: normal;
  background-color: #fff !important;
}
.fullsize-actual-image-wrapper {
  display: none;
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 9999;
  background: white;
  border: 3px solid #333;
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
  max-width: 90vw; max-height: 90vh;
  padding: 10px;
}
.fullsize-actual-image {
  max-width: 100%; max-height: 85vh;
  width: auto; height: auto;
  display: block;
}
#temp-fullsize-preview {
  display: block !important;
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 9999;
  background: white;
  border: 3px solid #333;
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
  max-width: 90vw; max-height: 90vh;
  padding: 10px;
}
#temp-fullsize-preview .fullsize-actual-image {
  max-width: 100%; max-height: 85vh;
  width: auto; height: auto;
  display: block;
}
</style>

<script type="text/javascript" src="view/javascript/shopmanager/card/card_listing_tab_cards.js?v={{ 'now'|date('U') }}"></script>
