{# Original: warehouse/card/import/active.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1><i class="fa-solid fa-chart-line me-2"></i>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">

    <!-- FETCH PANEL -->
    <div class="card mb-3">
      <div class="card-header">
        <i class="fa-brands fa-ebay me-2"></i>{{ text_fetch }}
      </div>
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label">{{ text_keyword }}</label>
            <input type="text" id="fetch-keyword" class="form-control" placeholder="e.g. 1991-92 O-Pee-Chee Hockey">
            {% if categories %}
            <div class="d-flex gap-2 mt-1">
              <select id="fetch-sport-select" class="form-select form-select-sm" onchange="cpaFilterSetsByCategory(this.value)" style="max-width:140px;">
                <option value="">— Sport —</option>
                {% for cat in categories %}
                <option value="{{ cat.category|escape('html_attr') }}">{{ cat.category|capitalize }}</option>
                {% endfor %}
              </select>
              <select id="fetch-card-select" class="form-select form-select-sm flex-grow-1" onchange="cpaFillKeywordFromSet(this)">
                <option value="">— {{ text_select_card_without_price|default('Set without prices') }} {% if cards_without_prices %}({{ cards_without_prices|length }}){% endif %} —</option>
                {% for s in cards_without_prices %}
                <option value="{{ s.year|escape('html_attr') }} {{ s.brand|escape('html_attr') }}{% if s.set_name and s.set_name != s.brand %} {{ s.set_name|escape('html_attr') }}{% endif %}"
                        data-category="{{ s.category|escape('html_attr') }}"
                        data-year="{{ s.year|escape('html_attr') }}"
                        data-brand="{{ s.brand|escape('html_attr') }}"
                        data-set="{{ s.set_name|escape('html_attr') }}"
                        data-count="{{ s.card_count }}">
                  {% if s.category %}[{{ s.category }}] {% endif %}{{ s.year }} {{ s.brand }}{% if s.set_name and s.set_name != s.brand %} — {{ s.set_name }}{% endif %} <small>({{ s.card_count }} cards)</small>
                </option>
                {% endfor %}
              </select>
            </div>
            {% endif %}
          </div>
          <div class="col-md-2">
            <label class="form-label">{{ text_site }}</label>
            <select id="fetch-site" class="form-select">
              <option value="0">eBay US</option>
              <option value="2" selected>eBay CA</option>
              <option value="3">eBay UK</option>
              <option value="77">eBay DE</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">{{ text_condition }}</label>
            <select id="fetch-condition" class="form-select">
              <option value="all">{{ text_all_conditions }}</option>
              <option value="raw">Raw Only</option>
              <option value="graded">Graded Only</option>
            </select>
          </div>
          <div class="col-md-2">
            <div class="d-flex gap-2">
              <button id="btn-fetch" class="btn btn-primary w-100" onclick="cpaFetchFromEbay()">
                <i class="fa-solid fa-download me-1"></i>{{ text_fetch }}
              </button>
            </div>
          </div>
        </div>

        <!-- Raw stats bar -->
        <div id="raw-stats-bar" class="mt-3 p-2 bg-light rounded border small text-muted" style="display:none;">
          <i class="fa-solid fa-database me-1"></i>
          <span id="raw-stats-text"></span>
        </div>

        <!-- Alert zone -->
        <div id="fetch-alert" class="mt-2" style="display:none;"></div>
      </div>
    </div>

    <!-- FILTER PANEL -->
    <div class="card mb-3">
      <div class="card-header">
        <i class="fa-solid fa-filter me-2"></i>{{ text_filter }}
      </div>
      <div class="card-body">
        <form method="get" id="form-filter">
          <input type="hidden" name="route" value="warehouse/card/import/active">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="row g-2 align-items-end">
            <div class="col-md-3">
              <label class="form-label">{{ text_keyword }}</label>
              <input type="text" name="filter_keyword" class="form-control" value="{{ filter_keyword }}">
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ text_condition }}</label>
              <select name="filter_is_graded" class="form-select">
                <option value="">{{ text_all_conditions }}</option>
                <option value="0" {% if filter_is_graded == '0' %}selected{% endif %}>Raw</option>
                <option value="1" {% if filter_is_graded == '1' %}selected{% endif %}>Graded</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ text_grader }}</label>
              <select name="filter_grader" class="form-select">
                <option value="">{{ text_all_graders }}</option>
                <option value="PSA"  {% if filter_grader == 'PSA'  %}selected{% endif %}>PSA</option>
                <option value="BGS"  {% if filter_grader == 'BGS'  %}selected{% endif %}>BGS</option>
                <option value="SGC"  {% if filter_grader == 'SGC'  %}selected{% endif %}>SGC</option>
                <option value="CGC"  {% if filter_grader == 'CGC'  %}selected{% endif %}>CGC</option>
                <option value="HGA"  {% if filter_grader == 'HGA'  %}selected{% endif %}>HGA</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ text_filter }}</label>
              <input type="date" name="filter_date_from" class="form-control" value="{{ filter_date_from }}">
            </div>
            <div class="col-md-2">
              <label class="form-label">&nbsp;</label>
              <input type="date" name="filter_date_to" class="form-control" value="{{ filter_date_to }}">
            </div>
            <div class="col-md-1">
              <label class="form-label">&nbsp;</label>
              <div class="d-flex gap-1">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-magnifying-glass"></i></button>
                <a href="{{ route_fetch|replace({'fetchFromEbay': ''})|raw }}{{ user_token }}" class="btn btn-outline-secondary" onclick="this.href='index.php?route=warehouse/card/import/active&user_token={{ user_token }}'"><i class="fa-solid fa-xmark"></i></a>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- RESULTS TABLE -->
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fa-solid fa-table me-2"></i>{{ heading_title }}
          <span class="badge bg-secondary ms-1">{{ total }}</span>
        </span>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="input-group input-group-sm" style="width:260px;">
            <input type="text" id="cpa-search-input" class="form-control" placeholder="{{ text_search_placeholder }}">
            <button type="button" id="cpa-btn-search" class="btn btn-outline-secondary">
              <i class="fa-solid fa-magnifying-glass"></i> {{ button_search_title }}
            </button>
          </div>
          <button type="button" id="cpa-btn-delete-found" class="btn btn-sm btn-danger" style="display:none;">
            <i class="fa-regular fa-trash-can me-1"></i>{{ button_delete_found }}
          </button>
        </div>
        <small class="text-muted">{{ results }}</small>
      </div>
      <div id="cpa-search-banner" class="alert alert-info rounded-0 border-0 mb-0 px-3 py-2 small" style="display:none;"></div>
      <div class="card-body p-0">
        {% if records %}
        <div class="table-responsive">
          <table class="table table-hover table-striped mb-0 small">
            <thead class="table-dark">
              <tr>
                <th style="width:30px;"><input type="checkbox" id="cpa-check-all" class="form-check-input"></th>
                <th style="width:70px;">{{ column_picture }}</th>
                <th>{{ column_card }}</th>
                <th>{{ column_title }}</th>
                <th style="width:100px;">{{ column_price }}</th>
                <th style="width:120px;">{{ column_condition }}</th>
                <th style="width:80px;">{{ column_grade }}</th>
                <th style="width:80px;">{{ column_grader }}</th>
                <th style="width:100px;">{{ column_date_sold }}</th>
                <th style="width:60px;">{{ column_action }}</th>
              </tr>
            </thead>
            <tbody>
              {% for r in records %}
              <tr id="row-{{ r.active_id }}">
                <td><input type="checkbox" name="selected[]" value="{{ r.active_id }}" class="form-check-input cpa-row-check"></td>
                <td>
                  {% if r.picture %}
                  <img src="{{ r.picture }}" style="width:50px;height:50px;object-fit:cover;cursor:zoom-in;border-radius:4px;" onclick="cpaZoomImage('{{ r.picture|escape('js') }}')">
                  {% else %}
                  <span class="text-muted">—</span>
                  {% endif %}
                </td>
                <td>
                  {% if r.player %}<strong>{{ r.player }}</strong><br>{% endif %}
                  <span class="text-muted">{{ r.year }} {{ r.brand }}</span><br>
                  <span class="badge bg-light text-dark border">{{ r.card_number }}</span>
                </td>
                <td>
                  <a href="{{ r.url }}" target="_blank" class="text-decoration-none">
                    {{ r.title|slice(0, 80) }}{% if r.title|length > 80 %}…{% endif %}
                  </a>
                </td>
                <td class="fw-bold text-success">${{ r.price_usd|number_format(2) }}</td>
                <td>
                  {% if r.is_graded %}
                  <span class="badge bg-warning text-dark">Graded</span>
                  {% else %}
                  <span class="badge bg-secondary">Raw</span>
                  {% endif %}
                </td>
                <td>{{ r.grade_score ? r.grade_score : '—' }}</td>
                <td>{{ r.grader ? r.grader : '—' }}</td>
                <td class="text-muted">{{ r.date_sold|slice(0, 10) }}</td>
                <td>
                  <button class="btn btn-sm btn-outline-danger" onclick="cpaDeleteRecord({{ r.active_id }})" title="Delete">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <div class="p-5 text-center text-muted">
          <i class="fa-solid fa-magnifying-glass fa-3x d-block mb-3 opacity-25"></i>
          <p>{{ text_no_results }}</p>
        </div>
        {% endif %}
      </div>
      {% if pagination %}
      <div class="card-footer d-flex justify-content-end">
        {{ pagination|raw }}
      </div>
      {% endif %}
    </div>

  </div><!-- /container-fluid -->
</div><!-- /content -->

<!-- Image zoom popup -->
<div id="cpa-img-popup" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.8);z-index:9999;align-items:center;justify-content:center;cursor:zoom-out;" onclick="this.style.display='none'">
  <img id="cpa-img-popup-src" src="" style="max-width:90vw;max-height:90vh;border-radius:6px;box-shadow:0 4px 32px #000;">
</div>

<script>
var ROUTE_FETCH   = '{{ route_fetch|escape('js') }}';
var ROUTE_PROCESS = '{{ route_process|escape('js') }}';
var ROUTE_DELETE  = '{{ route_delete|escape('js') }}';
var TEXT_CONFIRM_DELETE  = '{{ text_confirm_delete|escape('js') }}';
var TEXT_FETCHING        = '{{ text_fetching|escape('js') }}';
var TEXT_PROCESSING      = '{{ text_processing|escape('js') }}';
var TEXT_NO_RESULTS      = '{{ text_no_results|escape('js') }}';
var TEXT_RAW_STATS       = '{{ text_raw_stats|escape('js') }}';
var TEXT_SEARCH_FOUND    = '{{ text_search_found|escape('js') }}';
var TEXT_SEARCH_NONE     = '{{ text_search_none|escape('js') }}';
</script>
<script src="view/javascript/warehouse/card/import/active.js"></script>

<!-- eBay Fetch Progress Modal -->
<div class="modal fade" id="cpa-fetch-modal" tabindex="-1" aria-labelledby="cpaFetchModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="cpaFetchModalLabel">
          <i class="fa-brands fa-ebay me-2"></i>{{ text_fetch }} eBay
        </h5>
      </div>
      <div class="modal-body">
        <p id="cpa-fetch-status" class="mb-2 fw-semibold">Connecting to eBay...</p>
        <div class="progress mb-2" style="height:24px;">
          <div id="cpa-fetch-bar"
               class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
               role="progressbar"
               style="width:0%;">0%</div>
        </div>
        <p id="cpa-fetch-detail" class="text-end text-muted small mb-0"></p>
        <p id="cpa-fetch-step" class="text-muted small mt-1 mb-0">
          <i class="fa-solid fa-circle-notch fa-spin me-1"></i>Step 1/2: Fetching from eBay...
        </p>
      </div>
    </div>
  </div>
</div>

{{ footer }}
