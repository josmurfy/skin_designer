{# Original: shopmanager/card/import/card_importer_list.twig #}
<form id="form-preview-data">
  <style>
    /* Cache buster: {{ "now"|date("U") }} - Display real min/max price range */
    .field-warning {
      background-color: #ffe6e6 !important;
      border-color: #dc3545 !important;
    }
    .field-warning:focus {
      box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25) !important;
    }
    .image-preview {
      max-width: 60px;
      max-height: 60px;
      object-fit: cover;
      border: 1px solid #ddd;
      border-radius: 4px;
    }
    
    /* Brand Group Styles */
    .brand-group {
      border-bottom: 1px solid #e0e0e0;
      background: white;
      transition: all 0.3s ease;
    }
    .brand-group:last-child {
      border-bottom: none;
    }
    .brand-group.existing-listing {
      background: #fff3cd;
      border-left: 4px solid #ffc107;
      border-right: 4px solid #ffc107;
    }
    
    /* Category Color System */
    .brand-group.category-gray {
      border-left: 5px solid #6c757d;
      background: linear-gradient(to right, rgba(108, 117, 125, 0.05) 0%, rgba(108, 117, 125, 0.02) 100%);
    }
    .brand-group.category-blue {
      border-left: 5px solid #0d6efd;
      background: linear-gradient(to right, rgba(13, 110, 253, 0.05) 0%, rgba(13, 110, 253, 0.02) 100%);
    }
    .brand-group.category-orange {
      border-left: 5px solid #fd7e14;
      background: linear-gradient(to right, rgba(253, 126, 20, 0.05) 0%, rgba(253, 126, 20, 0.02) 100%);
    }
    .brand-group.category-gold {
      border-left: 5px solid #ffc107;
      background: linear-gradient(to right, rgba(255, 193, 7, 0.05) 0%, rgba(255, 193, 7, 0.02) 100%);
    }
    
    /* Price-based Row Coloring - REMOVED (consolidated below) */
    
    .category-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .category-badge.category-gray {
      background: #6c757d;
      color: white;
    }
    .category-badge.category-blue {
      background: #0d6efd;
      color: white;
    }
    .category-badge.category-orange {
      background: #fd7e14;
      color: white;
    }
    .category-badge.category-gold {
      background: #ffc107;
      color: #000;
    }
    .brand-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 0.75rem 1.25rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
    }
    .brand-group.existing-listing .brand-header {
      background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
      color: #000;
    }
    .brand-header:hover {
      background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }
    .brand-group.existing-listing .brand-header:hover {
      background: linear-gradient(135deg, #ff9800 0%, #ffc107 100%);
    }
    .existing-badge {
      background: rgba(255, 255, 255, 0.3);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: bold;
      margin-left: 10px;
    }
    .brand-stats {
      display: flex;
      gap: 15px;
      font-size: 0.9rem;
    }
    .brand-stats span {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    
    /* Compact Table */
    .cards-table {
      margin: 0;
      font-size: 0.85rem;
    }
    .cards-table td, .cards-table th {
      padding: 0.5rem;
      vertical-align: middle;
    }
    .cards-table input, .cards-table select {
      font-size: 0.85rem;
      padding: 0.25rem 0.5rem;
    }
    
    /* Price-based row coloring - FORCE OVERRIDE BOOTSTRAP */
    table.table.cards-table tbody tr.price-gray,
    table.table.cards-table tbody tr.price-gray td {
      background-color: #a9a9a9 !important; /* Dark gray for <$2 */
    }
    table.table.cards-table tbody tr.price-blue,
    table.table.cards-table tbody tr.price-blue td {
      background-color: #84b6f4 !important; /* Medium blue for $2-$10 */
    }
    table.table.cards-table tbody tr.price-orange,
    table.table.cards-table tbody tr.price-orange td {
      background-color: #ffad60 !important; /* Medium orange for $10-$50 */
    }
    table.table.cards-table tbody tr.price-gold,
    table.table.cards-table tbody tr.price-gold td {
      background-color: #ffcc00 !important; /* Bright gold for >$50 */
    }
    table.table.cards-table tbody tr.price-missing,
    table.table.cards-table tbody tr.price-missing td {
      background-color: #fde8e8 !important;
      border-color: #f5c2c2 !important;
    }
    table.table.cards-table tbody tr.price-missing:hover td {
      background-color: #fbd0d0 !important;
    }
    table.table.cards-table tbody tr.price-gray:hover td,
    table.table.cards-table tbody tr.price-blue:hover td,
    table.table.cards-table tbody tr.price-orange:hover td,
    table.table.cards-table tbody tr.price-gold:hover td {
      background-color: #5cb3ff !important; /* Bright blue on hover */
    }
    
    /* Group title input */
    .group-title-input {
      background: #f8f9fa;
      border: 2px solid #667eea;
      font-weight: 600;
      font-size: 0.95rem;
    }
    
    /* Filter Buttons */
    .filter-buttons {
      text-align: center;
    }
    .filter-buttons .btn {
      margin: 0.25rem;
      border-radius: 20px;
      font-weight: 600;
    }

    .market-manual-wrap {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 3px;
    }

    .market-manual-btn {
      font-size: 10px;
      padding: 2px 6px;
      line-height: 1.15;
      white-space: nowrap;
    }

    .brand-cell {
      background: #80c090;
      border-color: #28a745 !important;
    }

    .brand-cell.brand-cell-error {
      background: #f08080 !important;
      border-color: #dc3545 !important;
    }

    .brand-cell.brand-cell-error .form-control,
    .brand-cell.brand-cell-error .brand-input,
    .brand-cell.brand-cell-error select,
    .brand-cell.brand-cell-error input {
      background: #f08080 !important;
      border-color: #dc3545 !important;
      color: #1f1f1f !important;
    }
  </style>
  
  {% if groups is defined and groups is not empty %}
    <div class="alert alert-primary d-flex flex-wrap gap-3 align-items-center mb-3" id="preview-summary">
      <span class="fw-semibold"><i class="fa-solid fa-layer-group"></i> {{ text_remaining_listings|default('Listings remaining') }}: <span id="remaining-listings-count">0</span></span>
      <span class="fw-semibold"><i class="fa-solid fa-clone"></i> {{ text_remaining_cards|default('Cards remaining') }}: <span id="remaining-cards-count">0</span></span>
    </div>

  {# Display groups #}
  {% for group in groups %}
      {% set group_global_index = loop.index0 %}
      <div class="brand-group {% if group.is_existing %}existing-listing{% endif %} {% if group.price_category is defined %}category-{{ group.price_category }}{% endif %}">
            <div class="brand-header" data-bs-toggle="collapse" data-bs-target="#group-{{ group_global_index }}" aria-expanded="false">
              <div>
                <i class="fa-solid fa-copyright me-2"></i>
                <strong>{{ group.set|default('') }}</strong>
                {%- if group.price_category is defined %} <span class="badge category-badge category-{{ group.price_category }} ms-2"><i class="fa-solid fa-dollar-sign"></i> {%- if group.min_price is defined and group.max_price is defined %}{%- if group.min_price == group.max_price %} ${{ group.min_price|number_format(2) }}{%- else %} ${{ group.min_price|number_format(2) }} - ${{ group.max_price|number_format(2) }}{%- endif %}{%- else %} {% if group.price_category == 'gray' %}<$2{% elseif group.price_category == 'blue' %}$2-$10{% elseif group.price_category == 'orange' %}$10-$50{% else %}>$50{% endif %}{%- endif %}</span>{%- endif %}
                {%- if group.cards[0].category is defined and group.cards[0].category is not empty %} <span class="badge bg-info ms-2"><i class="fa-solid fa-basketball"></i> {{ group.cards[0].category }}</span>{%- endif %}
                {%- if group.is_existing %} <span class="existing-badge"><i class="fa-solid fa-{{ group.set_name_match is defined and group.set_name_match ? 'layer-group' : 'triangle-exclamation' }}"></i> {{ text_already_exists }} (ID: {{ group.existing_listing_id }}{% if group.set_name_match is defined and group.set_name_match %} — set{%- endif %})</span> <span class="existing-badge ms-1 d-inline-flex align-items-center gap-1" style="background:rgba(40,167,69,0.7); padding:2px 6px;"><i class="fa-solid fa-location-dot"></i><input type="text" name="groups[{{ group_global_index }}][location]" class="border-0 p-0 fw-bold" style="background:transparent;color:#fff;width:90px;font-size:0.77em;outline:none;" value="{{ group.existing_location|default('')|e }}" placeholder="{{ text_placeholder_location }}"></span>
                {%- if group.set_name_match is defined and group.set_name_match %}
                  <label class="existing-badge ms-2 d-inline-flex align-items-center gap-1" style="background:rgba(220,53,69,0.85); padding:2px 8px; cursor:pointer; user-select:none;" title="Forcer la création d'un nouveau listing distinct">
                    <input type="checkbox"
                           class="force-new-listing-cb"
                           data-group-index="{{ group_global_index }}"
                           data-original-id="{{ group.existing_listing_id }}"
                           style="cursor:pointer;">
                    <i class="fa-solid fa-plus-circle"></i> Nouveau listing
                  </label>
                {%- endif %}
                {%- endif %}
              </div>
              <div class="brand-stats">
                <button type="button"
                        class="btn btn-sm btn-danger remove-group-btn"
                        data-group-index="{{ group_global_index }}"
                        title="{{ button_remove_listing|default('Remove listing')|e }}"
                        style="padding:2px 8px; line-height:1.3; font-size:0.75rem;"
                  onclick="event.stopPropagation(); window.removeImporterGroup && window.removeImporterGroup(this);">
                  <i class="fa-solid fa-trash"></i>
                </button>
                {%- if (group.total_quantity ?? group.card_count) != group.card_count %} <span class="{{ group.is_existing ? 'text-dark' : 'text-white' }} ms-2">({{ group.card_count }} {{ text_unique }})</span>{%- endif %}
                <span>{{ text_total_prefix }} {{ group.total_quantity ?? group.card_count }} {{ text_cards }}</span>
              
                {%- if group.group_total_value is defined and group.group_total_value > 0 %} <span class="ms-3"><i class="fa-solid fa-dollar-sign"></i> <strong>{{ group.group_total_value|number_format(2) }}</strong></span>{%- endif %}
              </div>
            </div>
            
            <div id="group-{{ group_global_index }}" class="collapse {% if loop.first %}show{% endif %}">
              <div class="p-3 bg-light">
                {# Hidden fields to pass original data from CSV #}
                <input type="hidden" 
                       name="groups[{{ group_global_index }}][key]" 
                       value="{{ group.key|default('')|e }}">
                <input type="hidden" 
                       name="groups[{{ group_global_index }}][set_name]" 
                       value="{{ group.set|default('')|e }}">
                <input type="hidden"
                       name="groups[{{ group_global_index }}][subset]"
                       value="{{ group.subset|default('')|e }}">
                <input type="hidden" 
                       name="groups[{{ group_global_index }}][existing_listing_id]" 
                       value="{{ group.existing_listing_id|default(0) }}">
                <input type="hidden" 
                       name="groups[{{ group_global_index }}][is_existing]" 
                       value="{{ group.is_existing|default(false) ? '1' : '0' }}">
                
                <div class="row mb-3">
                  <div class="col-md-12">
                    <label class="form-label fw-bold mb-2">
                      <i class="fa-solid fa-pen-to-square"></i> {{ text_ebay_title_label }}:
                    </label>
                    <input type="text" 
                           class="form-control group-title-input" 
                           name="groups[{{ group_global_index }}][title]" 
                           value="{{ group.suggested_title|default('')|e }}" 
                           placeholder="{{ text_placeholder_listing_title }}"
                           maxlength="80"
                           required>
                  </div>
                </div>
              </div>
              
              <table class="table table-bordered table-hover cards-table">
                <thead class="table-light">
                  <tr>
                    <th style="width: 40px;">#</th>
                    <th style="min-width: 250px;">{{ column_card_title }}</th>
                    <th style="width: 90px;">{{ column_price }}</th>
                    <th style="width: 110px;">{{ text_market_column_auction|default('Auction') }}</th>
                    <th style="width: 110px;">{{ text_market_column_buy_now|default('Buy Now') }}</th>
                    <th style="width: 60px;">{{ column_qty }}</th>
                    <th style="width: 130px;">{{ column_condition }}</th>
                    <th style="width: 120px;">{{ column_brand }}</th>
                    <th style="width: 200px;">{{ column_images }}</th>
                    <th style="width: 55px;" class="text-center"><i class="fa-solid fa-trash"></i></th>
                  </tr>
                </thead>
                <tbody>
                    {% for card in group.cards %}
                      {% set market_keyword = '' %}
                      {% if card.set is defined and card.set is not empty %}
                        {% set market_keyword = card.set %}
                      {% endif %}
                      {% if card.player is defined and card.player is not empty %}
                        {% set market_keyword = market_keyword ~ (market_keyword ? ' ' : '') ~ card.player %}
                      {% endif %}
                      {% if card.card_number is defined and card.card_number is not empty %}
                        {% set market_keyword = market_keyword ~ (market_keyword ? ' ' : '') ~ '#' ~ card.card_number %}
                      {% endif %}
                      {% if market_keyword is empty and card.title is defined %}
                        {% set market_keyword = card.title %}
                      {% endif %}
                      {% set market_keyword_raw = market_keyword|trim %}
                      {% set manual_auction_raw_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&_sop=2&LH_Auction=1&Graded=No' %}
                      {% set manual_auction_graded_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&_sop=2&LH_Auction=1&Graded=Yes' %}
                      {% set manual_buy_now_raw_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&_sop=2&LH_BIN=1&Graded=No' %}
                      {% set manual_buy_now_graded_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&_sop=2&LH_BIN=1&Graded=Yes' %}
                      {% set manual_sold_graded_url = 'https://www.ebay.ca/sch/i.html?_nkw=' ~ market_keyword_raw|url_encode ~ '&_sacat=261328&LH_Sold=1&Graded=Yes&_sop=3&_udlo=35' %}
                      {% set card_price = card.sale_price|default(0) %}
                      {% set price_missing = (card_price == 0 or card_price == '' or card_price is empty) %}
                      {% set price_category = price_missing ? 'gray' : (card_price < 2 ? 'gray' : (card_price < 10 ? 'blue' : (card_price < 50 ? 'orange' : 'gold'))) %}
                        <tr data-index="{{ loop.index0 }}"
                          data-group="{{ group.key|e }}"
                          data-market-keyword="{{ (card.market_keyword|default(market_keyword))|e('html_attr') }}"
                          data-title="{{ card.title|default('')|e('html_attr') }}"
                          data-player="{{ card.player|default('')|e('html_attr') }}"
                          data-card-number="{{ card.card_number|default('')|e('html_attr') }}"
                          data-set-name="{{ card.set|default('')|e('html_attr') }}"
                          class="price-{{ price_category }}{% if price_missing %} price-missing{% endif %}">
                        <td class="text-center">
                          <strong>{{ loop.index }}</strong>
                          
                          {% if group.is_existing %}
                            {% if card.db_exists is defined and card.db_exists %}
                              <small class="d-block mt-1">
                                <span class="badge bg-warning text-dark" title="Carte déjà en base, quantité sera incrémentée">
                                  <i class="fa-solid fa-rotate"></i> +{{ card.quantity|default(1) }} &nbsp;(était: {{ card.db_quantity }})
                                </span>
                              </small>
                            {% else %}
                              <small class="d-block mt-1">
                                <span class="badge bg-success" title="Nouvelle carte, sera insérée">
                                  <i class="fa-solid fa-plus"></i> NEW
                                </span>
                              </small>
                            {% endif %}
                          {% endif %}
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][_row_number]" value="{{ card._row_number|default(loop.index) }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][_group_key]" value="{{ group.key|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][year]" value="{{ card.year|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][card_number]" value="{{ card.card_number|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][player]" value="{{ card.player|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][team]" value="{{ card.team|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][set]" value="{{ card.set|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][subset]" value="{{ card.subset|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][category]" value="{{ card.category|default('')|e }}">
                          <input type="hidden" name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][merge]" value="{% if card.sale_price is defined and card.sale_price < 10 %}1{% else %}0{% endif %}">
                        </td>
                        
                        <td>
                          <input type="text" 
                                 class="form-control form-control-sm {% if card.title is empty %}field-warning{% endif %}" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][title]" 
                                 value="{{ card.title|default('')|e }}" 
                                 placeholder="{{ text_placeholder_title }}" 
                                 required>

                          <input type="text" 
                                 class="form-control form-control-sm" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][description]" 
                                 value="{{ card.description|default(card.title)|e }}" 
                                 placeholder="{{ text_placeholder_description }}">
                           <small class="text-muted d-block mt-1">
                          {% if card.player is defined and card.player is not empty %}
                           
                              <i class="fa-solid fa-user"></i> {{ card.player|e }}
                              {% if card.team is defined and card.team is not empty %}
                                - {{ card.team|e }}
                              {% endif %}
                          
                          {% endif %}
                          
                          {% if card.set is defined and card.set is not empty %}
                             ----> 
                              <i class="fa-solid fa-layer-group"></i> {{ card.set|e }}
                              {% if card.card_number is defined and card.card_number is not empty %}
                                #{{ card.card_number|e }}
                              {% endif %}
                            
                          {% endif %}
                        </small>
                        </td>
                        
                        <td{% if card.price_source is defined and card.price_source == 'multiple' %} data-price-unresolved="1" style="background:#c0392b !important; border-color:#dc3545 !important; color:#fff !important;"{%- elseif card.market_is_profitable is defined and card.market_is_profitable %} style="background:#ffd700 !important; border-color:#d4a017 !important;"{%- elseif card.price_source is defined and card.price_source in ['db','db_min'] %} style="background:#80c090 !important; border-color:#28a745 !important;"{%- elseif card.price_source is defined and card.price_source == 'csv' %} style="background:#ffc857 !important; border-color:#fd7e14 !important;"{%- endif %}>
                          <div class="input-group input-group-sm">
                           
                            <input type="number" 
                                   step="0.01" 
                                   class="form-control form-control-sm {% if card.price_source is defined and card.price_source == 'multiple' %}field-warning{% elseif card.sale_price is empty or card.sale_price == 0 %}field-warning{% endif %}" 
                                   name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][sale_price]" 
                                   value="{{ card.sale_price|default('')|e }}" 
                                   placeholder="{{ text_placeholder_price }}" 
                                   required>
                          {% if card.debug_csv_price is defined and card.price_source != 'multiple' %}
                            <small class="text-muted d-block mt-1" style="font-size:10px;">
                              src: <strong>{{ card.price_source|default('?') }}</strong> | csv: {{ card.debug_csv_price }}
                            </small>
                          {% endif %}
                          {% if price_missing and card.price_source != 'multiple' %}
                            <small class="d-block mt-1 text-danger fw-semibold" style="font-size:10px;">
                              <i class="fa-solid fa-triangle-exclamation"></i> Pas dans oc_card_raw
                            </small>
                          {% endif %}
                          {% if card.price_source is defined and card.price_source == 'multiple' %}
                            <small class="d-block mt-1 fw-semibold" style="font-size:10px; color:#fff;">
                              <i class="fa-solid fa-triangle-exclamation"></i> {{ card.price_candidates|length }} prix trouvés — choisissez:
                            </small>
                            <div class="mt-1 d-flex flex-wrap gap-1">
                              {% for candidate in card.price_candidates %}
                                <button type="button"
                                        class="btn btn-xs btn-light price-candidate"
                                        style="font-size:10px; padding:2px 6px; line-height:1.3; color:#000;"
                                        data-price="{{ candidate.cad|e }}"
                                        title="USD ${{ candidate.usd|e }}"
                                        onclick="this.closest('tr').querySelector('input[type=number][name*=sale_price]').value='{{ candidate.cad|e }}'; this.closest('.d-flex').querySelectorAll('button').forEach(b=>{b.classList.remove('btn-primary','btn-light'); b.classList.add('btn-light'); b.style.color='#000';}); this.classList.remove('btn-light'); this.classList.add('btn-primary'); this.style.color='#fff'; this.closest('td').removeAttribute('data-price-unresolved'); window.checkSaveReady && window.checkSaveReady();">
                                  {{ candidate.label|e }} — <strong>CA${{ candidate.cad|e }}</strong>
                                </button>
                              {% endfor %}
                            </div>
                          {% endif %}
                          {% if card.market_is_profitable is defined and card.market_is_profitable and card.market_profit_potential is defined %}
                            <div class="grading-profit-note-importer" style="font-size:11px;line-height:1.2;margin-top:4px;">
                              <span style="font-weight:600;color:#7a5c00;">Profit potentiel grading: +${{ card.market_profit_potential|number_format(2, '.', '') }} CAD</span>
                            </div>
                          {% endif %}
                          {% if market_keyword_raw is not empty %}
                            <div class="mt-2">
                              <a class="btn btn-sm btn-dark market-manual-btn w-100" target="ebay_market_preview" href="{{ manual_sold_graded_url|e('html_attr') }}">{{ text_market_manual_sold_graded|default('Sold Graded') }}</a>
                            </div>
                          {% endif %}
                          </div>
                        </td>

                        <td class="market-price-auction text-center" style="font-size:12px;line-height:1.2;">
                          {% if card.price_sold is defined and card.price_sold is not empty %}
                            {% set auction_color = (((card.price_sold|default(0)) + 0) <= ((card.sale_price|default(0)) + 0)) ? '#dc3545' : '#28a745' %}
                            {% if card.price_sold_url is defined and card.price_sold_url %}
                              <a href="{{ card.price_sold_url|e('html_attr') }}" target="ebay_market_preview" style="text-decoration:none;"><span style="font-weight:700;color:#fff;background:{{ auction_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_sold|number_format(2, '.', '') }}</span></a>
                            {% else %}
                              <span style="font-weight:700;color:#fff;background:{{ auction_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_sold|number_format(2, '.', '') }}</span>
                            {% endif %}
                            {% if card.price_sold_bids is defined and card.price_sold_bids %}
                              <div style="font-size:11px;color:#666;line-height:1.1;">{{ card.price_sold_bids }} bid{% if card.price_sold_bids != 1 %}s{% endif %}</div>
                            {% endif %}
                            {% if card.price_sold_graded is defined and card.price_sold_graded is not empty %}
                              {% set auction_graded_color = (((card.price_sold_graded|default(0)) + 0) <= ((card.sale_price|default(0)) + 0)) ? '#dc3545' : '#28a745' %}
                              <div style="margin-top:3px;padding-top:3px;border-top:1px dashed #ddd;font-size:12px;">
                                {% if card.price_sold_graded_url is defined and card.price_sold_graded_url %}
                                  <a href="{{ card.price_sold_graded_url|e('html_attr') }}" target="ebay_market_preview" style="text-decoration:none;"><span style="font-weight:600;color:#fff;background:{{ auction_graded_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_sold_graded|number_format(2, '.', '') }}</span></a>
                                {% else %}
                                  <span style="font-weight:600;color:#fff;background:{{ auction_graded_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_sold_graded|number_format(2, '.', '') }}</span>
                                {% endif %}
                                {% if card.price_sold_graded_grade is defined and card.price_sold_graded_grade %}
                                  <span style="font-size:11px;color:#555;">{{ card.price_sold_graded_grade|e }}</span>
                                {% endif %}
                              </div>
                            {% endif %}
                          {% elseif market_keyword_raw is not empty %}
                            <div class="market-manual-wrap">
                              <a class="btn btn-sm btn-primary market-manual-btn" target="ebay_market_preview" href="{{ manual_auction_raw_url|e('html_attr') }}">{{ text_market_manual_raw|default('Raw') }}</a>
                              <a class="btn btn-sm btn-dark market-manual-btn" target="ebay_market_preview" href="{{ manual_auction_graded_url|e('html_attr') }}">{{ text_market_manual_graded|default('Graded') }}</a>
                            </div>
                          {% else %}
                            <span class="text-muted">—</span>
                          {% endif %}
                        </td>

                        <td class="market-price-list text-center" style="font-size:12px;line-height:1.2;">
                          {% if card.price_list is defined and card.price_list is not empty %}
                            {% set list_color = (((card.price_list|default(0)) + 0) <= ((card.sale_price|default(0)) + 0)) ? '#dc3545' : '#28a745' %}
                            {% if card.price_list_url is defined and card.price_list_url %}
                              <a href="{{ card.price_list_url|e('html_attr') }}" target="ebay_market_preview" style="text-decoration:none;"><span style="font-weight:700;color:#fff;background:{{ list_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_list|number_format(2, '.', '') }}</span></a>
                            {% else %}
                              <span style="font-weight:700;color:#fff;background:{{ list_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_list|number_format(2, '.', '') }}</span>
                            {% endif %}
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary ms-1 apply-raw-buy-now-price"
                                    title="{{ text_market_apply_raw_buy_now|default('Apply raw Buy Now price')|e('html_attr') }}"
                                    data-price="{{ card.price_list|number_format(2, '.', '')|e('html_attr') }}"
                                    style="padding:1px 6px; line-height:1.1;"
                                    aria-label="{{ text_market_apply_raw_buy_now|default('Apply raw Buy Now price')|e('html_attr') }}">
                                  <i class="fa-solid fa-arrow-left"></i>
                            </button>
                            {% if card.price_list_graded is defined and card.price_list_graded is not empty %}
                              {% set list_graded_color = (((card.price_list_graded|default(0)) + 0) <= ((card.sale_price|default(0)) + 0)) ? '#dc3545' : '#28a745' %}
                              <div style="margin-top:3px;padding-top:3px;border-top:1px dashed #ddd;font-size:12px;">
                                {% if card.price_list_graded_url is defined and card.price_list_graded_url %}
                                  <a href="{{ card.price_list_graded_url|e('html_attr') }}" target="ebay_market_preview" style="text-decoration:none;"><span style="font-weight:600;color:#fff;background:{{ list_graded_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_list_graded|number_format(2, '.', '') }}</span></a>
                                {% else %}
                                  <span style="font-weight:600;color:#fff;background:{{ list_graded_color }};padding:2px 6px;border-radius:4px;display:inline-block;">${{ card.price_list_graded|number_format(2, '.', '') }}</span>
                                {% endif %}
                                {% if card.price_list_graded_grade is defined and card.price_list_graded_grade %}
                                  <span style="font-size:11px;color:#555;">{{ card.price_list_graded_grade|e }}</span>
                                {% endif %}
                              </div>
                            {% endif %}
                          {% elseif market_keyword_raw is not empty %}
                            <div class="market-manual-wrap">
                              <a class="btn btn-sm btn-primary market-manual-btn" target="ebay_market_preview" href="{{ manual_buy_now_raw_url|e('html_attr') }}">{{ text_market_manual_raw|default('Raw') }}</a>
                              <a class="btn btn-sm btn-dark market-manual-btn" target="ebay_market_preview" href="{{ manual_buy_now_graded_url|e('html_attr') }}">{{ text_market_manual_graded|default('Graded') }}</a>
                            </div>
                          {% else %}
                            <span class="text-muted">—</span>
                          {% endif %}
                        </td>
                        
                        <td>
                          <input type="number" 
                                 min="1" 
                                 class="form-control form-control-sm quantity-input" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][quantity]" 
                                 value="{{ card.quantity|default(1)|e }}" 
                                 placeholder="1"
                                 data-group-index="{{ group_global_index }}"
                                 data-card-index="{{ loop.index0 }}">
                        </td>
                        
                        <td>
                          <input type="text" 
                                 class="form-control form-control-sm" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][condition]" 
                                 value="See Pictures" 
                                 placeholder="{{ text_placeholder_condition }}">
                       
                          
                        </td>
                         
                        <td class="brand-cell{% if card.brand is empty or card.brand == '' %} brand-cell-error{% endif %}">
                          {% if card.brand is empty or card.brand == '' %}
                            <select class="form-control form-control-sm brand-select brand-input field-warning" 
                                    name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][brand]" 
                                    data-group-index="{{ group_global_index }}"
                                    data-card-index="{{ loop.index0 }}">
                              <option value="">{{ text_placeholder_brand }}</option>
                              {% for manufacturer in manufacturers %}
                              <option value="{{ manufacturer|e }}">{{ manufacturer|e }}</option>
                              {% endfor %}
                              <option value="Other">Other</option>
                            </select>
                          {% else %}
                            <input type="text" 
                                   class="form-control form-control-sm brand-input" 
                                   name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][brand]" 
                                   value="{{ card.brand|e }}" 
                                   placeholder="{{ text_placeholder_brand }}"
                                   data-group-index="{{ group_global_index }}"
                                   data-card-index="{{ loop.index0 }}">
                          {% endif %}
                        </td>
                        
                        <td>
                          <div style="display: flex; gap: 5px; align-items: center; flex-wrap: wrap;">
                            {% if card.all_images is defined and card.all_images is not empty %}
                              {% for image in card.all_images %}
                                <img src="{{ image|e }}" class="image-preview" alt="Card Image">
                              {% endfor %}
                            {% elseif card.front_image is defined and card.front_image is not empty %}
                              <img src="{{ card.front_image|e }}" class="image-preview" alt="Front">
                            {% else %}
                              <div style="width: 60px; height: 60px; background: #f0f0f0; border: 1px solid #ddd; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-image text-muted"></i>
                              </div>
                            {% endif %}
                            
                            {% if card.back_image is defined and card.back_image is not empty and card.all_images is not defined %}
                              <img src="{{ card.back_image|e }}" class="image-preview" alt="Back">
                            {% endif %}
                          </div>
                          
                          <input type="hidden" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][front_image]" 
                                 value="{{ card.all_images[0] ?? card.front_image|default('')|e }}">
                          <input type="hidden" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][back_image]" 
                                 value="{{ card.all_images[1] ?? card.back_image|default('')|e }}">
                          <input type="hidden" 
                                 name="groups[{{ group_global_index }}][cards][{{ loop.index0 }}][all_images]" 
                                 value="{{ card.all_images|join('|')|e }}">
                        </td>
                        <td class="text-center">
                          <button type="button"
                                  class="btn btn-sm btn-danger text-white remove-card-line-btn"
                              onclick="event.stopPropagation(); window.removeImporterCardLine && window.removeImporterCardLine(this);"
                                  title="{{ button_remove_line|default('Remove line')|e }}"
                                  style="padding:2px 8px; line-height:1.2;">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
      <div class="alert alert-warning">
        <i class="fa-solid fa-exclamation-triangle"></i> No groups found. Please upload a valid CSV file.
      </div>
    {% endif %}
  </form>

<script>
// Debug: Log groups data to console
//console.log('=== GROUPS DATA ===');
//console.log({{ groups|json_encode|raw }});
//console.log('Total groups:', {{ groups|length }});
//console.log('===================');

$(document).ready(function() {
    // ===== UTILITY FUNCTIONS =====
    // Decentralized pattern: Each JS file has its own utilities to prevent cascade failures
    
    function htmlspecialchars(str) {
        if (!str) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }
    
    function htmlspecialchars_decode(str) {
        if (!str) return '';
        return String(str)
            .replace(/&amp;/g, '&')
            .replace(/&lt;/g, '<')
            .replace(/&gt;/g, '>')
            .replace(/&quot;/g, '"')
            .replace(/&#039;/g, "'");
    }

        var TEXT_REMOVE_CARD_LINE_CONFIRM = '{{ text_remove_card_line_confirm|default('Remove this card line from the preview?')|escape('js') }}';
        var TEXT_REMOVE_LISTING_CONFIRM = '{{ text_remove_listing_confirm|default('Remove this entire listing from the preview?')|escape('js') }}';
    
    // ===== END UTILITY FUNCTIONS =====

        function renumberGroupRows($group) {
          $group.find('table.cards-table tbody tr').each(function(index) {
            $(this).find('td:first strong').first().text(index + 1);
          });
        }

        function updatePreviewSummary() {
          var listingsCount = $('.brand-group').length;
          var cardsCount = 0;

          $('#form-preview-data .quantity-input').each(function() {
            var qty = parseInt($(this).val(), 10);
            cardsCount += (isNaN(qty) || qty < 1) ? 1 : qty;
          });

          $('#remaining-listings-count').text(listingsCount);
          $('#remaining-cards-count').text(cardsCount);
        }
        // Market search/fetch logic removed from JS: preview market data is injected by backend during CSV processing.

        function removeGroupIfEmpty($group) {
          if ($group.find('table.cards-table tbody tr').length === 0) {
            $group.remove();
            updatePreviewSummary();
            window.checkSaveReady && window.checkSaveReady();
          }
        }

        function handleRemoveCardLine(btn) {
          var $row = $(btn).closest('tr');
          var $group = $(btn).closest('.brand-group');

          if (!confirm(TEXT_REMOVE_CARD_LINE_CONFIRM)) {
            return;
          }

          $row.remove();
          renumberGroupRows($group);
          removeGroupIfEmpty($group);
          updatePreviewSummary();
          window.updateListingMenusVisibility && window.updateListingMenusVisibility();
          window.checkSaveReady && window.checkSaveReady();
        }

        function handleRemoveGroup(btn) {
          var $group = $(btn).closest('.brand-group');

          if (!confirm(TEXT_REMOVE_LISTING_CONFIRM)) {
            return;
          }

          $group.remove();
          updatePreviewSummary();
          window.updateListingMenusVisibility && window.updateListingMenusVisibility();
          window.checkSaveReady && window.checkSaveReady();
        }

        window.removeImporterCardLine = handleRemoveCardLine;
        window.removeImporterGroup = handleRemoveGroup;
    
    // Remove warning class when user modifies field
    $('#form-preview-data').on('input change', 'input.field-warning, select.field-warning', function() {
        var $field = $(this);
        var value = $field.val();
        
        if ($field.attr('type') === 'number') {
            if (parseFloat(value) > 0) {
                $field.removeClass('field-warning');
            }
        } else if (value && value.trim() !== '') {
            $field.removeClass('field-warning');
        }
    });
    
    // Add warning class if required field is emptied
    $('#form-preview-data').on('blur', 'input[required], select[required]', function() {
        var $field = $(this);
        var value = $field.val();
        
        if ($field.attr('type') === 'number') {
            if (parseFloat(value) == 0 || value === '') {
                $field.addClass('field-warning');
            }
        } else if (!value || value.trim() === '') {
            $field.addClass('field-warning');
        }
    });
    
    // Character counter for group titles (80 char limit)
    $('#form-preview-data').on('input', 'input.group-title-input', function() {
        var $input = $(this);
        var length = $input.val().length;
        var maxLength = 80;
        
        if (length > maxLength) {
            $input.val($input.val().substring(0, maxLength));
        }
    });
    
    // ===== BRAND SELECT AUTO-FOCUS & ZOOM =====
    
    // Function to zoom/scroll to element with highlight effect
    function zoomToElement($element) {
        if ($element.length === 0) return;
        
        // Open parent collapse if closed
        var $collapse = $element.closest('.collapse');
        if ($collapse.length && !$collapse.hasClass('show')) {
            $collapse.collapse('show');
        }
        
        // Wait for collapse animation
        setTimeout(function() {
            // Scroll to element with offset
            $('html, body').animate({
                scrollTop: $element.offset().top - 150
            }, 500);
            
            // Highlight effect
            $element.addClass('brand-highlight');
            setTimeout(function() {
                $element.removeClass('brand-highlight');
            }, 2000);
            
            // Focus the select
            $element.focus();
        }, $collapse.hasClass('show') ? 0 : 400);
    }
    
    // Auto-focus first empty brand select on load
    function focusFirstEmptyBrand() {
        var $firstEmpty = $('.brand-select').filter(function() {
            return $(this).val() === '';
        }).first();
        
        if ($firstEmpty.length > 0) {
            zoomToElement($firstEmpty);
        }
    }
    
    // When brand select changes, move to next empty one
    $('#form-preview-data').on('change', '.brand-select', function() {
        var $current = $(this);
        
        // Remove warning class
        if ($current.val() !== '') {
            $current.removeClass('field-warning');
        }
        
        // Find next empty brand select
        var $allSelects = $('.brand-select');
        var currentIndex = $allSelects.index($current);
        var $nextEmpty = null;
        
        for (var i = currentIndex + 1; i < $allSelects.length; i++) {
            if ($allSelects.eq(i).val() === '') {
                $nextEmpty = $allSelects.eq(i);
                break;
            }
        }
        
        // If found, zoom to it
        if ($nextEmpty && $nextEmpty.length > 0) {
            setTimeout(function() {
                zoomToElement($nextEmpty);
            }, 300);
        }
    });
    
    // Trigger focus after short delay (let DOM settle)
    setTimeout(focusFirstEmptyBrand, 500);
    updatePreviewSummary();
    // Market prices are injected by backend during CSV processing; no JS fetch initialization here.
    
    // ===== QUANTITY CHANGE HANDLER =====

    $('#form-preview-data').on('click', '.apply-raw-buy-now-price', function() {
      var $btn = $(this);
      var rawPrice = parseFloat($btn.data('price'));

      if (isNaN(rawPrice) || rawPrice <= 0) {
        return;
      }

      var $row = $btn.closest('tr');
      var $priceInput = $row.find('input[type="number"][name*="[sale_price]"]').first();

      if ($priceInput.length === 0) {
        return;
      }

      $priceInput.val(rawPrice.toFixed(2)).trigger('input').trigger('change').removeClass('field-warning');

      var $priceCell = $priceInput.closest('td');
      $priceCell.removeAttr('data-price-unresolved');

      $btn.removeClass('btn-outline-primary').addClass('btn-primary');
      setTimeout(function() {
        $btn.removeClass('btn-primary').addClass('btn-outline-primary');
      }, 900);

      window.checkSaveReady && window.checkSaveReady();
    });
    
    // Update total quantity display when quantity input changes
    $('#form-preview-data').on('input change', '.quantity-input', function() {
        var $input = $(this);
        var quantity = parseInt($input.val()) || 1;
        
        // Ensure minimum quantity of 1
        if (quantity < 1) {
            quantity = 1;
            $input.val(1);
        }
        
        // Get group and card indices
        var groupIndex = $input.data('group-index');
        var cardIndex = $input.data('card-index');
        
        // Update the corresponding hidden quantity field if it exists
        var $hiddenQuantity = $('input[name="groups\\[' + groupIndex + '\\]\\[cards\\]\\[' + cardIndex + '\\]\\[quantity\\]"]');

        if ($hiddenQuantity.length > 0) {
            $hiddenQuantity.val(quantity);
        }
        
        // Update total quantity display for the group if it exists
        updateGroupTotalQuantity(groupIndex);
        updatePreviewSummary();
        
        console.log('Quantity updated for card ' + cardIndex + ' in group ' + groupIndex + ': ' + quantity);
    });
    
    // Function to update total quantity display for a group
    function updateGroupTotalQuantity(groupIndex) {
        var totalQuantity = 0;
        
        // Sum all quantities in this group
        $('input[name^="groups[' + groupIndex + '][cards]"][name$="[quantity]"]').each(function() {
            var qty = parseInt($(this).val()) || 1;
            totalQuantity += qty;
        });
        
        // Update display if there's a total quantity element
        var $totalDisplay = $('#group-total-quantity-' + groupIndex);
        if ($totalDisplay.length > 0) {
            $totalDisplay.text(totalQuantity);
        }
        
        console.log('Updated total quantity for group ' + groupIndex + ': ' + totalQuantity);
    }
    
    // ===== BRAND VALIDATION HANDLER =====
    
    // Store original value when field is focused
    $('#form-preview-data').on('focusin', '.brand-input', function() {
        var $input = $(this);
        // Store the original value if not already stored
        if (!$input.data('original-value')) {
            $input.data('original-value', $input.val().trim());
        }
    });
    
    // Handle brand input/select change - validate and replicate across group
    $('#form-preview-data').on('change blur', '.brand-input', function() {
        var $input = $(this);
        var brandName = $input.val().trim();
        var originalValue = $input.data('original-value') || '';
        
        // Skip if empty or select dropdown (handled separately)
        if (!brandName || brandName === '' || brandName === 'Other') {
            return;
        }
        
        // Skip if value hasn't changed
        if (brandName === originalValue) {
            return;
        }
        
        var groupIndex = $input.data('group-index');
        var cardIndex = $input.data('card-index');
        
        var ajaxUrl = 'index.php?route=shopmanager/card/import/card_importer.validateManufacturer&user_token={{ user_token|default("") }}';
        console.log('Brand validation AJAX URL:', ajaxUrl);
        console.log('Brand name being validated:', brandName);
        
        // Validate brand exists in database
        $.ajax({
            url: ajaxUrl,
            type: 'POST',
            data: { name: brandName },
            dataType: 'json',
            beforeSend: function() {
                $input.prop('disabled', true).addClass('text-muted');
            },
            success: function(json) {
                $input.prop('disabled', false).removeClass('text-muted');
                
                if (json.success === false) {
                    // Error occurred
                    alert(json.error || 'Brand validation failed');
                    return;
                }
                
                if (json.exists) {
                    // Brand exists - update original value and replicate to all cards in this group
                    $input.data('original-value', brandName);
                    replicateBrandInGroup(groupIndex, brandName);
                } else {
                    // Brand doesn't exist - show confirmation modal
                    showBrandConfirmationModal(brandName, groupIndex, $input);
                }
            },
            error: function(xhr, status, error) {
                $input.prop('disabled', false).removeClass('text-muted');
                console.error('Brand validation error:', error);
                console.error('Response status:', xhr.status);
                console.error('Response text (first 500 chars):', xhr.responseText.substring(0, 500));
                alert('Error communicating with server: ' + error + ' (Status: ' + xhr.status + ')');
            }
        });
    });
    
    // Replicate brand to all cards in the same group
    function replicateBrandInGroup(groupIndex, brandName) {
        var selector = 'input[name^="groups\\[' + groupIndex + '\\]\\[cards\\]"][name$="[brand]"], ' +
                      'select[name^="groups\\[' + groupIndex + '\\]\\[cards\\]"][name$="[brand]"]';
                      
        
        $(selector).each(function() {
            var $field = $(this);
            if ($field.is('select')) {
                // For select dropdown
                var optionExists = $field.find('option[value="' + brandName + '"]').length > 0;
                if (optionExists) {
                    $field.val(brandName).removeClass('field-warning');
                } else {
                    // Add option if it doesn't exist
                    $field.append('<option value="' + htmlspecialchars(brandName) + '">' + htmlspecialchars(brandName) + '</option>');
                    $field.val(brandName).removeClass('field-warning');
                }
 } else {
                // For text input
                $field.val(brandName);
            }
            
            // Update original value to prevent re-validation
            $field.data('original-value', brandName);
            
            // Add highlight effect
            $field.addClass('brand-highlight');
            setTimeout(function() {
                $field.removeClass('brand-highlight');
            }, 2000);
        });
        
        console.log('Replicated brand "' + brandName + '" to all cards in group ' + groupIndex);
        window.checkSaveReady && window.checkSaveReady();
    }
    
    // Show brand confirmation modal
    function showBrandConfirmationModal(brandName, groupIndex, $originalInput) {
        var message = '{{ text_brand_not_found_message|escape('js') }}'.replace('%s', htmlspecialchars(brandName));
        
        // Create Bootstrap modal
        var modalHtml = '<div class="modal fade" id="brandConfirmModal" tabindex="-1">' +
            '<div class="modal-dialog modal-dialog-centered">' +
            '<div class="modal-content">' +
            '<div class="modal-header bg-warning text-white">' +
            '<h5 class="modal-title"><i class="fa-solid fa-exclamation-triangle me-2"></i>{{ text_brand_not_found|escape('js') }}</h5>' +
            '<button type="button" class="btn-close" data-bs-dismiss="modal"></button>' +
            '</div>' +
            '<div class="modal-body text-center">' +
            '<p>' + message + '</p>' +
            '</div>' +
            '<div class="modal-footer justify-content-center">' +
            '<button type="button" class="btn btn-success" id="btn-add-brand">' +
            '<i class="fa-solid fa-plus me-2"></i>{{ button_add_brand|escape('js') }}' +
            '</button>' +
            '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">' +
            '<i class="fa-solid fa-times me-2"></i>{{ button_cancel_brand|escape('js') }}' +
            '</button>' +
            '</div>' +
            '</div>' +
            '</div>' +
            '</div>';
        
        // Remove existing modal if any
        $('#brandConfirmModal').remove();
        
        // Add modal to page
        $('body').append(modalHtml);
        
        // Show modal
        var modal = new bootstrap.Modal(document.getElementById('brandConfirmModal'));
        modal.show();
        
        // Handle add brand button with event delegation (fix for button not clickable)
        // Use document-level delegation to ensure the event is properly attached
        $(document).off('click', '#btn-add-brand').on('click', '#btn-add-brand', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            var $btn = $(this);
            
            // Prevent double-click
            if ($btn.prop('disabled')) {
                return false;
            }
            
            $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i>{{ text_brand_validating|escape('js') }}');
            
            // Add brand via AJAX
            $.ajax({
                url: 'index.php?route=shopmanager/card/import/card_importer.addManufacturer&user_token={{ user_token|default("") }}',
                type: 'POST',
                data: { name: brandName },
                dataType: 'json',
                success: function(json) {
                    if (json.success) {
                        // Brand added successfully
                        modal.hide();
                        
                        // Show success message
                        var successMsg = '{{ text_brand_added|escape('js') }}'.replace('%s', htmlspecialchars(brandName));
                        alert(successMsg);
                        
                        // Update original value on the input field that triggered validation
                        $originalInput.data('original-value', brandName);
                        
                        // Replicate brand to all cards in group
                        // The original-value is set BEFORE changing value to prevent re-validation
                        replicateBrandInGroup(groupIndex, brandName);
                    } else {
                        // Show specific error or generic message
                        var errorMsg = json.error || '{{ error_brand_failed|escape('js') }}';
                        alert(errorMsg);
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-plus me-2"></i>{{ button_add_brand|escape('js') }}');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Add brand error:', error);
                    alert('Error communicating with server: ' + error);
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-plus me-2"></i>{{ button_add_brand|escape('js') }}');
                }
            });
            
            return false;
        });
        
        // Handle cancel - revert to original value
        $('#brandConfirmModal').on('hidden.bs.modal', function() {
            var originalValue = $originalInput.data('original-value') || '';
            
            // Temporarily set the original-value to the value we're about to set
            // This prevents the change event from triggering validation
            var selector = 'input[name^="groups\\[' + groupIndex + '][cards]"][name$="[brand]"], ' +
                          'select[name^="groups\\[' + groupIndex + '][cards]"][name$="[brand]"]';
            
            $(selector).each(function() {
                var $field = $(this);
                // Set original-value BEFORE updating the value to prevent validation loop
                $field.data('original-value', originalValue);
                $field.val(originalValue);
            });
            
            $originalInput.focus();
            $(this).remove();
            
            // Cleanup event handler
            $(document).off('click', '#btn-add-brand');
        });
    }
});

// Force-new-listing checkbox: zeroise existing_listing_id
$(document).on('change', '.force-new-listing-cb', function() {
    var groupIndex  = $(this).data('group-index');
    var originalId  = $(this).data('original-id');
    var $hiddenId   = $('input[name="groups[' + groupIndex + '][existing_listing_id]"]');
    var $hiddenEx   = $('input[name="groups[' + groupIndex + '][is_existing]"]');
    var $group      = $(this).closest('.brand-group');

    if ($(this).is(':checked')) {
        // Force new listing
        $hiddenId.val(0);
        $hiddenEx.val(0);
        $group.removeClass('existing-listing').addClass('forced-new-listing');
        $(this).closest('label').css('background', 'rgba(40,167,69,0.85)');
        $(this).siblings('i').removeClass('fa-plus-circle').addClass('fa-check-circle');
    } else {
        // Revert to existing
        $hiddenId.val(originalId);
        $hiddenEx.val(1);
        $group.addClass('existing-listing').removeClass('forced-new-listing');
        $(this).closest('label').css('background', 'rgba(220,53,69,0.85)');
        $(this).siblings('i').removeClass('fa-check-circle').addClass('fa-plus-circle');
    }
});

// Category filtering function
function filterGroups(category) {
    $('.brand-group').each(function() {
        var $group = $(this);
        if (category === 'all') {
            $group.show();
        } else {
            if ($group.hasClass('category-' + category)) {
                $group.show();
            } else {
                $group.hide();
            }
        }
    });
    
    // Update button states
    $('.filter-buttons .btn').removeClass('active');
    $('.filter-buttons .btn[onclick*="filterGroups(\'' + category + '\')"]').addClass('active');
}
</script>

