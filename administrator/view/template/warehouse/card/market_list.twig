{# Original: shopmanager/card/card_market_list.twig #}
<style>
.market-photo-trigger { cursor: pointer; transition: transform .15s, box-shadow .15s; }
.market-photo-trigger:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,.18); }
.market-thumb { width: 100%; aspect-ratio: 3/4; object-fit: cover; background: #f0f0f0; }
.market-thumb-placeholder { width: 100%; aspect-ratio: 3/4; display: flex; align-items: center; justify-content: center; background: #f5f5f5; color: #bbb; font-size: 2.5rem; }
.badge-graded-c { background: #1565c0; color: #fff; font-size: .7rem; }
.badge-raw-c    { background: #37474f; color: #fff; font-size: .7rem; }
.price-tag { font-size: .85rem; font-weight: 700; color: #1a6400; }
.card-title-clip { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: .8rem; line-height: 1.3; }
.market-meta { font-size: .75rem; color: #666; }
.badge-auction   { background: #e65100; color: #fff; font-size: .65rem; }
.badge-buynow    { background: #2e7d32; color: #fff; font-size: .65rem; }
.bid-count       { font-size: .68rem; color: #e65100; font-weight: 600; }
.thumb-wrap { position: relative; }
.grade-badge { position: absolute; top: 5px; right: 5px; }
</style>

{% if error %}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fa-solid fa-triangle-exclamation me-1"></i> {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endif %}

{% if not items and not error %}

  <div class="text-center py-5 text-muted">
    <i class="fa-brands fa-ebay" style="font-size:3rem;color:#e53238;"></i>
    <p class="mt-3" style="font-size:.95rem;">{{ text_search_notice|raw }}</p>
  </div>

{% elseif not items %}

  <div class="text-center py-5 text-muted">
    <i class="fa-solid fa-magnifying-glass" style="font-size:2.5rem;"></i>
    <p class="mt-3">{{ text_no_results }}</p>
  </div>

{% else %}

  {# ── Sort bar ─────────────────────────────────────────────────────────── #}
  <div class="sort-bar mb-3">
    {% if keyword_line %}
      <span class="text-muted me-2" style="font-size:.85rem;">{{ keyword_line|raw }}</span>
    {% endif %}
    <a href="{{ sort_price_desc }}" class="btn btn-sm {% if sort == 'price_desc' %}btn-primary{% else %}btn-outline-secondary{% endif %}" id="btn-sort-pd">
      <i class="fa-solid fa-arrow-down-wide-short"></i> {{ text_sort_price_desc }}
    </a>
    <a href="{{ sort_price_asc }}" class="btn btn-sm {% if sort == 'price_asc' %}btn-primary{% else %}btn-outline-secondary{% endif %}" id="btn-sort-pa">
      <i class="fa-solid fa-arrow-up-wide-short"></i> {{ text_sort_price_asc }}
    </a>
    <a href="{{ sort_date_desc }}" class="btn btn-sm {% if sort == 'date_desc' %}btn-primary{% else %}btn-outline-secondary{% endif %}" id="btn-sort-dd">
      <i class="fa-regular fa-clock"></i> {{ text_sort_date }}
    </a>
  </div>

  {# ── Card grid ────────────────────────────────────────────────────────── #}
  <div class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-2">

    {% for item in items %}
    <div class="col">
      <div class="card h-100 market-photo-trigger"
           data-picture="{{ item.picture|e('html_attr') }}"
           data-gallery="{{ item.gallery|e('html_attr') }}"
           data-title="{{ item.title|e('html_attr') }}"
           data-price="CA$ {{ item.price_cad|number_format(2) }}{% if item.currency != 'CAD' %} ({{ item.currency }} {{ item.price|number_format(2) }}){% endif %}"
           data-grade="{{ item.grade|e('html_attr') }}"
           data-grader="{{ item.grader|e('html_attr') }}"
         data-created="{{ item.date_created|e('html_attr') }}"
         data-ended="{{ item.date_ended|e('html_attr') }}"
           data-url="{{ item.url|e('html_attr') }}">

        {# Thumbnail #}
        <div class="thumb-wrap">
          {% if item.picture %}
            <img src="{{ item.picture }}" alt="{{ item.title|slice(0, 60)|e }}"
                 class="market-thumb card-img-top"
                 loading="lazy"
                 onerror="this.parentNode.innerHTML='<div class=\'market-thumb-placeholder\'><i class=\'fa-regular fa-image\'></i></div>'">
          {% else %}
            <div class="market-thumb-placeholder">
              <i class="fa-regular fa-image"></i>
            </div>
          {% endif %}

          {# Grade / condition badge #}
          <div class="grade-badge">
            {% if item.is_graded %}
              {% set grade_badge = item.grade %}
              {% if item.grader and item.grade and item.grade starts with item.grader %}
                {% set grade_badge = item.grade %}
              {% elseif item.grader and item.grade %}
                {% set grade_badge = item.grader ~ ' ' ~ item.grade %}
              {% elseif item.grader %}
                {% set grade_badge = item.grader %}
              {% endif %}
              <span class="badge badge-graded-c">
                {{ grade_badge|trim }}
              </span>
            {% else %}
              <span class="badge badge-raw-c">{{ text_raw_badge }}</span>
            {% endif %}
          </div>
        </div>

        {# Card body #}
        <div class="card-body p-2 d-flex flex-column">
          <div class="d-flex align-items-center gap-1 mb-1">
            <div>
              <div class="price-tag">CA$ {{ item.price_cad|number_format(2) }}</div>
              {% if item.currency != 'CAD' %}
                <div style="font-size:.7rem;color:#888;">{{ item.currency }} {{ item.price|number_format(2) }}</div>
              {% endif %}
            </div>
            {% if item.listing_type == 'AUCTION' %}
              <span class="badge badge-auction ms-auto">{{ text_auction }}</span>
            {% else %}
              <span class="badge badge-buynow ms-auto">{{ text_fixed_price }}</span>
            {% endif %}
          </div>
            {% if item.listing_type == 'AUCTION' %}
              <div class="bid-count mb-1"><i class="fa-solid fa-gavel fa-xs me-1"></i>{{ item.bid_count|default(0) }} {{ text_bids }}</div>
          {% endif %}
          <p class="card-title-clip mb-1">{{ item.title }}</p>

          <div class="market-meta mt-auto">
            {% if item.player %}
              <div><i class="fa-solid fa-user fa-xs me-1"></i>{{ item.player }}</div>
            {% endif %}
            {% if item.card_number %}
              <div><i class="fa-solid fa-hashtag fa-xs me-1"></i>{{ item.card_number }}</div>
            {% endif %}
            {% if item.date_created %}
              <div><i class="fa-regular fa-calendar-plus fa-xs me-1"></i>{{ column_date_created }}: {{ item.date_created }}</div>
            {% endif %}
            {% if item.date_ended %}
              <div><i class="fa-regular fa-calendar-check fa-xs me-1"></i>{{ column_date_ended }}: {{ item.date_ended }}</div>
            {% endif %}
          </div>
        </div>

        {# Card footer — eBay link #}
        <div class="card-footer p-2">
          <a href="{{ item.url }}" target="_blank" rel="noopener"
             class="btn btn-sm btn-outline-danger w-100"
             onclick="event.stopPropagation();">
            <i class="fa-brands fa-ebay me-1"></i>{{ text_view_on_ebay }}
          </a>
        </div>

      </div>{# /.card #}
    </div>{# /.col #}
    {% endfor %}

  </div>{# /.row #}

  {# ── Pagination ───────────────────────────────────────────────────────── #}
  <div class="row mt-3">
    <div class="col-sm-6 text-start">{{ pagination }}</div>
    <div class="col-sm-6 text-end text-muted" style="font-size:.85rem;line-height:2.2;">{{ results }}</div>
  </div>

{% endif %}
