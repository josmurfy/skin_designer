{# Original: shopmanager/inventory/allocation.twig #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-cubes"></i> {{ text_list }}</div>
      <div class="card-body">
        <div id="inventory">{{ list }}</div>
      </div>
    </div>
  </div>
</div>

<!-- Country Selection Modal with AI -->
<div class="modal fade" id="scanCountryModal" tabindex="-1" aria-labelledby="scanCountryModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="scanCountryModalLabel"><i class="fa-solid fa-exclamation-triangle"></i> {{ text_country_modal_title }}</h5>
      </div>
      <div class="modal-body">
        <p><strong>{{ text_country_modal_message }}</strong></p>
        <div id="scan-product-info" class="alert alert-info mb-3"></div>
        <div id="scan-ai-loader" class="alert alert-warning mb-3" style="display:none;">
          <i class="fa-solid fa-spinner fa-spin"></i> {{ text_ai_analyzing }}
        </div>
        <div id="scan-ai-result" class="alert alert-success mb-3" style="display:none;">
          <strong><i class="fa-solid fa-robot"></i> {{ text_ai_suggestion }}</strong> <span id="scan-ai-reasoning"></span>
        </div>
        <div class="mb-3">
          <label for="scan-country-select" class="form-label">{{ entry_made_in_country }}</label>
          <select id="scan-country-select" class="form-select" onkeydown="if(event.key === 'Enter' || event.keyCode === 13) { event.preventDefault(); document.getElementById('scan-apply-country').click(); }">
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <div class="form-check me-auto">
          <input class="form-check-input" type="checkbox" id="auto-accept-ai-country" />
          <label class="form-check-label" for="auto-accept-ai-country">
            {{ text_auto_accept_ai }}
          </label>
        </div>
        <button type="button" class="btn btn-primary" id="scan-apply-country">{{ button_apply }}</button>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
var TEXT_CONFIRM = '{{ text_confirm|escape('js') }}';
var TEXT_PLEASE_SELECT_COUNTRY = '{{ text_please_select_country|escape('js') }}';
var TEXT_SKU_NOT_FOUND = '{{ text_sku_not_found|escape('js') }}';
var TEXT_SELECT_AT_LEAST_ONE = '{{ text_select_at_least_one|escape('js') }}';
var TEXT_CANNOT_ADD_PRODUCT = '{{ text_cannot_add_product|escape('js') }}';
var TEXT_ALREADY_SCANNED = '{{ text_already_scanned|escape('js') }}';
var TEXT_ERROR_OCCURRED = '{{ text_error_occurred|escape('js') }}';
var TEXT_AJAX_ERROR = '{{ text_ajax_error|escape('js') }}';
var TEXT_JUST_NOW = '{{ text_just_now|escape('js') }}';
var TEXT_MINUTES_AGO = '{{ text_minutes_ago|escape('js') }}';
var TEXT_HOURS_AGO = '{{ text_hours_ago|escape('js') }}';
var TEXT_DAYS_AGO = '{{ text_days_ago|escape('js') }}';
var TEXT_WEEKS_AGO = '{{ text_weeks_ago|escape('js') }}';
var TEXT_MONTHS_AGO = '{{ text_months_ago|escape('js') }}';
var TEXT_YEARS_AGO = '{{ text_years_ago|escape('js') }}';
var TEXT_UNSAVED_CHANGES = '{{ text_unsaved_changes|escape('js') }}';
var USER_TOKEN = '{{ user_token }}';
</script>
<script type="text/javascript" src="view/javascript/shopmanager/sound.js"></script>
<script type="text/javascript" src="view/javascript/shopmanager/inventory/allocation.js"></script>
{{ footer }}
