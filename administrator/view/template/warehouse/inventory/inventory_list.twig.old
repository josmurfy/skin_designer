<form id="form-inventory" action="{{ action_update }}" method="post">
  <div class="alert alert-info mb-3">
    <div class="row align-items-center g-2">
      <div class="col-md-4">
        <label for="input-sku" class="form-label mb-0">{{ entry_sku }}</label>
        <input type="text" name="scan_sku" value="" placeholder="{{ entry_sku }}" id="input-sku" class="form-control" {% if filter_location %}autofocus{% endif %} />
      </div>
      <div class="col-md-4">
        <label for="input-new-location" class="form-label mb-0">{{ entry_new_location }}</label>
        <input type="text" name="new_location" value="" placeholder="{{ entry_new_location }}" id="input-new-location" class="form-control" />
      </div>
      <div class="col-md-4">
        <label class="form-label mb-0">&nbsp;</label>
        <button type="submit" form="form-inventory" class="btn btn-primary w-100" id="button-submit" disabled><i class="fa-solid fa-save"></i> {{ button_submit }}</button>
      </div>
    </div>
  </div>
  <input type="hidden" name="user_token" value="{{ user_token }}" />
  <input type="hidden" name="filter_location" value="{{ filter_location }}" id="hidden-filter-location" />
  <div id="hidden-inputs-container"></div>
  
  <div class="table-responsive">
    <table class="table table-bordered table-hover">
      <thead>
        <tr>
          <th class="text-center" style="width: 50px;"><input type="checkbox" id="select-all" /></th>
          <th class="text-center" style="width: 80px;">{{ column_image }}</th>
          <th><a href="{{ sort_sku }}"{% if sort == 'p.sku' %} class="{{ order|lower }}"{% endif %}>{{ column_sku }}</a></th>
          <th><a href="{{ sort_name }}"{% if sort == 'pd.name' %} class="{{ order|lower }}"{% endif %}>{{ column_name }}</a></th>
          <th class="text-center"><a href="{{ sort_quantity }}"{% if sort == 'p.quantity' %} class="{{ order|lower }}"{% endif %}>{{ column_quantity }}</a></th>
          <th class="text-center">Unalloc</th>
          <th class="text-center">Scanned</th>
          <th class="text-center"><a href="{{ sort_location }}"{% if sort == 'p.location' %} class="{{ order|lower }}"{% endif %}>{{ column_location }}</a></th>
          <th class="text-center" style="min-width: 200px;">{{ column_made_in_country }}</th>
          <th class="text-center" style="min-width: 100px;">Last Update</th>
        </tr>
      </thead>
      <tbody>
        {% if products %}
          {% for product in products %}
            <tr data-product-id="{{ product.product_id }}" data-sku="{{ product.sku }}" data-quantity="{{ product.quantity }}" data-scanned="0" data-location="{{ product.location }}"{% if not product.status_id %} class="opacity-50"{% endif %}>
              <td class="text-center">
                <input type="checkbox" name="product_id[{{ product.product_id }}]" value="{{ product.product_id }}" class="form-check-input product-checkbox" />
              </td>
              <td class="text-center">
                <img src="{{ product.image }}" alt="{{ product.name }}" class="img-thumbnail" />
              </td>
              <td class="sku-cell">{{ product.sku }}</td>
              <td>{{ product.name }}</td>
              <td class="text-center">
                <span class="quantity-display badge bg-primary" id="quantity-{{ product.product_id }}">{{ product.quantity }}</span>
              </td>
              <td class="text-center">
                <span class="badge bg-secondary">{{ product.unallocated_quantity }}</span>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark" id="scanned-{{ product.product_id }}">0</span>
              </td>
              <td class="text-center location-cell">{{ product.location }}</td>
              <td class="text-center country-cell" id="check-made-in-country-id-{{ product.product_id }}" {% if product.made_in_country_id == "0" or product.made_in_country_id is null %}style="background-color:RED !important"{% elseif product.made_in_country_id > 0 %}style="background-color:GREEN !important"{% endif %}>
                <select name="made_in_country_id_{{ product.product_id }}" id="input-made-in-country-id-{{ product.product_id }}" class="form-select form-select-sm made-in-country-select" data-product-id="{{ product.product_id }}" onchange="editMadeInCountry({{ product.product_id }})">
                  {% for country in countries %}
                    <option value="{{ country.country_id }}" {% if country.country_id == product.made_in_country_id %}selected="selected"{% endif %}>
                      {{ country.name }}
                    </option>
                  {% endfor %}
                </select>
              </td>
              <td class="text-center" style="font-size: 0.85em;">
                {% if product.date_modified %}
                  <span class="text-muted" title="{{ product.date_modified }}">
                    <i class="fa-solid fa-clock"></i> 
                    <span class="relative-time" data-timestamp="{{ product.date_modified }}"></span>
                  </span>
                {% elseif product.date_added %}
                  <span class="text-muted" title="Added: {{ product.date_added }}">
                    <i class="fa-solid fa-plus"></i> 
                    <span class="relative-time" data-timestamp="{{ product.date_added }}"></span>
                  </span>
                {% else %}
                  <span class="text-muted">-</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td class="text-center" colspan="10">{{ text_no_results }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
  
  {% if products %}
    <div class="row mt-3">
      <div class="col-sm-6 text-start">{{ results }}</div>
    </div>
  {% endif %}
</form>

<!-- Modal popup for missing Made In Country -->
<div class="modal fade" id="countryModal" tabindex="-1" aria-labelledby="countryModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="countryModalLabel"><i class="fa-solid fa-exclamation-triangle"></i> {{ text_country_required }}</h5>
      </div>
      <div class="modal-body">
        <p>{{ text_select_country_message }}</p>
        <div id="missing-products-list" class="mb-3"></div>
        <div class="mb-3">
          <label for="modal-country-select" class="form-label">{{ entry_made_in_country }}</label>
          <select id="modal-country-select" class="form-select">
            {% for country in countries %}
              <option value="{{ country.country_id }}">
                {{ country.name }}
              </option>
            {% endfor %}
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" id="modal-apply-country">{{ button_apply }}</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal popup for scan without country -->
<div class="modal fade" id="scanCountryModal" tabindex="-1" aria-labelledby="scanCountryModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="scanCountryModalLabel"><i class="fa-solid fa-exclamation-triangle"></i> {{ text_country_required }}</h5>
      </div>
      <div class="modal-body">
        <p><strong>{{ text_select_country_message }}</strong></p>
        <div id="scan-product-info" class="alert alert-info mb-3"></div>
        <div id="scan-ai-loader" class="alert alert-warning mb-3" style="display:none;">
          <i class="fa-solid fa-spinner fa-spin"></i> AI is analyzing the product to determine the country...
        </div>
        <div id="scan-ai-result" class="alert alert-success mb-3" style="display:none;">
          <strong><i class="fa-solid fa-robot"></i> AI Suggestion:</strong> <span id="scan-ai-reasoning"></span>
        </div>
        <div class="mb-3">
          <label for="scan-country-select" class="form-label">{{ entry_made_in_country }}</label>
          <select id="scan-country-select" class="form-select" onkeydown="if(event.key === 'Enter' || event.keyCode === 13) { event.preventDefault(); document.getElementById('scan-apply-country').click(); }">
            {% for country in countries %}
              <option value="{{ country.country_id }}">
                {{ country.name }}
              </option>
            {% endfor %}
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <div class="form-check me-auto">
          <input class="form-check-input" type="checkbox" id="auto-accept-ai-country" />
          <label class="form-check-label" for="auto-accept-ai-country">
            Auto-accept AI suggestions (until page reload)
          </label>
        </div>
        <button type="button" class="btn btn-primary" id="scan-apply-country">{{ button_apply }}</button>
      </div>
    </div>
  </div>
</div>

<script>
// Reinit after list loads
if (typeof window.reinitInventory === 'function') {
    window.reinitInventory();
}

// Set focus: if location is set, focus on SKU, otherwise location will already have focus from main page
var filterLocation = document.getElementById('hidden-filter-location')?.value;
if (filterLocation && filterLocation.trim() !== '') {
    var skuInput = document.getElementById('input-sku');
    if (skuInput) {
        skuInput.focus();
    }
}

// editMadeInCountry function from product_list.js
function editMadeInCountry(product_id) {
    var user_token = '';
    var tokenInput = document.querySelector('input[name="user_token"]');
    if (tokenInput) {
        user_token = tokenInput.value;
    }
    
    if (!user_token) {
        alert('Token not found');
        return;
    }
    
    var countrySelect = document.getElementById('input-made-in-country-id-' + product_id);
    if (!countrySelect) {
        console.error('Select not found for product ' + product_id);
        return;
    }
    
    var made_in_country_id = countrySelect.value;
    
    $.ajax({
        url: 'index.php?route=warehouse/product/product.editMadeInCountry&user_token=' + user_token,
        method: 'POST',
        data: {
            product_id: product_id,
            made_in_country_id: made_in_country_id
        },
        dataType: 'json',
        success: function (json) {
            if (json['error']) {
                alert('Error: ' + json['error']);
                return;
            }
            
            if (json['success']) {
                var cell = document.getElementById('check-made-in-country-id-' + product_id);
                if (made_in_country_id > 0) {
                    cell.style.backgroundColor = 'green';
                    cell.style.setProperty('background-color', 'green', 'important');
                } else {
                    cell.style.backgroundColor = 'red';
                    cell.style.setProperty('background-color', 'red', 'important');
                }
            }
        },
        error: function (xhr, ajaxOptions, thrownError) {
            console.error('AJAX Error:', xhr.responseText);
            alert('Error occurred: ' + thrownError);
        }
    });
}

// Validate Made In Country before form submission
$('#form-inventory').on('submit', function(e) {
    var missingProducts = [];
    var selectedCheckboxes = $('.product-checkbox:checked');
    
    selectedCheckboxes.each(function() {
        var productId = $(this).val();
        var countrySelect = $('#input-made-in-country-id-' + productId);
        var countryValue = countrySelect.val();
        
        if (!countryValue || countryValue == '0') {
            var row = $(this).closest('tr');
            var sku = row.find('.sku-cell').text().trim();
            missingProducts.push({
                id: productId,
                sku: sku,
                select: countrySelect
            });
        }
    });
    
    if (missingProducts.length > 0) {
        e.preventDefault();
        showCountryModal(missingProducts);
        return false;
    }
    
    return true;
});

function showCountryModal(missingProducts) {
    var listHtml = '<ul class="list-group">';
    missingProducts.forEach(function(product) {
        listHtml += '<li class="list-group-item"><strong>SKU:</strong> ' + product.sku + ' <strong>ID:</strong> ' + product.id + '</li>';
    });
    listHtml += '</ul>';
    
    $('#missing-products-list').html(listHtml);
    
    // Store missing products for later use
    $('#countryModal').data('missingProducts', missingProducts);
    
    var modal = new bootstrap.Modal(document.getElementById('countryModal'));
    modal.show();
}

$('#modal-apply-country').on('click', function() {
    var selectedCountry = $('#modal-country-select').val();
    var missingProducts = $('#countryModal').data('missingProducts');
    
    if (!selectedCountry || selectedCountry == '0') {
        alert('Please select a country');
        return;
    }
    
    var completed = 0;
    var total = missingProducts.length;
    
    missingProducts.forEach(function(product, index) {
        // Update the select value
        product.select.val(selectedCountry);
        
        // Call editMadeInCountry to save to database
        editMadeInCountry(product.id);
        
        completed++;
        
        // Close modal and submit form after all products are updated
        if (completed === total) {
            setTimeout(function() {
                var modal = bootstrap.Modal.getInstance(document.getElementById('countryModal'));
                modal.hide();
                $('#form-inventory').off('submit').submit();
            }, 500);
        }
    });
});

// Handler for scan country modal
$('#scan-apply-country').on('click', function() {
    var selectedCountry = $('#scan-country-select').val();
    var modal = document.getElementById('scanCountryModal');
    var productId = modal.dataset.productId;
    
    if (!selectedCountry || selectedCountry == '0') {
        alert('Please select a country');
        return;
    }
    
    // Check if auto-accept checkbox is checked and update session variable
    var autoAcceptCheckbox = document.getElementById('auto-accept-ai-country');
    if (autoAcceptCheckbox && autoAcceptCheckbox.checked) {
        window.autoAcceptAICountry = true;
        console.log('Auto-accept AI mode enabled');
    }
    
    // Update the country select in the row
    var countrySelect = document.getElementById('input-made-in-country-id-' + productId);
    if (countrySelect) {
        countrySelect.value = selectedCountry;
        
        // Save to database via AJAX
        var user_token = document.querySelector('input[name="user_token"]').value;
        
        $.ajax({
            url: 'index.php?route=warehouse/product/product.editMadeInCountry&user_token=' + user_token,
            method: 'POST',
            data: {
                product_id: productId,
                made_in_country_id: selectedCountry
            },
            dataType: 'json',
            success: function (json) {
                if (json['success']) {
                    var cell = document.getElementById('check-made-in-country-id-' + productId);
                    if (cell) {
                        cell.style.setProperty('background-color', 'green', 'important');
                    }
                    
                    // Close modal
                    var bsModal = bootstrap.Modal.getInstance(modal);
                    bsModal.hide();
                    
                    // Call callback to continue scan
                    if (window.scanCallback) {
                        window.scanCallback();
                        window.scanCallback = null;
                    }
                    
                    // Return focus to SKU input
                    var skuInput = document.getElementById('input-sku');
                    if (skuInput) {
                        setTimeout(function() {
                            skuInput.focus();
                        }, 300);
                    }
                } else {
                    alert('Error: ' + (json['error'] || 'Unknown error'));
                }
            },
            error: function (xhr, ajaxOptions, thrownError) {
                console.error('AJAX Error:', xhr.responseText);
                alert('Error occurred: ' + thrownError);
            }
        });
    }
});

// Function to format relative time
function formatRelativeTime(timestamp) {
    if (!timestamp) return '-';
    
    const now = new Date();
    const date = new Date(timestamp);
    const diffMs = now - date;
    const diffSec = Math.floor(diffMs / 1000);
    const diffMin = Math.floor(diffSec / 60);
    const diffHour = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHour / 24);
    
    if (diffSec < 60) {
        return 'Just now';
    } else if (diffMin < 60) {
        return diffMin + ' min' + (diffMin > 1 ? 's' : '') + ' ago';
    } else if (diffHour < 24) {
        return diffHour + ' hour' + (diffHour > 1 ? 's' : '') + ' ago';
    } else if (diffDay < 7) {
        return diffDay + ' day' + (diffDay > 1 ? 's' : '') + ' ago';
    } else if (diffDay < 30) {
        const weeks = Math.floor(diffDay / 7);
        return weeks + ' week' + (weeks > 1 ? 's' : '') + ' ago';
    } else if (diffDay < 365) {
        const months = Math.floor(diffDay / 30);
        return months + ' month' + (months > 1 ? 's' : '') + ' ago';
    } else {
        const years = Math.floor(diffDay / 365);
        return years + ' year' + (years > 1 ? 's' : '') + ' ago';
    }
}

// Update all relative time displays
function updateRelativeTimes() {
    document.querySelectorAll('.relative-time').forEach(function(elem) {
        const timestamp = elem.dataset.timestamp;
        if (timestamp) {
            elem.textContent = formatRelativeTime(timestamp);
        }
    });
}

// Initialize relative times on page load
document.addEventListener('DOMContentLoaded', function() {
    updateRelativeTimes();
    // Update every minute
    setInterval(updateRelativeTimes, 60000);
});

// Also update when products list is refreshed
if (typeof window.reinitInventory === 'function') {
    const originalReinit = window.reinitInventory;
    window.reinitInventory = function() {
        originalReinit();
        setTimeout(updateRelativeTimes, 100);
    };
}
</script>
