{# Original: shopmanager/print_report.twig #}
<!DOCTYPE html>
<html>
<head>
  <title>{{ heading_title }}</title>
  <style>
    body { font-family: Arial, sans-serif; font-size:14px; margin:10px; }
    table { width:100%; border-collapse:collapse; margin-top:10px; }
    th, td { border:1px solid #ddd; padding:12px; }
    th { background:#f2f2f2; font-size:14px; }
    td { font-size:18px; }
    .text-center { text-align:center; }
    thead { display:table-header-group; }
    tfoot { display:table-footer-group; }
    .page-break { page-break-before:always; }
    @media print {
      @page { size:8.5in 11in landscape; }
      table { page-break-inside:auto; width:100%; }
      tr.page-break { page-break-before:always; }
      .footer { position:fixed; bottom:0; width:100%; text-align:center; font-size:16px; }
    }
    .small-font { font-size:12px; font-weight:bold; }
    .bold-font { font-weight:bold; }
  </style>
</head>
<body>
  <div id="header">
    <h2 class="text-center">{{ heading_title }}</h2>
  </div>

  {% set row_count = 0 %}
  {% set rows_per_page = 25 %}

  <table>
    <thead>
      <tr>
        <th class="text-center">{{ column_product_id }}</th>
        <th class="text-center">{{ column_name }}</th>
        <th class="text-center">{{ column_upc }}</th>
        <th class="text-center">{{ column_image }}</th>
        <th class="text-center">{{ column_price }}</th>
        <th class="text-center">{{ column_quantity }}</th>
        <th class="text-center">{{ column_location }}</th>
        <th class="text-center">{{ column_unallocated_quantity }}</th>
      </tr>
    </thead>
    <tbody>
      {% for product in products %}
        {% if row_count > 0 and (row_count is divisible by(rows_per_page)) %}
          </tbody></table>
          <div class="page-break"></div>
          <table>
            <thead>
              <tr>
                <th class="text-center">{{ column_product_id }}</th>
                <th class="text-center">{{ column_name }}</th>
                <th class="text-center">{{ column_upc }}</th>
                <th class="text-center">{{ column_image }}</th>
                <th class="text-center">{{ column_price }}</th>
                <th class="text-center">{{ column_quantity }}</th>
                <th class="text-center">{{ column_location }}</th>
                <th class="text-center">{{ column_unallocated_quantity }}</th>
              </tr>
            </thead>
            <tbody>
        {% endif %}
        <tr>
          <td class="text-center bold-font">{{ product.product_id }}</td>
          <td class="text-center small-font">{{ product.name }}</td>
          <td class="text-center bold-font">{{ product.upc }}</td>
          <td class="text-center">
            {% if product.image %}
              <img src="{{ product.image }}" width="50" height="50" alt="{{ product.name }}">
            {% endif %}
          </td>
          <td class="text-left small-font">{{ product.price }}</td>
          <td class="text-center bold-font">{{ product.quantity }}</td>
          <td class="text-center bold-font">{{ product.location }}</td>
          <td class="text-center bold-font">{{ product.unallocated_quantity }}</td>
        </tr>
        {% set row_count = row_count + 1 %}
      {% endfor %}
      {% if products is empty %}
        <tr><td class="text-center" colspan="8">{{ text_no_results }}</td></tr>
      {% endif %}
    </tbody>
  </table>

  <div class="footer"></div>

  <script>
    window.onload = function(){ window.print(); };
  </script>
</body>
</html>
