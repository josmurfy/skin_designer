{# Original: shopmanager/inventory/allocation_list.twig #}
<form id="form-inventory" action="{{ action }}" method="post" enctype="multipart/form-data">
  <div class="alert alert-info mb-3">
    <div class="row align-items-center g-2">
      <div class="col-md-3">
        <label for="input-sku" class="form-label mb-0">{{ entry_sku }}</label>
        <input type="text" name="filter_sku" value="" placeholder="{{ entry_sku }}" id="input-sku" class="form-control" autofocus />
      </div>
      <div class="col-md-3">
        <label for="input-new-location" class="form-label mb-0">{{ entry_new_location }}</label>
        <input type="text" name="new_location" value="" placeholder="{{ entry_new_location }}" id="input-new-location" class="form-control" />
      </div>
      <div class="col-md-2">
        <label class="form-label mb-0">&nbsp;</label>
        <button type="button" class="btn btn-primary w-100" id="button-submit" disabled>{{ button_submit }}</button>
      </div>
    </div>
    <div class="row mt-2">
      <div class="col-md-12">
        <small class="text-muted">
          <strong>{{ product_total }}</strong> {{ text_products_to_process }}
        </small>
      </div>
    </div>
  </div>
  <input type="hidden" name="user_token" value="{{ user_token }}" />
  <div id="hidden-inputs-container"></div>
  <div class="table-responsive">
    <table class="table table-bordered table-hover">
      <thead>
        <tr>
          <th class="text-center" style="width: 1px;">
            <input type="checkbox" id="select-all-checkbox" class="form-check-input" title="{{ entry_select_all }}" />
          </th>
          <th class="text-center">{{ column_image }}</th>
          <th><a href="{{ sort_sku }}"{% if sort == 'p.sku' %} class="{{ order|lower }}"{% endif %}>{{ column_sku }}</a></th>
          <th><a href="{{ sort_name }}"{% if sort == 'pd.name' %} class="{{ order|lower }}"{% endif %}>{{ column_name }}</a></th>
          <th class="text-end">{{ column_total_quantity }}</th>
          <th class="text-end"><a href="{{ sort_unallocated_quantity }}"{% if sort == 'p.unallocated_quantity' %} class="{{ order|lower }}"{% endif %}>{{ column_unallocated_quantity }}</a></th>
          <th class="text-end"><a href="{{ sort_quantity }}"{% if sort == 'p.quantity' %} class="{{ order|lower }}"{% endif %}>{{ column_quantity }}</a></th>
          <th class="text-center"><a href="{{ sort_location }}"{% if sort == 'p.location' %} class="{{ order|lower }}"{% endif %}>{{ column_location }}</a></th>
          <th class="text-center" style="min-width: 200px;">{{ column_made_in_country }}</th>
          <th class="text-center" style="min-width: 100px;">{{ column_updated }}</th>
        </tr>
      </thead>
      <tbody>
        {% if products %}
          {% for product in products %}
            <tr data-product-id="{{ product.product_id }}"{% if not product.status_id %} class="opacity-50"{% endif %}>
              <td class="text-center">
                <input type="checkbox" name="product_id[{{ product.product_id }}]" value="{{ product.product_id }}" class="form-check-input" />
              </td>
              <td class="text-center">
                <img src="{{ product.image }}" alt="{{ product.name }}" class="img-thumbnail" />
              </td>
              <td>{{ product.sku }}</td>
              <td>{{ product.name }}</td>
              <td class="text-end total_quantity">
                {% if product.total_quantity <= 0 %}
                  <span id="total_quantity{{ product.product_id }}" class="badge bg-warning">{{ product.total_quantity }}</span>
                {% elseif product.total_quantity <= 5 %}
                  <span id="total_quantity{{ product.product_id }}" class="badge bg-danger">{{ product.total_quantity }}</span>
                {% else %}
                  <span id="total_quantity{{ product.product_id }}" class="badge bg-success">{{ product.total_quantity }}</span>
                {% endif %}
                <input id="quantity_hid{{ product.product_id }}" type="hidden" value="{{ product.quantity }}" />
                <input id="unallocated_quantity_hid{{ product.product_id }}" type="hidden" value="{{ product.unallocated_quantity }}" />
              </td>
              <td class="text-end unallocated_quantity">
                {% if product.unallocated_quantity <= 0 %}
                  <span id="unallocated_quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.unallocated_quantity }}" class="pedit-unallocated-quantity badge bg-warning">{{ product.unallocated_quantity }}</span>
                {% elseif product.unallocated_quantity <= 5 %}
                  <span id="unallocated_quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.unallocated_quantity }}" class="pedit-unallocated-quantity badge bg-danger">{{ product.unallocated_quantity }}</span>
                {% else %}
                  <span id="unallocated_quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.unallocated_quantity }}" class="pedit-unallocated-quantity badge bg-success">{{ product.unallocated_quantity }}</span>
                {% endif %}
              </td>
              <td class="text-end quantity"{% if product.quantity != 0 %} style="background-color: #dc3545; color: white;"{% endif %}>
                {% if product.quantity <= 0 %}
                  <span id="quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.quantity }}" class="pedit-quantity badge bg-warning"{% if product.quantity != 0 %} style="background-color: #dc3545;"{% endif %}>{{ product.quantity }}</span>
                {% elseif product.quantity <= 5 %}
                  <span id="quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.quantity }}" class="pedit-quantity badge bg-danger">{{ product.quantity }}</span>
                {% else %}
                  <span id="quantity{{ product.product_id }}" rel="{{ product.product_id }}" rel1="{{ product.quantity }}" class="pedit-quantity badge bg-success">{{ product.quantity }}</span>
                {% endif %}
              </td>
              <td class="text-center"{% if product.location is not empty %} style="background-color: #dc3545; color: white;"{% endif %}>
                {{ product.location }}
                <input id="old_location{{ product.product_id }}" type="hidden" value="{{ product.location }}" />
              </td>
              <td class="text-center country-cell" id="check-made-in-country-id-{{ product.product_id }}" {% if product.made_in_country_id == "0" or product.made_in_country_id is null %}style="background-color:RED !important"{% elseif product.made_in_country_id > 0 %}style="background-color:GREEN !important"{% endif %}>
                <select name="made_in_country_id_{{ product.product_id }}" id="input-made-in-country-id-{{ product.product_id }}" class="form-select form-select-sm made-in-country-select" data-product-id="{{ product.product_id }}">
                  {% for country in countries %}
                    <option value="{{ country.country_id }}" {% if country.country_id == product.made_in_country_id %}selected="selected"{% endif %}>
                      {{ country.name }}
                    </option>
                  {% endfor %}
                </select>
              </td>
              <td class="text-center" style="font-size: 0.85em;">
                {% if product.date_modified %}
                  <span class="text-muted" title="{{ product.date_modified }}">
                    <i class="fa-solid fa-clock"></i> 
                    <span class="relative-time" data-timestamp="{{ product.date_modified }}"></span>
                  </span>
                {% elseif product.date_added %}
                  <span class="text-muted" title="Added: {{ product.date_added }}">
                    <i class="fa-solid fa-plus"></i> 
                    <span class="relative-time" data-timestamp="{{ product.date_added }}"></span>
                  </span>
                {% else %}
                  <span class="text-muted">-</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td class="text-center" colspan="10">{{ text_no_results }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
  <div class="row">
    <div class="col-sm-6 text-start">{{ pagination }}</div>
    <div class="col-sm-6 text-end">{{ results }}</div>
  </div>
</form>
