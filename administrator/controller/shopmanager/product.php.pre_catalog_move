	/**
	* Save
	*
	* @return void
	*/
	public function save(): void {
		$lang = $this->load->language('shopmanager/product');
		$data = $data ?? [];
		$data += $lang;

		$json = [];

		if (!$this->user->hasPermission('modify', 'shopmanager/product')) {
			$json['error']['warning'] = ($lang['error_permission'] ?? '');
		}

		$required = [
			'product_id' => 0,
			'master_id' => 0,
			'product_description' => [],
			'model' => '',
			'product_code' => [],
			'location'            => '',
			'variant'             => [],
			'override'            => [],
			'quantity'            => 0,
			'unallocated_quantity'  => 0,
			'minimum'             => 0,
			'subtract'            => 0,
			'stock_status_id' => 0,
			'date_available' => '',
			'manufacturer_id' => 0,
			'shipping' => 0,
			'price' => 0.0,
			'points' => 0,
			'weight' => 0.0,
			'weight_class_id' => 0,
			'length' => 0.0,
			'length_class_id' => 0,
			'status' => 0,
			'tax_class_id' => 0,
			'sort_order' => 0,
			'sku' => '',
			'upc' => '',
			'ean' => '',
			'jan' => '',
			'isbn' => '',
			'mpn' => ''
		];

		$post_info = $this->request->post + $required;

		foreach ($post_info['product_description'] as $language_id => $value) {
			if (!oc_validate_length($value['name'], 1, 255)) {
				$json['error']['name_' . $language_id] = ($lang['error_name'] ?? '');
			}

			if (!oc_validate_length($value['meta_title'], 1, 255)) {
				$json['error']['meta_title_' . $language_id] = ($lang['error_meta_title'] ?? '');
			}
		}

		if (!oc_validate_length($post_info['model'], 1, 64)) {
			$json['error']['model'] = ($lang['error_model'] ?? '');
		}

		// Identifier
		$this->load->model('shopmanager/identifier');

		foreach ($post_info['product_code'] as $key => $product_code) {
			$identifier_info = $this->model_shopmanager_identifier->getIdentifierByCode($product_code['code']);

			if ($identifier_info && $identifier_info['validation'] && !oc_validate_regex($product_code['value'], $identifier_info['validation'])) {
				$json['error']['code_' . $key] = sprintf(($lang['error_regex'] ?? ''), $product_code['code']);
			}
		}

		$this->load->model('shopmanager/product');

		if ($post_info['master_id']) {
			$product_options = $this->model_shopmanager_product->getOptions($post_info['master_id']);

			foreach ($product_options as $product_option) {
				if (isset($post_info['override']['variant'][$product_option['product_option_id']]) && $product_option['required'] && empty($post_info['variant'][$product_option['product_option_id']])) {
					$json['error']['option_' . $product_option['product_option_id']] = sprintf(($lang['error_required'] ?? ''), $product_option['name']);
				}
			}
		}

		// SEO
		if ($post_info['product_seo_url']) {
			$this->load->model('design/seo_url');

			foreach ($post_info['product_seo_url'] as $store_id => $language) {
				foreach ($language as $language_id => $keyword) {
				// Trim and skip empty keywords
				$keyword = trim($keyword);
				if (empty($keyword)) {
					continue;
				}

				if (!oc_validate_length($keyword, 1, 64)) {
					$json['error']['keyword_' . $store_id . '_' . $language_id] = ($lang['error_keyword'] ?? '');
				}

				if (!oc_validate_path($keyword)) {
					$json['error']['keyword_' . $store_id . '_' . $language_id] = ($lang['error_keyword_character'] ?? '');
				}

				$seo_url_info = $this->model_design_seo_url->getSeoUrlByKeyword($keyword, $store_id);

				if ($seo_url_info && ($seo_url_info['key'] != 'product_id' || !isset($post_info['product_id']) || $seo_url_info['value'] != (int)$post_info['product_id'])) {
					$json['error']['keyword_' . $store_id . '_' . $language_id] = ($lang['error_keyword_exists'] ?? '');
				}
			}
		}
	}

	if (isset($json['error']) && !isset($json['error']['warning'])) {
		$json['error']['warning'] = ($lang['error_warning'] ?? '');
	}

	if (!$json) {
			if (!$post_info['product_id']) {
				if (!$post_info['master_id']) {
					// Normal product add
					$json['product_id'] = $this->model_shopmanager_product->addProduct($post_info);
				} else {
					// Variant product add
					$json['product_id'] = $this->model_shopmanager_product->addVariant($post_info['master_id'], $post_info);
				}
			} else {
				if (!$post_info['master_id']) {
