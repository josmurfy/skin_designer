			}
		}

		if (!$this->user->hasPermission('modify', 'shopmanager/product')) {
			$json['error'] = ($lang['error_permission'] ?? '');
		}

		if (!$json) {
			$this->load->model('shopmanager/product');

			foreach ($selected as $product_id) {
				$this->model_shopmanager_product->editStatus($product_id,0);
			}

			$json['success'] = ($lang['text_success'] ?? '');
		}

		$this->response->addHeader('Content-Type: application/json');
		$this->response->setOutput(json_encode($json));

	}
}
