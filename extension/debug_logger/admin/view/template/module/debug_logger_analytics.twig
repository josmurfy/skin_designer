{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ reports_url }}" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-list"></i> {{ text_reports }}</a>
        <a href="{{ settings_url }}" class="btn btn-sm btn-light"><i class="fa-solid fa-cog"></i></a>
      </div>
      <h1><i class="fa-solid fa-chart-bar"></i> {{ text_analytics_title }}
        {% if is_pro %}
        <span class="badge bg-warning text-dark" style="font-size:.45em;vertical-align:middle">PRO</span>
        {% else %}
        <span class="badge bg-secondary" style="font-size:.45em;vertical-align:middle">FREE</span>
        {% endif %}
      </h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">

    {# ── Stats cards ── #}
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold">{{ total }}</div>
            <small class="text-muted">{{ text_total_reports_stat }}</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-danger">{{ total_open }}</div>
            <small class="text-muted">{{ text_open_stat }}</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-success">{{ total_closed }}</div>
            <small class="text-muted">{{ text_closed_stat }}</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-warning">{{ avg_resolution }}</div>
            <small class="text-muted">{{ text_avg_resolution }}</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-danger">{{ sev_bug }}</div>
            <small class="text-muted">Bugs</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-warning">{{ sev_warning }}</div>
            <small class="text-muted">Warnings</small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg">
        <div class="card text-center h-100">
          <div class="card-body py-3">
            <div class="fs-2 fw-bold text-info">{{ sev_info }}</div>
            <small class="text-muted">Info</small>
          </div>
        </div>
      </div>
    </div>

    {# ── Charts row 1 ── #}
    <div class="row g-3 mb-4">
      <div class="col-lg-8">
        <div class="card h-100">
          <div class="card-header fw-semibold">{{ text_reports_per_day }}</div>
          <div class="card-body"><canvas id="chart-daily" style="max-height:300px"></canvas></div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card h-100">
          <div class="card-header fw-semibold">{{ text_severity_dist }}</div>
          <div class="card-body"><canvas id="chart-severity" style="max-height:300px"></canvas></div>
        </div>
      </div>
    </div>

    {# ── Charts row 2 ── #}
    <div class="row g-3 mb-4">
      <div class="col-lg-8">
        <div class="card h-100">
          <div class="card-header fw-semibold">{{ text_activity_by_hour }}</div>
          <div class="card-body"><canvas id="chart-hourly" style="max-height:300px"></canvas></div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card h-100">
          <div class="card-header fw-semibold">{{ text_source_dist }}</div>
          <div class="card-body"><canvas id="chart-source" style="max-height:300px"></canvas></div>
        </div>
      </div>
    </div>

    {# ── Top Error Pages ── #}
    <div class="card mb-4">
      <div class="card-header fw-semibold">{{ text_top_pages }}</div>
      <div class="card-body p-0">
        {% if top_pages %}
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr><th>#</th><th>URL</th><th class="text-end">Reports</th></tr></thead>
            <tbody>
            {% for i, page in top_pages %}
            <tr>
              <td>{{ i + 1 }}</td>
              <td class="text-truncate" style="max-width:500px" title="{{ page.url }}">{% if page.route %}<span class="badge bg-dark font-monospace" style="font-size:.72rem">{{ page.route }}</span> {% endif %}{{ page.display }}</td>
              <td class="text-end"><span class="badge bg-primary">{{ page.cnt }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="text-muted text-center py-3 mb-0">{{ text_no_data }}</p>
        {% endif %}
      </div>
    </div>

    {# ── Recurring Issues ── #}
    <div class="card mb-4">
      <div class="card-header fw-semibold">{{ text_recurring_issues }}</div>
      <div class="card-body p-0">
        {% if grouped %}
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr><th>URL</th><th>Severity</th><th class="text-end">Count</th><th>First Seen</th><th>Last Seen</th></tr></thead>
            <tbody>
            {% for g in grouped %}
            <tr>
              <td class="text-truncate" style="max-width:400px" title="{{ g.url }}">{% if g.route %}<span class="badge bg-dark font-monospace" style="font-size:.72rem">{{ g.route }}</span> {% endif %}{{ g.display }}</td>
              <td><span class="badge {% if g.severity == 'bug' %}bg-danger{% elseif g.severity == 'warning' %}bg-warning text-dark{% else %}bg-info{% endif %}">{{ g.severity|upper }}</span></td>
              <td class="text-end"><span class="badge bg-primary">{{ g.cnt }}</span></td>
              <td><small>{{ g.first_seen }}</small></td>
              <td><small>{{ g.last_seen }}</small></td>
            </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="text-muted text-center py-3 mb-0">{{ text_no_recurring }}</p>
        {% endif %}
      </div>
    </div>

    {# ── Recent Activity ── #}
    <div class="card mb-4">
      <div class="card-header fw-semibold">{{ text_recent_activity }}</div>
      <div class="card-body p-0">
        {% if recent %}
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr><th>#</th><th>Date</th><th>Severity</th><th>Source</th><th>Status</th><th>User</th><th>URL</th></tr></thead>
            <tbody>
            {% for r in recent %}
            <tr>
              <td>#{{ r.id }}</td>
              <td><small>{{ r.date_added }}</small></td>
              <td><span class="badge {% if r.severity == 'bug' %}bg-danger{% elseif r.severity == 'warning' %}bg-warning text-dark{% else %}bg-info{% endif %}">{{ r.severity|upper }}</span></td>
              <td><span class="badge {% if r.source == 'admin' %}bg-primary{% else %}bg-success{% endif %}">{{ r.source }}</span></td>
              <td><span class="badge {% if r.status == 1 %}bg-success{% else %}bg-danger{% endif %}">{% if r.status == 1 %}{{ text_closed_stat }}{% else %}{{ text_open_stat }}{% endif %}</span></td>
              <td><small>{{ r.admin_user }}</small></td>
              <td class="text-truncate" style="max-width:300px" title="{{ r.url }}">{% if r.route %}<span class="badge bg-dark font-monospace" style="font-size:.72rem">{{ r.route }}</span>{% else %}{{ r.display }}{% endif %}</td>
            </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="text-muted text-center py-3 mb-0">{{ text_no_data }}</p>
        {% endif %}
      </div>
    </div>

  </div>
</div>
<script src="{{ chart_js_url }}"></script>
<script>
(function() {
  var textColor = '#6c757d';
  var gridColor = '#dee2e6';

  // Daily stacked bar chart
  new Chart(document.getElementById('chart-daily'), {
    type: 'bar',
    data: {
      labels: {{ day_labels|raw }},
      datasets: [
        { label: 'Bug', data: {{ day_bug|raw }}, backgroundColor: '#ef4444', borderRadius: 3 },
        { label: 'Warning', data: {{ day_warn|raw }}, backgroundColor: '#f59e0b', borderRadius: 3 },
        { label: 'Info', data: {{ day_info|raw }}, backgroundColor: '#3b82f6', borderRadius: 3 }
      ]
    },
    options: {
      responsive: true,
      scales: {
        x: { stacked: true, grid: { display: false }, ticks: { color: textColor, maxTicksLimit: 10 } },
        y: { stacked: true, beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor } }
      },
      plugins: { legend: { labels: { color: textColor } } }
    }
  });

  // Severity doughnut
  new Chart(document.getElementById('chart-severity'), {
    type: 'doughnut',
    data: {
      labels: ['Bug', 'Warning', 'Info'],
      datasets: [{ data: [{{ sev_bug }}, {{ sev_warning }}, {{ sev_info }}], backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6'], borderWidth: 0 }]
    },
    options: { responsive: true, cutout: '60%', plugins: { legend: { labels: { color: textColor } } } }
  });

  // Hourly bar chart
  new Chart(document.getElementById('chart-hourly'), {
    type: 'bar',
    data: {
      labels: {{ hour_labels|raw }},
      datasets: [{ label: 'Reports', data: {{ hour_values|raw }}, backgroundColor: '#6366f1', borderRadius: 3 }]
    },
    options: {
      responsive: true,
      scales: {
        x: { grid: { display: false }, ticks: { color: textColor } },
        y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor } }
      },
      plugins: { legend: { display: false } }
    }
  });

  // Source pie
  new Chart(document.getElementById('chart-source'), {
    type: 'pie',
    data: {
      labels: ['Admin', 'Catalog'],
      datasets: [{ data: [{{ src_admin }}, {{ src_catalog }}], backgroundColor: ['#6366f1', '#10b981'], borderWidth: 0 }]
    },
    options: { responsive: true, plugins: { legend: { labels: { color: textColor } } } }
  });
})();
</script>
{{ footer }}
