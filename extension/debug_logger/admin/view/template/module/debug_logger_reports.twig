{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        {% if is_pro %}
        <a href="{{ base_url }}&amp;action=export&amp;format=csv" class="btn btn-sm btn-outline-success"><i class="fa-solid fa-file-csv"></i> CSV</a>
        <a href="{{ base_url }}&amp;action=export&amp;format=json" class="btn btn-sm btn-outline-success"><i class="fa-solid fa-file-code"></i> JSON</a>
        {% endif %}
        <a href="{{ analytics_url }}" class="btn btn-sm btn-outline-warning"><i class="fa-solid fa-chart-bar"></i> {{ text_analytics }}</a>
        <a href="{{ settings_url }}" class="btn btn-sm btn-light"><i class="fa-solid fa-cog"></i></a>
      </div>
      <h1><i class="fa-solid fa-bug"></i> {{ heading_title }} - {{ text_reports }}
        {% if is_pro %}
        <span class="badge bg-warning text-dark" style="font-size:.45em;vertical-align:middle">PRO</span>
        {% else %}
        <span class="badge bg-secondary" style="font-size:.45em;vertical-align:middle">FREE</span>
        {% endif %}
      </h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">

    {# ── Filter toolbar ── #}
    <div class="card mb-3">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <a href="{{ base_url }}" class="btn btn-sm {% if filter_status < 0 and not filter_source %}btn-primary{% else %}btn-outline-secondary{% endif %}">All ({{ total }})</a>
          <a href="{{ base_url }}&amp;filter_status=0" class="btn btn-sm {% if filter_status == 0 %}btn-danger{% else %}btn-outline-danger{% endif %}">Open ({{ total_open }})</a>
          <a href="{{ base_url }}&amp;filter_status=1" class="btn btn-sm {% if filter_status == 1 and not filter_source %}btn-success{% else %}btn-outline-success{% endif %}">Closed ({{ total_closed }})</a>
          <span class="vr"></span>
          <a href="{{ base_url }}&amp;filter_source=admin" class="btn btn-sm {% if filter_source == 'admin' %}btn-info{% else %}btn-outline-info{% endif %}">Admin</a>
          <a href="{{ base_url }}&amp;filter_source=catalog" class="btn btn-sm {% if filter_source == 'catalog' %}btn-info{% else %}btn-outline-info{% endif %}">Catalog</a>
          <span class="text-muted small ms-2">{{ showing }} {{ report_count }}</span>
          {% if total > 0 %}
          <a href="{{ base_url }}&amp;action=clear_all" class="btn btn-sm btn-outline-danger ms-auto" onclick="return confirm('{{ text_confirm_clear_all }}')"><i class="fa-solid fa-trash"></i> Clear All</a>
          {% endif %}
        </div>
        {# Tag filters #}
        {% if all_tag_names %}
        <div class="d-flex flex-wrap align-items-center gap-1 mt-2">
          <small class="text-muted">Tags:</small>
          {% for tn in all_tag_names %}
          <a href="{{ base_url }}&amp;filter_tag={{ tn|url_encode }}" class="btn btn-sm {% if filter_tag == tn %}btn-primary{% else %}btn-outline-secondary{% endif %}" style="font-size:.75rem">{{ tn }}</a>
          {% endfor %}
          {% if filter_tag %}
          <a href="{{ base_url }}" class="btn btn-sm btn-outline-dark" style="font-size:.72rem">&times; Clear</a>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>

    {# ── Bulk action bar ── #}
    <div class="card mb-3 d-none" id="bulk-bar">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <input type="checkbox" class="form-check-input" id="cb-all" onclick="dlToggleAll(this)">
          <span class="fw-semibold text-primary" id="bulk-count">0 selected</span>
          <button class="btn btn-sm btn-outline-primary" onclick="dlBulk('close')">Close Selected</button>
          <button class="btn btn-sm btn-outline-success" onclick="dlBulk('open')">Reopen Selected</button>
          <button class="btn btn-sm btn-outline-danger" onclick="if(confirm('Delete selected reports?'))dlBulk('delete')">Delete Selected</button>
        </div>
      </div>
    </div>

    {# ── Report cards ── #}
    {% if reports %}
    {% for report in reports %}
    <div class="card mb-2 {% if report.status == 1 %}opacity-50{% endif %}" data-rid="{{ report.id }}">
      <div class="card-body py-2 px-3">
        {# Meta row #}
        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
          <input type="checkbox" class="form-check-input cb-item" value="{{ report.id }}" onclick="dlUpdateBulk()">
          <select class="form-select form-select-sm dl-sev-select" data-rid="{{ report.id }}" style="width:auto;color:{{ report.sev_color }};border-color:{{ report.sev_color }};font-weight:600;font-size:.78rem">
            {% for sv, sc in sev_colors %}
            <option value="{{ sv }}" style="color:{{ sc }}" {% if report.severity == sv %}selected{% endif %}>{{ sv|upper }}</option>
            {% endfor %}
          </select>
          <span class="badge" style="background:{{ report.src_color }}">{{ report.source }}</span>
          {% if report.admin_user %}
          <small class="text-muted">{{ report.admin_user }}</small>
          {% endif %}
          {% if is_pro and admin_users %}
          <select class="form-select form-select-sm dl-assign-select" data-rid="{{ report.id }}" style="width:auto;font-size:.75rem">
            <option value="0">-- Unassigned --</option>
            {% for u in admin_users %}
            <option value="{{ u.user_id }}" {% if report.assigned_to == u.user_id %}selected{% endif %}>{{ u.firstname }} {{ u.lastname }}</option>
            {% endfor %}
          </select>
          {% endif %}
          <small class="text-muted ms-auto">#{{ report.id }} &middot; {{ report.date_added }}</small>
        </div>

        {# URL #}
        {% if report.url %}
        <div class="mb-1" style="font-size:.78rem">
          {% if report.route %}
          <span class="badge bg-dark font-monospace" style="font-size:.72rem">{{ report.route }}</span>
          {% endif %}
          <a href="{{ report.url }}" target="_blank" class="text-muted" style="word-break:break-all">{{ report.url }}</a>
        </div>
        {% endif %}

        {# Comment (inline editable) #}
        <div class="dl-comment-display border-start border-primary border-3 bg-light p-2 rounded-end mb-1" data-rid="{{ report.id }}" onclick="dlEditComment(this)" title="Click to edit" style="font-size:.82rem;cursor:pointer;white-space:pre-wrap;min-height:1.5em">{{ report.comment|nl2br }}</div>

        {# Tags #}
        <div class="d-flex flex-wrap align-items-center gap-1 mb-1" id="tags-{{ report.id }}">
          {% for tag in report.tags %}
          <span class="badge bg-primary dl-tag-badge" data-tagid="{{ tag.tag_id }}">{{ tag.tag_name }} <span class="dl-tag-x" onclick="dlRemoveTag(this,{{ tag.tag_id }})" style="cursor:pointer;opacity:.7">&times;</span></span>
          {% endfor %}
          <input type="text" class="form-control form-control-sm" placeholder="+ tag" data-rid="{{ report.id }}" style="width:100px;font-size:.72rem" onkeydown="if(event.key==='Enter'){dlAddTag(this);event.preventDefault()}">
        </div>

        {# Resolution #}
        <div class="mb-1">
          <small class="text-warning fw-semibold"><i class="fa-solid fa-gear"></i> Resolution</small>
          <div class="dl-resolution-display border-start border-warning border-3 p-2 rounded-end" data-rid="{{ report.id }}" onclick="dlEditResolution(this)" title="Click to add resolution" style="font-size:.82rem;cursor:pointer;white-space:pre-wrap;min-height:1.5em;background:#fffbeb;color:#92400e">{{ report.resolution|nl2br }}</div>
        </div>

        {# Console log #}
        {% if report.console_log %}
        <pre class="bg-dark text-light rounded p-2 mb-1" style="font-size:.72rem;max-height:200px;overflow:auto">{{ report.console_log }}</pre>
        {% endif %}

        {# Network log #}
        {% if report.network_log %}
        <details class="mb-1">
          <summary class="text-muted" style="font-size:.78rem;cursor:pointer">Network log</summary>
          <pre class="bg-dark text-light rounded p-2" style="font-size:.72rem;max-height:200px;overflow:auto">{{ report.network_log }}</pre>
        </details>
        {% endif %}

        {# Screenshot #}
        {% if report.screenshot %}
        <img class="img-thumbnail mb-1" src="{{ report.screenshot }}" alt="Screenshot" style="max-width:300px;cursor:pointer" onclick="dlShowSS(this.src)">
        {% endif %}

        {# Action buttons #}
        <div class="d-flex gap-2 mt-1">
          {% if report.status == 1 %}
          <a href="{{ base_url }}&amp;action=open&amp;report_id={{ report.id }}" class="btn btn-sm btn-outline-success">Reopen</a>
          {% else %}
          <a href="{{ base_url }}&amp;action=close&amp;report_id={{ report.id }}" class="btn btn-sm btn-outline-primary">Close</a>
          {% endif %}
          <a href="{{ base_url }}&amp;action=delete&amp;report_id={{ report.id }}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')">Delete</a>
        </div>
      </div>
    </div>
    {% endfor %}
    {% else %}
    <div class="card">
      <div class="card-body text-center text-muted py-5">
        <i class="fa-solid fa-inbox fa-3x mb-2 d-block"></i>
        No reports found.
      </div>
    </div>
    {% endif %}

  </div>
</div>

{# ── Screenshot overlay ── #}
<div id="dl-ss-overlay" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;padding:1rem" onclick="this.style.display='none'">
  <span style="position:fixed;top:12px;right:16px;color:#fff;font-size:2rem;cursor:pointer;z-index:100000">&times;</span>
  <img id="dl-ss-img" src="" style="max-width:96vw;max-height:96vh;border-radius:6px;object-fit:contain" onclick="event.stopPropagation();window.open(this.src,'_blank')">
</div>

<script>
// ── AJAX URLs ──
var _updateUrl  = '{{ update_url }}';
var _addTagUrl  = '{{ add_tag_url }}';
var _removeTagUrl = '{{ remove_tag_url }}';
var _bulkUrl    = '{{ bulk_url }}';
{% if is_pro and assign_url %}
var _assignUrl  = '{{ assign_url }}';
{% endif %}

// ── Screenshot lightbox ──
function dlShowSS(src) {
  var o = document.getElementById('dl-ss-overlay');
  document.getElementById('dl-ss-img').src = src;
  o.style.display = 'flex';
  document.addEventListener('keydown', function kh(e) {
    if (e.key === 'Escape') { o.style.display = 'none'; document.removeEventListener('keydown', kh); }
  });
}

// ── Generic update ──
function dlUpdate(rid, field, value, cb) {
  fetch(_updateUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'report_id=' + rid + '&field=' + field + '&value=' + encodeURIComponent(value)
  }).then(function(r) { return r.json(); }).then(function(j) { if (cb) cb(j); });
}

// ── Severity change ──
document.querySelectorAll('.dl-sev-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    var c = { bug: '#ef4444', warning: '#f59e0b', info: '#3b82f6' };
    this.style.color = c[this.value] || '#ef4444';
    this.style.borderColor = c[this.value] || '#ef4444';
    dlUpdate(this.dataset.rid, 'severity', this.value);
  });
});

// ── Inline comment editing ──
function txtEsc(s) { var d = document.createElement('div'); d.appendChild(document.createTextNode(s)); return d.innerHTML; }
function nl2br(s) { return s.replace(/\n/g, '<br>'); }

function dlEditComment(el) {
  if (el.querySelector('textarea')) return;
  var rid = el.dataset.rid, txt = el.innerText || '';
  el.innerHTML = '<textarea class="form-control form-control-sm" style="min-height:60px">' + txtEsc(txt) + '</textarea>'
    + '<div class="mt-1"><button class="btn btn-sm btn-success me-1" onclick="dlSaveComment(this)">Save</button>'
    + '<button class="btn btn-sm btn-secondary" onclick="dlCancelComment(this)">Cancel</button></div>';
  var ta = el.querySelector('textarea'); ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length);
}
function dlSaveComment(btn) {
  var wrap = btn.closest('.dl-comment-display'), ta = wrap.querySelector('textarea');
  var val = ta.value, rid = wrap.dataset.rid;
  dlUpdate(rid, 'comment', val, function() { wrap.innerHTML = val ? nl2br(txtEsc(val)) : ''; });
}
function dlCancelComment(btn) { location.reload(); }

// ── Resolution editing ──
function dlEditResolution(el) {
  if (el.querySelector('textarea')) return;
  var rid = el.dataset.rid, txt = el.innerText || '';
  el.innerHTML = '<textarea class="form-control form-control-sm" style="min-height:60px;background:#fffbeb;color:#92400e">' + txtEsc(txt) + '</textarea>'
    + '<div class="mt-1"><button class="btn btn-sm btn-warning me-1" onclick="dlSaveResolution(this)">Save</button>'
    + '<button class="btn btn-sm btn-secondary" onclick="dlCancelComment(this)">Cancel</button></div>';
  var ta = el.querySelector('textarea'); ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length);
}
function dlSaveResolution(btn) {
  var wrap = btn.closest('.dl-resolution-display'), ta = wrap.querySelector('textarea');
  var val = ta.value, rid = wrap.dataset.rid;
  dlUpdate(rid, 'resolution', val, function() { wrap.innerHTML = val ? nl2br(txtEsc(val)) : ''; });
}

// ── Tags ──
function dlAddTag(input) {
  var tag = input.value.trim(); if (!tag) return;
  var rid = input.dataset.rid;
  fetch(_addTagUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'report_id=' + rid + '&tag_name=' + encodeURIComponent(tag)
  }).then(function(r) { return r.json(); }).then(function(j) {
    if (j.success) {
      var s = document.createElement('span');
      s.className = 'badge bg-primary dl-tag-badge'; s.dataset.tagid = j.tag_id;
      s.innerHTML = txtEsc(j.tag_name) + '<span class="dl-tag-x" onclick="dlRemoveTag(this,' + j.tag_id + ')" style="cursor:pointer;opacity:.7">&times;</span>';
      input.parentNode.insertBefore(s, input); input.value = '';
    }
  });
}
function dlRemoveTag(el, tagId) {
  fetch(_removeTagUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'tag_id=' + tagId
  }).then(function(r) { return r.json(); }).then(function(j) {
    if (j.success) el.closest('.dl-tag-badge').remove();
  });
}

// ── Bulk actions ──
function dlUpdateBulk() {
  var cbs = document.querySelectorAll('.cb-item:checked');
  var bar = document.getElementById('bulk-bar');
  var cnt = document.getElementById('bulk-count');
  if (cbs.length > 0) { bar.classList.remove('d-none'); cnt.textContent = cbs.length + ' selected'; }
  else { bar.classList.add('d-none'); }
}
function dlToggleAll(master) {
  document.querySelectorAll('.cb-item').forEach(function(cb) { cb.checked = master.checked; });
  dlUpdateBulk();
}
function dlBulk(action) {
  var ids = []; document.querySelectorAll('.cb-item:checked').forEach(function(cb) { ids.push(cb.value); });
  if (!ids.length) return;
  fetch(_bulkUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'action=' + action + '&ids=' + encodeURIComponent(JSON.stringify(ids))
  }).then(function(r) { return r.json(); }).then(function(j) {
    if (j.success) location.reload();
  });
}

// ── Assignment ──
{% if is_pro and assign_url %}
document.querySelectorAll('.dl-assign-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    fetch(_assignUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'report_id=' + this.dataset.rid + '&user_id=' + this.value });
  });
});
{% endif %}
</script>
{{ footer }}
