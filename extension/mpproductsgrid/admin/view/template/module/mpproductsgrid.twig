{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-mpproductsgrid" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-mpproductsgrid" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <ul class="nav nav-tabs">
            <li class="nav-item"><a href="#tab-general" data-bs-toggle="tab" class="nav-link active">{{ tab_general }}</a></li>
            <li class="nav-item"><a href="#tab-category" data-bs-toggle="tab" class="nav-link">{{ tab_category }}</a></li>
            <li class="nav-item"><a href="#tab-manufacturer" data-bs-toggle="tab" class="nav-link">{{ tab_manufacturer }}</a></li>
          </ul>
          <div class="tab-content">
            <div class="tab-pane active" id="tab-general">
              <input type="hidden" name="module_id" value="{{ module_id }}" id="input-module-id"/>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-name">{{ entry_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="name" value="{{ name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
                  <div id="error-name" class="invalid-feedback"></div>
                </div>
              </div>
              {% if not module_id %}
                <div class="alert alert-info">{{ text_info }}</div>
              {% endif %}
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <select name="status" id="input-status" class="form-select" {% if not module_id %}disabled="disabled"{% endif %}>
                    <option value="1" {% if status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if not status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-heading_title">{{ entry_heading_title }}</label>
                <div class="col-sm-10">
                  {% for language in languages %}
                  <div class="input-group"> <span class="input-group-text"><img src="{{ language.image }}" title="{{ language.name }}" /></span>
                    <input type="text" name="pheading_title[{{ language.language_id }}]" value="{{ (pheading_title[language.language_id]) ? pheading_title[language.language_id] : '' }}" placeholder="{{ entry_heading_title }}" class="form-control" />
                  </div>
                  <div id="error-pheading-title-{{ language.language_id }}" class="invalid-feedback"></div>
                  {% endfor %}
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_filter_display }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="filter_display" value="0" {% if filter_display == '0' %}checked="checked"{% endif %} class="form-check-input" id="input-filter-display-0" />
                    <label class="form-check-label" for="input-filter-display-0">{{ text_filter_image }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="filter_display" value="1" {% if filter_display == '1' %}checked="checked"{% endif %} class="form-check-input" id="input-filter-display-1" />
                    <label class="form-check-label" for="input-filter-display-1">{{ text_filter_text }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="filter_display" value="2"  {% if filter_display == '2' %}checked="checked"{% endif %} class="form-check-input" id="input-filter-display-2" />
                    <label class="form-check-label" for="input-filter-display-2">{{ text_filter_both }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_product_name }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_name" value="1" {% if show_product_name %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-name-1" />
                    <label class="form-check-label" for="input-show-product-name-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_name" value="0" {% if not show_product_name %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-name-0" />
                    <label class="form-check-label" for="input-show-product-name-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_product_price }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_price" value="1" {% if show_product_price %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-price-1"/>
                    <label class="form-check-label" for="input-show-product-price-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_price" value="0" {% if not show_product_price %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-price-0"/>
                    <label class="form-check-label" for="input-show-product-price-0">{{ text_no }}</label>
                  </div>
                </div>
              </div> 
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_product_description }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_description" value="1" {% if show_product_description %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-description-1"/>
                    <label class="form-check-label" for="input-show-product-description-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_description" value="0" {% if not show_product_description %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-description-0"/>
                    <label class="form-check-label" for="input-show-product-description-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>  
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-product_description_length"><span data-bs-toggle="tooltip" title="{{ help_product_description_length }}">{{ entry_product_description_length }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="product_description_length" value="{{ product_description_length }}" placeholder="{{ entry_product_description_length }}" id="input-product_description_length" class="form-control" />
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_product_review }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_review" value="1" {% if show_product_review %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-review-1"/>
                    <label class="form-check-label" for="input-show-product-review-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_review" value="0" {% if not show_product_review %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-review-0"/>
                    <label class="form-check-label" for="input-show-product-review-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label"><span data-bs-toggle="tooltip" title="{{ help_show_product_additional_images }}">{{ entry_show_product_additional_images }}</span></label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_additional_images" value="1" {% if show_product_additional_images %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-additional-images-1"/>
                    <label class="form-check-label" for="input-show-product-additional-images-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_product_additional_images" value="0" {% if not show_product_additional_images %}checked="checked"{% endif %} class="form-check-input" id="input-show-product-additional-images-0"/>
                    <label class="form-check-label" for="input-show-product-additional-images-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_prevnextbuttons }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_prevnextbuttons" value="1" {% if show_prevnextbuttons %}checked="checked"{% endif %} class="form-check-input" id="input-show-prevnextbuttons-1"/>
                    <label class="form-check-label" for="input-show-prevnextbuttons-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_prevnextbuttons" value="0" {% if not show_prevnextbuttons %}checked="checked"{% endif %} class="form-check-input" id="input-show-prevnextbuttons-0"/>
                    <label class="form-check-label" for="input-show-prevnextbuttons-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_show_pagedots }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_pagedots" value="1" {% if show_pagedots %}checked="checked"{% endif %} class="form-check-input" id="input-show-pagedots-1"/>
                    <label class="form-check-label" for="input-show-pagedots-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="show_pagedots" value="0" {% if not show_pagedots %}checked="checked"{% endif %} class="form-check-input" id="input-show-pagedots-0"/>
                    <label class="form-check-label" for="input-show-pagedots-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_slider_autoplay }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="slider_autoplay" value="1" {% if slider_autoplay %}checked="checked"{% endif %} class="form-check-input" id="input-slider-autoPlay-1"/>
                    <label class="form-check-label" for="input-slider-autoPlay-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="slider_autoplay" value="0" {% if not slider_autoplay %}checked="checked"{% endif %} class="form-check-input" id="input-slider-autoPlay-0"/>
                    <label class="form-check-label" for="input-slider-autoPlay-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_slider_pauseautoplayonhover }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-check-inline">
                    <input type="radio" name="slider_pauseautoplayonhover" value="1" {% if slider_pauseautoplayonhover %}checked="checked"{% endif %} class="form-check-input" id="input-slider-pauseautoplayonhover-1"/>
                    <label class="form-check-label" for="input-slider-pauseautoplayonhover-1">{{ text_yes }}</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input type="radio" name="slider_pauseautoplayonhover" value="0" {% if not slider_pauseautoplayonhover %}checked="checked"{% endif %} class="form-check-input" id="input-slider-pauseautoplayonhover-0"/>
                    <label class="form-check-label" for="input-slider-pauseautoplayonhover-0">{{ text_no }}</label>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-slider_autoplayspeed"><span data-bs-toggle="tooltip" title="{{ help_slider_autoplayspeed }}">{{ entry_slider_autoplayspeed }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="slider_autoplayspeed" value="{{ slider_autoplayspeed }}" placeholder="{{ entry_slider_autoplayspeed }}" id="input-slider_autoplayspeed" class="form-control" />
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-limit"><span data-bs-toggle="tooltip" title="{{ help_limit }}">{{ entry_limit }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="limit" value="{{ limit }}" placeholder="{{ entry_limit }}" id="input-limit" class="form-control" />
                </div>
              </div>
            </div>
            <div class="tab-pane" id="tab-category">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-category"><span data-bs-toggle="tooltip" title="{{ help_category }}">{{ text_category }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="category" value="" placeholder="{{ text_category }}" id="input-category" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-category" autocomplete="off"{% else %}list="list-category"{% endif %} />
                  {% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-category" class="dropdown-menu"></ul>{% else %}<datalist id="list-category"></datalist>{% endif %}
                  <div id="grid-category" class="form-control" style="height: 150px; overflow: auto;">
                    {% for grid_category in grid_categories %}
                    <div data-id="{{ grid_category.category_id }}" id="grid-category{{ grid_category.category_id }}"><i class="fa fa-minus-circle"></i> {{ grid_category.name }}
                      <input type="hidden" name="grid_category[]" value="{{ grid_category.category_id }}" />
                    </div>
                    {% endfor %}
                  </div>
                </div>
                <div class="col-sm-12">
                   <div class="table-responsive">
                    <table id="categoryproducts" class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <td>{{ column_categoryname }}</td>
                          <td><span data-bs-toggle="tooltip" title="{{ help_categoryproducts }}">{{ column_categoryproducts }}</span></td>
                          <td>{{ column_status }}</td>
                          <td>{{ column_sort_order }}</td>
                        </tr>
                      </thead>
                      <tbody>
                        {% for category_product in category_products %}
                        <tr id="categoryproduct-{{ category_product.category_id }}">
                          <td>{{ category_product.name }}</td>
                          <td>
                            <div class="col-sm-12">
                              <input type="text" name="categoryproduct" value="" placeholder="{{ column_categoryproducts }}" id="input-categoryproducts-{{ category_product.category_id }}" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-categoryproducts-{{ category_product.category_id }}" autocomplete="off"{% else %}list="list-categoryproducts-{{ category_product.category_id }}"{% endif %} />
                              {% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-categoryproducts-{{ category_product.category_id }}" class="dropdown-menu"></ul>{% else %}<datalist id="list-categoryproducts-{{ category_product.category_id }}"></datalist>{% endif %}
                              <div id="grid-categoryproducts{{ category_product.category_id }}" class="form-control" style="height: 150px; overflow: auto;">
                                  {% for highlightproducts in category_product.highlightproducts %}
                                  <div id="grid-categoryproducts{{ category_product.category_id }}-{{ highlightproducts.product_id }}"><i class="fa fa-minus-circle"></i> {{ highlightproducts.name }}
                                    <input type="hidden" name="grid_categoryproducts[{{ category_product.category_id }}][product_id][]" value="{{ highlightproducts.product_id }}" />
                                  </div>
                                  {% endfor %}
                              </div>
                            </div>  
                          </td>
                          <td>                            
                            <select name="grid_categoryproducts[{{ category_product.category_id }}][status]" id="input-categoryproduct-status-{{ category_product.category_id }}" class="form-select">
                              <option value="1" {% if category_product.status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                              <option value="0" {% if not category_product.status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                            </select>                            
                          </td>
                          <td><input type="text" name="grid_categoryproducts[{{ category_product.category_id }}][sort_order]" value="{{ category_product.sort_order }}" class="form-control" /></td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>      
                </div>
              </div>
            </div>
            <div class="tab-pane" id="tab-manufacturer">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-manufacturer"><span data-bs-toggle="tooltip" title="{{ help_manufacturer }}">{{ text_manufacturer }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="manufacturer" value="" placeholder="{{ text_manufacturer }}" id="input-manufacturer" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-manufacturer" autocomplete="off"{% else %}list="list-manufacturer"{% endif %} />
                  {% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-manufacturer" class="dropdown-menu"></ul>{% else %}<datalist id="list-manufacturer"></datalist>{% endif %}
                  <div id="grid-manufacturer" class="form-control" style="height: 150px; overflow: auto;">
                    {% for grid_manufacturer in grid_manufacturers %}
                    <div data-id="{{ grid_manufacturer.manufacturer_id }}" id="grid-manufacturer{{ grid_manufacturer.manufacturer_id }}"><i class="fa fa-minus-circle"></i> {{ grid_manufacturer.name }}
                      <input type="hidden" name="grid_manufacturer[]" value="{{ grid_manufacturer.manufacturer_id }}" />
                    </div>
                    {% endfor %}
                  </div>
                </div>
                <div class="col-sm-12">
                   <div class="table-responsive">
                    <table id="manufacturerproducts" class="table table-bordered table-hover">
                      <thead>
                        <tr>
                          <td>{{ column_manufacturername }}</td>
                          <td><span data-bs-toggle="tooltip" title="{{ help_manufacturerproducts }}">{{ column_manufacturerproducts }}</span></td>
                          <td>{{ column_status }}</td>
                          <td>{{ column_sort_order }}</td>
                        </tr>
                      </thead>
                      <tbody>
                        {% for manufacturer_product in manufacturer_products %}
                        <tr id="manufacturerproduct-{{ manufacturer_product.manufacturer_id }}">
                          <td>{{ manufacturer_product.name }}</td>
                          <td>
                            <div class="col-sm-12">
                              <input type="text" name="manufacturerproduct" value="" placeholder="{{ column_manufacturerproducts }}" id="input-manufacturerproducts-{{ manufacturer_product.manufacturer_id }}" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-manufacturerproducts-{{ manufacturer_product.manufacturer_id }}" autocomplete="off"{% else %}list="list-manufacturerproducts-{{ manufacturer_product.manufacturer_id }}"{% endif %} />
                              {% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-manufacturerproducts-{{ manufacturer_product.manufacturer_id }}" class="dropdown-menu"></ul>{% else %}<datalist id="list-manufacturerproducts-{{ manufacturer_product.manufacturer_id }}"></datalist>{% endif %}
                              <div id="grid-manufacturerproducts{{ manufacturer_product.manufacturer_id }}" class="form-control" style="height: 150px; overflow: auto;">
                                  {% for highlightproducts in manufacturer_product.highlightproducts %}
                                  <div id="grid-manufacturerproducts{{ manufacturer_product.manufacturer_id }}-{{ highlightproducts.product_id }}"><i class="fa fa-minus-circle"></i> {{ highlightproducts.name }}
                                    <input type="hidden" name="grid_manufacturerproducts[{{ manufacturer_product.manufacturer_id }}][product_id][]" value="{{ highlightproducts.product_id }}" />
                                  </div>
                                  {% endfor %}
                              </div>
                            </div>  
                          </td>
                          <td>                            
                            <select name="grid_manufacturerproducts[{{ manufacturer_product.manufacturer_id }}][status]" id="input-manufacturerproduct-status-{{ manufacturer_product.manufacturer_id }}" class="form-select">
                              <option value="1" {% if manufacturer_product.status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                              <option value="0" {% if not manufacturer_product.status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                            </select>                            
                          </td>
                          <td><input type="text" name="grid_manufacturerproducts[{{ manufacturer_product.manufacturer_id }}][sort_order]" value="{{ manufacturer_product.sort_order }}" class="form-control" /></td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>      
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
  <script type="text/javascript"><!--
$(function(){

  // Category
  $('input[name=\'category\']').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=catalog/category|autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item['name'],
              value: item['category_id']
            }
          }));
        }
      });
    },
    'select': function(item) {
      $('input[name=\'category\']').val('');

      $('#categoryproduct-'+item['value']).remove();
      $('#grid-category' + item['value']).remove();

      $('#grid-category').append('<div data-id="' + item['value'] + '" id="grid-category' + item['value'] + '"><i class="fa fa-minus-circle"></i> ' + item['label'] + '<input type="hidden" name="grid_category[]" value="' + item['value'] + '" /></div>');


      var html = '<tr id="categoryproduct-' + item['value'] + '">';
          html += ' <td><label>' + item['label'] + '</label></td>';
          html += ' <td><div class="col-sm-12"><input type="text" name="categoryproduct" value="" placeholder="{{ column_categoryproducts }}" id="input-categoryproducts-' + item['value'] + '" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-categoryproducts-' + item['value'] + '" autocomplete="off"{% else %}list="list-categoryproducts-' + item['value'] + '"{% endif %} />{% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-categoryproducts-' + item['value'] + '" class="dropdown-menu"></ul>{% else %}<datalist id="list-categoryproducts-' + item['value'] + '"></datalist>{% endif %}<div id="grid-categoryproducts' + item['value'] + '" class="form-control" style="height: 150px; overflow: auto;"></div></div></td>';
          html += '<td><select name="grid_categoryproducts[' + item['value'] + '][status]" id="input-categoryproduct-status-' + item['value'] + '" class="form-select"><option value="1" selected="selected">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></td>';
          html += '<td><input type="text" name="grid_categoryproducts[' + item['value'] + '][sort_order]" value="0" class="form-control" /></td>';
          html += '</tr>';


      $('#categoryproducts > tbody').append(html);
      
      categoryHighlightProducts(item['value']);
    }
  });

  $('#grid-category').delegate('.fa-minus-circle', 'click', function() {
    var category_id = $(this).parent().attr('data-id');
    $('#categoryproduct-'+category_id).remove();
    $(this).parent().remove();
  });

  // category highlight products

  $('#categoryproducts input[name=\'categoryproduct\']').each(function() {

    var category_id = $(this).attr('id').replace('input-categoryproducts-','');

    categoryHighlightProducts(category_id);

  });

  // Manufacturer
  $('input[name=\'manufacturer\']').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=catalog/manufacturer|autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item['name'],
              value: item['manufacturer_id']
            }
          }));
        }
      });
    },
    'select': function(item) {
      $('input[name=\'manufacturer\']').val('');

      $('#manufacturerproduct-'+item['value']).remove();
      $('#grid-manufacturer' + item['value']).remove();

      $('#grid-manufacturer').append('<div data-id="' + item['value'] + '" id="grid-manufacturer' + item['value'] + '"><i class="fa fa-minus-circle"></i> ' + item['label'] + '<input type="hidden" name="grid_manufacturer[]" value="' + item['value'] + '" /></div>');


      var html = '<tr id="manufacturerproduct-' + item['value'] + '">';
          html += ' <td><label>' + item['label'] + '</label></td>';
          html += ' <td><div class="col-sm-12"><input type="text" name="manufacturerproduct" value="" placeholder="{{ column_manufacturerproducts }}" id="input-manufacturerproducts-' + item['value'] + '" class="form-control" {% if constant('VERSION') > '4.0.1.1' %}data-oc-target="autocomplete-manufacturerproducts-' + item['value'] + '" autocomplete="off"{% else %}list="list-manufacturerproducts-' + item['value'] + '"{% endif %} />{% if (constant('VERSION') > '4.0.1.1') %}<ul id="autocomplete-manufacturerproducts-' + item['value'] + '" class="dropdown-menu"></ul>{% else %}<datalist id="list-manufacturerproducts-' + item['value'] + '"></datalist>{% endif %}<div id="grid-manufacturerproducts' + item['value'] + '" class="form-control" style="height: 150px; overflow: auto;"></div></div></td>';
          html += '<td><select name="grid_manufacturerproducts[' + item['value'] + '][status]" id="input-manufacturerproduct-status-' + item['value'] + '" class="form-select"><option value="1" selected="selected">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></td>';
          html += '<td><input type="text" name="grid_manufacturerproducts[' + item['value'] + '][sort_order]" value="0" class="form-control" /></td>';
          html += '</tr>';


      $('#manufacturerproducts > tbody').append(html);
      
      manufacturerHighlightProducts(item['value']);
    }
  });

  $('#grid-manufacturer').delegate('.fa-minus-circle', 'click', function() {
    var manufacturer_id = $(this).parent().attr('data-id');
    $('#manufacturerproduct-'+manufacturer_id).remove();
    $(this).parent().remove();
  });

  // manufacturer highlight products

  $('#manufacturerproducts input[name=\'manufacturerproduct\']').each(function() {

    var manufacturer_id = $(this).attr('id').replace('input-manufacturerproducts-','');

    manufacturerHighlightProducts(manufacturer_id);

  });



});


